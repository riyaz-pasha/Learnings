592,"seed":1977860676,"boundElements":[],"y":-2314.6798051287624,"opacity":100,"height":40,"width":360,"frameId":null,"strokeStyle":"solid","versionNonce":1363689212},{"seed":742054340,"strokeStyle":"solid","id":"OL3zD1WjYHJNKsb9629cO","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":11,"opacity":100,"verticalAlign":"top","updated":1772895874879,"locked":false,"text":"SELECT video_id FROM user_watch_history WHERE user_id=? ORDER BY watched_at DESC LIMIT 1000","version":6,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bja","roundness":null,"containerId":null,"originalText":"SELECT video_id FROM user_watch_history WHERE user_id=? ORDER BY watched_at DESC LIMIT 1000","height":13.75,"link":null,"strokeColor":"#7EC8A4","fillStyle":"solid","groupIds":[],"versionNonce":1480216260,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":2038.1204674799592,"angle":0,"y":-2302.6798051287624,"width":577.1591796875},{"seed":1187184964,"strokeStyle":"dashed","id":"7oHM4ryhotAJWNzZDIqQB","strokeWidth":1,"roughness":0,"isDeleted":false,"startBinding":null,"endArrowhead":null,"opacity":100,"updated":1772895686408,"locked":false,"points":[[0,0],[0,2720]],"polygon":false,"version":5,"type":"line","backgroundColor":"transparent","index":"bjb","roundness":null,"lastCommittedPoint":null,"height":2720,"link":null,"startArrowhead":null,"strokeColor":"#2A2D3A","fillStyle":"solid","groupIds":[],"endBinding":null,"versionNonce":1885273980,"frameId":null,"boundElements":[],"x":3568.1204674799592,"angle":0,"y":-4874.6798051287624,"width":0},{"isDeleted":false,"locked":false,"strokeColor":"#2A2D3A","link":null,"roughness":0,"groupIds":[],"index":"bjc","backgroundColor":"#1E2030","angle":0,"fillStyle":"solid","strokeWidth":1,"version":5,"roundness":null,"type":"rectangle","updated":1772895686408,"id":"PnkdxQvB_G7L-lxh_GiS-","x":3588.1204674799592,"seed":1020934340,"boundElements":[],"y":-4832.6798051287624,"opacity":100,"height":2630,"width":860,"frameId":null,"strokeStyle":"solid","versionNonce":145737284},{"seed":1780383812,"strokeStyle":"solid","id":"fvdZDqCUeOEuhKC2u76lI","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":16,"opacity":100,"verticalAlign":"top","updated":1772895686408,"locked":false,"text":"FR-1: Upload — How It Actually Works","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bjd","roundness":null,"containerId":null,"originalText":"FR-1: Upload — How It Actually Works","height":20,"link":null,"strokeColor":"#4D9E7C","fillStyle":"solid","groupIds":[],"versionNonce":1875488764,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":3604.1204674799592,"angle":0,"y":-4816.6798051287624,"width":299.55172729492188},{"seed":107861956,"strokeStyle":"solid","id":"Zj82R0JIGV34QtPDUA8qi","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772895686408,"locked":false,"text":"The API server never touches a video byte. The client\nreceives a presigned S3 URL and uploads directly. S3\nemits an ObjectCreated event to Kafka, which boots\nthe transcode pipeline. The Orchestrator splits each\nvideo into 10-second chunks — 360 chunks for a 1-hr\nvideo — encoded by 30K CPUs in parallel, cutting\nwall-clock time from 40 minutes to under 3 minutes.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bje","roundness":null,"containerId":null,"originalText":"The API server never touches a video byte. The client\nreceives a presigned S3 URL and uploads directly. S3\nemits an ObjectCreated event to Kafka, which boots\nthe transcode pipeline. The Orchestrator splits each\nvideo into 10-second chunks — 360 chunks for a 1-hr\nvideo — encoded by 30K CPUs in parallel, cutting\nwall-clock time from 40 minutes to under 3 minutes.","height":113.75,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":249978308,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":3604.1204674799592,"angle":0,"y":-4790.6798051287624,"width":349.97262573242188},{"seed":501628740,"strokeStyle":"solid","id":"TnI8kPDd3PVAOLGjTwXbG","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1772895686408,"locked":false,"text":"What Can Go Wrong (FR-1)","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bjf","roundness":null,"containerId":null,"originalText":"What Can Go Wrong (FR-1)","height":18.75,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":2139771004,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":3604.1204674799592,"angle":0,"y":-4630.6798051287624,"width":196.49992370605469},{"seed":149272260,"strokeStyle":"solid","id":"x5EtQthATVCrYsi_hMNA_","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772895686408,"locked":false,"text":"Silent S3 event loss is the most dangerous failure:\nvideo stays in status=processing forever. Recovery:\na compensating cron scans videos where status=\nprocessing AND created_at older than 10 minutes,\nthen re-emits the transcode job. Worker crashes\nre-enqueue up to 3 times; beyond that, DLQ.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bjg","roundness":null,"containerId":null,"originalText":"Silent S3 event loss is the most dangerous failure:\nvideo stays in status=processing forever. Recovery:\na compensating cron scans videos where status=\nprocessing AND created_at older than 10 minutes,\nthen re-emits the transcode job. Worker crashes\nre-enqueue up to 3 times; beyond that, DLQ.","height":97.5,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":1365116228,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":3604.1204674799592,"angle":0,"y":-4606.6798051287624,"width":328.27560424804688},{"isDeleted":false,"locked":false,"strokeColor":"#4D9E7C","link":null,"roughness":0,"groupIds":[],"index":"bjh","backgroundColor":"#252838","angle":0,"fillStyle":"solid","strokeWidth":1,"version":5,"roundness":{"type":3},"type":"rectangle","updated":1772895686408,"id":"Z-F9VFpcmmnR3VqvcG4Ac","x":3592.1204674799592,"seed":1678392900,"boundElements":[],"y":-4484.6798051287624,"opacity":100,"height":68,"width":852,"frameId":null,"strokeStyle":"solid","versionNonce":2137186556},{"seed":137483716,"strokeStyle":"solid","id":"3-ybEOkyhjM4hDSDr56lw","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772895686408,"locked":false,"text":"Key insight (FR-1): Presigned URLs eliminate OOM on the\nupload path permanently. No byte enters API server memory.\nThe S3 event is the only coupling between upload and transcode.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bji","roundness":null,"containerId":null,"originalText":"Key insight (FR-1): Presigned URLs eliminate OOM on the\nupload path permanently. No byte enters API server memory.\nThe S3 event is the only coupling between upload and transcode.","height":48.75,"link":null,"strokeColor":"#9AA0B4","fillStyle":"solid","groupIds":[],"versionNonce":1165278404,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":3608.1204674799592,"angle":0,"y":-4472.6798051287624,"width":412.8665771484375},{"seed":41581892,"strokeStyle":"solid","id":"OF6Tl7mKhN1wvKwhp7WMH","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":16,"opacity":100,"verticalAlign":"top","updated":1772895686408,"locked":false,"text":"FR-2: ABR Streaming — How It Actually Works","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bjj","roundness":null,"containerId":null,"originalText":"FR-2: ABR Streaming — How It Actually Works","height":20,"link":null,"strokeColor":"#6BA3D6","fillStyle":"solid","groupIds":[],"versionNonce":114647420,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":3604.1204674799592,"angle":0,"y":-4388.6798051287624,"width":367.88766479492188},{"seed":205665476,"strokeStyle":"solid","id":"MA5ucGA_Mr-2bWdFih1Zp","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772895686408,"locked":false,"text":"The ABR player never fetches a monolithic file. It gets\na master manifest listing all renditions, picks starting\nquality from bandwidth estimate, then downloads 2-6\nsecond segments continuously. Every segment download\nmeasures actual speed — if bandwidth drops, the next\nsegment request switches to a lower rendition. The\nbuffer (15-30s ahead) makes transitions invisible.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bjk","roundness":null,"containerId":null,"originalText":"The ABR player never fetches a monolithic file. It gets\na master manifest listing all renditions, picks starting\nquality from bandwidth estimate, then downloads 2-6\nsecond segments continuously. Every segment download\nmeasures actual speed — if bandwidth drops, the next\nsegment request switches to a lower rendition. The\nbuffer (15-30s ahead) makes transitions invisible.","height":113.75,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":80249924,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":3604.1204674799592,"angle":0,"y":-4362.6798051287624,"width":353.48260498046875},{"seed":52886596,"strokeStyle":"solid","id":"v83Txpm7TWIQhmZxhjM7X","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1772895686408,"locked":false,"text":"What Can Go Wrong (FR-2)","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bjl","roundness":null,"containerId":null,"originalText":"What Can Go Wrong (FR-2)","height":18.75,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":1831064060,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":3604.1204674799592,"angle":0,"y":-4202.6798051287624,"width":201.044921875},{"seed":1627837380,"strokeStyle":"solid","id":"RJcAji-hmuH6lIf_liDnW","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772895686408,"locked":false,"text":"Thundering herd on viral content: 200 CDN PoPs get\ncache misses simultaneously. Without origin shield,\n200 × N viewers each send S3 fetch requests. Shield\ncollapses these into 1 fetch per region. Master manifest\nuses Cache-Control: no-store; segments are immutable\nwith infinite TTL — cache invalidation never occurs.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bjm","roundness":null,"containerId":null,"originalText":"Thundering herd on viral content: 200 CDN PoPs get\ncache misses simultaneously. Without origin shield,\n200 × N viewers each send S3 fetch requests. Shield\ncollapses these into 1 fetch per region. Master manifest\nuses Cache-Control: no-store; segments are immutable\nwith infinite TTL — cache invalidation never occurs.","height":97.5,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":1161255876,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":3604.1204674799592,"angle":0,"y":-4178.6798051287624,"width":355.87457275390625},{"isDeleted":false,"locked":false,"strokeColor":"#6BA3D6","link":null,"roughness":0,"groupIds":[],"index":"bjn","backgroundColor":"#252838","angle":0,"fillStyle":"solid","strokeWidth":1,"version":5,"roundness":{"type":3},"type":"rectangle","updated":1772895686408,"id":"SCp8c8XOINCXu3HoKdION","x":3592.1204674799592,"seed":872397636,"boundElements":[],"y":-4034.6798051287624,"opacity":100,"height":68,"width":852,"frameId":null,"strokeStyle":"solid","versionNonce":1364210300},{"seed":376419012,"strokeStyle":"solid","id":"8yAJG2pz1JmGtGbDnVXhe","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772895686408,"locked":false,"text":"Key insight (FR-2): Segment immutability is the CDN strategy.\nOnce written, a segment s3_key never changes. CDN TTL is\ninfinite. This eliminates cache invalidation as a failure mode.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bjo","roundness":null,"containerId":null,"originalText":"Key insight (FR-2): Segment immutability is the CDN strategy.\nOnce written, a segment s3_key never changes. CDN TTL is\ninfinite. This eliminates cache invalidation as a failure mode.","height":48.75,"link":null,"strokeColor":"#9AA0B4","fillStyle":"solid","groupIds":[],"versionNonce":1356809028,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":3608.1204674799592,"angle":0,"y":-4022.6798051287624,"width":393.32757568359375},{"seed":653572676,"strokeStyle":"solid","id":"4fHUCtusxrDCB4QGVFvwX","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":16,"opacity":100,"verticalAlign":"top","updated":1772895686408,"locked":false,"text":"FR-3: Recommendations — How It Actually Works","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bjp","roundness":null,"containerId":null,"originalText":"FR-3: Recommendations — How It Actually Works","height":20,"link":null,"strokeColor":"#8B7FD4","fillStyle":"solid","groupIds":[],"versionNonce":572293884,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":3604.1204674799592,"angle":0,"y":-3938.6798051287624,"width":385.16766357421875},{"seed":7131588,"strokeStyle":"solid","id":"ow3sJ0Y7sPL4AGmZfvAql","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772895686408,"locked":false,"text":"Recommendations use a two-stage pipeline. Recall uses\na two-tower neural net producing 256-dim embedding\nvectors for users and videos. ANN search over 10M\nvideo vectors finds top 500 candidates in under 8ms.\nThe ranker applies dense features — CTR, watch_pct,\nrecency, diversity — to score and reorder the 500,\nreturning the top 20 videos in under 25ms total.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bjq","roundness":null,"containerId":null,"originalText":"Recommendations use a two-stage pipeline. Recall uses\na two-tower neural net producing 256-dim embedding\nvectors for users and videos. ANN search over 10M\nvideo vectors finds top 500 candidates in under 8ms.\nThe ranker applies dense features — CTR, watch_pct,\nrecency, diversity — to score and reorder the 500,\nreturning the top 20 videos in under 25ms total.","height":113.75,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":2115910340,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":3604.1204674799592,"angle":0,"y":-3912.6798051287624,"width":346.74853515625},{"seed":838203716,"strokeStyle":"solid","id":"q7N7Pf56v3vTmyZ-ogYPa","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1772895686408,"locked":false,"text":"What Can Go Wrong (FR-3)","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bjr","roundness":null,"containerId":null,"originalText":"What Can Go Wrong (FR-3)","height":18.75,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":638239612,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":3604.1204674799592,"angle":0,"y":-3752.6798051287624,"width":199.6649169921875},{"seed":921579716,"strokeStyle":"solid","id":"mrzy0ZcJggmBFVoN8W4uI","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772895686408,"locked":false,"text":"Feature store staleness is the silent failure. Redis lag\nbeyond the 1-hr TTL reverts recommendations to global\npopularity ranking. Ranker timeout beyond 30ms triggers\na fallback to recall-only results. Cold-start for new users\nuses demographic + onboarding signals until enough\nwatch events accumulate to generate a personal vector.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bjs","roundness":null,"containerId":null,"originalText":"Feature store staleness is the silent failure. Redis lag\nbeyond the 1-hr TTL reverts recommendations to global\npopularity ranking. Ranker timeout beyond 30ms triggers\na fallback to recall-only results. Cold-start for new users\nuses demographic + onboarding signals until enough\nwatch events accumulate to generate a personal vector.","height":97.5,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":663896644,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":3604.1204674799592,"angle":0,"y":-3728.6798051287624,"width":363.62246704101562},{"seed":1861449796,"strokeStyle":"solid","id":"EXyM5lRAwgxoc3y2iLaSd","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1772895686408,"locked":false,"text":"Latency Budget (FR-3)","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bjt","roundness":null,"containerId":null,"originalText":"Latency Budget (FR-3)","height":18.75,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":56423420,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":3604.1204674799592,"angle":0,"y":-3584.6798051287624,"width":170.80490112304688},{"isDeleted":false,"locked":false,"strokeColor":"#2A2D3A","link"