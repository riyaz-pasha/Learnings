hness":0,"groupIds":[],"index":"bcG","backgroundColor":"#1A1C26","angle":0,"fillStyle":"solid","strokeWidth":1,"version":5,"roundness":null,"type":"rectangle","updated":1772895686408,"id":"19F3BEn1EiHEce3kOu0t5","x":2520.1204674799592,"seed":1355226308,"boundElements":[{"type":"text","id":"VebAMnf7Z1-1uDa0UtRlI"}],"y":-8326.6798051287624,"opacity":100,"height":90,"width":200,"frameId":null,"strokeStyle":"solid","versionNonce":1519548484},{"seed":919528516,"strokeStyle":"solid","id":"VebAMnf7Z1-1uDa0UtRlI","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"middle","updated":1772895686410,"locked":false,"text":"1.2 EB total\nObject store","version":7,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bcH","roundness":null,"containerId":"19F3BEn1EiHEce3kOu0t5","originalText":"1.2 EB total\nObject store","height":37.5,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":987777220,"textAlign":"center","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":2573.402964885965,"angle":0,"y":-8300.4298051287624,"width":93.435005187988281},{"seed":661765060,"strokeStyle":"dashed","id":"ZbwN7eutaSDqSU_ZqKDcK","strokeWidth":1,"roughness":0,"isDeleted":false,"startBinding":null,"endArrowhead":null,"opacity":100,"updated":1772895686408,"locked":false,"points":[[0,0],[0,1090]],"polygon":false,"version":5,"type":"line","backgroundColor":"transparent","index":"bcI","roundness":null,"lastCommittedPoint":null,"height":1090,"link":null,"startArrowhead":null,"strokeColor":"#2A2D3A","fillStyle":"solid","groupIds":[],"endBinding":null,"versionNonce":899862468,"frameId":null,"boundElements":[],"x":3568.1204674799592,"angle":0,"y":-9264.6798051287624,"width":0},{"isDeleted":false,"locked":false,"strokeColor":"#2A2D3A","link":null,"roughness":0,"groupIds":[],"index":"bcJ","backgroundColor":"#1E2030","angle":0,"fillStyle":"solid","strokeWidth":1,"version":5,"roundness":null,"type":"rectangle","updated":1772895686408,"id":"mai9dMG2s6W1FWTCN4sil","x":3588.1204674799592,"seed":1020109636,"boundElements":[],"y":-9224.6798051287624,"opacity":100,"height":960,"width":860,"frameId":null,"strokeStyle":"solid","versionNonce":109444732},{"seed":490773188,"strokeStyle":"solid","id":"RFJK_miVQjn2j2RI-xX7C","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":18,"opacity":100,"verticalAlign":"top","updated":1772895686408,"locked":false,"text":"Why These Numbers Matter","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bcK","roundness":null,"containerId":null,"originalText":"Why These Numbers Matter","height":22.5,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":196884292,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":3604.1204674799592,"angle":0,"y":-9208.6798051287624,"width":241.39785766601562},{"seed":1936237124,"strokeStyle":"solid","id":"gECcr8qvlze4pFxZp5_Ht","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772895686408,"locked":false,"text":"The QPS calculation chain reveals that CDN is not an optimization\nbut a structural requirement. At 2.5M segment requests per second\npeak, no origin cluster can absorb that load directly with\nacceptable latency. The 10% CDN miss rate is the decisive\nassumption: if cache hit rate drops to 80%, origin load jumps\n5x to 1.25M req\/s, collapsing the entire API tier.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bcL","roundness":null,"containerId":null,"originalText":"The QPS calculation chain reveals that CDN is not an optimization\nbut a structural requirement. At 2.5M segment requests per second\npeak, no origin cluster can absorb that load directly with\nacceptable latency. The 10% CDN miss rate is the decisive\nassumption: if cache hit rate drops to 80%, origin load jumps\n5x to 1.25M req\/s, collapsing the entire API tier.","height":105,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":1186516732,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":3604.1204674799592,"angle":0,"y":-9180.6798051287624,"width":460.62744140625},{"seed":1713617348,"strokeStyle":"solid","id":"qdTl3atcC6HGzV4rvVt0E","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":18,"opacity":100,"verticalAlign":"top","updated":1772895686408,"locked":false,"text":"Peak vs Average","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bcM","roundness":null,"containerId":null,"originalText":"Peak vs Average","height":22.5,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":960278212,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":3604.1204674799592,"angle":0,"y":-9052.6798051287624,"width":143.27993774414062},{"seed":277864772,"strokeStyle":"solid","id":"_9OTK5AIElUKWcWa6l1L6","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772895686408,"locked":false,"text":"The 10x peak factor reflects two separate phenomena: primetime\nevening viewing (8-10pm local time) is predictable and can be\nhandled with scheduled scaling. Viral spikes are not predictable\n— a single trending video causes simultaneous cache misses\nacross all 200 CDN PoPs globally. The system must absorb\nthis within 2 minutes using pre-warmed autoscale pools.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bcN","roundness":null,"containerId":null,"originalText":"The 10x peak factor reflects two separate phenomena: primetime\nevening viewing (8-10pm local time) is predictable and can be\nhandled with scheduled scaling. Viral spikes are not predictable\n— a single trending video causes simultaneous cache misses\nacross all 200 CDN PoPs globally. The system must absorb\nthis within 2 minutes using pre-warmed autoscale pools.","height":105,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":155029372,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":3604.1204674799592,"angle":0,"y":-9024.6798051287624,"width":444.86346435546875},{"seed":2047547588,"strokeStyle":"solid","id":"CBQmBM1NC7ZYvjmJD4y3z","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":18,"opacity":100,"verticalAlign":"top","updated":1772895686408,"locked":false,"text":"Storage Growth Rate","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bcO","roundness":null,"containerId":null,"originalText":"Storage Growth Rate","height":22.5,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":1589786180,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":3604.1204674799592,"angle":0,"y":-8896.6798051287624,"width":191.73587036132812},{"seed":238248004,"strokeStyle":"solid","id":"8gftbBG14vrlydft5Q0zM","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772895686408,"locked":false,"text":"At 1.5 PB of new video per day, object storage is the dominant\ninfrastructure cost. The 12-rendition requirement is the key\ndriver: removing 4K output alone reduces storage by ~40%.\nThe 3-year retention assumption caps growth — infinite retention\nlike YouTube requires 5x more capacity. Compression at ingestion\nis non-negotiable; each 10% improvement saves 120 TB\/day.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bcP","roundness":null,"containerId":null,"originalText":"At 1.5 PB of new video per day, object storage is the dominant\ninfrastructure cost. The 12-rendition requirement is the key\ndriver: removing 4K output alone reduces storage by ~40%.\nThe 3-year retention assumption caps growth — infinite retention\nlike YouTube requires 5x more capacity. Compression at ingestion\nis non-negotiable; each 10% improvement saves 120 TB\/day.","height":105,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":240533500,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":3604.1204674799592,"angle":0,"y":-8868.6798051287624,"width":453.3194580078125},{"isDeleted":false,"locked":false,"strokeColor":"#4D9E7C","link":null,"roughness":0,"groupIds":[],"index":"bcQ","backgroundColor":"#252838","angle":0,"fillStyle":"solid","strokeWidth":1,"version":5,"roundness":{"type":3},"type":"rectangle","updated":1772895686408,"id":"EeGB8oAwsex9wYqjKupg1","x":3592.1204674799592,"seed":350664644,"boundElements":[],"y":-8722.6798051287624,"opacity":100,"height":96,"width":852,"frameId":null,"strokeStyle":"solid","versionNonce":1495977412},{"seed":709041988,"strokeStyle":"solid","id":"llYV1PWtx9jrFH1ZmqhNs","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772895686408,"locked":false,"text":"Key insight: The 30,000-CPU transcode cluster runs at near-100%\nutilization continuously — this is not bursty batch work. It is an\nindustrial-scale pipeline that must never fall behind the upload rate\nor the job queue grows unboundedly and the 5-min SLA is violated.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bcR","roundness":null,"containerId":null,"originalText":"Key insight: The 30,000-CPU transcode cluster runs at near-100%\nutilization continuously — this is not bursty batch work. It is an\nindustrial-scale pipeline that must never fall behind the upload rate\nor the job queue grows unboundedly and the 5-min SLA is violated.","height":70,"link":null,"strokeColor":"#9AA0B4","fillStyle":"solid","groupIds":[],"versionNonce":1040507004,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":3608.12