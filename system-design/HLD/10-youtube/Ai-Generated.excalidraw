se,"text":"Progressive MP4","version":6,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bq6","roundness":null,"containerId":null,"originalText":"Progressive MP4","height":15,"link":null,"strokeColor":"#9AA0B4","fillStyle":"solid","groupIds":[],"versionNonce":9501124,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":2504.1204674799592,"angle":0,"y":1343.3201948712376,"width":96.419830322265625},{"seed":298088260,"strokeStyle":"dashed","id":"Y78ur2iG-x5_BTN-D9Ce0","strokeWidth":1,"roughness":0,"isDeleted":false,"startBinding":null,"endArrowhead":null,"opacity":100,"updated":1772895686408,"locked":false,"points":[[0,0],[0,970]],"polygon":false,"version":6,"type":"line","backgroundColor":"transparent","index":"bq7","roundness":null,"lastCommittedPoint":null,"height":970,"link":null,"startArrowhead":null,"strokeColor":"#2A2D3A","fillStyle":"solid","groupIds":[],"endBinding":null,"versionNonce":1214739580,"frameId":null,"boundElements":[],"x":3568.1204674799592,"angle":0,"y":535.32019487123762,"width":0},{"isDeleted":false,"locked":false,"strokeColor":"#2A2D3A","link":null,"roughness":0,"groupIds":[],"index":"bq8","backgroundColor":"#1E2030","angle":0,"fillStyle":"solid","strokeWidth":1,"version":6,"roundness":null,"type":"rectangle","updated":1772895686408,"id":"VOVoQBz5bxfk7KwDSp4ur","x":3588.1204674799592,"seed":1413279428,"boundElements":[],"y":575.32019487123762,"opacity":100,"height":900,"width":860,"frameId":null,"strokeStyle":"solid","versionNonce":1800741188},{"seed":800749124,"strokeStyle":"solid","id":"YRmCdDV-FYZfnrB7BxJia","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":17,"opacity":100,"verticalAlign":"top","updated":1772895686408,"locked":false,"text":"30-Second Verbal Summary","version":6,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bq9","roundness":null,"containerId":null,"originalText":"30-Second Verbal Summary","height":21.25,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":2029749500,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":3604.1204674799592,"angle":0,"y":591.32019487123762,"width":216.8858642578125},{"seed":1629162948,"strokeStyle":"solid","id":"HwPX1NSCbHqmzXstgTlJ8","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772895686408,"locked":false,"text":"This is a video streaming platform at YouTube scale —\n500 million daily users. Two completely separate pipelines.\nUpload: creators upload directly to S3 via presigned URLs —\nzero bytes touch the API server. S3 fires a Kafka event that\nschedules 30,000 CPU-cores on a spot fleet to transcode\ninto HLS segments across 12 renditions in under 3 minutes.\nDelivery: viewers request segments from 200 CDN PoPs.\nOrigin shields per region collapse viral thundering-herd\ncache misses from N-PoPs times M-viewers down to one S3\nfetch per region. Metadata in Cassandra for 100K writes\nper second, Redis caches hot reads at under 1ms.\nRecommendations: fast ANN recall over 10M videos finds\n500 candidates in 8ms, dense ranker returns top 20 in\n25ms total. Multi-region with async Cassandra replication,\nKafka MirrorMaker2, and S3 CRR: 99.99% availability,\n2-minute RTO.","version":6,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bqA","roundness":null,"containerId":null,"originalText":"This is a video streaming platform at YouTube scale —\n500 million daily users. Two completely separate pipelines.\nUpload: creators upload directly to S3 via presigned URLs —\nzero bytes touch the API server. S3 fires a Kafka event that\nschedules 30,000 CPU-cores on a spot fleet to transcode\ninto HLS segments across 12 renditions in under 3 minutes.\nDelivery: viewers request segments from 200 CDN PoPs.\nOrigin shields per region collapse viral thundering-herd\ncache misses from N-PoPs times M-viewers down to one S3\nfetch per region. Metadata in Cassandra for 100K writes\nper second, Redis caches hot reads at under 1ms.\nRecommendations: fast ANN recall over 10M videos finds\n500 candidates in 8ms, dense ranker returns top 20 in\n25ms total. Multi-region with async Cassandra replication,\nKafka MirrorMaker2, and S3 CRR: 99.99% availability,\n2-minute RTO.","height":260,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":1244158148,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":3604.1204674799592,"angle":0,"y":617.32019487123762,"width":395.95358276367188},{"seed":1501345092,"strokeStyle":"solid","id":"p1lnjbBTZJIw3PhEDlEa0","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":17,"opacity":100,"verticalAlign":"top","updated":1772895686408,"locked":false,"text":"Likely Follow-up Questions","version":6,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bqB","roundness":null,"containerId":null,"originalText":"Likely Follow-up Questions","height":21.25,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":230262140,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":3604.1204674799592,"angle":0,"y":869.32019487123762,"width":216.64784240722656},{"seed":909995204,"strokeStyle":"solid","id":"Qgd-QMZ0INZceNeeAsziu","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772895686408,"locked":false,"text":"Q: How do you handle a video going viral?\nA: Origin shield coalesces N PoP misses to 1 S3 fetch per\nregion. Trending Kafka topic pre-warms edge before spike.\nSegment immutability means TTL is infinite once warmed.\n\nQ: How do you guarantee exactly-once transcoding?\nA: SHA-256 idempotency key per chunk stored in Redis TTL=24h.\nWorker checks before processing. Kafka offset committed only\nafter S3 write + Redis SET. Re-run on crash hits key, skips.\n\nQ: Walk me through Region A complete failure.\nA: LB detects unhealthy in 10s, DNS failover 30s, Cassandra\nreplica promoted, MirrorMaker2 makes Region B authoritative,\nS3 CRR already has segments, Redis cold for 5-10min.\nRTO: 2min. RPO: 100ms async lag.","version":6,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bqC","roundness":null,"containerId":null,"originalText":"Q: How do you handle a video going viral?\nA: Origin shield coalesces N PoP misses to 1 S3 fetch per\nregion. Trending Kafka topic pre-warms edge before spike.\nSegment immutability means TTL is infinite once warmed.\n\nQ: How do you guarantee exactly-once transcoding?\nA: SHA-256 idempotency key per chunk stored in Redis TTL=24h.\nWorker checks before processing. Kafka offset committed only\nafter S3 write + Redis SET. Re-run on crash hits key, skips.\n\nQ: Walk me through Region A complete failure.\nA: LB detects unhealthy in 10s, DNS failover 30s, Cassandra\nreplica promoted, MirrorMaker2 makes Region B authoritative,\nS3 CRR already has segments, Redis cold for 5-10min.\nRTO: 2min. RPO: 100ms async lag.","height":243.75,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":1755881540,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":3604.1204674799592,"angle":0,"y":895.32019487123762,"width":415.71359252929688},{"seed":955987012,"strokeStyle":"solid","id":"9UA0HFW5rHg9pqaXvWGAE","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":17,"opacity":100,"verticalAlign":"top","updated":1772895686408,"locked":false,"text":"Senior vs Staff Answer","version":6,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bqD","roundness":null,"containerId":null,"originalText":"Senior vs Staff Answer","height":21.25,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":1273198076,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":3604.1204674799592,"angle":0,"y":1129.3201948712376,"width":191.24980163574219},{"seed":1066666948,"strokeStyle":"solid","id":"GPUlMLgkZeGSrIrQNcEBI","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772895686408,"locked":false,"text":"A Senior answer names the right components and explains\neach one's purpose. A Staff answer starts from the binding\nconstraint — 99.99% availability — and derives every\nsubsequent decision from it: availability forces multi-region,\nwhich forces CDN-first delivery, which requires HLS\/DASH\nsegments, which defines transcode output format, which\nshapes the storage schema. Staff quantifies every threshold:\nPostgreSQL ceiling at 5K wps, 10x peak factor, 200ms TTFF,\n2-minute RTO. Staff proactively names the silent failure\nmodes — missed S3 events, cold Redis on failover — before\nbeing asked. The distinction is derivation, not enumeration.","version":6,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bqE","roundness":null,"containerId":null,"originalText":"A Senior answer names the right components and explains\neach one's purpose. A Staff answer starts from the binding\nconstraint — 99.99% availability — and derives every\nsubsequent decision from it: availability forces multi-region,\nwhich forces CDN-first delivery, which requires HLS\/DASH\nsegments, which defines transcode output format, which\nshapes the storage schema. Staff quantifies every threshold:\nPostgreSQL ceiling at 5K wps, 10x peak factor, 200ms TTFF,\n2-minute RTO. Staff proactively names the silent failure\nmodes — missed S3 events, cold Redis on failover — before\nbeing asked. The distinction is derivation, not enumeration.","height":178.75,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":1857288132,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":3604.1204674799592,"angle":0,"y":1155.3201948712376,"width":392.69052124023438},{"isDeleted":false,"locked":false,"strokeColor":"#4D9E7C","link":null,"roughness":0,"groupIds":[],"index":"bqF","backgroundColor":"#252838","angle":0,"fillStyle":"solid","strokeWidth":1.5,"version":6,"roundness":{"type":3},"type":"rectangle","updated":1772895686408,"id":"qfUFaV7pQF5rYXAKnuqAo","x":3592.1204674799592,"seed":1009120068,"boundElements":[],"y":1333.3201948712376,"opacity":100,"height":108,"width":852,"frameId":null,"strokeStyle":"solid","versionNonce":8083068},{"seed":755952324,"strokeStyle":"solid","id":"lqk-Aujcpe0EUNtj0vhf-","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772895686408,"locked":false,"text":"Key insight: This system is memorable because of one\nstructural insight — upload and delivery are completely\ndecoupled pipelines with opposing optimization targets.\nUpload optimizes for durability and throughput. Delivery\noptimizes for latency and availability. Every architectural\ndecision follows from keeping them separate.","version":6,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bqG","roundness":null,"containerId":null,"originalText":"Key insight: This system is memorable because of one\nstructural insight — upload and delivery are completely\ndecoupled pipelines with opposing optimization targets.\nUpload optimizes for durability and throughput. Delivery\noptimizes for latency and availability. Every architectural\ndecision follows from keeping them separate.","height":105,"link":null,"strokeColor":"#9AA0B4","fillStyle":"solid","groupIds":[],"versionNonce":1483235140,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":3608.1204674799592,"angle":0,"y":1347.3201948712376,"width":388.62554931640625}],"appState":{"shouldCacheIgnoreZoom":false,"exportScale":2,"defaultSidebarDockedPreference":false,"openMenu":null,"showWelcomeScreen":true,"currentItemStrokeColor":"#13141a","bindMode":"orbit","exportWithDarkMode":false,"lockedMultiSelections":{},"currentItemRoughness":1,"currentItemTextAlign":"left","exportBackground":true,"scrolledOutside":false,"selectedElementIds":{},"zenModeEnabled":false,"currentItemStartArrowhead":null,"zoom":{"value":1.0941559999999999},"theme":"light","activeTool":{"locked":false,"fromSelection":false,"lastActiveTool":{"locked":false,"fromSelection":false,"lastActiveTool":null,"type":"frame","customType":null},"type":"selection","customType":null},"exportEmbedScene":false,"gridStep":5,"lastPointerDownWith":"mouse","selectedGroupIds":{},"currentItemBackgroundColor":"#13141a","scrollY":2462.3468250465548,"penDetected":false,"viewBackgroundColor":"#ffffff","name":"Untitled-2026-03-06-1235","currentItemFontFamily":5,"currentItemArrowType":"round","currentItemOpacity":100,"preferredSelectionTool":{"type":"selection","initialized":true},"scrollX":-999.94076411360356,"stats":{"open":false,"panels":3},"objectsSnapModeEnabled":false,"gridSize":20,"gridModeEnabled":false,"openSidebar":null,"currentItemRoundness":"round","currentItemStrokeStyle":"solid","editingGroupId":null,"previousSelectedElementIds":{"OL3zD1WjYHJNKsb9629cO":true},"currentChartType":"bar","currentItemStrokeWidth":2,"cursorButton":"up","currentItemEndArrowhead":"arrow","currentItemFillStyle":"solid","currentItemFontSize":20,"selectedLinearElement":null,"penMode":false},"version":2,"files":{},"type":"excalidraw"}