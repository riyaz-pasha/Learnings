8818359375},{"seed":1202644420,"strokeStyle":"solid","id":"0ZJc_w1JSh1A-W9sIiIB-","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772895686408,"locked":false,"text":"[!] Videos are immutable post-processing. If edits are allowed,\ncache invalidation + segment re-transcoding becomes a major subsystem.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"baw","roundness":null,"containerId":null,"originalText":"[!] Videos are immutable post-processing. If edits are allowed,\ncache invalidation + segment re-transcoding becomes a major subsystem.","height":35,"link":null,"strokeColor":"#C45C5C","fillStyle":"solid","groupIds":[],"versionNonce":951665860,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":3604.1204674799592,"angle":0,"y":-9700.6798051287624,"width":491.30142211914062},{"seed":1876266308,"strokeStyle":"solid","id":"W6rt9vSuvTzOvuBMSp55z","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":18,"opacity":100,"verticalAlign":"top","updated":1772895686408,"locked":false,"text":"The Binding Constraint","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bax","roundness":null,"containerId":null,"originalText":"The Binding Constraint","height":22.5,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":1040013692,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":3604.1204674799592,"angle":0,"y":-9642.6798051287624,"width":204.19184875488281},{"seed":1002128580,"strokeStyle":"solid","id":"Sa_Svpl5cNAXYKsOvfeEp","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772895686408,"locked":false,"text":"Availability at 99.99% is the root driver of every major decision.\nIt forces multi-region active-active deployment, which forces a\nCDN-first delivery model, which requires segment-based formats\n(HLS\/DASH), which means transcoding must produce fine-grained\n2-6 second segments rather than monolithic video files. Each\nconstraint is a direct consequence of the one before it.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bay","roundness":null,"containerId":null,"originalText":"Availability at 99.99% is the root driver of every major decision.\nIt forces multi-region active-active deployment, which forces a\nCDN-first delivery model, which requires segment-based formats\n(HLS\/DASH), which means transcoding must produce fine-grained\n2-6 second segments rather than monolithic video files. Each\nconstraint is a direct consequence of the one before it.","height":105,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":775687236,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":3604.1204674799592,"angle":0,"y":-9614.6798051287624,"width":442.37139892578125},{"isDeleted":false,"locked":false,"strokeColor":"#4D9E7C","link":null,"roughness":0,"groupIds":[],"index":"baz","backgroundColor":"#252838","angle":0,"fillStyle":"solid","strokeWidth":1,"version":5,"roundness":{"type":3},"type":"rectangle","updated":1772895686408,"id":"wfH5I7ZlkXoLAQjW1KFUz","x":3592.1204674799592,"seed":16649284,"boundElements":[],"y":-9462.6798051287624,"opacity":100,"height":78,"width":852,"frameId":null,"strokeStyle":"solid","versionNonce":1821166076},{"seed":830202820,"strokeStyle":"solid","id":"8rWxEuxmHP8MQBf0lOlet","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772895686408,"locked":false,"text":"Key insight: Availability (99.99%) is not just an ops target — it is a\ndata format decision. Segments (HLS\/DASH) exist precisely because\nmonolithic files cannot satisfy 99.99% under partial infrastructure failure.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b