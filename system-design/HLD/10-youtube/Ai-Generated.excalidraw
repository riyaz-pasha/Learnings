Color":"#2A2D3A","fillStyle":"solid","groupIds":[],"endBinding":null,"versionNonce":321240444,"frameId":null,"boundElements":[],"x":3568.1204674799592,"angle":0,"y":-2154.6798051287624,"width":0},{"isDeleted":false,"locked":false,"strokeColor":"#2A2D3A","link":null,"roughness":0,"groupIds":[],"index":"blY","backgroundColor":"#1E2030","angle":0,"fillStyle":"solid","strokeWidth":1,"version":5,"roundness":null,"type":"rectangle","updated":1772895686408,"id":"kMXehKvu-uqDGSjw6pX_g","x":3588.1204674799592,"seed":919993540,"boundElements":[],"y":-2114.6798051287624,"opacity":100,"height":870,"width":860,"frameId":null,"strokeStyle":"solid","versionNonce":1765533764},{"seed":939639876,"strokeStyle":"solid","id":"aNtcRIFnwj_nE__W95nyZ","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":16,"opacity":100,"verticalAlign":"top","updated":1772895686408,"locked":false,"text":"Complete Request Lifecycle (Video Watch)","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"blZ","roundness":null,"containerId":null,"originalText":"Complete Request Lifecycle (Video Watch)","height":20,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":1191751164,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":3604.1204674799592,"angle":0,"y":-2098.6798051287624,"width":325.6317138671875},{"seed":1061723076,"strokeStyle":"solid","id":"FImzwmcZRUpD_H-wl9Kst","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772895686408,"locked":false,"text":"(1) Client DNS resolves to nearest Global LB via Anycast.\n(2) API Gateway verifies JWT token with Auth Service,\napplies rate limiting, and routes to Playback Service.\n(3) Playback Service checks Redis for cached manifest URL\n(<1ms hit); on miss, queries Cassandra (~10ms) and\npopulates Redis. Returns CDN manifest URL to client.\n(4) Client fetches master.m3u8 from CDN edge. ABR\nselects starting rendition. First 2s segment (~500KB)\nserved from CDN edge. First frame displays at T+200ms.\n(5) Ongoing: ABR player monitors download speed each\nsegment, switching renditions on bandwidth change.\nAll segment fetches: CDN edge -> origin shield -> S3.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bla","roundness":null,"containerId":null,"originalText":"(1) Client DNS resolves to nearest Global LB via Anycast.\n(2) API Gateway verifies JWT token with Auth Service,\napplies rate limiting, and routes to Playback Service.\n(3) Playback Service checks Redis for cached manifest URL\n(<1ms hit); on miss, queries Cassandra (~10ms) and\npopulates Redis. Returns CDN manifest URL to client.\n(4) Client fetches master.m3u8 from CDN edge. ABR\nselects starting rendition. First 2s segment (~500KB)\nserved from CDN edge. First frame displays at T+200ms.\n(5) Ongoing: ABR player monitors download speed each\nsegment, switching renditions on bandwidth change.\nAll segment fetches: CDN edge -> origin shield -> S3.","height":195,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":228474820,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":3604.1204674799592,"angle":0,"y":-2072.6798051287624,"width":377.41555786132812},{"seed":1992852292,"strokeStyle":"solid","id":"PyHeELccVe_hYwjlDlDmI","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":16,"opacity":100,"verticalAlign":"top","updated":1772895686408,"locked":false,"text":"Failover Runbook (Region A fails)","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"blb","roundness":null,"containerId":null,"originalText":"Failover Runbook (Region A fails)","height":20,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":1379503740,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":3604.1204674799592,"angle":0,"y":-1876.6798051287624,"width":259.67974853515625},{"seed":350190276,"strokeStyle":"solid","id":"8sDmNa_71PJgY-vI7RDAr","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772895686408,"locked":false,"text":"Step 1: Global LB health check detects Region A down\n(10-second timeout). DNS failover begins.\nStep 2: Anycast routes all traffic to Region B (~30s\nDNS propagation to 95% of clients).\nStep 3: Cassandra read replica in Region B promoted\nto primary via automatic coordinator election.\nStep 4: Kafka MirrorMaker 2 promotes Region B topics\nas authoritative. New events written to Region B.\nStep 5: S3 Cross-Region Replication already has all\nsegments in Region B bucket — no object migration.\nStep 6: Redis in Region B is cold — Cassandra absorbs\nread spike for 5-10 minutes until Redis warms.\nRTO: ~2 minutes. RPO: ~100ms of async lag.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"blc","roundness":null,"containerId":null,"originalText":"Step 1: Global LB health check detects Region A down\n(10-second timeout). DNS failover begins.\nStep 2: Anycast routes all traffic to Region B (~30s\nDNS propagation to 95% of clients).\nStep 3: Cassandra read replica in Region B promoted\nto primary via automatic coordinator election.\nStep 4: Kafka MirrorMaker 2 promotes Region B topics\nas authoritative. New events written to Region B.\nStep 5: S3 Cross-Region Replication already has all\nsegments in Region B bucket — no object migration.\nStep 6: Redis in Region B is cold — Cassandra absorbs\nread spike for 5-10 minutes until Redis warms.\nRTO: ~2 minutes. RPO: ~100ms of async lag.","height":211.25,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":852076356,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":3604.1204674799592,"angle":0,"y":-1850.6798051287624,"width":350.128662109375},{"seed":1412137540,"strokeStyle":"solid","id":"zWpdI732j_PF1JnH700Bw","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":16,"opacity":100,"verticalAlign":"top","updated":1772895686408,"locked":false,"text":"Most Latency-Sensitive Path","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bld","roundness":null,"containerId":null,"originalText":"Most Latency-Sensitive Path","height":20,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":1970953980,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":3604.1204674799592,"angle":0,"y":-1618.6798051287624,"width":226.03181457519531},{"seed":1804245444,"strokeStyle":"solid","id":"FFXKlJ0HgR5Pe4qzl-vhE","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772895686408,"locked":false,"text":"Playback Service to Redis to Cassandra is the most\nlatency-sensitive synchronous call. This cannot be\nasync because the manifest URL must be returned in\nthe same HTTP response the client uses to start\nplayback. A 202 'come back later' response is\nphysically incompatible with a <200ms TTFF target.\nRedis cache is mandatory: P99 Redis = <1ms vs\nCassandra P99 = ~10ms. Cache miss on first play\nof a new video is acceptable — it only adds 9ms.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"ble","roundness":null,"containerId":null,"originalText":"Playback Service to Redis to Cassandra is the most\nlatency-sensitive synchronous call. This cannot be\nasync because the manifest URL must be returned in\nthe same HTTP response the client uses to start\nplayback. A 202 'come back later' response is\nphysically incompatible with a <200ms TTFF target.\nRedis cache is mandatory: P99 Redis = <1ms vs\nCassandra P99 = ~10ms. Cache miss on first play\nof a new video is acceptable — it only adds 9ms.","height":146.25,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":2098994884,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":3604.1204674799592,"angle":0,"y":-1592.6798051287624,"width":334.918701171875},{"isDeleted":false,"locked":false,"strokeColor":"#8B7FD4","link":null,"roughness":0,"groupIds":[],"index":"blf","backgroundColor":"#252838","angle":0,"fillStyle":"solid","strokeWidth":1,"version":5,"roundness":{"type":3},"type":"rectangle","updated":1772895686408,"id":"IIPhqNyBFfTYLK7nIvUQQ","x":3592.1204674799592,"seed":102416708,"boundElements":[],"y":-1442.6798051287624,"opacity":100,"height":100,"width":852,"frameId":null,"strokeStyle":"solid","versionNonce":156049276},{"seed":993654980,"strokeStyle":"solid","id":"UWctHC2MVk6caGYP-MTIy","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772895686408,"locked":false,"text":"Key insight: The Cassandra read replica in Region B is the\nhardest component to fail over. It handles 200K reads\/sec\nat steady state. The 5-10 minute cold Redis period after\nfailover is the true RTO cost — not DNS propagation.\nPre-warming Region B Redis from Cassandra on every\ndeploy reduces this from 10min to under 2min.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"blg","roundness":null,"containerId":null,"originalText":"Key insight: The Cassandra read replica in Region B is the\nhardest component to fail over. It handles 200K reads\/sec\nat steady state. The 5-10 minute cold Redis period after\nfailover is the true RTO cost — not DNS propagation.\nPre-warming Region B Redis from Cassandra on every\ndeploy reduces this from 10min to under 2min.","height":97.5,"link":null,"strokeColor":"#9AA0B4","fillStyle":"solid","groupIds":[],"versionNonce":1429448260,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":3608.1204674799592,"angle":0,"y":-1428.6798051287624,"width":378.79351806640625},{"seed":109461572,