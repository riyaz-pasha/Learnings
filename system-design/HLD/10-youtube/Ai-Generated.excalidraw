ersionNonce":1503428292},{"seed":336822596,"strokeStyle":"solid","id":"jaPKshcnfqVTytidhQf81","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772895686408,"locked":false,"text":"Trade-off: Pre-warming needs accurate trending signal","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bfT","roundness":null,"containerId":null,"originalText":"Trade-off: Pre-warming needs accurate trending signal","height":16.25,"link":null,"strokeColor":"#C4913A","fillStyle":"solid","groupIds":[],"versionNonce":2072166268,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":2204.1204674799592,"angle":0,"y":-5180.6798051287624,"width":341.2105712890625},{"seed":203077828,"strokeStyle":"solid","id":"9_Y-VYHs5-3Yvshvz4swv","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":12,"opacity":100,"verticalAlign":"top","updated":1772895686408,"locked":false,"text":"Feature store Redis lag causes stale recommendations at peak load.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bfU","roundness":null,"containerId":null,"originalText":"Feature store Redis lag causes stale recommendations at peak load.","height":15,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":44566084,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":2204.1204674799592,"angle":0,"y":-5158.6798051287624,"width":400.27130126953125},{"isDeleted":false,"locked":false,"strokeColor":"#2A2D3A","link":null,"roughness":0,"groupIds":[],"index":"bfV","backgroundColor":"#1E2030","angle":0,"fillStyle":"solid","strokeWidth":1,"version":5,"roundness":null,"type":"rectangle","updated":1772895686408,"id":"RFT6nx0iKW-qAvY9PIS6K","x":1658.1204674799592,"seed":2102329412,"boundElements":[],"y":-5084.6798051287624,"opacity":100,"height":136,"width":1860,"frameId":null,"strokeStyle":"solid","versionNonce":1618309116},{"seed":1603164100,"strokeStyle":"solid","id":"iBQjGupgjiPu77Y2FqYbc","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772895686408,"locked":false,"text":"What We Learned","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bfW","roundness":null,"containerId":null,"originalText":"What We Learned","height":17.5,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":534158788,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1674.1204674799592,"angle":0,"y":-5070.6798051287624,"width":116.3538818359375},{"seed":2130100036,"strokeStyle":"solid","id":"SSwYJiiIWzWBtxSfo2dv7","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772895686408,"locked":false,"text":"Every upgrade removed one form of shared mutable state: DB polling -> Kafka stops workers competing for row locks.\nPresigned URLs remove the API process from the data path entirely. Polyglot storage stops writers sharing WAL throughput.\nOrigin shield collapses N thundering-herd cache misses into 1 origin request. Decomposing coordination is the governing pattern.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bfX","roundness":null,"containerId":null,"originalText":"Every upgrade removed one form of shared mutable state: DB polling -> Kafka stops workers competing for row locks.\nPresigned URLs remove the API process from the data path entirely. Polyglot storage stops writers sharing WAL throughput.\nOrigin shield collapses N thundering-herd cache misses into 1 origin request. Decomposing coordination is the governing pattern.","height":48.75,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":1690177660,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1674.1204674799592,"angle":0,"y":-5044.6798051287624,"width":806.5450439453125},{"seed":1944467140,"strokeStyle":"dashed","id":"AvU3CqNGnmGaoWwo-rn15","strokeWidth":1,"roughness":0,"isDeleted":false,"startBinding":null,"endArrowhead":null,"opacity":100,"updated":1772895686408,"locked":false,"points":[[0,0],[0,1480]],"polygon":false,"version":5,"type":"line","backgroundColor":"transparent","index":"bfY","roundness":null,"lastCommittedPoint":null,"height":1480,"link":null,"startArrowhead":null,"strokeColor":"#2A2D3A","fillStyle":"solid","groupIds":[],"endBinding":null,"versionNonce":1514554692,"frameId":null,"boundElements":[],"x":3568.1204674799592,"angle":0,"y":-6354.6798051287624,"width":0},{"isDeleted":false,"locked":false,"strokeColor":"#2A2D3A","link":null,"roughness":0,"groupIds":[],"index":"bfZ","backgroundColor":"#1E2030","angle":0,"fillStyle":"solid","strokeWidth":1,"version":5,"roundness":null,"type":"rectangle","updated":1772895686408,"id":"PQWc65gDNgTDORrDtBpJi","x":3588.1204674799592,"seed":452640324,"boundElements":[],"y":-6314.6798051287624,"opacity":100,"height":1080,"width":860,"frameId":null,"strokeStyle":"solid","versionNonce":136225020},{"seed":219305412,"strokeStyle":"solid","id":"CctyonNltLneexDeTdmEg","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1772895686408,"locked":false,"text":"V1 -> V2: Replace DB Job Queue","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bfa","roundness":null,"containerId":null,"originalText":"V1 -> V2: Replace DB Job Queue","height":18.75,"link":null,"strokeColor":"#4D9E7C","fillStyle":"solid","groupIds":[],"versionNonce":123010244,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":3604.1204674799592,"angle":0,"y":-6298.6798051287624,"width":236.86485290527344},{"seed":390790468,"strokeStyle":"solid","id":"dkpYbuhsCuGcHkKA5zk5S","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772895686408,"locked":false,"text":"The polling anti-pattern was chosen for V1 simplicity but becomes\nfatal at scale. Kafka is chosen over RabbitMQ because it retains\nprocessed messages, enabling job replay without a separate dead-\nletter store. Consumer groups give horizontal worker scaling with\nzero row-lock coordination overhead.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bfb","roundness":null,"containerId":null,"originalText":"The polling anti-pattern was chosen for V1 simplicity but becomes\nfatal at scale. Kafka is chosen over RabbitMQ because it retains\nprocessed messages, enabling job replay without a separate dead-\nletter store. Consumer groups give horizontal worker scaling with\nzero row-lock coordination overhead.","height":81.25,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":35201404,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":3604.1204674799592,"angle":0,"y":-6272.6798051287624,"width":417.2344970703125},{"seed":855815364,"strokeStyle":"solid","id":"-VQk9fjfK9mMSMVtGAsTZ","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1772895686408,"locked":false,"text":"V2 -> V3: Elastic Transcode Fleet","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bfc","roundness":null,"containerId":null,"originalText":"V2 -> V3: Elastic Transcode Fleet","height":18.75,"link":null,"strokeColor":"#C4913A","fillStyle":"solid","groupIds":[],"versionNonce":547406916,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":3604.1204674799592,"angle":0,"y":-6152.6798051287624,"width":249.32986450195312},{"seed":2111274052,"strokeStyle":"solid","id":"acuBiOnwJjZT2ib56O1ye","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772895686408,"locked":false,"text":"Encoding is embarrassingly parallel at the chunk level: a 1-hour\nvideo splits into 360 ten-second chunks encoded independently\nthen stitched — wall-clock drops from 40min to under 3min. SQS\nwas rejected because Kafka already exists; adding a second broker\npurely for queueing adds ops cost with no benefit.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bfd","roundness":null,"containerId":null,"originalText":"Encoding is embarrassingly parallel at the chunk level: a 1-hour\nvideo splits into 360 ten-second chunks encoded independently\nthen stitched — wall-clock drops from 40min to under 3min. SQS\nwas rejected because Kafka already exists; adding a second broker\npurely for queueing adds ops cost with no benefit.","height":81.25,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":1240437244,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":3604.1204674799592,"angle":0,"y":-6126.6798051287624,"width":425.37246704101562},{"seed":833049540,"strokeStyle":"solid","id":"0j1NS0ldKxyhp47Dy6Wh4","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1772895686408,"locked":false,"text":"V3 -> V4: Presigned URLs + Service Split","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bfe","roundness":null,"containerId":null,"originalText":"V3 -> V4: Presigned URLs + Service Split","height":18.75,"link":null,"strokeColor":"#8B7FD4","fillStyle":"solid","groupIds":[],"versionNonce":1007131588,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":3604.1204674799592,"angle":0,"y":-6006.6798051287624,"width":295.54476928710938},{"seed":479214404,"strokeStyle":"solid","id":"vKDO-NbZSsM3r2e4LJpxd","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772895686408,"locked":false,"text":"Presigned URLs are the highest-leverage change in this evolution.\nBytes never enter the API process again. S3 events trigger transcode\njobs, replacing explicit API calls on the upload path. Service split is\nnow safe because services share no mutable state — each one can\nbe deployed and scaled independently without data integrity risk.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bff","roundness":null,"containerId":null,"originalText":"Presigned URLs are the highest-leverage change in this evolution.\nBytes never enter the API process again. S3 events trigger transcode\njobs, replacing explicit API calls on the upload path. Service split is\nnow safe because services share no mutable state — each one can\nbe deployed and scaled independently without data integrity risk.","height":81.25,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":514060924,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":3604.1204674799592,"angle":0,"y":-5980.6798051287624,"width":449.59149169921875},{"seed":418394820,"strokeStyle":"solid","id":"tpVKP-i1ssM7lvp-es_R9","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1772895686408,"locked":false,"text":"V4 -> V5: Polyglot Storage Tier","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bfg","roundness":null,"containerId":null,"originalText":"V4 -> V5: Polyglot Storage Tier","height":18.75,"link":null,"strokeColor":"#C47B3A","fillStyle":"solid","groupIds":[],"versionNonce":61309764,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":3604.1204674799592,"angle":0,"y":-5860.6798051287624,"width":231.94485473632812},{"seed":90520132,"strokeStyle":"solid","id":"xkq5Apnt43b4LmauhyW-w","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772895686408,"locked":false,"text":"PostgreSQL hits its WAL fsync ceiling at ~5K writes\/sec. Each\nreplacement is chosen by access pattern: Cassandra for high-write\nmetadata, ClickHouse for columnar analytics without a separate ETL\npipeline, Redis to absorb 95% of read load at sub-millisecond\nlatency before any request touches a persistent store.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bfh","roundness":null,"containerId":null,"originalText":"PostgreSQL hits its WAL fsync ceiling at ~5K writes\/sec. Each\nreplacement is chosen by access pattern: Cassandra for high-write\nmetadata, ClickHouse for columnar analytics without a separate ETL\npipeline, Redis to absorb 95% of read load at sub-millisecond\nlatency before any request touches a persistent store.","height":81.25,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":251151100,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":3604.1204674799592,"angle":0,"y":-5834.6798051287624,"width":436.071533203125},{"seed":1020088772,"strokeStyle":"solid","id":"j0KyLXfQfMdWVusPe_Qyp","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1772895686408,"locked":false,"text":"V5 -> V6: Origin Shield + Recommendations","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bfi","roundness":null,"containerId":null,"originalText":"V5 -> V6: Origin Shield + Recommendations","height":18.75,"link":null,"strokeColor":"#3A9E8E","fillStyle":"solid","groupIds":[],"versionNonce":769555140,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":3604.1204674799592,"angle":0,"y":-5714.6798051287624,"width":308.96978759765625},{"seed":239499588,"strokeStyle":"solid","id":"5BqgY4PAYoS_bBpfUASZc","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772895686408,"locked":false,"text":"Origin shield turns viral thundering herd from O(200 PoPs) origin\nrequests into O(1) per region. Pre-warming from the trending Kafka\ntopic pushes content to edge before demand arrives. Two-tower\nrecommendation separates slow recall from fast ranking — each\nscales independently with different latency budgets.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bfj","roundness":null,"containerId":null,"originalText":"Origin shield turns viral thundering herd from O(200 PoPs) origin\nrequests into O(1) per region. Pre-warming from the trending Kafka\ntopic pushes content to edge before demand arrives. Two-tower\nrecommendation separates slow recall from fast ranking — each\nscales independently with different latency budgets.","height":81.25,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":24019836,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":3604.1204674799592,"angle":0,"y":-5688.6798051287624,"width":423.21456909179688},{"seed":892252356,"strokeStyle":"solid","id":"4IOpBr4o_-ABBCOg4Ux8T","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1772895686408,"locked":false,"text":"The Pattern","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bfk","roundness":null,"containerId":null,"originalText":"The Pattern","height":18.75,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":1967817284,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":3604.1204674799592,"angle":0,"y":-5568.6798051287624,"width":92.639938354492188},{"seed":1361311812,"strokeStyle":"solid","id":"tfBhuIce6Z36OsldcXBom","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772895686408,"locked":false,"text":"Every upgrade in this system removed one form of shared mutable\nstate. Workers stopped competing for row locks. Features stopped\nsharing a process boundary. Writers stopped contending for WAL\nthroughput. Cache misses stopped amplifying to origin. The single\ngoverning principle across all six versions is: identify where\ncoordination creates a bottleneck, then replace it with independence.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bfl","roundness":null,"containerId":null,"originalText":"Every upgrade in this system removed one form of shared mutable\nstate. Workers stopped competing for row locks. Features stopped\nsharing a process boundary. Writers stopped contending for WAL\nthroughput. Cache misses stopped amplifying to origin. The single\ngoverning principle across all six versions is: identify where\ncoordination creates a bottleneck, then replace it with independence.","height":97.5,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":1011397628,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":3604.1204674799592,"angle":0,"y":-5542.6798051287624,"width":437.1634521484375},{"isDeleted":false,"locked":false,"strokeColor":"#4D9E7C","link":null,"roughness":0,"groupIds":[],"index":"bfm","backgroundColor":"#252838","angle":0,"fillStyle":"solid","strokeWidth":1,"version":5,"roundness":{"type":3},"type":"rectangle","updated":1772895686408,"id":"RT2iUNP07jkk9sJU1duIJ","x":3592.1204674799592,"seed":1577340868,"boundElements":[],"y":-5390.6798051287624,"opacity":100,"height":100,"width":852,"frameId":null,"strokeStyle":"solid","versionNonce":281647556},{"seed":736999236,"strokeStyle":"solid","id":"FQSkslziJbFYp0Su2hq8l","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772895686408,"locked":false,"text":"Key insight: The most consequential single change is V4 presigned\nURLs. It appears to be an implementation detail but permanently\nremoves the API server from the data path — making all subsequent\nservice decomposition safe without risking data integrity.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bfn","roundness":null,"containerId":null,"originalText":"Key insight: The most consequential single change is V4 presigned\nURLs. It appears to be an implementation detail but permanently\nremoves the API server from the data path — making all subsequent\nservice decomposition safe without risking data integrity.","height":70,"link":null,"strokeColor":"#9AA0B4","fillStyle":"solid","groupIds":[],"versionNonce":1837683836,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":3608.1204674799592,"angle":0,"y":-5376.6798051287624,"width":470.3714599609375},{"seed":1463692996,"strokeStyle":"dashed","id":"TCbuhVaRi2cFv0ab1euZD","strokeWidth":1,"roughness":0,"isDeleted":false,"startBinding":null,"endArrowhead":null,"opacity":100,"updated":1772895686408,"locked":false,"points":[[0,0],[3000,0]],"polygon":false,"version":5,"type":"line","backgroundColor":"transparent","index":"bfo","roundness":null,"lastCommittedPoint":null,"height":0,"link":null,"startArrowhead":null,"strokeColor":"#2A2D3A","fillStyle":"solid","groupIds":[],"endBinding":null,"versionNonce":729399620,"frameId":null,"boundElements":[],"x":1608.1204674799592,"angle":0,"y":-4874.6798051287624,"width":3000},{"isDeleted":false,"locked":false,"strokeColor":"#C47B3A","link":null,"roughness":0,"groupIds":[],"index":"bfp","backgroundColor":"#C47B3A","angle":0,"fillStyle":"solid","strokeWidth":2,"version":5,"roundness":null,"type":"ellipse","updated":1772895686408,"id":"U2mqY7ZiV4jOIFJKcaUrX","x":1636.1204674799592,"seed":1083422276,"boundElements":[],"y":-4854.6798051287624,"opacity":100,"height":36,"width":36,"frameId":null,"strokeStyle":"solid","versionNonce":854648060},{"seed":80498116,"strokeStyle":"solid","id":"AnbFfcEkQIw4w7ZUxGNaa","strokeWidth":2,"roughness":1,"isDeleted":