ex":"boy","roundness":null,"containerId":null,"originalText":"Revisit if:","height":15,"link":null,"strokeColor":"#9AA0B4","fillStyle":"solid","groupIds":[],"versionNonce":755299140,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":2284.1204674799592,"angle":0,"y":443.32019487123762,"width":57.443893432617188},{"seed":1063787076,"strokeStyle":"solid","id":"s6KYTC2CyomF3Ig-zABgS","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":12,"opacity":100,"verticalAlign":"top","updated":1772895686408,"locked":false,"text":"Avg content duration drops under 5min (shorts use case)","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"boz","roundness":null,"containerId":null,"originalText":"Avg content duration drops under 5min (shorts use case)","height":15,"link":null,"strokeColor":"#7EC8A4","fillStyle":"solid","groupIds":[],"versionNonce":1214894844,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":2368.1204674799592,"angle":0,"y":443.32019487123762,"width":336.16748046875},{"seed":1936994756,"strokeStyle":"dashed","id":"gFXjGPrnRYO9yegpWA010","strokeWidth":1,"roughness":0,"isDeleted":false,"startBinding":null,"endArrowhead":null,"opacity":100,"updated":1772895686408,"locked":false,"points":[[0,0],[0,850]],"polygon":false,"version":5,"type":"line","backgroundColor":"transparent","index":"bp0","roundness":null,"lastCommittedPoint":null,"height":850,"link":null,"startArrowhead":null,"strokeColor":"#2A2D3A","fillStyle":"solid","groupIds":[],"endBinding":null,"versionNonce":705555140,"frameId":null,"boundElements":[],"x":3568.1204674799592,"angle":0,"y":-314.67980512876238,"width":0},{"isDeleted":false,"locked":false,"strokeColor":"#2A2D3A","link":null,"roughness":0,"groupIds":[],"index":"bp1","backgroundColor":"#1E2030","angle":0,"fillStyle":"solid","strokeWidth":1,"version":5,"roundness":null,"type":"rectangle","updated":1772895686408,"id":"9WqUG3qjP_jXXk9na6_Q0","x":3588.1204674799592,"seed":219240772,"boundElements":[],"y":-274.67980512876238,"opacity":100,"height":780,"width":860,"frameId":null,"strokeStyle":"solid","versionNonce":908989308},{"seed":1469944004,"strokeStyle":"solid","id":"sJQUTUBwBnO1MATbxLpzu","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":17,"opacity":100,"verticalAlign":"top","updated":1772895686408,"locked":false,"text":"The Hardest Trade-off","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bp2","roundness":null,"containerId":null,"originalText":"The Hardest Trade-off","height":21.25,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":436990532,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":3604.1204674799592,"angle":0,"y":-258.67980512876238,"width":192.796875},{"seed":45537348,"strokeStyle":"solid","id":"tZ386y4LAvBp4TlOE4UFJ","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772895686408,"locked":false,"text":"Cassandra versus PostgreSQL is the most genuinely difficult\ndecision in this system. PostgreSQL is compelling precisely\nbecause everyone knows it: ACID is free, schema migrations\nare simple, read replicas extend read throughput, and it\nworks perfectly at launch-scale. The case for staying on\nPostgreSQL until it actually breaks is strong — premature\nCassandra adoption means accepting eventual consistency\nbefore you need the write throughput, paying the schema\nmigration tax early, and building app-level conflict resolution\nfor cases PostgreSQL would have handled automatically.\n\nThe decision pivots entirely on one number: 5,000 write\nQPS. At 500M DAU with per-second engagement events,\nyou will hit it. The question is only when. Choosing\nCassandra from the start avoids a painful live migration\nunder load — which is the worst possible time to do it.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bp3","roundness":null,"containerId":null,"originalText":"Cassandra versus PostgreSQL is the most genuinely difficult\ndecision in this system. PostgreSQL is compelling precisely\nbecause everyone knows it: ACID is free, schema migrations\nare simple, read replicas extend read throughput, and it\nworks perfectly at launch-scale. The case for staying on\nPostgreSQL until it actually breaks is strong — premature\nCassandra adoption means accepting eventual consistency\nbefore you need the write throughput, paying the schema\nmigration tax early, and building app-level conflict resolution\nfor cases PostgreSQL would have handled automatically.\n\nThe decision pivots entirely on one number: 5,000 write\nQPS. At 500M DAU with per-second engagement events,\nyou will hit it. The question is only when. Choosing\nCassandra from the start avoids a painful live migration\nunder load — which is the worst possible time to do it.","height":260,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":1385579516,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":3604.1204674799592,"angle":0,"y":-232.67980512876238,"width":383.39559936523438},{"seed":440086468,"strokeStyle":"solid","id":"eTIjBygLXhU4ZyyWN-Tlr","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":17,"opacity":100,"verticalAlign":"top","updated":1772895686408,"locked":false,"text":"What Most Designs Get Wrong","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bp4","roundness":null,"containerId":null,"originalText":"What Most Designs Get Wrong","height":21.25,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":2078083524,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":3604.1204674799592,"angle":0,"y":19.320194871237618,"width":255.01678466796875},{"seed":2118686532,"strokeStyle":"solid","id":"U2mslKgaZKUlkXGgBRvuT","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772895686408,"locked":false,"text":"Candidates treat recommendations as a SQL query:\nSELECT video_id FROM videos ORDER BY relevance_score\nLIMIT 20. This fundamentally misunderstands the scale.\nYou cannot compute relevance scores for 10 million videos\nin a single query in under 25ms — the math does not work\nat any level of database hardware. The two-tower\narchitecture exists precisely because no single-stage\napproach satisfies both the latency constraint and the\nquality requirement simultaneously. Recall and ranking are\nnot implementation details — they are architectural\nboundaries with completely different latency, accuracy,\nand infrastructure tradeoffs. Conflating them demonstrates\na misunderstanding of production ML systems.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bp5","roundness":null,"containerId":null,"originalText":"Candidates treat recommendations as a SQL query:\nSELECT video_id FROM videos ORDER BY relevance_score\nLIMIT 20. This fundamentally misunderstands the scale.\nYou cannot compute relevance scores for 10 million videos\nin a single query in under 25ms — the math does not work\nat any level of database hardware. The two-tower\narchitecture exists precisely because no single-stage\napproach satisfies both the latency constraint and the\nquality requirement simultaneously. Recall and ranking are\nnot implementation details — they are architectural\nboundaries with completely different latency, accuracy,\nand infrastructure tradeoffs. Conflating them demonstrates\na misunderstanding of production ML systems.","height":211.25,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":61105276,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":3604.1204674799592,"angle":0,"y":45.320194871237618,"width":381.34155273437