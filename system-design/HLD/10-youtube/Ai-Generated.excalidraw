1069069764,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":2119.1204674799592,"angle":0,"y":-6594.6798051287624,"width":176.65171813964844},{"seed":1971121988,"strokeStyle":"solid","id":"Cw0XF_VRO1UX48JzWpQH1","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":12,"opacity":100,"verticalAlign":"top","updated":1772895686408,"locked":false,"text":"All segment events, watch events, metadata updates hit\none primary. PostgreSQL WAL fsyncs serialize at ~5K\/s.\nGrowing WAL sync latency collapses all write throughput.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bdz","roundness":null,"containerId":null,"originalText":"All segment events, watch events, metadata updates hit\none primary. PostgreSQL WAL fsyncs serialize at ~5K\/s.\nGrowing WAL sync latency collapses all write throughput.","height":45,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":1034516604,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":2119.1204674799592,"angle":0,"y":-6574.6798051287624,"width":330.7314453125},{"seed":438724292,"strokeStyle":"solid","id":"GJn5HaySWSwiukK4MVRPP","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":12,"opacity":100,"verticalAlign":"top","updated":1772895686408,"locked":false,"text":"Category: IO","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"be0","roundness":null,"containerId":null,"originalText":"Category: IO","height":15,"link":null,"strokeColor":"#9AA0B4","fillStyle":"solid","groupIds":[],"versionNonce":1713724740,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":2119.1204674799592,"angle":0,"y":-6514.6798051287624,"width":76.415878295898438},{"seed":1773465156,"strokeStyle":"dashed","id":"m9frpbCVe5bAEFMYObXgn","strokeWidth":1.5,"roughness":0,"isDeleted":false,"startBinding":null,"endArrowhead":"arrow","opacity":100,"updated":1772895686408,"locked":false,"points":[[0,0],[0,-325]],"version":5,"elbowed":false,"type":"arrow","backgroundColor":"transparent","index":"be1","roundness":null,"lastCommittedPoint":null,"height":325,"link":null,"startArrowhead":null,"strokeColor":"#C45C5C","fillStyle":"solid","groupIds":[],"endBinding":null,"versionNonce":2136803580,"frameId":null,"boundElements":[],"x":2268.1204674799592,"angle":0,"y":-6633.1798051287624,"width":0},{"seed":1694926276,"strokeStyle":"dashed","id":"RiwKJGUSDLDDRN0T8ifmf","strokeWidth":1,"roughness":0,"isDeleted":false,"startBinding":null,"endArrowhead":null,"opacity":100,"updated":1772895686408,"locked":false,"points":[[0,0],[0,940]],"polygon":false,"version":5,"type":"line","backgroundColor":"transparent","index":"be2","roundness":null,"lastCommittedPoint":null,"height":940,"link":null,"startArrowhead":null,"strokeColor":"#2A2D3A","fillStyle":"solid","groupIds":[],"endBinding":null,"versionNonce":2005996740,"frameId":null,"boundElements":[],"x":3568.1204674799592,"angle":0,"y":-7294.6798051287624,"width":0},{"isDeleted":false,"locked":false,"strokeColor":"#2A2D3A","link":null,"roughness":0,"groupIds":[],"index":"be3","backgroundColor":"#1E2030","angle":0,"fillStyle":"solid","strokeWidth":1,"version":5,"roundness":null,"type":"rectangle","updated":1772895686408,"id":"Nw2DTv84MdOjkq5PkDHth","x":3588.1204674799592,"seed":1094266180,"boundElements":[],"y":-7254.6798051287624,"opacity":100,"height":840,"width":860,"frameId":null,"strokeStyle":"solid","versionNonce":1430948220},{"seed":1605035204,"strokeStyle":"solid","id":"opkYVRMx5PObSXM7Mi3KW","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":18,"opacity":100,"verticalAlign":"top","updated":1772895686408,"locked":false,"text":"The Two Most Critical Bottlenecks","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"be4","roundness":null,"containerId":null,"originalText":"The Two Most Critical Bottlenecks","height":22.5,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":1637473348,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":3604.1204674799592,"angle":0,"y":-7238.6798051287624,"width":312.87579345703125},{"seed":1173990468,"strokeStyle":"solid","id":"rRSq15QrA7eczNMcMaj7f","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1772895686408,"locked":false,"text":"BN-1: DB-as-Job-Queue","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"be5","roundness":null,"containerId":null,"originalText":"BN-1: DB-as-Job-Queue","height":18.75,"link":null,"strokeColor":"#C45C5C","fillStyle":"solid","groupIds":[],"versionNonce":45349372,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":3604.1204674799592,"angle":0,"y":-7204.6798051287624,"width":171.29986572265625},{"seed":369329092,"strokeStyle":"solid","id":"qbbVUsKvTZ9VUdAn1vjWT","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772895686408,"locked":false,"text":"This is the bottleneck that triggers the fatal cascade. The\nworker poll pattern — SELECT WHERE status=pending FOR\nUPDATE — is deceptively dangerous. With a growing table,\nPostgreSQL must scan every row to find pending entries unless\na partial index exists, which the baseline does not have. Thirty\nworkers each polling every second produce 30 concurrent\ntable scans holding row-level locks. As rows accumulate, lock\ncontention causes transactions to queue behind each other.\nDB CPU reaches 100%, query latency spikes from 1ms to\n500ms+, and the API connection pool — typically 20-50\nconnections — exhausts within seconds. Every incoming\nHTTP request then blocks waiting for a DB connection slot.\nThe API server's thread pool fills, memory grows, and the OOM\nkiller terminates the process. This is not a graceful degradation;\nit is a hard crash with zero user-visible warning.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"be6","roundness":null,"containerId":null,"originalText":"This is the bottleneck that triggers the fatal cascade. The\nworker poll pattern — SELECT WHERE status=pending FOR\nUPDATE — is deceptively dangerous. With a growing table,\nPostgreSQL must scan every row to find pending entries unless\na partial index exists, which the baseline does not have. Thirty\nworkers each polling every second produce 30 concurrent\ntable scans holding row-level locks. As rows accumulate, lock\ncontention causes transactions to queue behind each other.\nDB CPU reaches 100%, query latency spikes from 1ms to\n500ms+, and the API connection pool — typically 20-50\nconnections — exhausts within seconds. Every incoming\nHTTP request then blocks waiting for a DB connection slot.\nThe API server's thread pool fills, memory grows, and the OOM\nkiller terminates the process. This is not a graceful degradation;\nit is a hard crash with zero user-visible warning.","height":243.75,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":773698500,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":3604.1204674799592,"angle":0,"y":-7178.6798051287624,"width":411.33245849609375},{"seed":98986820,"strokeStyle":"solid","id":"JPj7L9NoinaaQpzsUVKkT","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1772895686408,"locked":false,"text":"BN-2: Monolith Upload OOM","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"be7","roundness":null,"containerId":null,"originalText":"BN-2: Monolith Upload OOM","height":18.75,"link":null,"strokeColor":"#C45C5C","fillStyle":"solid","groupIds":[],"versionNonce":312171132,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":3604.1204674799592,"angle":0,"y":-6910.6798051287624,"width":204.32989501953125},{"seed":1476420292,"strokeStyle":"solid","id":"VrCr_l39xguyBsMrWG1YY","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772895686408,"locked":false,"text":"The monolith's upload handler reads multipart body chunks\ninto memory before handing them off to the S3 upload SDK.\nThis seems harmless at low concurrency but becomes lethal\nat scale. 200 concurrent uploads at 100MB average means\n20GB of resident memory is required. The OS OOM killer\ntriggered on the API process kills not just upload handling\nbut authentication, metadata reads, and playback redirect\nlogic simultaneously — because they all live in the same\nprocess. From a user perspective: all active sessions drop,\nlogins fail, and streams freeze at exactly the same moment.\nThe fix — streaming upload directly to object storage using\npresigned URLs — bypasses the API server entirely for\nbytes, eliminating this class of failure permanently.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"be8","roundness":null,"containerId":null,"originalText":"The monolith's upload handler reads multipart body chunks\ninto memory before handing them off to the S3 upload SDK.\nThis seems harmless at low concurrency but becomes lethal\nat scale. 200 concurrent uploads at 100MB average means\n20GB of resident memory is required. The OS OOM killer\ntriggered on the API process kills not just upload handling\nbut authentication, metadata reads, and playback redirect\nlogic simultaneously — because they all live in the same\nprocess. From a user perspective: all active sessions drop,\nlogins fail, and streams freeze at exactly the same moment.\nThe fix — streaming upload directly to object storage using\npresigned URLs — bypasses the API server entirely for\nbytes, eliminating this class of failure permanently.","height":211.25,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":2067438404,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":3604.1204674799592,"angle":0,"y":-6884.6798051287624,"width":382.7196044921875},{"isDeleted":false,"locked":false,"strokeColor":"#C45C5C","link":null,"roughness":0,"groupIds":[],"index":"be9","backgroundColor":"#252838","angle":0,"fillStyle":"solid","strokeWidth":1,"version":5,"roundness":{"type":3},"type":"rectangle","updated":1772895686408,"id":"ngRHIGZcbHu_a7l8USf_P","x":3592.1204674799592,"seed":1391422020,"boundElements":[],"y":-6646.6798051287624,"opacity":100,"height":96,"width":852,"frameId":null,"strokeStyle":"solid","versionNonce":1606593276},{"seed":965837252,"strokeStyle":"solid","id":"4jDhTPAcvku7_vkIvLhEp","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772895686408,"locked":false,"text":"Key insight: BN-1 and BN-2 are causally linked. The DB job\nqueue grows because transcode workers can't drain it (BN-3),\nwhich slows DB queries, which exhausts the API connection pool,\nwhich causes upload buffers to back up, which triggers BN-2.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"beA","roundness":null,"containerId":null,"originalText":"Key insight: BN-1 and BN-2 are causally linked. The DB job\nqueue grows because transcode workers can't drain it (BN-3),\nwhich slows DB queries, which exhausts the API connection pool,\nwhich causes upload buffers to back up, which triggers BN-2.","height":70,"link":null,"strokeColor":"#9AA0B4","fillStyle":"solid","groupIds":[],"versionNonce":1934529220,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":3608.1204674799592,"angle":0,"y":-6630.6798051287624,"width":446.66943359375},{"seed":1124378948,"strokeStyle":"dashed","id":"kSnljmgcKVU3fpTL1tplh","strokeWidth":1,"roughness":0,"isDeleted":false,"startBinding":null,"endArrowhead":null,"opacity":100,"updated":17728956