6844484,"strokeStyle":"solid","id":"u08XlhCSQ80M7UcROHxhR","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":11,"opacity":100,"verticalAlign":"middle","updated":1772895686414,"locked":false,"text":"MISS","version":7,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bnY","roundness":null,"containerId":"8yUuPLGOgUwXeRPOp1QLy","originalText":"MISS","height":13.75,"link":null,"strokeColor":"#C45C5C","fillStyle":"solid","groupIds":[],"versionNonce":315620932,"textAlign":"center","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":3304.067967708841,"angle":0,"y":-759.55480512876238,"width":28.104999542236328},{"isDeleted":false,"locked":false,"strokeColor":"#C45C5C","link":null,"roughness":0,"groupIds":[],"index":"bnZ","backgroundColor":"#3d1010","angle":0,"fillStyle":"solid","strokeWidth":1,"version":5,"roundness":{"type":3},"type":"rectangle","updated":1772895686408,"id":"iI-1K3blM4yYzgcc-AvQX","x":3238.1204674799592,"seed":143705668,"boundElements":[{"type":"text","id":"xBqRis6KmuY2ZFKUbgNft"}],"y":-818.67980512876238,"opacity":100,"height":40,"width":160,"frameId":null,"strokeStyle":"solid","versionNonce":181460220},{"seed":1789353412,"strokeStyle":"solid","id":"xBqRis6KmuY2ZFKUbgNft","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":12,"opacity":100,"verticalAlign":"middle","updated":1772895686414,"locked":false,"text":"Process + SET key\nTTL=24h","version":7,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bna","roundness":null,"containerId":"iI-1K3blM4yYzgcc-AvQX","originalText":"Process + SET key TTL=24h","height":30,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":1480562116,"textAlign":"center","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":3261.8824685175568,"angle":0,"y":-813.67980512876238,"width":112.47599792480469},{"seed":218039620,"strokeStyle":"solid","id":"V50_cQYrya_YRH9WZ0HNx","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":12,"opacity":100,"verticalAlign":"top","updated":1772895686408,"locked":false,"text":"Worker can crash after S3 write but before Kafka commit.\nWithout idempotency: chunk re-runs, wastes 40 CPU-min.\nWith idem key: re-run detects prior completion, skips.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bnb","roundness":null,"containerId":null,"originalText":"Worker can crash after S3 write but before Kafka commit.\nWithout idempotency: chunk re-runs, wastes 40 CPU-min.\nWith idem key: re-run detects prior completion, skips.","height":45,"link":null,"strokeColor":"#9AA0B4","fillStyle":"solid","groupIds":[],"versionNonce":1797512572,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":2844.1204674799592,"angle":0,"y":-570.67980512876238,"width":339.6234130859375},{"seed":1693826244,"strokeStyle":"dashed","id":"gUIOtuYulwshDai9Juiik","strokeWidth":1,"roughness":0,"isDeleted":false,"startBinding":null,"endArrowhead":null,"opacity":100,"updated":1772895686408,"locked":false,"points":[[0,0],[0,740]],"polygon":false,"version":5,"type":"line","backgroundColor":"transparent","index":"bnc","roundness":null,"lastCommittedPoint":null,"height":740,"link":null,"startArrowhead":null,"strokeColor":"#2A2D3A","fillStyle":"solid","groupIds":[],"endBinding":null,"versionNonce":800049220,"frameId":null,"boundElements":[],"x":3568.1204674799592,"angle":0,"y":-1204.6798051287624,"width":0},{"isDeleted":false,"locked":false,"strokeColor":"#2A2D3A","link":null,"roughness":0,"groupIds":[],"index":"bnd","backgroundColor":"#1E2030","angle":0,"fillStyle":"solid","strokeWidth":1,"version":5,"roundness":null,"type":"rectangle","updated":1772895686408,"id":"XlxZeOi2RxH8MkLl_qw0z","x":3588.1204674799592,"seed":204047428,"boundElements":[],"y":-1164.6798051287624,"opacity":100,"height":680,"width":860,"frameId":null,"strokeStyle":"solid","versionNonce":977456636},{"seed":947411908,"strokeStyle":"solid","id":"qJsIwelrnoBDa3cyxegNw","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":17,"opacity":100,"verticalAlign":"top","updated":1772895686408,"locked":false,"text":"Retry Strategy","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bne","roundness":null,"containerId":null,"originalText":"Retry Strategy","height":21.25,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":446046148,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":3604.1204674799592,"angle":0,"y":-1148.6798051287624,"width":126.92190551757812},{"seed":872432452,"strokeStyle":"solid","id":"pxHvtkxb8TKiPQvcVJV1O","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772895686408,"locked":false,"text":"The formula wait = min(base x 2^attempt + jitter, 30s)\nuses base=100ms and caps at 30s to prevent indefinite\nblocking. The jitter term — random(0, 500ms) — is\ncritical: without it, all workers that fail simultaneously\n(e.g. during a Kafka broker restart) would retry at\nidentical intervals, creating a synchronized thundering\nherd against the recovering service. Jitter desynchronizes\nthem. Five attempts span roughly 6-7 seconds total before\nthe job moves to the DLQ.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bnf","roundness":null,"containerId":null,"originalText":"The formula wait = min(base x 2^attempt + jitter, 30s)\nuses base=100ms and caps at 30s to prevent indefinite\nblocking. The jitter term — random(0, 500ms) — is\ncritical: without it, all workers that fail simultaneously\n(e.g. during a Kafka broker restart) would retry at\nidentical intervals, creating a synchronized thundering\nherd against the recovering service. Jitter desynchronizes\nthem. Five attempts span roughly 6-7 seconds total before\nthe job moves to the DLQ.","height":146.25,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":422555260,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":3604.1204674799592,"angle":0,"y":-1122.6798051287624,"width":376.83056640625},{"seed":1428110020,"strokeStyle":"solid","id":"aKb0r-Pr-R8o_hGh9hdzz","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":17,"opacity":100,"verticalAlign":"top","updated":1772895686408,"locked":false,"text":"Dead Letter Queue Policy","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bng","roundness":null,"containerId":null,"originalText":"Dead Letter Queue Policy","height":21.25,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":365266756,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":3604.1204674799592,"angle":0,"y":-950.67980512876238,"width":213.21385192871094},{"seed":1987265092,"strokeStyle":"solid","id":"Wj9Mq1bqIsgmWbyIRecCS","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772895686408,"locked":false,"text":"DLQ entry is triggered after the 5th failed attempt. Each\nentry contains the full job context: video_id, chunk_index,\nrendition, all attempt timestamps, the last error message,\nand the original Kafka offset. PagerDuty fires a P2 alert\n(non-urgent, 30-minute SLA). On-call reviews the error\ntype: transient infrastructure errors (S3 throttle, spot\npreemption) get manually re-enqueued with one command.\nCorrupt source files trigger a creator notification and\nre-upload request. Encoding bugs page the video infra team.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bnh","roundness":null,"containerId":null,"originalText":"DLQ entry is triggered after the 5th failed attempt. Each\nentry contains the full job context: video_id, chunk_index,\nrendition, all attempt timestamps, the last error message,\nand the original Kafka offset. PagerDuty fires a P2 alert\n(non-urgent, 30-minute SLA). On-call reviews the error\ntype: transient infrastructure errors (S3 throttle, spot\npreemption) get manually re-enqueued with one command.\nCorrupt source files trigger a creator notification and\nre-upload request. Encoding bugs page the video infra team.","height":146.25,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":950828796,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":3604.1204674799592,"angle":0,"y":-924.67980512876238,"width":379.76858520507812},{"seed":1859803588,"strokeStyle":"solid","id":"SzTtHX0U4cKsMXrSLqPCj","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":17,"opacity":100,"verticalAlign":"top","updated":1772895686408,"locked":false,"text":"Idempotency Implementation","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bni","roundness":null,"containerId":null,"originalText":"Idempotency Implementation","height":21.25,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":1436286660,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":3604.1204674799592,"angle":0,"y":-734.67980512876238,"width":234.97383117675781},{"seed":158499140,"strokeStyle":"solid","id":"I8YzXS1_fPfIHiYjFypw6","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772895686408,"locked":false,"text":"The idempotency key is SHA-256(video_id + chunk_index +\nrendition + attempt_number). It is stored as a Redis key\nwith prefix idem: and TTL of 24 hours. When a worker\nreceives a job, it first executes Redis GET on the key.\nA HIT means this exact chunk was already successfully\nencoded and written to S3 — the worker acks the Kafka\noffset and moves on without any processing. A MISS means\nthe work is genuinely new. After successful S3 write, the\nworker executes Redis SET before committing the offset,\nmaking the operation crash-safe in both directions.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bnj","roundness":null,"containerId":null,"originalText":"The idempotency key is SHA-256(video_id + chunk_index +\nrendition + attempt_number). It is stored as a Redis key\nwith prefix idem: and TTL of 24 hours. When a worker\nreceives a job, it first executes Redis GET on the key.\nA HIT means this exact chunk was already successfully\nencoded and written to S3 — the worker acks the Kafka\noffset and moves on without any processing. A MISS means\nthe work is genuinely new. After successful S3 write, the\nworker executes Redis SET before committing the offset,\nmaking the operation crash-safe in both directions.","height":162.5,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":1631272828,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":3604.1204674799592,"angle":0,"y":-708.67980512876238,"width":379.31362915039062},{"isDeleted":false,"locked":false,"strokeColor":"#C45C5C","link":null,"roughness":0,"groupIds":[],"index":"bnk","backgroundColor":"#252838","angle":0,"fillStyle":"solid","strokeWidth":1,"version":5,"roundness":{"type":3},"type":"rectangle","updated":1772895686408,"id":"TwyEOyZXW5eitYOn_gQdv","x":3592.1204674799592,"seed":2107226308,"boundElements":[],"y":-516.67980512876238,"opacity":100,"height":96,"width":852,"frameId":null,"strokeStyle":"solid","versionNonce":1387759172},{"seed":1726873668,"strokeStyle":"solid","id":"b11FOvGbleznUQ6FUpQFx","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772895686408,"locked":false,"text":"Key insight: The most dangerous failure mode is the silent\none — a missed S3 ObjectCreated event that leaves a video\nstuck in processing=pending forever. No retry fires because\nno job was enqueued. Only the compensating cron scan\ndetects it. This is why every async trigger needs a\nsynchronous compensating sweep with a time-based threshold.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bnl","roundness":null,"containerId":null,"originalText":"Key insight: The most dangerous failure mode is the silent\none — a missed S3 ObjectCreated event that leaves a video\nstuck in processing=pending forever. No retry fires because\nno job was enqueued. Only the compensating cron scan\ndetects it. This is why every async trigger needs a\nsynchronous compensating sweep with a time-based threshold.","height":97.5,"link":null,"strokeColor":"#9AA0B4","fillStyle":"solid","groupIds":[],"versionNonce":2065559548,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":3608.1204674799592,"angle":0,"y":-502.67980512876238,"width":392.98953247070312},{"seed":1028478916,"strokeStyle":"dashed","id":"vXbkej2TUfKMvObx5Obzj","strokeWidth":1,"roughness":0,"isDeleted":false,"startBinding":null,"endArrowhead":null,"opacity":100,"updated":1772895686408,"locked":false,"points":[[0,0],[3000,0]],"polygon":false,"version":5,"type":"line","backgroundColor":"transparent","index":"bnm","roundness":null,"lastCommittedPoint":null,"height":0,"link":null,"startArrowhead":null,"strokeColor":"#2A2D3A","fillStyle":"solid","groupIds":[],"endBinding":null,"versionNonce":1106648516,"frameId":null,"boundElements":[],"x":1608.1204674799592,"angle":0,"y":-314.67980512876238,"width":3000},{"isDeleted":false,"locked":false,"strokeColor":"#C4913A","link":null,"roughness":0,"groupIds":[],"index":"bnn","backgroundColor":"#C4913A","angle":0,"fillStyle":"solid","strokeWidth":2,"version":5,"roundness":null,"type":"ellipse","updated":1772895686408,"id":"ODC3tp__doH5ijJSbtjDS","x":1636.1204674799592,"seed":1289076548,"boundElements":[],"y":-274.67980512876238,"opacity":100,"height":36,"width":36,"frameId":null,"strokeStyle":"solid","versionNonce":374771836},{"seed":769996484,"strokeStyle":"