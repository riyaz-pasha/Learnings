"y":-10804.679805128762,"opacity":100,"height":720,"width":860,"frameId":null,"strokeStyle":"solid","versionNonce":171240260},{"seed":1190922820,"strokeStyle":"solid","id":"i87xEqHDSVxfzJJrBf33b","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":18,"opacity":100,"verticalAlign":"top","updated":1772895686408,"locked":false,"text":"What This System Does","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bYz","roundness":null,"containerId":null,"originalText":"What This System Does","height":22.5,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":274029308,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":3604.1204674799592,"angle":0,"y":-10788.679805128762,"width":174.48046875},{"seed":1124737476,"strokeStyle":"solid","id":"_e3aqijHzIKoljq3AI6KC","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":16,"opacity":100,"verticalAlign":"top","updated":1772895686408,"locked":false,"text":"A video streaming platform ingests raw video from creators and studios,\ntranscodes each upload into 12+ renditions (360p to 4K, H.264\/H.265\/\nAV1), stores all output at exabyte scale, then delivers on-demand to\n500M daily users with adaptive quality and sub-200ms startup time.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bZ0","roundness":null,"containerId":null,"originalText":"A video streaming platform ingests raw video from creators and studios,\ntranscodes each upload into 12+ renditions (360p to 4K, H.264\/H.265\/\nAV1), stores all output at exabyte scale, then delivers on-demand to\n500M daily users with adaptive quality and sub-200ms startup time.","height":80,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":1316938436,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":3604.1204674799592,"angle":0,"y":-10760.679805128762,"width":463.4453125},{"seed":1416186180,"strokeStyle":"solid","id":"hE3saBX7Gs5RB0CpQJom_","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":16,"opacity":100,"verticalAlign":"top","updated":1772895686408,"locked":false,"text":"Two fundamentally different workloads coexist: a write-heavy upload and\nprocessing pipeline where correctness and durability are paramount, and\na read-heavy delivery pipeline where latency and availability dominate.\nThese halves have opposing optimization requirements and must be\narchitected and scaled as completely separate systems.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bZ1","roundness":null,"containerId":null,"originalText":"Two fundamentally different workloads coexist: a write-heavy upload and\nprocessing pipeline where correctness and durability are paramount, and\na read-heavy delivery pipeline where latency and availability dominate.\nThese halves have opposing optimization requirements and must be\narchitected and scaled as completely separate systems.","height":100,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":124296060,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":3604.1204674799592,"angle":0,"y":-10622.679805128762,"width":474},{"seed":1316454596,"strokeStyle":"solid","id":"o38JeW-9uhMAZf3-xNbp7","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":18,"opacity":100,"verticalAlign":"top","updated":1772895686408,"locked":false,"text":"Key Challenges","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bZ2","roundness":null,"containerId":null,"originalText":"Key Challenges","height":22.5,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":1973283396,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":3604.1204674799592,"angle":0,"y":-10476.679805128762,"width":114.46875},{"seed":1758644292,"strokeStyle":"solid","id":"u0kIdvJG8eJdOFbRfi7Qc","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":16,"opacity":100,"verticalAlign":"top","updated":1772895686408,"locked":false,"text":"Transcoding at scale: 500hr\/min x 12 renditions requires thousands of\nparallel encoding jobs running continuously on dedicated compute.\nAdaptive bitrate delivery: 2-6 second segments allow invisible quality\nswitching as each viewer's bandwidth fluctuates in real time.\nLong-tail CDN: 90% of watch time hits under 5% of content (Zipf\ndistribution), yet billions of rarely-watched videos must be served.\nThundering herd: viral content triggers simultaneous CDN cache misses\nacross all edge nodes at once. Recommendation inference: real-time ML\nscoring over billions of user-video pairs on every single page load.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bZ3","roundness":null,"containerId":null,"originalText":"Transcoding at scale: 500hr\/min x 12 renditions requires thousands of\nparallel encoding jobs running continuously on dedicated compute.\nAdaptive bitrate delivery: 2-6 second segments allow invisible quality\nswitching as each viewer's bandwidth fluctuates in real time.\nLong-tail CDN: 90% of watch time hits under 5% of content (Zipf\ndistribution), yet billions of rarely-watched videos must be served.\nThundering herd: viral content triggers simultaneous CDN cache misses\nacross all edge nodes at once. Recommendation inference: real-time ML\nscoring over billions of user-video pairs on every single page load.","height":180,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":725601276,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":3604.1204674799592,"angle":0,"y":-10448.679805128762,"width":463.8125},{"isDeleted":false,"locked":false,"strokeColor":"#4D9E7C","link":null,"roughness":0,"groupIds":[],"index":"bZ4","backgroundColor":"#252838","angle":0,"fillStyle":"solid",