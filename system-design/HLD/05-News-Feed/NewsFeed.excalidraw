oupIds":[],"versionNonce":642710908,"textAlign":"left","fontFamily":8,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-1195.1413263995755,"angle":0,"y":-1689.9023214913927,"width":316.79998779296875},{"seed":2039367676,"strokeStyle":"solid","id":"DBAF_yhXTDllgOwDne8hY","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":20,"opacity":100,"verticalAlign":"top","updated":1772704418409,"locked":false,"text":"1. Functions Requirements\n\np0 - Users should be able to see the feed ( reverse chronoclogical order (newer post first) )\np0 - User should be able to post\n","version":192,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"a1","roundness":null,"containerId":null,"originalText":"1. Functions Requirements\n\np0 - Users should be able to see the feed ( reverse chronoclogical order (newer post first) )\np0 - User should be able to post\n","height":125,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":1749461060,"textAlign":"left","fontFamily":8,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-1519.1413263995755,"angle":0,"y":-1535.9023214913927,"width":1023},{"seed":352053372,"strokeStyle":"solid","id":"rTXu5OB7A4uCyBNBS43Bp","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":20,"opacity":100,"verticalAlign":"top","updated":1772704418409,"locked":false,"text":"2. Non Functional requirements\n\n- strong consistency for post creation and should be reliable.\n- eventual consistency for new feeds ( new post can appeat with some delay )\n\n- highly scalable \n- highly available","version":229,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"a2","roundness":null,"containerId":null,"originalText":"2. Non Functional requirements\n\n- strong consistency for post creation and should be reliable.\n- eventual consistency for new feeds ( new post can appeat with some delay )\n\n- highly scalable \n- highly available","height":175,"link":null,"strokeColor":"#1e1e1e","fill