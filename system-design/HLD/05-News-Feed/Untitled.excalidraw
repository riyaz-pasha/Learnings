151","fillStyle":"solid","groupIds":[],"versionNonce":1311777092,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-241.5596923828125,"angle":0,"y":-713,"width":803.9769287109375},{"seed":1834079300,"strokeStyle":"solid","id":"tBOc7w1E8EfaUaxpLHqVC","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772747707441,"locked":false,"text":"New tradeoff: Like counts in DB are stale by up to 30s. Redis is source of truth for counts. If Redis node fails, recent\nlike counts since last flush are lost. Must accept eventual consistency on engagement numbers.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b2o","roundness":null,"containerId":null,"originalText":"New tradeoff: Like counts in DB are stale by up to 30s. Redis is source of truth for counts. If Redis node fails, recent\nlike counts since last flush are lost. Must accept eventual consistency on engagement numbers.","height":35,"link":null,"strokeColor":"#b45309","fillStyle":"solid","groupIds":[],"versionNonce":89163004,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-241.5596923828125,"angle":0,"y":324,"width":826.05487060546875},{"seed":1880533956,"strokeStyle":"solid","id":"xRN5LFlnuMNZC5l3ffLr7","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":16,"opacity":100,"verticalAlign":"top","updated":1772747707441,"locked":false,"text":"Scale ceiling: ~50M DAU","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b2p","roundness":null,"containerId":null,"originalText":"Scale ceiling: ~50M DAU","height":20,"link":null,"strokeColor":"#b91c1c","fillStyle":"solid","groupIds":[],"versionNonce":430135492,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":828.4403076171875,"angle":0,"y":202,"width":185.85585021972656},{"seed":55874372,"strokeStyle":"solid","id":"XcOtzTtmnApDQ