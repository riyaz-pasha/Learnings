:\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b0C\",\"roundness\":null,\"seed\":1627787632,\"version\":2,\"versionNonce\":686614928,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Availability\",\"fontSize\":16,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Availability\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s3ab\",\"type\":\"text\",\"x\":24,\"y\":1703,\"width\":321.859619140625,\"height\":140,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b0D\",\"roundness\":null,\"seed\":657587600,\"version\":2,\"versionNonce\":1474049904,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Target: 99.99% = 52 min downtime per year\\nRead path: 99.99%  |  Write path: 99.9%\\n(users tolerate post-fail more than feed-down)\\n\\nViolated by: single-AZ DB, no read replicas,\\nno circuit breakers on downstream services.\\nResponsible: multi-AZ fleet, cache fallback\\n(stale feed is always better than no feed).\",\"fontSize\":14,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Target: 99.99% = 52 min downtime per year\\nRead path: 99.99%  |  Write path: 99.9%\\n(users tolerate post-fail more than feed-down)\\n\\nViolated by: single-AZ DB, no read replicas,\\nno circuit breakers on downstream services.\\nResponsible: multi-AZ fleet, cache fallback\\n(stale feed is always better than no feed).\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s3b\",\"type\":\"rectangle\",\"x\":530,\"y\":1666,\"width\":502,\"height\":205,\"angle\":0,\"strokeColor\":\"#fca5a5\",\"backgroundColor\":\"#fff1f2\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b0E\",\"roundness\":{\"type\":3},\"seed\":455238512,\"version\":2,\"versionNonce\":1287206800,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s3bt\",\"type\":\"text\",\"x\":544,\"y\":1678,\"width\":60.303955078125,\"height\":20,\"angle\":0,\"strokeColor\":\"#b91c1c\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b0F\",\"roundness\":null,\"seed\":1765526416,\"version\":2,\"versionNonce\":1615055216,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Latency\",\"fontSize\":16,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Latency\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s3bb\",\"type\":\"text\",\"x\":544,\"y\":1703,\"width\":320.235595703125,\"height\":140,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b0G\",\"roundness\":null,\"seed\":837055856,\"version\":2,\"versionNonce\":231458192,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Feed Read:   P50 < 80ms    P99 < 500ms\\nPost Write:  P50 < 200ms   P99 < 1000ms\\nLike\/React:  P50 < 50ms    P99 < 200ms\\n\\nViolated by: cache miss forcing DB query,\\nN+1 fetches hydrating post metadata per item.\\nResponsible: Redis feed cache, CDN for media,\\nprecomputed ranked feeds, connection pooling.\",\"fontSize\":14,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Feed Read:   P50 < 80ms    P99 < 500ms\\nPost Write:  P50 < 200ms   P99 < 1000ms\\nLike\/React:  P50 < 50ms    P99 < 200ms\\n\\nViolated by: cache miss forcing DB query,\\nN+1 fetches hydrating post metadata per item.\\nResponsible: Redis feed cache, CDN for media,\\nprecomputed ranked feeds, connection pooling.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s3c\",\"type\":\"rectangle\",\"x\":1058,\"y\":1666,\"width\":512,\"height\":205,\"angle\":0,\"strokeColor\":\"#fca5a5\",\"backgroundColor\":\"#fff1f2\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b0H\",\"roundness\":{\"type\":3},\"seed\":618387856,\"version\":2,\"versionNonce\":1508449136,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s3ct\",\"type\":\"text\",\"x\":1072,\"y\":1678,\"width\":91.90391540527344,\"height\":20,\"angle\":0,\"strokeColor\":\"#b91c1c\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b0I\",\"roundness\":null,\"seed\":177489776,\"version\":2,\"versionNonce\":1767674768,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Throughput\",\"fontSize\":16,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Throughput\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s3cb\",\"type\":\"text\",\"x\":1072,\"y\":1703,\"width\":320.48760986328125,\"height\":140,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b0J\",\"roundness\":null,\"seed\":1296705424,\"version\":2,\"versionNonce\":1460940144,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Feed reads:   50K QPS avg   200K QPS peak\\nPost writes:  500 QPS avg   2K QPS peak\\nLike events:  50K QPS avg   500K QPS peak\\n\\nViolated by: no horizontal scaling, DB as\\nbottleneck for all reads, single Kafka partition.\\nResponsible: horizontally scaled API tier,\\nKafka partitioned by user_id, Redis cluster.\",\"fontSize\":14,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Feed reads:   50K QPS avg   200K QPS peak\\nPost writes:  500 QPS avg   2K QPS peak\\nLike events:  50K QPS avg   500K QPS peak\\n\\nViolated by: no horizontal scaling, DB as\\nbottleneck for all reads, single Kafka partition.\\nResponsible: horizontally scaled API tier,\\nKafka partitioned by user_id, Redis cluster.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s3d\",\"type\":\"rectangle\",\"x\":10,\"y\":1882,\"width\":502,\"height\":200,\"angle\":0,\"strokeColor\":\"#fcd34d\",\"backgroundColor\":\"#fffbeb\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b0K\",\"roundness\":{\"type\":3},\"seed\":561633648,\"version\":2,\"versionNonce\":1973658000,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s3dt\",\"type\":\"text\",\"x\":24,\"y\":1894,\"width\":74.03192138671875,\"height\":20,\"angle\":0,\"strokeColor\":\"#b45309\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b0L\",\"roundness\":null,\"seed\":784250256,\"version\":2,\"versionNonce\":1628241776,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Durability\",\"fontSize\":16,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Durability\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s3db\",\"type\":\"text\",\"x\":24,\"y\":1919,\"width\":330.8336181640625,\"height\":122.5,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b0M\",\"roundness\":null,\"seed\":702360432,\"version\":2,\"versionNonce\":1104736144,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Target: 99.9999% (6 nines) — zero post loss\\nMedia: S3-class object storage (11 nines)\\n\\nViolated by: write-to-cache-only, async DB write\\nthat fails silently, no WAL replication.\\nResponsible: sync write to DB primary before\\nACK, WAL to 2+ replicas, cross-region backup.\",\"fontSize\":14,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Target: 99.9999% (6 nines) — zero post loss\\nMedia: S3-class object storage (11 nines)\\n\\nViolated by: write-to-cache-only, async DB write\\nthat fails silently, no WAL replication.\\nResponsible: sync write to DB primary before\\nACK, WAL to 2+ replicas, cross-region backup.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s3e\",\"type\":\"rectangle\",\"x\":530,\"y\":1882,\"width\":502,\"height\":200,\"angle\":0,\"strokeColor\":\"#fcd34d\",\"backgroundColor\":\"#fffbeb\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b0N\",\"roundness\":{\"type\":3},\"seed\":1316062096,\"version\":2,\"versionNonce\":404459888,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s3et\",\"type\":\"text\",\"x\":544,\"y\":1894,\"width\":141.8878936767578,\"height\":20,\"angle\":0,\"strokeColor\":\"#b45309\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b0O\",\"roundness\":null,\"seed\":772160880,\"version\":2,\"versionNonce\":909409680,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Consistency Model\",\"fontSize\":16,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Consistency Model\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s3eb\",\"type\":\"text\",\"x\":544,\"y\":1919,\"width\":331.715576171875,\"height\":140,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b0P\",\"roundness\":null,\"seed\":1251643792,\"version\":2,\"versionNonce\":1401414512,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Feed content:     Eventual  (2-5s lag OK)\\nFollow\/Unfollow:  Read-your-writes (strong)\\nLike counts:      Eventual  (delta of 20 fine)\\n\\nViolated by: reading replica after unfollow —\\nuser sees the unfollowed person's posts again.\\nResponsible: route social graph reads to primary;\\nfeed content from replica is fine.\",\"fontSize\":14,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Feed content:     Eventual  (2-5s lag OK)\\nFollow\/Unfollow:  Read-your-writes (strong)\\nLike counts:      Eventual  (delta of 20 fine)\\n\\nViolated by: reading replica after unfollow —\\nuser sees the unfollowed person's posts again.\\nResponsible: route social graph reads to primary;\\nfeed content from replica is fine.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s3f\",\"type\":\"rectangle\",\"x\":1058,\"y\":1882,\"width\":512,\"height\":200,\"angle\":0,\"strokeColor\":\"#fcd34d\",\"backgroundColor\":\"#fffbeb\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b0Q\",\"roundness\":{\"type\":3},\"seed\":792530800,\"version\":2,\"versionNonce\":1944996752,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s3ft\",\"type\":\"text\",\"x\":1072,\"y\":1894,\"width\":98.19192504882812,\"height\":20,\"angle\":0,\"strokeColor\":\"#b45309\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b0R\",\"roundness\":null,\"seed\":980541328,\"version\":2,\"versionNonce\":1100608880,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Idempotency\",\"fontSize\":16,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Idempotency\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s3fb\",\"type\":\"text\",\"x\":1072,\"y\":1919,\"width\":336.2095947265625,\"height\":140,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b0S\",\"roundness\":null,\"seed\":1170841968,\"version\":2,\"versionNonce\":893278608,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Post creation: client sends UUID idem_key.\\nLike: set-based (liked_by table), not counter.\\nDouble-like = upsert, never double-count.\\nFan-out worker: dedup by (post_id, user_id).\\n\\nViolated by: retry POST \/posts without key\\n= duplicate post published to feed.\\nResponsible: API checks key in Redis (TTL 24h).\",\"fontSize\":14,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Post creation: client sends UUID idem_key.\\nLike: set-based (liked_by table), not counter.\\nDouble-like = upsert, never double-count.\\nFan-out worker: dedup by (post_id, user_id).\\n\\nViolated by: retry POST \/posts without key\\n= duplicate post published to feed.\\nResponsible: API checks key in Redis (TTL 24h).\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s3g\",\"type\":\"rectangle\",\"x\":10,\"y\":2093,\"width\":502,\"height\":192,\"angle\":0,\"strokeColor\":\"#86efac\",\"backgroundColor\":\"#f0fdf4\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b0T\",\"roundness\":{\"type\":3},\"seed\":237989264,\"version\":2,\"versionNonce\":127518576,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s3gt\",\"type\":\"text\",\"x\":24,\"y\":2105,\"width\":63.51995849609375,\"height\":20,\"angle\":0,\"strokeColor\":\"#15803d\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b0U\",\"roundness\":null,\"seed\":1089729392,\"version\":2,\"versionNonce\":761046928,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Security\",\"fontSize\":16,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Security\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s3gb\",\"type\":\"text\",\"x\":24,\"y\":2130,\"width\":327.02557373046875,\"height\":140,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b0V\",\"roundness\":null,\"seed\":1863007120,\"version\":2,\"versionNonce\":1640978800,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Auth: JWT \/ OAuth2 on every API call.\\nPrivate accounts: follow-check before returning\\nany content from private profiles.\\nRate limits: 100 reads\/min, 10 posts\/min.\\n\\nViolated by: missing auth on feed endpoint\\nexposes private posts. No rate limit = DDoS.\\nResponsible: API gateway (auth + rate limiting).\",\"fontSize\":14,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Auth: JWT \/ OAuth2 on every API call.\\nPrivate accounts: follow-check before returning\\nany content from private profiles.\\nRate limits: 100 reads\/min, 10 posts\/min.\\n\\nViolated by: missing auth on feed endpoint\\nexposes private posts. No rate limit = DDoS.\\nResponsible: API gateway (auth + rate limiting).\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s3h\",\"type\":\"rectangle\",\"x\":530,\"y\":2093,\"width\":502,\"height\":192,\"angle\":0,\"strokeColor\":\"#86efac\",\"backgroundColor\":\"#f0fdf4\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b0W\",\"roundness\":{\"type\":3},\"seed\":1191445872,\"version\":2,\"versionNonce\":1753298320,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s3ht\",\"type\":\"text\",\"x\":544,\"y\":2105,\"width\":99.77589416503906,\"height\":20,\"angle\":0,\"strokeColor\":\"#15803d\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b0X\",\"roundness\":null,\"seed\":524110224,\"version\":2,\"versionNonce\":1132637040,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Observability\",\"fontSize\":16,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Observability\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s3hb\",\"type\":\"text\",\"x\":544,\"y\":2130,\"width\":309.59564208984375,\"height\":122.5,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b0Y\",\"roundness\":null,\"seed\":1967249264,\"version\":2,\"versionNonce\":736363408,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Key metrics: feed_p99_ms, cache_hit_ratio,\\nfan_out_lag_s, like_event_lag_ms.\\nDistributed traces: OTEL per request\\n(API → cache → DB → ranker → response).\\nAlerts: p99 > 500ms for 2 min → page oncall.\\nViolated by: no tracing makes it impossible\\nto debug which step caused a P99 spike.\",\"fontSize\":14,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Key metrics: feed_p99_ms, cache_hit_ratio,\\nfan_out_lag_s, like_event_lag_ms.\\nDistributed traces: OTEL per request\\n(API → cache → DB → ranker → response).\\nAlerts: p99 > 500ms for 2 min → page oncall.\\nViolated by: no tracing makes it impossible\\nto debug which step caused a P99 spike.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s3i\",\"type\":\"rectangle\",\"x\":1058,\"y\":2093,\"width\":512,\"height\":192,\"angle\":0,\"strokeColor\":\"#93c5fd\",\"backgroundColor\":\"#eff6ff\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b0Z\",\"roundness\":{\"type\":3},\"seed\":1509791632,\"version\":2,\"versionNonce\":1996209520,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s3it\",\"type\":\"text\",\"x\":1072,\"y\":2105,\"width\":95.119903