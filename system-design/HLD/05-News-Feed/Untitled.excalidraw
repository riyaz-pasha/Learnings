trokeStyle":"solid","versionNonce":672930812},{"seed":1942659196,"strokeStyle":"solid","id":"VqZj8VDc-_hfvLuuRwnhz","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":16,"opacity":100,"verticalAlign":"top","updated":1772748823810,"locked":false,"text":"Consistency Model","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bF3","roundness":null,"containerId":null,"originalText":"Consistency Model","height":20,"link":null,"strokeColor":"#b45309","fillStyle":"solid","groupIds":[],"versionNonce":1521433724,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":2342.8699240820788,"angle":0,"y":-3949.3457143105743,"width":141.88789367675781},{"seed":655962364,"strokeStyle":"solid","id":"C_MJHrsrjvmLrWG7ue1KU","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772748823810,"locked":false,"text":"Feed content:     Eventual  (2-5s lag OK)\nFollow\/Unfollow:  Read-your-writes (strong)\nLike counts:      Eventual  (delta of 20 fine)\n\nViolated by: reading replica after unfollow —\nuser sees the unfollowed person's posts again.\nResponsible: route social graph reads to primary;\nfeed content from replica is fine.","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bF4","roundness":null,"containerId":null,"originalText":"Feed content:     Eventual  (2-5s lag OK)\nFollow\/Unfollow:  Read-your-writes (strong)\nLike counts:      Eventual  (delta of 20 fine)\n\nViolated by: reading replica after unfollow —\nuser sees the unfollowed person's posts again.\nResponsible: route social graph reads to primary;\nfeed content from replica is fine.","height":140,"link":null,"strokeColor":"#334155","fillStyle":"solid","groupIds":[],"versionNonce":2131381500,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":2342.8699240820788,"angle":0,"y":-3924.3457143105743,"width":331.715576171875},