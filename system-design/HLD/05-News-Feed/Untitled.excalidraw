,"boundElements":[{"type":"text","id":"OKX6wzuVv5pTxMqwDa4v7"}],"y":-5211,"opacity":100,"height":100,"width":220,"frameId":null,"strokeStyle":"solid","versionNonce":938019524},{"seed":824145732,"strokeStyle":"solid","id":"OKX6wzuVv5pTxMqwDa4v7","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":16,"opacity":100,"verticalAlign":"middle","updated":1772747707446,"locked":false,"text":"10M Follower\nFeed Caches\nUpdated","version":7,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"ac","roundness":null,"containerId":"w1KI_x7McNs82oBwfsPUp","originalText":"10M Follower\nFeed Caches\nUpdated","height":60,"link":null,"strokeColor":"#ef4444","fillStyle":"solid","groupIds":[],"versionNonce":135212156,"textAlign":"center","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":329.00030899047852,"angle":0,"y":-5191,"width":98.879997253417969},{"seed":1345842884,"strokeStyle":"solid","id":"1dvAwHARpKM7dFgoW72yh","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":16,"opacity":100,"verticalAlign":"top","updated":1772747707441,"locked":false,"text":"This is why naive fan-out-on-write\nbreaks for celebrity accounts.\nHybrid fan-out is the solution.","version":6,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"ad","roundness":null,"containerId":null,"originalText":"This is why naive fan-out-on-write\nbreaks for celebrity accounts.\nHybrid fan-out is the solution.","height":60,"link":null,"strokeColor":"#7f1d1d","fillStyle":"solid","groupIds":[],"versionNonce":2139296324,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":518.4403076171875,"angle":0,"y":-5196,"width":270.623779296875},{"seed":1951757892,"strokeStyle":"solid","id":"IZD85ZRJ9sct_N04BBipI","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":26,"opacity":100,"verticalAlign":"top","updated":1772747707441,"locked":false,"text":"NEWS FEED — Step 2: Functional Requirements","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"ae","roundness":null,"containerId":null,"originalText":"NEWS FEED — Step 2: Functional Requirements","height":32.5,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":2074158076,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":78.4403076171875,"angle":0,"y":-4966,"width":610.16766357421875},{"seed":1515589060,"strokeStyle":"solid","id":"xYblKedfvOmP1OAkGUdJo","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":16,"opacity":100,"verticalAlign":"top","updated":1772747707441,"locked":false,"text":"RED = P0 (breaks)   YELLOW = P1 (degrades)   PURPLE = P2 (nice to have)","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"af","roundness":null,"containerId":null,"originalText":"RED = P0 (breaks)   YELLOW = P1 (degrades)   PURPLE = P2 (nice to have)","height":20,"link":null,"strokeColor":"#757575","fillStyle":"solid","groupIds":[],"versionNonce":1701849540,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-241.5596923828125,"angle":0,"y":-4925,"width":603.90362548828125},{"isDeleted":false,"locked":false,"strokeColor":"#ef4444","link":null,"roughness":1,"groupIds":[],"index":"ag","backgroundColor":"#ffc9c9","angle":0,"fillStyle":"solid","strokeWidth":2,"version":5,"roundness":{"type":3},"type":"rectangle","updated":1772747707441,"id":"O83EtHvrj6-LBPRkdNS9O","x":-251.5596923828125,"seed":1935127876,"boundElements":[{"type":"text","id":"tLZabpJZUa1o8_TKFYuDf"}],"y":-4901,"opacity":100,"height":160,"width":490,"frameId":null,"strokeStyle":"solid","versionNonce":139674748},{"seed":1555590340,"strokeStyle":"solid","id":"tLZabpJZUa1o8_TKFYuDf","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"middle","updated":1772747707446,"locked":false,"text":"FR1 — Post Creation [P0]\nStore post durably on write.\nExample: @celebrity posts album art,\nstored once, fan-out to 100M.\nHidden: Idempotency on retry —\nnetwork drop after write = duplicate\npost if client retries w\/o dedup key.","version":7,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"ah","roundness":null,"containerId":"O83EtHvrj6-LBPRkdNS9O","originalText":"FR1 — Post Creation [P0]\nStore post durably on write.\nExample: @celebrity posts album art,\nstored once, fan-out to 100M.\nHidden: Idempotency on retry —\nnetwork drop after write = duplicate\npost if client retries w\/o dedup key.","height":122.5,"link":null,"strokeColor":"#ef4444","fillStyle":"solid","groupIds":[],"versionNonce":1525431548,"textAlign":"center","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-132.00670623779297,"angle":0,"y":-4882.25,"width":250.89402770996094},{"isDeleted":false,"locked":false,"strokeColor":"#ef4444","link":null,"roughness":1,"groupIds":[],"index":"ai","backgroundColor":"#ffc9c9","angle":0,"fillStyle":"solid","strokeWidth":2,"version":5,"roundness":{"type":3},"type":"rectangle","updated":1772747707441,"id":"GkyXOx__TUUPLvxiv_md_","x":268.4403076171875,"seed":1477850180,"boundElements":[{"type":"text","id":"slxpr3olFbWQagc8FWI6h"}],"y":-4901,"opacity":100,"height":160,"width":490,"frameId":null,"strokeStyle":"solid","versionNonce":1793938684},{"seed":1129253828,"strokeStyle":"solid","id":"slxpr3olFbWQagc8FWI6h","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"middle","updated":1772747707447,"locked":false,"text":"FR2 — Feed Generation \/ Fan-out [P0]\nPropagate post to follower feed caches.\nExample: 500-follower user posts,\n500 feed entries updated in <100ms.\nHidden: Celebrity (10M followers) breaks\nsync fan-out. Need HYBRID strategy:\nwrite for normals, read for mega accounts.","version":7,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"aj","roundness":null,"containerId":"GkyXOx__TUUPLvxiv_md_","originalText":"FR2 — Feed Generation \/ Fan-out [P0]\nPropagate post to follower feed caches.\nExample: 500-follower user posts,\n500 feed entries updated in <100ms.\nHidden: Celebrity (10M followers) breaks\nsync fan-out. Need HYBRID strategy:\nwrite for normals, read for mega accounts.","height":122.5,"link":null,"strokeColor":"#ef4444","fillStyle":"solid","groupIds":[],"versionNonce":1624456572,"textAlign":"center","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":368.20429992675781,"angle":0,"y":-4882.25,"width":290.47201538085938},{"isDeleted":false,"locked":false,"strokeColor":"#ef4444","link":null,"roughness":1,"groupIds":[],"index":"ak","backgroundColor":"#ffc9c9","angle":0,"fillStyle":"solid","strokeWidth":2,"version":5,"roundness":{"type":3},"type":"rectangle","updated":1772747707441,"id":"YVkKG0XE_4U68vjei-4Cv","x":788.4403076171875,"seed":276886340,"boundElements":[{"type":"text","id":"6wXVFh-1IhLnHIUe-08Mj"}],"y":-4901,"opacity":100,"height":160,"width":490,"frameId":null,"strokeStyle":"solid","versionNonce":15816060},{"seed":1040837316,"strokeStyle":"solid","id":"6wXVFh-1IhLnHIUe-08Mj","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"middle","updated":1772747707447,"locked":false,"text":"FR3 — Feed Retrieval [P0]\nReturn ranked, paginated feed on open.\nExample: Instagram loads top 20 posts\nfrom 300 followed accounts in <200ms.\nHidden: Merging celebrity fan-on-read\nwith precomputed cache without blowing\nlatency budget at read time.","version":7,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"al","roundness":null,"containerId":"YVkKG0XE_4U68vjei-4Cv","originalText":"FR3 — Feed Retrieval [P0]\nReturn ranked, paginated feed on open.\nExample: Instagram loads top 20 posts\nfrom 300 followed accounts in <200ms.\nHidden: Merging celebrity fan-on-read\nwith precomputed cache without blowing\nlatency budget at read time.","height":122.5,"link":null,"strokeColor":"#ef4444","fillStyle":"solid","groupIds":[],"versionNonce":50736636,"textAlign":"center","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":896.84231567382812,"angle":0,"y":-4882.25,"width":273.19598388671875},{"isDeleted":false,"locked":false,"strokeColor":"#ef4444","link":null,"roughness":1,"groupIds":[],"index":"am","backgroundColor":"#ffc9c9","angle":0,"fillStyle":"solid","strokeWidth":2,"version":5,"roundness":{"type":3},"type":"rectangle","updated":1772747707441,"id":"eD29fJHt_VZnVUYJi3GPo","x":-251.5596923828125,"seed":1317532228,"boundElements":[{"type":"text","id":"Ap9D6UZyUXHgccewZAtXO"}],"y":-4721,"opacity":100,"height":155,"width":490,"frameId":null,"strokeStyle":"solid","versionNonce":664880636},{"seed":1087965636,"strokeStyle":"solid","id":"Ap9D6UZyUXHgccewZAtXO","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"middle","updated":1772747707447,"locked":false,"text":"FR4 — Follow \/ Unfollow [P0]\nUser follows or unfollows an account.\nExample: Alice unfollows Bob — Bob's\nposts must disappear from feed fast.\nHidden: Unfollow must INVALIDATE Alice's\nfeed cache. New follow needs historical\npost backfill into existing cache.","version":7,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"an","roundness":null,"containerId":"eD29fJHt_VZnVUYJi3GPo","originalText":"FR4 — Follow \/ Unfollow [P0]\nUser follows or unfollows an account.\nExample: Alice unfollows Bob — Bob's\nposts must disappear from feed fast.\nHidden: Unfollow must INVALIDATE Alice's\nfeed cache. New follow needs historical\npost backfill into existing cache.","height":122.5,"link":null,"strokeColor":"#ef4444","fillStyle":"solid","groupIds":[],"versionNonce":847711868,"textAlign":"center","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-151.15870666503906,"angle":0,"y":-4704.75,"width":289.19802856445312},{"isDeleted":false,"locked":false,"strokeColor":"#f59e0b","link":null,"roughness":1,"groupIds":[],"index":"ao","backgroun