check in feed service,\nrate limits 100 reads\/min and 10 posts\/min.\nViolated by: celebrity read-path merge at V6 must\nalso enforce private-account visibility — easy to miss.\nGap: mute\/block lists not applied in celebrity_posts\nmerge path — a muted celebrity's posts could appear.","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bJ2","roundness":null,"containerId":null,"originalText":"Covered: JWT verified at gateway on every request,\nprivate-account follow-check in feed service,\nrate limits 100 reads\/min and 10 posts\/min.\nViolated by: celebrity read-path merge at V6 must\nalso enforce private-account visibility — easy to miss.\nGap: mute\/block lists not applied in celebrity_posts\nmerge path — a muted celebrity's posts could appear.","height":113.75,"link":null,"strokeColor":"#334155","fillStyle":"solid","groupIds":[],"versionNonce":1775851516,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":2870.8699240820783,"angle":0,"y":2993.6542856894257,"width":343.21258544921875},{"isDeleted":false,"locked":false,"strokeColor":"#86efac","link":null,"roughness":1,"groupIds":[],"index":"bJ3","backgroundColor":"#f0fdf4","angle":0,"fillStyle":"solid","strokeWidth":1,"version":121,"roundness":{"type":3},"type":"rectangle","updated":1772748823814,"id":"G5AFm7gomODZXD4-LR78c","x":1808.8699240820786,"seed":782523516,"boundElements":[],"y":3162.6542856894257,"opacity":100,"height":180,"width":502,"frameId":null,"strokeStyle":"solid","versionNonce":1768224892},{"seed":1465609468,"strokeStyle":"solid","id":"u3DpZmrq_slVBzs4xWdiT","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1772748823814,"locked":false,"text":"Observability","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bJ4","roundness":null,"containerId":null,"originalText":"Observability","height":18.75,"link":null,"strokeColor":"#15803d","fi