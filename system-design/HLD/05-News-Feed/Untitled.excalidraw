s\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Feed reads:   500M x 10   =  5,000,000,000  per day\\nPost writes:  500M x 0.1  =     50,000,000  per day\\nLike events:  500M x 20   = 10,000,000,000  per day\",\"fontSize\":14,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Feed reads:   500M x 10   =  5,000,000,000  per day\\nPost writes:  500M x 0.1  =     50,000,000  per day\\nLike events:  500M x 20   = 10,000,000,000  per day\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s4qps\",\"type\":\"rectangle\",\"x\":10,\"y\":2558,\"width\":750,\"height\":175,\"angle\":0,\"strokeColor\":\"#fcd34d\",\"backgroundColor\":\"#fffbeb\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b0n\",\"roundness\":{\"type\":3},\"seed\":221165968,\"version\":2,\"versionNonce\":1317813104,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s4qpst\",\"type\":\"text\",\"x\":24,\"y\":2570,\"width\":283.759765625,\"height\":20,\"angle\":0,\"strokeColor\":\"#b45309\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b0o\",\"roundness\":null,\"seed\":761227120,\"version\":2,\"versionNonce\":1543205776,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"QPS Calculations  (volume \/ 86,400)\",\"fontSize\":16,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"QPS Calculations  (volume \/ 86,400)\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s4qpsb\",\"type\":\"text\",\"x\":24,\"y\":2595,\"width\":455.2933349609375,\"height\":105,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b0p\",\"roundness\":null,\"seed\":1749092240,\"version\":2,\"versionNonce\":173231472,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Feed reads avg:   5B  \/ 86,400 =  57,870  ~  58K QPS\\nPost writes avg:  50M \/ 86,400 =     579  ~   580 QPS\\nLike events avg:  10B \/ 86,400 = 115,740  ~ 116K QPS\\n\\nPeak QPS  (x4 — evening prime-time spike):\\n  Feed reads:  232K QPS  |  Writes: 2.3K QPS  |  Likes: 464K QPS\",\"fontSize\":14,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Feed reads avg:   5B  \/ 86,400 =  57,870  ~  58K QPS\\nPost writes avg:  50M \/ 86,400 =     579  ~   580 QPS\\nLike events avg:  10B \/ 86,400 = 115,740  ~ 116K QPS\\n\\nPeak QPS  (x4 — evening prime-time spike):\\n  Feed reads:  232K QPS  |  Writes: 2.3K QPS  |  Likes: 464K QPS\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s4rw\",\"type\":\"rectangle\",\"x\":778,\"y\":2558,\"width\":792,\"height\":175,\"angle\":0,\"strokeColor\":\"#fca5a5\",\"backgroundColor\":\"#fff1f2\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b0q\",\"roundness\":{\"type\":3},\"seed\":2111895920,\"version\":2,\"versionNonce\":1902543248,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s4rwt\",\"type\":\"text\",\"x\":792,\"y\":2570,\"width\":151.2958526611328,\"height\":20,\"angle\":0,\"strokeColor\":\"#b91c1c\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b0r\",\"roundness\":null,\"seed\":131700112,\"version\":2,\"versionNonce\":526917488,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Read \/ Write Ratio\",\"fontSize\":16,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Read \/ Write Ratio\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s4rwb\",\"type\":\"text\",\"x\":792,\"y\":2595,\"width\":357.1116638183594,\"height\":140,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b0s\",\"roundness\":null,\"seed\":744508272,\"version\":2,\"versionNonce\":37736336,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"58K reads QPS \/ 580 write QPS  =  100 : 1\\n\\nWhy? Users consume far more than they create.\\nEven active users post once a week but open\\nthe feed 10+ times daily.\\n\\nThis ratio drives the core design principle:\\nOPTIMISE AGGRESSIVELY FOR THE READ PATH.\",\"fontSize\":14,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"58K reads QPS \/ 580 write QPS  =  100 : 1\\n\\nWhy? Users consume far more than they create.\\nEven active users post once a week but open\\nthe feed 10+ times daily.\\n\\nThis ratio drives the core design principle:\\nOPTIMISE AGGRESSIVELY FOR THE READ PATH.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s4stor\",\"type\":\"rectangle\",\"x\":10,\"y\":2745,\"width\":750,\"height\":268,\"angle\":0,\"strokeColor\":\"#93c5fd\",\"backgroundColor\":\"#eff6ff\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b0t\",\"roundness\":{\"type\":3},\"seed\":19948432,\"version\":2,\"versionNonce\":504541552,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s4stort\",\"type\":\"text\",\"x\":24,\"y\":2757,\"width\":299.3917236328125,\"height\":20,\"angle\":0,\"strokeColor\":\"#1d4ed8\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b0u\",\"roundness\":null,\"seed\":858086768,\"version\":2,\"versionNonce\":113204624,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Storage Per Record  +  Total Storage\",\"fontSize\":16,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Storage Per Record  +  Total Storage\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s4storb\",\"type\":\"text\",\"x\":24,\"y\":2782,\"width\":421.589599609375,\"height\":243.75,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b0v\",\"roundness\":null,\"seed\":41775504,\"version\":2,\"versionNonce\":1302004592,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Post row:\\n  post_id(8) + user_id(8) + content(500)\\n  + media_url(100) + created_at(8)\\n  + like_count(8) + metadata(200)  =  ~850B ~ 1KB\\n\\nFeed cache (Redis sorted set per user):\\n  20 post_ids(160) + 20 scores(160) + meta(30) = 350B\\n\\nSocial graph edge:  follower_id(8)+followee_id(8)+ts(8) = 24B\\n\\nTotal (with 3x replication):\\n  Posts:      50M\/day x 1KB x 365 x 3  =  55 TB\/yr\\n  Media:      50M x 30% x 500KB x 3    =  22 TB\/DAY  → S3\\n  Soc.Graph:  500M x 300 x 24B x 3     =  11 TB total\\n  Feed cache: 100M active users x 350B  =  35 GB  ← fits Redis!\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Post row:\\n  post_id(8) + user_id(8) + content(500)\\n  + media_url(100) + created_at(8)\\n  + like_count(8) + metadata(200)  =  ~850B ~ 1KB\\n\\nFeed cache (Redis sorted set per user):\\n  20 post_ids(160) + 20 scores(160) + meta(30) = 350B\\n\\nSocial graph edge:  follower_id(8)+followee_id(8)+ts(8) = 24B\\n\\nTotal (with 3x replication):\\n  Posts:      50M\/day x 1KB x 365 x 3  =  55 TB\/yr\\n  Media:      50M x 30% x 500KB x 3    =  22 TB\/DAY  → S3\\n  Soc.Graph:  500M x 300 x 24B x 3     =  11 TB total\\n  Feed cache: 100M active users x 350B  =  35 GB  ← fits Redis!\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s4bw\",\"type\":\"rectangle\",\"x\":778,\"y\":2745,\"width\":792,\"height\":268,\"angle\":0,\"strokeColor\":\"#d8b4fe\",\"backgroundColor\":\"#fdf4ff\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b0w\",\"roundness\":{\"type\":3},\"seed\":58208112,\"version\":2,\"versionNonce\":807218064,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s4bwt\",\"type\":\"text\",\"x\":792,\"y\":2757,\"width\":258.70379638671875,\"height\":20,\"angle\":0,\"strokeColor\":\"#7e22ce\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b0x\",\"roundness\":null,\"seed\":855162768,\"version\":2,\"versionNonce\":1279858032,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Bandwidth  +  Kafka Throughput\",\"fontSize\":16,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Bandwidth  +  Kafka Throughput\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s4bwb\",\"type\":\"text\",\"x\":792,\"y\":2782,\"width\":337.9346618652344,\"height\":260,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b0y\",\"roundness\":null,\"seed\":631292272,\"version\":2,\"versionNonce\":1217477008,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Feed payload per response:\\n  20 posts x 700B (content+meta+CDN URL) = 14KB\\n\\nOutbound bandwidth (peak):\\n  232K QPS x 14KB = 3.2 GB\/s outbound\\n  Inbound writes: 2.3K x 2KB = 4.6 MB\/s (trivial)\\n\\nKafka fan-out messages:\\n  2.3K posts\/sec x 300 followers x 100B = 69 MB\/s\\n\\nKafka like events:\\n  464K likes\/sec x 100B = 46 MB\/s\\n\\nTotal Kafka throughput:  ~115 MB\/s\\n\\nCDN media egress:  22 TB\/day = ~255 MB\/s\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Feed payload per response:\\n  20 posts x 700B (content+meta+CDN URL) = 14KB\\n\\nOutbound bandwidth (peak):\\n  232K QPS x 14KB = 3.2 GB\/s outbound\\n  Inbound writes: 2.3K x 2KB = 4.6 MB\/s (trivial)\\n\\nKafka fan-out messages:\\n  2.3K posts\/sec x 300 followers x 100B = 69 MB\/s\\n\\nKafka like events:\\n  464K likes\/sec x 100B = 46 MB\/s\\n\\nTotal Kafka throughput:  ~115 MB\/s\\n\\nCDN media egress:  22 TB\/day = ~255 MB\/s\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s4inf\",\"type\":\"rectangle\",\"x\":10,\"y\":3025,\"width\":1560,\"height\":220,\"angle\":0,\"strokeColor\":\"#f59e0b\",\"backgroundColor\":\"#fef3c7\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b0z\",\"roundness\":{\"type\":3},\"seed\":316296592,\"version\":2,\"versionNonce\":795142000,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s4inft\",\"type\":\"text\",\"x\":24,\"y\":3037,\"width\":164.30384826660156,\"height\":20,\"angle\":