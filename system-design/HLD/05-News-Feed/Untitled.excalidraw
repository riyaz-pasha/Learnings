lowing_count) index lookups\nper feed read. At 500 followees = 500 index\nscans per request.\n\nWorks fine up to ~50K DAU. Then collapses.\n\nNo cache. No queue. Every read hits disk.","height":122.5,"link":null,"strokeColor":"#64748b","fillStyle":"solid","groupIds":[],"versionNonce":1256934396,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":2802.8699240820783,"angle":0,"y":-2243.3457143105743,"width":306.277587890625},{"isDeleted":false,"locked":false,"strokeColor":"#22c55e","link":null,"roughness":1,"groupIds":[],"index":"bGb","backgroundColor":"#dcfce7","angle":0,"fillStyle":"solid","strokeWidth":1,"version":121,"roundness":{"type":3},"type":"rectangle","updated":1772748823812,"id":"MmheZqc43uF1fDLRv5R07","x":1808.8699240820786,"seed":1166266492,"boundElements":[],"y":-1997.3457143105743,"opacity":100,"height":100,"width":750,"frameId":null,"strokeStyle":"solid","versionNonce":1008233596},{"seed":1244422396,"strokeStyle":"solid","id":"ENyijlFJtjOb1c4vwkPKB","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1772748823812,"locked":false,"text":"Why It Works at Low Scale","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bGc","roundness":null,"containerId":null,"originalText":"Why It Works at Low Scale","height":18.75,"link":null,"strokeColor":"#15803d","fillStyle":"solid","groupIds":[],"versionNonce":1003322620,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1822.8699240820786,"angle":0,"y":-1985.3457143105743,"width":198.80989074707031},{"seed":1013899644,"strokeStyle":"solid","id":"rORFBDAvxquqwDn9j_5Zc","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772748823812,"locked":false,"text":"Single PostgreSQL handles 1K+ simple queries\/sec  |  Deploy on 2 servers total  |  One engineer can understand entire system\nJoins complete i