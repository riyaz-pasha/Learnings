.\\nCross-region write lag ~500ms.\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"API Fleet: 50 nodes\\nRedis Cluster: regional\\nKafka: MirrorMaker2 replication\\nAurora: secondary reader\\nCassandra: LOCAL_QUORUM\\nS3: APAC-only bucket\\n\\nHigh read volume. Local CDN edge.\\nCross-region write lag ~500ms.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s11rep1\",\"type\":\"arrow\",\"x\":500.5,\"y\":9596,\"width\":27,\"height\":0,\"angle\":0,\"strokeColor\":\"#22c55e\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b4p\",\"roundness\":null,\"seed\":1713655696,\"version\":2,\"versionNonce\":917669232,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"points\":[[0,0],[27,0]],\"lastCommittedPoint\":null,\"startBinding\":null,\"endBinding\":null,\"startArrowhead\":null,\"endArrowhead\":\"arrow\",\"elbowed\":false},{\"id\":\"s11rep1l\",\"type\":\"text\",\"x\":504,\"y\":9578,\"width\":71.72390747070312,\"height\":15,\"angle\":0,\"strokeColor\":\"#15803d\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b4q\",\"roundness\":null,\"seed\":951464304,\"version\":2,\"versionNonce\":666290576,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"WAL <300ms\",\"fontSize\":12,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"WAL <300ms\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s11rep2\",\"type\":\"arrow\",\"x\":1056.5,\"y\":9596,\"width\":9,\"height\":0,\"angle\":0,\"strokeColor\":\"#22c55e\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2