opacity":100,"height":95,"width":215,"frameId":null,"strokeStyle":"solid","versionNonce":1917975548},{"seed":828670076,"strokeStyle":"solid","id":"DE9cSOaz1gXpLfsqiwsEc","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772748823809,"locked":false,"text":"10M Feed Caches\nRedis Sorted Sets\nAll receive post_id\nin their feed list","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bE1","roundness":null,"containerId":null,"originalText":"10M Feed Caches\nRedis Sorted Sets\nAll receive post_id\nin their feed list","height":65,"link":null,"strokeColor":"#9d174d","fillStyle":"solid","groupIds":[],"versionNonce":589896828,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":2398.8699240820788,"angle":0,"y":-5490.3457143105743,"width":118.02687072753906},{"isDeleted":false,"locked":false,"strokeColor":"#e2e8f0","link":null,"roughness":1,"groupIds":[],"index":"bE2","backgroundColor":"#ffffff","angle":0,"fillStyle":"solid","strokeWidth":1,"version":121,"roundness":{"type":3},"type":"rectangle","updated":1772748823809,"id":"Iny9GfsJSnk2lkJMp423U","x":2618.8699240820783,"seed":1450643708,"boundElements":[],"y":-5506.3457143105743,"opacity":100,"height":220,"width":730,"frameId":null,"strokeStyle":"solid","versionNonce":1565011196},{"seed":1273205116,"strokeStyle":"solid","id":"P9kakelPvjJUyhyYybQ8N","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1772748823809,"locked":false,"text":"Why Naive Breaks + The Hybrid Fix","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bE3","roundness":null,"containerId":null,"originalText":"Why Naive Breaks + The Hybrid Fix","height":18.75,"link":null,"strokeColor":"#1e3a5f","fillStyle":"solid","groupIds":[],"versionNonce":305212796,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":2634.8699240820783,"angle":0,"y":-5493.3457143105743,"width":255.97482299804688},{"seed":1357644284,"strokeStyle":"solid","id":"caCugZF7Ssk4pznWXYBPw","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772748823809,"locked":false,"text":"NAIVE (breaks): Sync fan-out — API writes to 10M\nRedis entries inline. Thread blocks for seconds.\nSystem collapses completely at celebrity scale.\n\nFIX — Hybrid Fan-out (the production approach):\n  Normal users (<1M followers): fan-out-on-write.\n  Kafka async workers propagate within 30 seconds.\n\n  Celebrities (>1M followers): fan-out-on-read.\n  Posts not pushed to caches at write time.\n  Merged with precomputed feed at read time.","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bE4","roundness":null,"containerId":null,"originalText":"NAIVE (breaks): Sync fan-out — API writes to 10M\nRedis entries inline. Thread blocks for seconds.\nSystem collapses completely at celebrity scale.\n\nFIX — Hybrid Fan-out (the production approach):\n  Normal users (<1M followers): fan-out-on-write.\n  Kafka async workers propagate within 30 seconds.\n\n  Celebrities (>1M followers): fan-out-on-read.\n  Posts not pushed to caches at write time.\n  Merged with precomputed feed at read time.","height":192.5,"link":null,"strokeColor":"#334155","fillStyle":"solid","groupIds":[],"versionNonce":858136060,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":2634.8699240820783,"angle":0,"y":-5468.3457143105743,"width":356.55157470703125},{"isDeleted":false,"locked":false,"strokeColor":"#6ee7b7","link":null,"roughness":1,"groupIds":[],"index":"bE5","backgroundColor":"#ecfdf5","angle":0,"fillStyle":"solid","strokeWidth":1,"version":121,"roundness":{"type":3},"type":"rectangle","updated":1772748823809,"id":"27Y1jXyFwjFTR-j7CGjbq","x":2618.8699240820783,"seed":1821532796,"boundElements":[],"y":-5277.3457143105743,"opacity