\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b1w\",\"roundness\":{\"type\":3},\"seed\":648256880,\"version\":2,\"versionNonce\":43326864,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s5workst\",\"type\":\"text\",\"x\":24,\"y\":3858,\"width\":198.8098907470703,\"height\":18.75,\"angle\":0,\"strokeColor\":\"#15803d\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b1x\",\"roundness\":null,\"seed\":1023619472,\"version\":2,\"versionNonce\":1929462640,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Why It Works at Low Scale\",\"fontSize\":15,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Why It Works at Low Scale\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s5worksb\",\"type\":\"text\",\"x\":24,\"y\":3882,\"width\":796.6522216796875,\"height\":32.5,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b1y\",\"roundness\":null,\"seed\":1831759728,\"version\":2,\"versionNonce\":725281680,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Single PostgreSQL handles 1K+ simple queries\/sec  |  Deploy on 2 servers total  |  One engineer can understand entire system\\nJoins complete in <20ms when tables are small and warm in memory  |  No distributed systems complexity\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Single PostgreSQL handles 1K+ simple queries\/sec  |  Deploy on 2 servers total  |  One engineer can understand entire system\\nJoins complete in <20ms when tables are small and warm in memory  |  No distributed systems complexity\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s5ceil\",\"type\":\"rectangle\",\"x\":778,\"y\":3846,\"width\":792,\"height\":100,\"angle\":0,\"strokeColor\":\"#fca5a5\",\"backgroundColor\":\"#fff1f2\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b1z\",\"roundness\":{\"type\":3},\"seed\":382107536,\"version\":2,\"versionNonce\":1793545584,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s5ceilt\",\"type\":\"text\",\"x\":792,\"y\":3858,\"width\":326.684814453125,\"height\":18.75,\"angle\":0,\"strokeColor\":\"#b91c1c\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b20\",\"roundness\":null,\"seed\":2123301232,\"version\":2,\"versionNonce\":435616144,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Capacity Ceiling  — Breaks Above ~50K DAU\",\"fontSize\":15,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Capacity Ceiling  — Breaks Above ~50K DAU\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s5ceilb\",\"type\":\"text\",\"x\":792,\"y\":3882,\"width\":677.67626953125,\"height\":32.5,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b21\",\"roundness\":null,\"seed\":921701776,\"version\":2,\"versionNonce\":1614489456,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"JOIN on follows+posts = expensive full index scan per request  |  No caching: every read is a disk I\/O\\nSingle writer: post + like + follow writes contend on one instance  |  One slow query blocks the API thread\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"JOIN on follows+posts = expensive full index scan per request  |  No caching: every read is a disk I\/O\\nSingle writer: post + like + follow writes contend on one instance  |  One slow query blocks the API thread\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s5say\",\"type\":\"rectangle\",\"x\":10,\"y\":3958,\"width\":1560,\"height\":50,\"angle\":0,\"strokeColor\":\"#1e3a5f\",\"backgroundColor\":\"#1e3a5f\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b22\",\"roundness\":{\"type\":3},\"seed\":2047693680,\"version\":2,\"versionNonce\":838944656,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s5sayt\",\"type\":\"text\",\"x\":24,\"y\":3971,\"width\":1352.916015625,\"height\":17.5,\"angle\":0,\"strokeColor\":\"#f1f5f9\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b23\",\"roundness\":null,\"seed\":1991760784,\"version\":2,\"versionNonce\":1598339440,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Say to interviewer: \\\"Starting simple to establish a baseline and make tradeoffs explicit. This works at startup scale but has a hard ceiling around 50K DAU. Let me identify exactly where it breaks.\\\"\",\"fontSize\":14,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Say to interviewer: \\\"Starting simple to establish a baseline and make tradeoffs explicit. This works at startup scale but has a hard ceiling around 50K DAU. Let me identify exactly where it breaks.\\\"\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s6bg\",\"type\":\"rectangle\",\"x\":10,\"y\":4050,\"width\":1560,\"height\":1160,\"angle\":0,\"strokeColor\":\"#cbd5e1\",\"backgroundColor\":\"#f8fafc\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b24\",\"roundness\":{\"type\":3},\"seed\":1441883504,\"version\":2,\"versionNonce\":798086544,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s6hd\",\"type\":\"rectangle\",\"x\":10,\"y\":4050,\"width\":1560,\"height\":46,\"angle\":0,\"strokeColor\":\"#7f1d1d\",\"backgroundColor\":\"#7f1d1d\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b25\",\"roundness\":{\"type\":3},\"seed\":1213589904,\"version\":2,\"versionNonce\":726403952,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s6tt\",\"type\":\"text\",\"x\":420,\"y\":4063,\"width\":523.8656616210938,\"height\":26.25,\"angle\":0,\"strokeColor\":\"#fef2f2\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b26\",\"roundness\":null,\"seed\":2139305840,\"version\":2,\"versionNonce\":132162448,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"STEP 6  —  Bottleneck Identification  (be brutal)\",\"fontSize\":21,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"STEP 6  —  Bottleneck Identification  (be brutal)\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s6b1\",\"type\":\"rectangle\",\"x\":10,\"y\":4106,\"width\":754,\"height\":188,\"angle\":0,\"strokeColor\":\"#f87171\",\"backgroundColor\":\"#fff1f2\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b27\",\"roundness\":{\"type\":3},\"seed\":386021264,\"version\":2,\"versionNonce\":1587092848,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s6b1t\",\"type\":\"text\",\"x\":24,\"y\":4118,\"width\":489.23968505859375,\"height\":18.75,\"angle\":0,\"strokeColor\":\"#b91c1c\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b28\",\"roundness\":null,\"seed\":2064304496,\"version\":2,\"versionNonce\":1227207056,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"BN1 — Feed Query JOIN at Read Time  [I\/O-bound + CPU-bound]\",\"fontSize\":15,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"BN1 — Feed Query JOIN at Read Time  [I\/O-bound + CPU-bound]\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s6b1b\",\"type\":\"text\",\"x\":24,\"y\":4143,\"width\":406.23638916015625,\"height\":97.5,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b29\",\"roundness\":null,\"seed\":653575568,\"version\":2,\"versionNonce\":175370096,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"PostgreSQL fan-in JOIN across posts+follows at 232K QPS.\\n500 followees x 232K QPS = 116M index ops\/sec needed.\\nPostgreSQL ceiling: ~50K complex reads\/sec on one instance.\\nThreshold: breaks at ~500 concurrent users (~50K DAU).\\nRoot cause: no precomputed feed — every read recomputes the\\nfull merge from scratch, work cannot be amortized across users.\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"PostgreSQL fan-in JOIN across posts+follows at 232K QPS.\\n500 followees x 232K QPS = 116M index ops\/sec needed.\\nPostgreSQL ceiling: ~50K complex reads\/sec on one instance.\\nThreshold: breaks at ~500 concurrent users (~50K DAU).\\nRoot cause: no precomputed feed — every read recomputes the\\nfull merge from scratch, work cannot be amortized across users.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s6b2\",\"type\":\"rectangle\",\"x\":782,\"y\":4106,\"width\":788,\"height\":188,\"angle\":0,\"strokeColor\":\"#f87171\",\"backgroundColor\":\"#fff1f2\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b2A\",\"roundness\":{\"type\":3},\"seed\":63970160,\"version\":2,\"versionNonce\":2056847248,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s6b2t\",\"type\":\"text\",\"x\":796,\"y\":4118,\"width\":456.209716796875,\"height\":18.75,\"angle\":0,\"strokeColor\":\"#b91c1c\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b2B\",\"roundness\":null,\"seed\":1969591184,\"version\":2,\"versionNonce\":1462010224,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"BN2 — Single PostgreSQL Writer  [I\/O + Coordination-bound]\",\"fontSize\":15,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"BN2 — Single PostgreSQL Writer  [I\/O + Coordination-bound]\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s6b2b\",\"type\":\"text\",\"x\":796,\"y\":4143,\"width\":392.8465576171875,\"height\":97.5,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b2C\",\"roundness\":null,\"seed\":739978608,\"version\":2,\"versionNonce\":2087882128,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Single writer hits ~5K TPS ceiling under like+post+follow load.\\n464K like\/sec as UPDATE posts SET likes=likes+1\\n= serialized row-level lock contention on hot post rows.\\nThreshold: breaks at ~5K writes\/sec.\\nRoot cause: row-level lock on a single hot row serializes ALL\\nlike writes. Impossible to shard without app-layer changes.\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Single writer hits ~5K TPS ceiling under like+post+follow load.\\n464K like\/sec as UPDATE posts SET likes=likes+1\\n= serialized row-level lock contention on hot post rows.\\nThreshold: breaks at ~5K writes\/sec.\\nRoot cause: row-level lock on a single hot row serializes ALL\\nlike writes. Impossible to shard without app-layer changes.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s6b3\",\"type\":\"rectangle\",\"x\":10,\"y\":4306,\"width\":754,\"height\":178,\"angle\":0,\"strokeColor\":\"#fcd34d\",\"backgroundColor\":\"#fffbeb\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b2D\",\"roundness\":{\"type\":3},\"seed\":411869584,\"version\":2,\"versionNonce\":603116400,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s6b3t\",\"type\":\"text\",\"x\":24,\"y\":4318,\"width\":288.2248229980469,\"height\":18.75,\"angle\":0,\"strokeColor\":\"#b45309\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b2E\",\"roundness\":null,\"seed\":2100559728,\"version\":2,\"versionNonce\":1743412112,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"BN3 — Zero Cache Layer  [I\/O-bound]\",\"fontSize\":15,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"BN3 — Zero Cache Layer  [I\/O-bound]\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s6b3b\",\"type\":\"text\",\"x\":24,\"y\":4343,\"width\":438.4635009765625,\"height\":97.5,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b2F\",\"roundness\":null,\"seed\":530706320,\"version\":2,\"versionNonce\":656860528,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"100% of 232K peak QPS hits PostgreSQL disk I\/O directly.\\nSSD random read ceiling ~50K-100K IOPS. Need 232K min.\\nThreshold: breaks at >5K DAU — any meaningful traffic.\\nRoot cause: feeds are highly cacheable (same user sees same\\nfeed for 30-60s) but we recompute from scratch every request.\\nFeeds are read 100x more than they change — obvious cache target.\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"100% of 232K peak QPS hits PostgreSQL disk I\/O directly.\\nSSD random read ceiling ~50K-100K IOPS. Need 232K min.\\nThreshold: breaks at >5K DAU — any meaningful traffic.\\nRoot cause: feeds are highly cacheable (same user sees same\\nfeed for 30-60s) but we recompute from scratch every request.\\nFeeds are read 100x more than they change — obvious cache target.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s6b4\",\"type\":\"rectangle\",\"x\":782,\"y\":4306,\"width\":788,\"height\":178,\"angle\":0,\"strokeColor\":\"#fcd34d\",\"backgroundColor\":\"#fffbeb\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b2G\",\"roundness\":{\"type\":3},\"seed\":392335728,\"version\":2,\"versionNonce\":1865968016,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s6b4t\",\"type\":\"text\",\"x\":796,\"y\":4318,\"width\":367.6047668457031,\"height\":18.75,\"angle\":0,\"strokeColor\":\"#b45309\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b2H\",\"roundness\":null,\"seed\":1927118224,\"version\":2,\"versionNonce\":235452272,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"BN4 — Single API Server  [CPU + Network-bound]\",\"fontSize\":15,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"BN4 — Single API Server  [CPU + Network-bound]\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s6b4b\",\"type\":\"text\",\"x\":796,\"y\":4343,\"width\":377.194580078125,\"height\":97.5,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b2I\",\"roundness\":null,\"seed\":1374610288,\"version\":2,\"versionNonce\":1033156496,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Single monolith process handles ~2-5K QPS max before\\nthread pool exhaustion and GC pressure kick in.\\nAt 232K peak QPS we need 100+ API nodes.\\nThreshold: breaks at ~5K QPS (~500K DAU).\\nRoot cause: no load balancer, no horizontal scaling.\\nFeed read spikes starve post-write threads — no isolation.\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Single monolith process handles ~2-5K QPS max before\\nthread pool exhaustion and GC pressure kick in.\\nAt 232K peak QPS we need 100+ API nodes.\\nThreshold: breaks at ~5K QPS (~500K DAU).\\nRoot cause: no load balancer, no horizontal scaling.\\nFeed read spikes starve post-write threads — no isolation.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s6b5\",\"type\":\"rectangle\",\"x\":10,\"y\":4496,\"width\":754,\"height\":188,\"angle\":0,\"strokeColor\":\"#f87171\",\"backgroundColor\":\"#fff1f2\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b2J\",\"roundness\":{\"type\":3},\"seed\":863456144,\"version\":2,\"versionNonce\":484460912,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s6b5t\",\"type\":\"text\",\"x\":24,\"y\":4508,\"width\":449.3997497558594,\"height\":18.75,\"angle\":0,\"strokeColor\":\"#b91c1c\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b2K\",\"roundness\":null,\"seed\":1528886640,\"version\":2,\"versionNonce\":1463240080,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"BN5 — Celebrity Fan-out at Read Time  [Dependency-bound]\",\"fontSize\":15,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"BN5 — Celebrity Fan-out at Read Time  [Dependency-bound]\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s6b5b\",\"type\":\"text\",\"x\":24,\"y\":4533,\"width\":437.69647216796875,\"height\":97.5,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b2L\",\"roundness\":null,\"seed\":463952272,\"version\":2,\"versionNonce\":1324718960,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"No precomputed feeds: every one of celebrity's 10M followers\\nrecomputes the full merge independently at their read time.\\n10M followers x 10 opens\/day = 100M DB queries\/day per celebrity.\\nThreshold: breaks at >100K followers on any single account.\\nRoot cause: work is not amortized. Fan-out-on-write does the merge\\nONCE at post time. Pull model repeats it 100M times per day.\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"No precomputed feeds: every one of celebrity's 10M followers\\nrecomputes the full merge independently at their read time.\\n10M followers x 10 opens\/day = 100M DB queries\/day per celebrity.\\nThreshold: breaks at >100K followers on any single account.\\nRoot cause: work is not amortized. Fan-out-on-write does the merge\\nONCE at post time. Pull model repeats it 100M times per day.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s6b6\",\"type\":\"rectangle\",\"x\":782,\"y\":4496,\"width\":788,\"height\":188,\"angle\":0,\"strokeColor\":\"#fcd34d\",\"backgroundColor\":\"#fffbeb\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b2M\",\"roundness\":{\"type\":3},\"seed\":1480640368,\"version\":2,\"versionNonce\":2035815312,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s6b6t\",\"type\":\"text\",\"x\":796,\"y\":4508,\"width\":485.11468505859375,\"height\":18.75,\"angle\":0,\"strokeColor\":\"#b45309\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b2N\",\"roundness\":null,\"seed\":1587914640,\"version\":2,\"versionNonce\":1989193072,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"BN6 — Sync Media Upload in API Thread  [I\/O + Network-bound]\",\"fontSize\":15,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"BN6 — Sync Media Upload in API Thread  [I\/O + Network-bound]\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s6b6b\",\"type\":\"text\",\"x\":796,\"y\":4533,\"width\":442.51959228515625,\"height\":97.5,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b2O\",\"roundness\":null,\"seed\":93739376,\"version\":2,\"versionNonce\":2049909136,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"API thread held open during full media upload to S3.\\n10MB video on 5Mbps mobile = 16 seconds of blocking.\\nWith 100-thread pool: 7 concurrent uploads starve all traffic.\\nThreshold: breaks at 10-20 simultaneous uploads.\\nRoot cause: slow synchronous I\/O in the request hot path.\\nFix: presigned S3 URLs — client uploads direct, API just stores URL.\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"API thread held open during full media upload to S3.\\n10MB video on 5Mbps mobile = 16 seconds of blocking.\\nWith 100-thread pool: 7 concurrent uploads starve all traffic.\\nThreshold: breaks at 10-20 simultaneous uploads.\\nRoot cause: slow synchronous I\/O in the request hot path.\\nFix: presigned S3 URLs — client uploads direct, API just stores URL.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s6b7\",\"type\":\"rectangle\",\"x\":10,\"y\":4696,\"width\":1560,\"height\":168,\"angle\":0,\"strokeColor\":\"#a78bfa\",\"backgroundColor\":\"#f5f3ff\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b2P\",\"roundness\":{\"type\":3},\"seed\":145372560,\"version\":2,\"versionNonce\":1559854960,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s6b7t\",\"type\":\"text\",\"x\":24,\"y\":4708,\"width\":738.9596557617188,\"height\":18.75,\"angle\":0,\"strokeColor\":\"#6d28d9\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b2Q\",\"roundness\":null,\"seed\":1449765744,\"version\":2,\"versionNonce\":687107984,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"BN7 — No Workload Isolation: All Traffic Competes on One DB  [State-bound + Coordination-bound]\",\"fontSize\":15,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"BN7 — No Workload Isolation: All Traffic Competes on One DB  [State-bound + Coordination-bound]\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s6b7b\",\"type\":\"text\",\"x\":24,\"y\":4733,\"width\":783.45703125,\"height\":97.5,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b2R\",\"roundness\":null,\"seed\":1592591248,\"version\":2,\"versionNonce\":1652035952,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Follow\/unfollow, feed reads, like writes, post writes all compete for the same PostgreSQL connection pool (100-200 conns)\\nand same disk I\/O budget. A viral post causing like spikes starves feed read connections entirely.\\nUnfollow needs strong consistency (must read primary) but competes with eventual-ok feed reads on same instance.\\nThreshold: visible at ~50K DAU. Critical at ~500K DAU.\\nRoot cause: different workloads need different infra — OLTP writes, graph traversal, and cache-population\\nhave completely different access patterns. One DB cannot serve all optimally.\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Follow\/unfollow, feed reads, like writes, post writes all compete for the same PostgreSQL connection pool (100-200 conns)\\nand same disk I\/O budget. A viral post causing like spikes starves feed read connections entirely.\\nUnfollow needs strong consistency (must read primary) but competes with eventual-ok feed reads on same instance.\\nThreshold: visible at ~50K DAU. Critical at ~500K DAU.\\nRoot cause: different workloads need different infra — OLTP writes, graph traversal, and cache-population\\nhave completely different access patterns. One DB cannot serve all optimally.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s6fix\",\"type\":\"rectangle\",\"x\":10,\"y\":4876,\"width\":1560,\"height\":80,\"angle\":0,\"strokeColor\":\"#1e3a5f\",\"backgroundColor\":\"#1e3a5f\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b2S\",\"roundness\":{\"type\":3},\"seed\":352501104,\"version\":2,\"versionNonce\":769654160,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s6fixt\",\"type\":\"text\",\"x\":24,\"y\":4888,\"width\":418.57470703125,\"height\":18.75,\"angle\":0,\"strokeColor\":\"#93c5fd\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b2T\",\"roundness\":null,\"seed\":1067848080,\"version\":2,\"versionNonce\":508846960,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Fix Priority Order  (Step 7 addresses these one by one):\",\"fontSize\":15,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Fix Priority Order  (Step 7 addresses these one by one):\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s6fixb\",\"type\":\"text\",\"x\":24,\"y\":4912,\"width\":1425.855712890625,\"height\":17.5,\"angle\":0,\"strokeColor\":\"#f1f5f9\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b2U\",\"roundness\":null,\"seed\":44666736,\"version\":2,\"versionNonce\":1781123984,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"1) Redis feed cache (fixes BN1+BN3)   2) Horizontal API + LB (BN4)   3) Kafka + fan-out workers (BN5)   4) Redis INCR for likes (BN2)   5) Presigned S3 URLs (BN6)   6) Separate social graph store (BN7)\",\"fontSize\":14,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"1) Redis feed cache (fixes BN1+BN3)   2) Horizontal API + LB (BN4)   3) Kafka + fan-out workers (BN5)   4) Redis INCR for likes (BN2)   5) Presigned S3 URLs (BN6)   6) Separate social graph store (BN7)\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s7bg\",\"type\":\"rectangle\",\"x\":10,\"y\":4990,\"width\":1560,\"height\":1220,\"angle\":0,\"strokeColor\":\"#cbd5e1\",\"backgroundColor\":\"#f8fafc\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b2V\",\"roundness\":{\"type\":3},\"seed\":34430864,\"version\":2,\"versionNonce\":2127983984,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s7hd\",\"type\":\"rectangle\",\"x\":10,\"y\":4990,\"width\":1560,\"height\":46,\"angle\":0,\"strokeColor\":\"#7f1d1d\",\"backgroundColor\":\"#7f1d1d\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b2W\",\"roundness\":{\"type\":3},\"seed\":2007376240,\"version\":2,\"versionNonce\":1477040528,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s7tt\",\"type\":\"text\",\"x\":390,\"y\":5003,\"width\":610.7427368164062,\"height\":26.25,\"angle\":0,\"strokeColor\":\"#fef2f2\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b2X\",\"roundness\":null,\"seed\":1448799632,\"version\":2,\"versionNonce\":1766213488,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"STEP 7  —  Progressive Architecture Evolution  (V1 to V7)\",\"fontSize\":21,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"STEP 7  —  Progressive Architecture Evolution  (V1 to V7)\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s7v1\",\"type\":\"rectangle\",\"x\":10,\"y\":5046,\"width\":1560,\"height\":148,\"angle\":0,\"strokeColor\":\"#93c5fd\",\"backgroundColor\":\"#eff6ff\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b2Y\",\"roundness\":{\"type\":3},\"seed\":54555504,\"version\":2,\"versionNonce\":1790453648,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s7v1t\",\"type\":\"text\",\"x\":24,\"y\":5058,\"width\":467.009765625,\"height\":18.75,\"angle\":0,\"strokeColor\":\"#1d4ed8\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b2Z\",\"roundness\":null,\"seed\":633781136,\"version\":2,\"versionNonce\":1508628848,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"V1 — Read Replicas + Connection Pooling   [ceiling: ~100K DAU]\",\"fontSize\":15,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"V1 — Read Replicas + Connection Pooling   [ceiling: ~100K DAU]\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s7v1b\",\"type\":\"text\",\"x\":24,\"y\":5082,\"width\":850.1082153320312,\"height\":48.75,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b2a\",\"roundness\":null,\"seed\":197166448,\"version\":2,\"versionNonce\":1852618128,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Fixes BN3+BN4 (partial). Added: 2 PostgreSQL read replicas + PgBouncer. Route all SELECTs to replicas, writes to primary.\\nAPI servers now pooled behind nginx\/HAProxy round-robin. PgBouncer multiplexes 1000s of app connections into 100 DB connections.\\nNew tradeoff: replica lag (~10-50ms) means unfollow may not be reflected immediately on replica reads (RYOW violation).\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Fixes BN3+BN4 (partial). Added: 2 PostgreSQL read replicas + PgBouncer. Route all SELECTs to replicas, writes to primary.\\nAPI servers now pooled behind nginx\/HAProxy round-robin. PgBouncer multiplexes 1000s of app connections into 100 DB connections.\\nNew tradeoff: replica lag (~10-50ms) means unfollow may not be reflected immediately on replica reads (RYOW violation).\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s7v1f\",\"type\":\"text\",\"x\":1200,\"y\":5058,\"width\":241.78668212890625,\"height\":32.5,\"angle\":0,\"strokeColor\":\"#64748b\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b2b\",\"roundness\":null,\"seed\":1921567120,\"version\":2,\"versionNonce\":68103024,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"New failure: replica lag spike during\\nprimary write burst causes stale feed.\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"New failure: replica lag spike during\\nprimary write burst causes stale feed.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s7v2\",\"type\":\"rectangle\",\"x\":10,\"y\":5204,\"width\":1560,\"height\":158,\"angle\":0,\"strokeColor\":\"#86efac\",\"backgroundColor\":\"#f0fdf4\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b2c\",\"roundness\":{\"type\":3},\"seed\":1852725104,\"version\":2,\"versionNonce\":1751090064,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s7v2t\",\"type\":\"text\",\"x\":24,\"y\":5216,\"width\":573.1947021484375,\"height\":18.75,\"angle\":0,\"strokeColor\":\"#15803d\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b2d\",\"roundness\":null,\"seed\":936974224,\"version\":2,\"versionNonce\":1912094064,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"V2 — Redis Feed Cache + Horizontal Stateless API Fleet   [ceiling: ~1M DAU]\",\"fontSize\":15,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"V2 — Redis Feed Cache + Horizontal Stateless API Fleet   [ceiling: ~1M DAU]\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s7v2b\",\"type\":\"text\",\"x\":24,\"y\":5240,\"width\":849.6141967773438,\"height\":65,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b2e\",\"roundness\":null,\"seed\":529656176,\"version\":2,\"versionNonce\":1992855952,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Fixes BN1+BN3+BN4. Added: Redis cluster (6 nodes). On post create, API writes post_id into each follower's\\nfeed sorted set in Redis (ZADD). Feed read = ZREVRANGEBYSCORE — pure O(1) Redis lookup.\\nAPI tier now 50+ stateless nodes. Cache miss falls through to DB and populates Redis.\\nNew tradeoff: fan-out still synchronous in API thread — celebrity post (10M followers) = 10M Redis writes inline. Blocks for seconds.\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Fixes BN1+BN3+BN4. Added: Redis cluster (6 nodes). On post create, API writes post_id into each follower's\\nfeed sorted set in Redis (ZADD). Feed read = ZREVRANGEBYSCORE — pure O(1) Redis lookup.\\nAPI tier now 50+ stateless nodes. Cache miss falls through to DB and populates Redis.\\nNew tradeoff: fan-out still synchronous in API thread — celebrity post (10M followers) = 10M Redis writes inline. Blocks for seconds.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s7v2f\",\"type\":\"text\",\"x\":1200,\"y\":5216,\"width\":229.39768981933594,\"height\":48.75,\"angle\":0,\"strokeColor\":\"#64748b\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b2f\",\"roundness\":null,\"seed\":1240442256,\"version\":2,\"versionNonce\":619646832,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"New failure: Redis cluster eviction\\nunder memory pressure spikes DB\\nload as all cache misses hit at once.\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"New failure: Redis cluster eviction\\nunder memory pressure spikes DB\\nload as all cache misses hit at once.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s7v3\",\"type\":\"rectangle\",\"x\":10,\"y\":5372,\"width\":1560,\"height\":158,\"angle\":0,\"strokeColor\":\"#eab308\",\"backgroundColor\":\"#fef9c3\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b2g\",\"roundness\":{\"type\":3},\"seed\":1249065840,\"version\":2,\"versionNonce\":819978128,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s7v3t\",\"type\":\"text\",\"x\":24,\"y\":5384,\"width\":433.90472412109375,\"height\":18.75,\"angle\":0,\"strokeColor\":\"#713f12\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b2h\",\"roundness\":null,\"seed\":906261392,\"version\":2,\"versionNonce\":893100400,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"V3 — Kafka + Async Fan-out Workers   [ceiling: ~10M DAU]\",\"fontSize\":15,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"V3 — Kafka + Async Fan-out Workers   [ceiling: ~10M DAU]\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s7v3b\",\"type\":\"text\",\"x\":24,\"y\":5408,\"width\":866.3321533203125,\"height\":65,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b2i\",\"roundness\":null,\"seed\":1901743472,\"version\":2,\"versionNonce\":115174800,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Fixes BN5. Added: Kafka cluster (post_created topic). On post create, API publishes ONE event to Kafka and returns 200 immediately.\\n150 fan-out workers consume from Kafka, look up follower list in Cassandra, write to each follower Redis feed sorted set.\\nMechanism: post creation is O(1) from API perspective. Workers partitioned by author user_id for ordering guarantee.\\nNew tradeoff: feed propagation now eventually consistent — follower may not see new post for up to 30 seconds.\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Fixes BN5. Added: Kafka cluster (post_created topic). On post create, API publishes ONE event to Kafka and returns 200 immediately.\\n150 fan-out workers consume from Kafka, look up follower list in Cassandra, write to each follower Redis feed sorted set.\\nMechanism: post creation is O(1) from API perspective. Workers partitioned by author user_id for ordering guarantee.\\nNew tradeoff: feed propagation now eventually consistent — follower may not see new post for up to 30 seconds.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s7v3f\",\"type\":\"text\",\"x\":1200,\"y\":5384,\"width\":226.771728515625,\"height\":48.75,\"angle\":0,\"strokeColor\":\"#64748b\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b2j\",\"roundness\":null,\"seed\":575635856,\"version\":2,\"versionNonce\":1915089776,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"New failure: Kafka consumer lag\\nbuilds under traffic spike — delayed\\nfeed. DLQ needed for poison pills.\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"New failure: Kafka consumer lag\\nbuilds under traffic spike — delayed\\nfeed. DLQ needed for poison pills.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s7v4\",\"type\":\"rectangle\",\"x\":10,\"y\":5540,\"width\":1560,\"height\":148,\"angle\":0,\"strokeColor\":\"#d8b4fe\",\"backgroundColor\":\"#fdf4ff\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b2k\",\"roundness\":{\"type\":3},\"seed\":227483504,\"version\":2,\"versionNonce\":569981840,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s7v4t\",\"type\":\"text\",\"x\":24,\"y\":5552,\"width\":560.2196655273438,\"height\":18.75,\"angle\":0,\"strokeColor\":\"#7e22ce\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b2l\",\"roundness\":null,\"seed\":772329360,\"version\":2,\"versionNonce\":32900464,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"V4 — Redis INCR for Like Counters + Async DB Flush   [ceiling: ~50M DAU]\",\"fontSize\":15,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"V4 — Redis INCR for Like Counters + Async DB Flush   [ceiling: ~50M DAU]\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s7v4b\",\"type\":\"text\",\"x\":24,\"y\":5576,\"width\":681.9793090820312,\"height\":65,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b2m\",\"roundness\":null,\"seed\":794407280,\"version\":2,\"versionNonce\":1147881872,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Fixes BN2. Like events go to Redis INCR on key like_count:{post_id} instead of DB UPDATE.\\nLike flusher service consumes in batches every 30s and writes aggregated counts to DB.\\nLike dedup: SADD liked_by:{post_id} {user_id} — returns 0 if already liked. Atomic, no race condition.\\nNew tradeoff: like counts in DB stale by up to 30s. Redis node failure loses recent counts since last flush.\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Fixes BN2. Like events go to Redis INCR on key like_count:{post_id} instead of DB UPDATE.\\nLike flusher service consumes in batches every 30s and writes aggregated counts to DB.\\nLike dedup: SADD liked_by:{post_id} {user_id} — returns 0 if already liked. Atomic, no race condition.\\nNew tradeoff: like counts in DB stale by up to 30s. Redis node failure loses recent counts since last flush.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s7v4f\",\"type\":\"text\",\"x\":1200,\"y\":5552,\"width\":227.95469665527344,\"height\":48.75,\"angle\":0,\"strokeColor\":\"#64748b\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b2n\",\"roundness\":null,\"seed\":1365794192,\"version\":2,\"versionNonce\":32757616,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"New failure: Redis node failure loses\\nlike counts since last DB flush.\\nNeeds Redis AOF persistence.\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"New failure: Redis node failure loses\\nlike counts since last DB flush.\\nNeeds Redis AOF persistence.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s7v5\",\"type\":\"rectangle\",\"x\":10,\"y\":5698,\"width\":1560,\"height\":148,\"angle\":0,\"strokeColor\":\"#06b6d4\",\"backgroundColor\":\"#cffafe\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b2o\",\"roundness\":{\"type\":3},\"seed\":503448432,\"version\":2,\"versionNonce\":694917008,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s7v5t\",\"type\":\"text\",\"x\":24,\"y\":5710,\"width\":555.1947021484375,\"height\":18.75,\"angle\":0,\"strokeColor\":\"#0e7490\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b2p\",\"roundness\":null,\"seed\":1034300304,\"version\":2,\"versionNonce\":644311408,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"V5 — Presigned S3 URLs + Async Media Transcoding   [ceiling: ~100M DAU]\",\"fontSize\":15,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"V5 — Presigned S3 URLs + Async Media Transcoding   [ceiling: ~100M DAU]\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s7v5b\",\"type\":\"text\",\"x\":24,\"y\":5734,\"width\":839.6561889648438,\"height\":65,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b2q\",\"roundness\":null,\"seed\":2010125680,\"version\":2,\"versionNonce\":1697785232,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Fixes BN6. Client requests presigned S3 URL from API (fast, <10ms). Client uploads directly to S3 — API thread freed immediately.\\nMedia upload triggers S3 event → SQS → transcoding workers (FFmpeg). Post stored with status=media_pending.\\nPost moves from media_pending to published once transcoder writes CDN URLs back. Feed filters media_pending posts.\\nNew tradeoff: post publish delayed by transcoding (5-60s for video). User sees processing state. More moving parts.\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Fixes BN6. Client requests presigned S3 URL from API (fast, <10ms). Client uploads directly to S3 — API thread freed immediately.\\nMedia upload triggers S3 event → SQS → transcoding workers (FFmpeg). Post stored with status=media_pending.\\nPost moves from media_pending to published once transcoder writes CDN URLs back. Feed filters media_pending posts.\\nNew tradeoff: post publish delayed by transcoding (5-60s for video). User sees processing state. More moving parts.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s7v6\",\"type\":\"rectangle\",\"x\":10,\"y\":5856,\"width\":1560,\"height\":158,\"angle\":0,\"strokeColor\":\"#fca5a5\",\"backgroundColor\":\"#fff1f2\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b2r\",\"roundness\":{\"type\":3},\"seed\":1023031696,\"version\":2,\"versionNonce\":1519958896,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s7v6t\",\"type\":\"text\",\"x\":24,\"y\":5868,\"width\":619.9196166992188,\"height\":18.75,\"angle\":0,\"strokeColor\":\"#b91c1c\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b2s\",\"roundness\":null,\"seed\":1376511856,\"version\":2,\"versionNonce\":1157034896,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"V6 — Hybrid Fan-out: Write for Normals, Read for Celebrities   [ceiling: ~500M DAU]\",\"fontSize\":15,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"V6 — Hybrid Fan-out: Write for Normals, Read for Celebrities   [ceiling: ~500M DAU]\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s7v6b\",\"type\":\"text\",\"x\":24,\"y\":5892,\"width\":819.3111572265625,\"height\":65,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b2t\",\"roundness\":null,\"seed\":312248208,\"version\":2,\"versionNonce\":1624231280,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Fixes BN5 at mega-scale. Fan-out workers check follower count. If author <1M followers: fan-out-on-write (push to caches).\\nIf author >1M followers: skip fan-out. Store post in celebrity_posts table only.\\nAt read time: fetch precomputed Redis cache AND query celebrity_posts for all celebrities followed, merge by ranking score.\\nNew tradeoff: read path has conditional complexity. Must maintain celebrity_list per user. 1M threshold is a tunable magic number.\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Fixes BN5 at mega-scale. Fan-out workers check follower count. If author <1M followers: fan-out-on-write (push to caches).\\nIf author >1M followers: skip fan-out. Store post in celebrity_posts table only.\\nAt read time: fetch precomputed Redis cache AND query celebrity_posts for all celebrities followed, merge by ranking score.\\nNew tradeoff: read path has conditional complexity. Must maintain celebrity_list per user. 1M threshold is a tunable magic number.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s7v6f\",\"type\":\"text\",\"x\":1200,\"y\":5868,\"width\":214.03170776367188,\"height\":48.75,\"angle\":0,\"strokeColor\":\"#64748b\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b2u\",\"roundness\":null,\"seed\":1493006704,\"version\":2,\"versionNonce\":787612048,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"New failure: celebrity_posts query\\nat read time must also enforce\\nprivate-account visibility rules.\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"New failure: celebrity_posts query\\nat read time must also enforce\\nprivate-account visibility rules.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s7v7\",\"type\":\"rectangle\",\"x\":10,\"y\":6024,\"width\":1560,\"height\":148,\"angle\":0,\"strokeColor\":\"#a78bfa\",\"backgroundColor\":\"#f5f3ff\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b2v\",\"roundness\":{\"type\":3},\"seed\":1522865552,\"version\":2,\"versionNonce\":1918148464,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s7v7t\",\"type\":\"text\",\"x\":24,\"y\":6036,\"width\":547.2597045898438,\"height\":18.75,\"angle\":0,\"strokeColor\":\"#6d28d9\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b2w\",\"roundness\":null,\"seed\":1877789552,\"version\":2,\"versionNonce\":39538576,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"V7 — Social Graph Isolation + DB Sharding by user_id   [ceiling: 1B+ DAU]\",\"fontSize\":15,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"V7 — Social Graph Isolation + DB Sharding by user_id   [ceiling: 1B+ DAU]\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s7v7b\",\"type\":\"text\",\"x\":24,\"y\":6060,\"width\":709.0321044921875,\"height\":65,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b2x\",\"roundness\":null,\"seed\":1789649808,\"version\":2,\"versionNonce\":1601122672,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Fixes BN7. Social graph moved to dedicated Cassandra cluster (wide-row: partition=follower_id, cols=followees).\\nPosts DB sharded by user_id (10 shards x 1 primary + 2 replicas = 30 nodes). Likes DB sharded by post_id.\\nCassandra 'get all followees for user X' = single partition read in ~1ms. No hot-partition on posts table.\\nNew tradeoff: cross-shard transactions eliminated. No JOINs across services. App layer handles all aggregation.\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Fixes BN7. Social graph moved to dedicated Cassandra cluster (wide-row: partition=follower_id, cols=followees).\\nPosts DB sharded by user_id (10 shards x 1 primary + 2 replicas = 30 nodes). Likes DB sharded by post_id.\\nCassandra 'get all followees for user X' = single partition read in ~1ms. No hot-partition on posts table.\\nNew tradeoff: cross-shard transactions eliminated. No JOINs across services. App layer handles all aggregation.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s7sum\",\"type\":\"rectangle\",\"x\":10,\"y\":6182,\"width\":1560,\"height\":50,\"angle\":0,\"strokeColor\":\"#7f1d1d\",\"backgroundColor\":\"#7f1d1d\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b2y\",\"roundness\":{\"type\":3},\"seed\":1361173872,\"version\":2,\"versionNonce\":2003492240,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s7sumt\",\"type\":\"text\",\"x\":24,\"y\":6196,\"width\":971.598876953125,\"height\":17.5,\"angle\":0,\"strokeColor\":\"#fef2f2\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b2z\",\"roundness\":null,\"seed\":814281104,\"version\":2,\"versionNonce\":795313008,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"V1(100K)→V2(1M)→V3(10M)→V4(50M)→V5(100M)→V6(500M)→V7(1B+)  |  Each version fixes one bottleneck and introduces one new tradeoff\",\"fontSize\":14,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"V1(100K)→V2(1M)→V3(10M)→V4(50M)→V5(100M)→V6(500M)→V7(1B+)  |  Each version fixes one bottleneck and introduces one new tradeoff\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s8bg\",\"type\":\"rectangle\",\"x\":10,\"y\":6270,\"width\":1560,\"height\":2050,\"angle\":0,\"strokeColor\":\"#cbd5e1\",\"backgroundColor\":\"#f8fafc\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b30\",\"roundness\":{\"type\":3},\"seed\":769961840,\"version\":2,\"versionNonce\":2136517520,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s8hd\",\"type\":\"rectangle\",\"x\":10,\"y\":6270,\"width\":1560,\"height\":46,\"angle\":0,\"strokeColor\":\"#4c1d95\",\"backgroundColor\":\"#4c1d95\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b31\",\"roundness\":{\"type\":3},\"seed\":328482704,\"version\":2,\"versionNonce\":1082496368,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s8tt\",\"type\":\"text\",\"x\":430,\"y\":6283,\"width\":439.92877197265625,\"height\":26.25,\"angle\":0,\"strokeColor\":\"#f5f3ff\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b32\",\"roundness\":null,\"seed\":1316831600,\"version\":2,\"versionNonce\":610056592,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"STEP 8  —  Deep Dives  (FR2, FR3, FR5)\",\"fontSize\":21,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"STEP 8  —  Deep Dives  (FR2, FR3, FR5)\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s8d1h\",\"type\":\"rectangle\",\"x\":10,\"y\":6326,\"width\":1560,\"height\":40,\"angle\":0,\"strokeColor\":\"#b91c1c\",\"backgroundColor\":\"#b91c1c\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b33\",\"roundness\":{\"type\":3},\"seed\":1409666448,\"version\":2,\"versionNonce\":1745971056,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s8d1ht\",\"type\":\"text\",\"x\":24,\"y\":6339,\"width\":470.5086669921875,\"height\":21.25,\"angle\":0,\"strokeColor\":\"#fff1f2\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b34\",\"roundness\":null,\"seed\":842240880,\"version\":2,\"versionNonce\":1773078416,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Deep Dive 1 — FR2: Feed Generation (Fan-out on Write)\",\"fontSize\":17,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Deep Dive 1 — FR2: Feed Generation (Fan-out on Write)\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s8d1a\",\"type\":\"rectangle\",\"x\":10,\"y\":6376,\"width\":490,\"height\":310,\"angle\":0,\"strokeColor\":\"#fdba74\",\"backgroundColor\":\"#fff7ed\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b35\",\"roundness\":{\"type\":3},\"seed\":1796578192,\"version\":2,\"versionNonce\":307427696,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s8d1at\",\"type\":\"text\",\"x\":24,\"y\":6388,\"width\":234.80775451660156,\"height\":17.5,\"angle\":0,\"strokeColor\":\"#c2410c\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b36\",\"roundness\":null,\"seed\":793748848,\"version\":2,\"versionNonce\":730305936,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"A. User Journey + Latency Budget\",\"fontSize\":14,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"A. User Journey + Latency Budget\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s8d1ab\",\"type\":\"text\",\"x\":24,\"y\":6412,\"width\":309.12664794921875,\"height\":260,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b37\",\"roundness\":null,\"seed\":1794877840,\"version\":2,\"versionNonce\":1653754736,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"1. User taps Post with text or photo\\n2. Client sends POST \/posts + idempotency_key\\n3. Server responds 200 in <200ms\\n4. Client shows post in own feed immediately\\n5. Followers see post within 5-30 seconds\\n\\nDuring failure:\\n  Kafka down: post saved, fan-out queued\\n  in DB outbox table. Publishes on recovery.\\n  Worker crash mid-fan-out: retries from\\n  last Kafka offset. ZADD is idempotent.\\n\\nLatency budget:\\n  API write (save + Kafka publish): <200ms\\n  Fan-out normal user (500 followers): <5s\\n  Fan-out celeb (1M followers): <30s\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"1. User taps Post with text or photo\\n2. Client sends POST \/posts + idempotency_key\\n3. Server responds 200 in <200ms\\n4. Client shows post in own feed immediately\\n5. Followers see post within 5-30 seconds\\n\\nDuring failure:\\n  Kafka down: post saved, fan-out queued\\n  in DB outbox table. Publishes on recovery.\\n  Worker crash mid-fan-out: retries from\\n  last Kafka offset. ZADD is idempotent.\\n\\nLatency budget:\\n  API write (save + Kafka publish): <200ms\\n  Fan-out normal user (500 followers): <5s\\n  Fan-out celeb (1M followers): <30s\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s8d1b\",\"type\":\"rectangle\",\"x\":518,\"y\":6376,\"width\":620,\"height\":310,\"angle\":0,\"strokeColor\":\"#86efac\",\"backgroundColor\":\"#f0fdf4\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b38\",\"roundness\":{\"type\":3},\"seed\":320436080,\"version\":2,\"versionNonce\":2132698000,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s8d1bt\",\"type\":\"text\",\"x\":532,\"y\":6388,\"width\":215.34776306152344,\"height\":17.5,\"angle\":0,\"strokeColor\":\"#15803d\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b39\",\"roundness\":null,\"seed\":1592784784,\"version\":2,\"versionNonce\":1394040176,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"B. Internal Flow (step by step)\",\"fontSize\":14,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"B. Internal Flow (step by step)\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s8d1bb\",\"type\":\"text\",\"x\":532,\"y\":6412,\"width\":400.9195556640625,\"height\":276.25,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b3A\",\"roundness\":null,\"seed\":1104742768,\"version\":2,\"versionNonce\":313225616,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"1.  API receives POST \/posts {content, idem_key}\\n2.  Check Redis: GET idem:{hash} — duplicate? Return cached.\\n3.  INSERT into posts table (sync write to primary)\\n4.  Publish ONE event to Kafka post_created topic\\n5.  Return 200 to client  ← API is done here\\n\\n[Async — fan-out workers]\\n6.  Worker consumes from Kafka post_created\\n7.  Fetch follower list from Cassandra\\n    (partition key = author_id, O(1) lookup)\\n8.  For each follower: ZADD NX feed:{follower_id}\\n    score=timestamp member=post_id\\n    ZADD NX is idempotent — replay-safe\\n9.  Commit Kafka offset after batch completes\\n\\nCritical path (latency): steps 1-5 only\\nAsync path: steps 6-9 (not on P99 budget)\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"1.  API receives POST \/posts {content, idem_key}\\n2.  Check Redis: GET idem:{hash} — duplicate? Return cached.\\n3.  INSERT into posts table (sync write to primary)\\n4.  Publish ONE event to Kafka post_created topic\\n5.  Return 200 to client  ← API is done here\\n\\n[Async — fan-out workers]\\n6.  Worker consumes from Kafka post_created\\n7.  Fetch follower list from Cassandra\\n    (partition key = author_id, O(1) lookup)\\n8.  For each follower: ZADD NX feed:{follower_id}\\n    score=timestamp member=post_id\\n    ZADD NX is idempotent — replay-safe\\n9.  Commit Kafka offset after batch completes\\n\\nCritical path (latency): steps 1-5 only\\nAsync path: steps 6-9 (not on P99 budget)\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s8d1c\",\"type\":\"rectangle\",\"x\":1156,\"y\":6376,\"width\":414,\"height\":310,\"angle\":0,\"strokeColor\":\"#93c5fd\",\"backgroundColor\":\"#eff6ff\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b3B\",\"roundness\":{\"type\":3},\"seed\":724206992,\"version\":2,\"versionNonce\":1428828016,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s8d1ct\",\"type\":\"text\",\"x\":1170,\"y\":6388,\"width\":96.8939208984375,\"height\":17.5,\"angle\":0,\"strokeColor\":\"#1d4ed8\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b3C\",\"roundness\":null,\"seed\":1456888688,\"version\":2,\"versionNonce\":224837520,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"C. Data Model\",\"fontSize\":14,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"C. Data Model\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s8d1cb\",\"type\":\"text\",\"x\":1170,\"y\":6412,\"width\":252.94073486328125,\"height\":325,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b3D\",\"roundness\":null,\"seed\":1826837392,\"version\":2,\"versionNonce\":1897054576,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"posts table:\\n  post_id    UUID  PK\\n  author_id  UUID  IDX\\n  content    TEXT\\n  media_url  TEXT\\n  status     ENUM\\n  created_at TIMESTAMPTZ\\n  IDX: (author_id, created_at DESC)\\n\\nRedis feed cache:\\n  Key:  feed:{user_id}\\n  Type: Sorted Set\\n  Member: post_id\\n  Score: unix_timestamp\\n  TTL:  7 days\\n\\nKey operations:\\n  ZADD NX feed:alice 1709123 post:xyz\\n  ZREVRANGEBYSCORE feed:alice\\n    +inf 0 LIMIT 0 20\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"posts table:\\n  post_id    UUID  PK\\n  author_id  UUID  IDX\\n  content    TEXT\\n  media_url  TEXT\\n  status     ENUM\\n  created_at TIMESTAMPTZ\\n  IDX: (author_id, created_at DESC)\\n\\nRedis feed cache:\\n  Key:  feed:{user_id}\\n  Type: Sorted Set\\n  Member: post_id\\n  Score: unix_timestamp\\n  TTL:  7 days\\n\\nKey operations:\\n  ZADD NX feed:alice 1709123 post:xyz\\n  ZREVRANGEBYSCORE feed:alice\\n    +inf 0 LIMIT 0 20\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s8d2h\",\"type\":\"rectangle\",\"x\":10,\"y\":6698,\"width\":1560,\"height\":40,\"angle\":0,\"strokeColor\":\"#5b21b6\",\"backgroundColor\":\"#5b21b6\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b3E\",\"roundness\":{\"type\":3},\"seed\":1146711408,\"version\":2,\"versionNonce\":1871203728,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s8d2ht\",\"type\":\"text\",\"x\":24,\"y\":6711,\"width\":469.52264404296875,\"height\":21.25,\"angle\":0,\"strokeColor\":\"#f5f3ff\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b3F\",\"roundness\":null,\"seed\":1515348368,\"version\":2,\"versionNonce\":1712919408,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Deep Dive 2 — FR3: Feed Retrieval (Hybrid Read Merge)\",\"fontSize\":17,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Deep Dive 2 — FR3: Feed Retrieval (Hybrid Read Merge)\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s8d2a\",\"type\":\"rectangle\",\"x\":10,\"y\":6748,\"width\":490,\"height\":340,\"angle\":0,\"strokeColor\":\"#fdba74\",\"backgroundColor\":\"#fff7ed\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b3G\",\"roundness\":{\"type\":3},\"seed\":1940537200,\"version\":2,\"versionNonce\":1917328272,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s8d2at\",\"type\":\"text\",\"x\":24,\"y\":6760,\"width\":234.80775451660156,\"height\":17.5,\"angle\":0,\"strokeColor\":\"#c2410c\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b3H\",\"roundness\":null,\"seed\":581939088,\"version\":2,\"versionNonce\":1250239856,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"A. User Journey + Latency Budget\",\"fontSize\":14,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"A. User Journey + Latency Budget\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s8d2ab\",\"type\":\"text\",\"x\":24,\"y\":6784,\"width\":326.2995910644531,\"height\":357.5,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b3I\",\"roundness\":null,\"seed\":1695601008,\"version\":2,\"versionNonce\":1742612880,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"1. User opens app or pulls to refresh\\n2. Client: GET \/feed?cursor=null&limit=20\\n3. Server checks Redis cache:\\n   HIT:  return in <30ms\\n   MISS: compute from DB, return in <200ms\\n4. Client renders 20 posts\\n5. Scroll: GET \/feed?cursor=<score:post_id>\\n\\nDuring failure:\\n  Redis down: fallback to DB query.\\n  Latency spikes to 200-500ms.\\n  Celebrity DB slow: serve precomputed\\n  feed without celebrity posts (degrade gracefully).\\n\\nLatency budget (P99 < 500ms):\\n  Redis ZRANGE:            5ms\\n  Celebrity DB query:     20ms\\n  Merge + rank 40 posts:   5ms\\n  Metadata hydration:     15ms\\n  Network + serial:       20ms\\n  Total P50:           ~65ms\\n  Total P99:          ~500ms (cache miss)\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"1. User opens app or pulls to refresh\\n2. Client: GET \/feed?cursor=null&limit=20\\n3. Server checks Redis cache:\\n   HIT:  return in <30ms\\n   MISS: compute from DB, return in <200ms\\n4. Client renders 20 posts\\n5. Scroll: GET \/feed?cursor=<score:post_id>\\n\\nDuring failure:\\n  Redis down: fallback to DB query.\\n  Latency spikes to 200-500ms.\\n  Celebrity DB slow: serve precomputed\\n  feed without celebrity posts (degrade gracefully).\\n\\nLatency budget (P99 < 500ms):\\n  Redis ZRANGE:            5ms\\n  Celebrity DB query:     20ms\\n  Merge + rank 40 posts:   5ms\\n  Metadata hydration:     15ms\\n  Network + serial:       20ms\\n  Total P50:           ~65ms\\n  Total P99:          ~500ms (cache miss)\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s8d2b\",\"type\":\"rectangle\",\"x\":518,\"y\":6748,\"width\":620,\"height\":340,\"angle\":0,\"strokeColor\":\"#86efac\",\"backgroundColor\":\"#f0fdf4\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b3J\",\"roundness\":{\"type\":3},\"seed\":1311980944,\"version\":2,\"versionNonce\":731838320,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s8d2bt\",\"type\":\"text\",\"x\":532,\"y\":6760,\"width\":110.7958984375,\"height\":17.5,\"angle\":0,\"strokeColor\":\"#15803d\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b3K\",\"roundness\":null,\"seed\":1339368304,\"version\":2,\"versionNonce\":461535120,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"B. Internal Flow\",\"fontSize\":14,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"B. Internal Flow\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s8d2bb\",\"type\":\"text\",\"x\":532,\"y\":6784,\"width\":349.03656005859375,\"height\":308.75,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b3L\",\"roundness\":null,\"seed\":504695696,\"version\":2,\"versionNonce\":766413168,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"1.  GET \/feed — JWT verified at API gateway\\n2.  Redis: ZREVRANGEBYSCORE feed:{uid}\\n    +inf (cursor_score) LIMIT 0 20\\n    HIT  → skip to step 6\\n    MISS → continue to step 3\\n3.  [MISS] Fetch followees from Cassandra\\n4.  [MISS] SELECT posts WHERE author_id\\n    IN (followees) AND created_at > since\\n    ORDER BY created_at DESC LIMIT 20 per shard\\n5.  [MISS] ZADD feed:{uid} to populate cache\\n6.  Fetch celebrity list: SMEMBERS celeb_follows:{uid}\\n7.  If not empty: SELECT FROM celebrity_posts\\n    WHERE author_id IN (celeb_ids)\\n    AND created_at > cursor LIMIT 20\\n8.  Merge: interleave precomputed + celebrity\\n    posts sorted by ranking_score\\n9.  Apply mute\/block filter list\\n10. Return top 20, cursor = lowest score seen\\n11. Hydrate author metadata from cache\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"1.  GET \/feed — JWT verified at API gateway\\n2.  Redis: ZREVRANGEBYSCORE feed:{uid}\\n    +inf (cursor_score) LIMIT 0 20\\n    HIT  → skip to step 6\\n    MISS → continue to step 3\\n3.  [MISS] Fetch followees from Cassandra\\n4.  [MISS] SELECT posts WHERE author_id\\n    IN (followees) AND created_at > since\\n    ORDER BY created_at DESC LIMIT 20 per shard\\n5.  [MISS] ZADD feed:{uid} to populate cache\\n6.  Fetch celebrity list: SMEMBERS celeb_follows:{uid}\\n7.  If not empty: SELECT FROM celebrity_posts\\n    WHERE author_id IN (celeb_ids)\\n    AND created_at > cursor LIMIT 20\\n8.  Merge: interleave precomputed + celebrity\\n    posts sorted by ranking_score\\n9.  Apply mute\/block filter list\\n10. Return top 20, cursor = lowest score seen\\n11. Hydrate author metadata from cache\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s8d2c\",\"type\":\"rectangle\",\"x\":1156,\"y\":6748,\"width\":414,\"height\":340,\"angle\":0,\"strokeColor\":\"#93c5fd\",\"backgroundColor\":\"#eff6ff\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b3M\",\"roundness\":{\"type\":3},\"seed\":1111438704,\"version\":2,\"versionNonce\":829228432,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s8d2ct\",\"type\":\"text\",\"x\":1170,\"y\":6760,\"width\":96.8939208984375,\"height\":17.5,\"angle\":0,\"strokeColor\":\"#1d4ed8\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b3N\",\"roundness\":null,\"seed\":1821186448,\"version\":2,\"versionNonce\":737926000,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"C. Data Model\",\"fontSize\":14,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"C. Data Model\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s8d2cb\",\"type\":\"text\",\"x\":1170,\"y\":6784,\"width\":241.03274536132812,\"height\":503.75,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b3O\",\"roundness\":null,\"seed\":1100416880,\"version\":2,\"versionNonce\":114676624,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Redis feed cache:\\n  Key:  feed:{user_id}\\n  Type: Sorted Set\\n  Score: ranking_score (float)\\n  Member: post_id\\n\\nCursor design:\\n  cursor = base64(score:post_id)\\n  Stable — new posts inserted at top\\n  don't affect the cursor position.\\n  No offset shifting on live feed.\\n\\nCelebrity follows:\\n  Key:  celeb_follows:{user_id}\\n  Type: Redis Set\\n  Member: author_id\\n  Set if followee count > 1M\\n\\nPost hydration:\\n  Key:  post:{post_id}\\n  Type: Redis Hash\\n  TTL:  1 hour\\n  Fields: author, content,\\n    media_url, like_count\\n\\nCommon query (cache miss):\\n  SELECT p.* FROM posts p\\n  WHERE p.author_id = ANY(:ids)\\n  AND p.created_at > :since\\n  ORDER BY created_at DESC\\n  LIMIT 20\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Redis feed cache:\\n  Key:  feed:{user_id}\\n  Type: Sorted Set\\n  Score: ranking_score (float)\\n  Member: post_id\\n\\nCursor design:\\n  cursor = base64(score:post_id)\\n  Stable — new posts inserted at top\\n  don't affect the cursor position.\\n  No offset shifting on live feed.\\n\\nCelebrity follows:\\n  Key:  celeb_follows:{user_id}\\n  Type: Redis Set\\n  Member: author_id\\n  Set if followee count > 1M\\n\\nPost hydration:\\n  Key:  post:{post_id}\\n  Type: Redis Hash\\n  TTL:  1 hour\\n  Fields: author, content,\\n    media_url, like_count\\n\\nCommon query (cache miss):\\n  SELECT p.* FROM posts p\\n  WHERE p.author_id = ANY(:ids)\\n  AND p.created_at > :since\\n  ORDER BY created_at DESC\\n  LIMIT 20\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s8d3h\",\"type\":\"rectangle\",\"x\":10,\"y\":7100,\"width\":1560,\"height\":40,\"angle\":0,\"strokeColor\":\"#0e7490\",\"backgroundColor\":\"#0e7490\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b3P\",\"roundness\":{\"type\":3},\"seed\":215181200,\"version\":2,\"versionNonce\":1489956208,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s8d3ht\",\"type\":\"text\",\"x\":24,\"y\":7113,\"width\":543.7105712890625,\"height\":21.25,\"angle\":0,\"strokeColor\":\"#cffafe\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b3Q\",\"roundness\":null,\"seed\":1780783472,\"version\":2,\"versionNonce\":301261200,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Deep Dive 3 — FR5: Like \/ React (Counter Aggregation at Scale)\",\"fontSize\":17,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Deep Dive 3 — FR5: Like \/ React (Counter Aggregation at Scale)\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s8d3a\",\"type\":\"rectangle\",\"x\":10,\"y\":7150,\"width\":490,\"height\":330,\"angle\":0,\"strokeColor\":\"#fdba74\",\"backgroundColor\":\"#fff7ed\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b3R\",\"roundness\":{\"type\":3},\"seed\":723514768,\"version\":2,\"versionNonce\":1567604592,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s8d3at\",\"type\":\"text\",\"x\":24,\"y\":7162,\"width\":234.80775451660156,\"height\":17.5,\"angle\":0,\"strokeColor\":\"#c2410c\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b3S\",\"roundness\":null,\"seed\":254798704,\"version\":2,\"versionNonce\":1107439504,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"A. User Journey + Latency Budget\",\"fontSize\":14,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"A. User Journey + Latency Budget\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s8d3ab\",\"type\":\"text\",\"x\":24,\"y\":7186,\"width\":284.7776794433594,\"height\":373.75,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b3T\",\"roundness\":null,\"seed\":749388688,\"version\":2,\"versionNonce\":2049331568,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"1. User double-taps post (Instagram style)\\n2. Client OPTIMISTICALLY updates UI —\\n   shows heart filled, +1 count immediately\\n3. Client sends POST \/likes {post_id}\\n4. Server responds 200 in <50ms\\n5. Like count updates for all viewers\\n   within ~30 seconds (eventual consistency)\\n\\nDuring failure:\\n  Server 5xx: client rolls back optimistic\\n  update, shows error toast, user retries.\\n  Redis fails: like queued in Kafka for\\n  async retry. Count eventually correct.\\n\\nLatency budget (P99 < 200ms):\\n  JWT auth check:         2ms\\n  Idempotency check:      3ms\\n  Redis SADD liked_by:    3ms\\n  Redis INCR like_count:  2ms\\n  Kafka publish:          5ms\\n  Return 200:             5ms\\n  Total P50:          ~20ms\\n  Total P99:         ~150ms\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"1. User double-taps post (Instagram style)\\n2. Client OPTIMISTICALLY updates UI —\\n   shows heart filled, +1 count immediately\\n3. Client sends POST \/likes {post_id}\\n4. Server responds 200 in <50ms\\n5. Like count updates for all viewers\\n   within ~30 seconds (eventual consistency)\\n\\nDuring failure:\\n  Server 5xx: client rolls back optimistic\\n  update, shows error toast, user retries.\\n  Redis fails: like queued in Kafka for\\n  async retry. Count eventually correct.\\n\\nLatency budget (P99 < 200ms):\\n  JWT auth check:         2ms\\n  Idempotency check:      3ms\\n  Redis SADD liked_by:    3ms\\n  Redis INCR like_count:  2ms\\n  Kafka publish:          5ms\\n  Return 200:             5ms\\n  Total P50:          ~20ms\\n  Total P99:         ~150ms\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s8d3b\",\"type\":\"rectangle\",\"x\":518,\"y\":7150,\"width\":620,\"height\":330,\"angle\":0,\"strokeColor\":\"#86efac\",\"backgroundColor\":\"#f0fdf4\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b3U\",\"roundness\":{\"type\":3},\"seed\":1526791536,\"version\":2,\"versionNonce\":1597357456,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s8d3bt\",\"type\":\"text\",\"x\":532,\"y\":7162,\"width\":110.7958984375,\"height\":17.5,\"angle\":0,\"strokeColor\":\"#15803d\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b3V\",\"roundness\":null,\"seed\":262918544,\"version\":2,\"versionNonce\":641377136,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"B. Internal Flow\",\"fontSize\":14,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"B. Internal Flow\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s8d3bb\",\"type\":\"text\",\"x\":532,\"y\":7186,\"width\":311.5186462402344,\"height\":406.25,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b3W\",\"roundness\":null,\"seed\":1860161392,\"version\":2,\"versionNonce\":1791462288,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"LIKE PATH:\\n1.  POST \/likes {post_id, reaction_type}\\n2.  JWT auth (API gateway)\\n3.  SISMEMBER liked_by:{post_id} {uid}\\n    Already liked? Return 200 (idempotent no-op)\\n4.  SADD liked_by:{post_id} {user_id}\\n5.  INCR like_count:{post_id}\\n6.  Publish like_event to Kafka (async notify)\\n7.  Return {post_id, new_count} 200\\n\\nUNLIKE PATH:\\n3b. SREM liked_by:{post_id} {user_id}\\n5b. DECR like_count:{post_id}\\n\\nASYNC DB FLUSH (every 30 seconds):\\n  Like Flusher reads like_count:{post_id}\\n  for all dirty post_ids in Redis.\\n  UPDATE posts SET like_count = :n\\n  WHERE post_id = :id\\n  (single query per post, not per like)\\n\\nHOT POST HANDLING:\\n  liked_by set capped at 10M members.\\n  For counts >10M: switch to HyperLogLog.\\n  Redis HLL = ~0.81% error, 12KB memory.\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"LIKE PATH:\\n1.  POST \/likes {post_id, reaction_type}\\n2.  JWT auth (API gateway)\\n3.  SISMEMBER liked_by:{post_id} {uid}\\n    Already liked? Return 200 (idempotent no-op)\\n4.  SADD liked_by:{post_id} {user_id}\\n5.  INCR like_count:{post_id}\\n6.  Publish like_event to Kafka (async notify)\\n7.  Return {post_id, new_count} 200\\n\\nUNLIKE PATH:\\n3b. SREM liked_by:{post_id} {user_id}\\n5b. DECR like_count:{post_id}\\n\\nASYNC DB FLUSH (every 30 seconds):\\n  Like Flusher reads like_count:{post_id}\\n  for all dirty post_ids in Redis.\\n  UPDATE posts SET like_count = :n\\n  WHERE post_id = :id\\n  (single query per post, not per like)\\n\\nHOT POST HANDLING:\\n  liked_by set capped at 10M members.\\n  For counts >10M: switch to HyperLogLog.\\n  Redis HLL = ~0.81% error, 12KB memory.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s8d3c\",\"type\":\"rectangle\",\"x\":1156,\"y\":7150,\"width\":414,\"height\":330,\"angle\":0,\"strokeColor\":\"#93c5fd\",\"backgroundColor\":\"#eff6ff\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b3X\",\"roundness\":{\"type\":3},\"seed\":1264263056,\"version\":2,\"versionNonce\":804566384,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s8d3ct\",\"type\":\"text\",\"x\":1170,\"y\":7162,\"width\":96.8939208984375,\"height\":17.5,\"angle\":0,\"strokeColor\":\"#1d4ed8\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b3Y\",\"roundness\":null,\"seed\":51667312,\"version\":2,\"versionNonce\":2129631632,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"C. Data Model\",\"fontSize\":14,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"C. Data Model\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s8d3cb\",\"type\":\"text\",\"x\":1170,\"y\":7186,\"width\":279.5126647949219,\"height\":455,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b3Z\",\"roundness\":null,\"seed\":804302224,\"version\":2,\"versionNonce\":1553762160,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Redis (source of truth for counts):\\n  like_count:{post_id}\\n    Type: String (integer)\\n    INCR \/ DECR  — no TTL\\n\\n  liked_by:{post_id}\\n    Type: Set\\n    SADD \/ SREM \/ SISMEMBER\\n    Cap: 10M  |  TTL: 90 days\\n\\n  liked_posts:{user_id}\\n    Type: Set — 'did I like this?'\\n    TTL: 30 days\\n\\nDB (durable, slightly stale):\\n  likes table:\\n    post_id  UUID  IDX\\n    user_id  UUID  IDX\\n    created_at TIMESTAMPTZ\\n    UNIQUE (post_id, user_id)\\n\\n  posts.like_count INT\\n    Updated by async flusher\\n\\nWhy Redis SET not DB table:\\n  'Did I like this?' is hot-path <5ms.\\n  DB join would add 20-50ms per feed load.\\n  DB likes table = analytics + recovery only.\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Redis (source of truth for counts):\\n  like_count:{post_id}\\n    Type: String (integer)\\n    INCR \/ DECR  — no TTL\\n\\n  liked_by:{post_id}\\n    Type: Set\\n    SADD \/ SREM \/ SISMEMBER\\n    Cap: 10M  |  TTL: 90 days\\n\\n  liked_posts:{user_id}\\n    Type: Set — 'did I like this?'\\n    TTL: 30 days\\n\\nDB (durable, slightly stale):\\n  likes table:\\n    post_id  UUID  IDX\\n    user_id  UUID  IDX\\n    created_at TIMESTAMPTZ\\n    UNIQUE (post_id, user_id)\\n\\n  posts.like_count INT\\n    Updated by async flusher\\n\\nWhy Redis SET not DB table:\\n  'Did I like this?' is hot-path <5ms.\\n  DB join would add 20-50ms per feed load.\\n  DB likes table = analytics + recovery only.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s8sum\",\"type\":\"rectangle\",\"x\":10,\"y\":7492,\"width\":1560,\"height\":70,\"angle\":0,\"strokeColor\":\"#4c1d95\",\"backgroundColor\":\"#4c1d95\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b3a\",\"roundness\":{\"type\":3},\"seed\":115782512,\"version\":2,\"versionNonce\":786818960,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s8sumt\",\"type\":\"text\",\"x\":24,\"y\":7504,\"width\":179.08486938476562,\"height\":18.75,\"angle\":0,\"strokeColor\":\"#e9d5ff\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b3b\",\"roundness\":null,\"seed\":1185184656,\"version\":2,\"versionNonce\":142219632,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Deep Dive Key Patterns:\",\"fontSize\":15,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Deep Dive Key Patterns:\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s8sumv\",\"type\":\"text\",\"x\":24,\"y\":7528,\"width\":1123.2745361328125,\"height\":35,\"angle\":0,\"strokeColor\":\"#f5f3ff\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b3c\",\"roundness\":null,\"seed\":1084147056,\"version\":2,\"versionNonce\":1726117264,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Fan-out: Kafka decouples write from propagation. ZADD NX = replay-safe.  |  Feed Read: cursor=(score:post_id) stable on live feed. Hybrid merge under 500ms P99.\\nLikes: Redis INCR as hot counter. SADD set = idempotent dedup. Async flush to DB every 30s. Optimistic UI with rollback on failure.\",\"fontSize\":14,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Fan-out: Kafka decouples write from propagation. ZADD NX = replay-safe.  |  Feed Read: cursor=(score:post_id) stable on live feed. Hybrid merge under 500ms P99.\\nLikes: Redis INCR as hot counter. SADD set = idempotent dedup. Async flush to DB every 30s. Optimistic UI with rollback on failure.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s9bg\",\"type\":\"rectangle\",\"x\":10,\"y\":7620,\"width\":1560,\"height\":940,\"angle\":0,\"strokeColor\":\"#cbd5e1\",\"backgroundColor\":\"#f8fafc\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b3d\",\"roundness\":{\"type\":3},\"seed\":833522064,\"version\":2,\"versionNonce\":1188391792,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s9hd\",\"type\":\"rectangle\",\"x\":10,\"y\":7620,\"width\":1560,\"height\":46,\"angle\":0,\"strokeColor\":\"#4c1d95\",\"backgroundColor\":\"#4c1d95\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b3e\",\"roundness\":{\"type\":3},\"seed\":1837406064,\"version\":2,\"versionNonce\":1276986256,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s9tt\",\"type\":\"text\",\"x\":460,\"y\":7633,\"width\":290.03082275390625,\"height\":26.25,\"angle\":0,\"strokeColor\":\"#f5f3ff\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b3f\",\"roundness\":null,\"seed\":205969296,\"version\":2,\"versionNonce\":32931184,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"STEP 9  —  Failure Handling\",\"fontSize\":21,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"STEP 9  —  Failure Handling\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s9a\",\"type\":\"rectangle\",\"x\":10,\"y\":7676,\"width\":754,\"height\":192,\"angle\":0,\"strokeColor\":\"#f87171\",\"backgroundColor\":\"#fff1f2\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b3g\",\"roundness\":{\"type\":3},\"seed\":1642080624,\"version\":2,\"versionNonce\":483283344,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s9at\",\"type\":\"text\",\"x\":24,\"y\":7688,\"width\":339.73480224609375,\"height\":18.75,\"angle\":0,\"strokeColor\":\"#b91c1c\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b3h\",\"roundness\":null,\"seed\":1252353424,\"version\":2,\"versionNonce\":455430000,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Client Errors (4xx) — Validate Early, Fail Fast\",\"fontSize\":15,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Client Errors (4xx) — Validate Early, Fail Fast\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s9ab\",\"type\":\"text\",\"x\":24,\"y\":7712,\"width\":389.3625183105469,\"height\":178.75,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b3i\",\"roundness\":null,\"seed\":687438704,\"version\":2,\"versionNonce\":271425424,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Validate AT: API gateway before ANY downstream call.\\nNever let invalid data reach Kafka or the DB.\\n\\n400 Bad Request:   missing content, invalid media type\\n401 Unauthorized:  missing\/expired JWT — no retry\\n403 Forbidden:     posting to group you are not in\\n409 Conflict:      duplicate idempotency_key — return cached\\n413 Too Large:     content >10KB, video >500MB\\n\\nClient behavior: show error, NO automatic retry.\\nNO message queued. NO worker triggered. NO DB touched.\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Validate AT: API gateway before ANY downstream call.\\nNever let invalid data reach Kafka or the DB.\\n\\n400 Bad Request:   missing content, invalid media type\\n401 Unauthorized:  missing\/expired JWT — no retry\\n403 Forbidden:     posting to group you are not in\\n409 Conflict:      duplicate idempotency_key — return cached\\n413 Too Large:     content >10KB, video >500MB\\n\\nClient behavior: show error, NO automatic retry.\\nNO message queued. NO worker triggered. NO DB touched.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s9b\",\"type\":\"rectangle\",\"x\":782,\"y\":7676,\"width\":788,\"height\":192,\"angle\":0,\"strokeColor\":\"#fcd34d\",\"backgroundColor\":\"#fffbeb\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b3j\",\"roundness\":{\"type\":3},\"seed\":436351888,\"version\":2,\"versionNonce\":178905456,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s9bt\",\"type\":\"text\",\"x\":796,\"y\":7688,\"width\":203.95484924316406,\"height\":18.75,\"angle\":0,\"strokeColor\":\"#b45309\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b3k\",\"roundness\":null,\"seed\":622366064,\"version\":2,\"versionNonce\":913517968,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"External \/ Provider Failures\",\"fontSize\":15,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"External \/ Provider Failures\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s9bb\",\"type\":\"text\",\"x\":796,\"y\":7712,\"width\":375.99853515625,\"height\":211.25,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b3l\",\"roundness\":null,\"seed\":1083523472,\"version\":2,\"versionNonce\":2144088944,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"S3 upload fails:\\n  Circuit breaker opens after 5 failures in 10s.\\n  Return presigned URL to client anyway.\\n  Client retries upload directly — server not in loop.\\n\\nCDN origin unreachable:\\n  Serve stale cached media from edge (extend TTL).\\n  Alert if origin down >60 seconds.\\n\\nKafka broker unavailable:\\n  Producer: retry with backoff (3 attempts: 500ms\/1s\/2s).\\n  Fallback: write fan-out task to DB outbox table.\\n  Outbox poller publishes when Kafka recovers.\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"S3 upload fails:\\n  Circuit breaker opens after 5 failures in 10s.\\n  Return presigned URL to client anyway.\\n  Client retries upload directly — server not in loop.\\n\\nCDN origin unreachable:\\n  Serve stale cached media from edge (extend TTL).\\n  Alert if origin down >60 seconds.\\n\\nKafka broker unavailable:\\n  Producer: retry with backoff (3 attempts: 500ms\/1s\/2s).\\n  Fallback: write fan-out task to DB outbox table.\\n  Outbox poller publishes when Kafka recovers.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s9c\",\"type\":\"rectangle\",\"x\":10,\"y\":7878,\"width\":754,\"height\":222,\"angle\":0,\"strokeColor\":\"#a78bfa\",\"backgroundColor\":\"#f5f3ff\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b3m\",\"roundness\":{\"type\":3},\"seed\":797269872,\"version\":2,\"versionNonce\":1490484112,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s9ct\",\"type\":\"text\",\"x\":24,\"y\":7890,\"width\":311.47479248046875,\"height\":18.75,\"angle\":0,\"strokeColor\":\"#6d28d9\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b3n\",\"roundness\":null,\"seed\":2107019152,\"version\":2,\"versionNonce\":13911408,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Internal Service Failures — Outbox + Saga\",\"fontSize\":15,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Internal Service Failures — Outbox + Saga\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s9cb\",\"type\":\"text\",\"x\":24,\"y\":7914,\"width\":382.60272216796875,\"height\":260,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b3o\",\"roundness\":null,\"seed\":948433264,\"version\":2,\"versionNonce\":1502677392,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Fan-out worker crash mid-fan-out:\\n  Kafka offset NOT committed until batch completes.\\n  Worker restarts and reprocesses from last offset.\\n  ZADD NX is idempotent — same post_id added twice\\n  to same feed = no-op. Safe to replay any time.\\n\\nPost created but Kafka publish fails:\\n  Transactional outbox pattern:\\n  1. INSERT post + INSERT outbox_event in same DB txn.\\n  2. Outbox poller reads unflushed events, publishes.\\n  3. Marks event as published. Guarantees no lost fan-outs.\\n\\nFeed hydration service down:\\n  Return Redis cache without metadata hydration.\\n  Degrade: show post_ids + names from cache, skip\\n  real-time like counts. Stale is better than empty.\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Fan-out worker crash mid-fan-out:\\n  Kafka offset NOT committed until batch completes.\\n  Worker restarts and reprocesses from last offset.\\n  ZADD NX is idempotent — same post_id added twice\\n  to same feed = no-op. Safe to replay any time.\\n\\nPost created but Kafka publish fails:\\n  Transactional outbox pattern:\\n  1. INSERT post + INSERT outbox_event in same DB txn.\\n  2. Outbox poller reads unflushed events, publishes.\\n  3. Marks event as published. Guarantees no lost fan-outs.\\n\\nFeed hydration service down:\\n  Return Redis cache without metadata hydration.\\n  Degrade: show post_ids + names from cache, skip\\n  real-time like counts. Stale is better than empty.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s9d\",\"type\":\"rectangle\",\"x\":782,\"y\":7878,\"width\":788,\"height\":222,\"angle\":0,\"strokeColor\":\"#06b6d4\",\"backgroundColor\":\"#cffafe\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b3p\",\"roundness\":{\"type\":3},\"seed\":1765678480,\"version\":2,\"versionNonce\":185210736,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s9dt\",\"type\":\"text\",\"x\":796,\"y\":7890,\"width\":167.72982788085938,\"height\":18.75,\"angle\":0,\"strokeColor\":\"#0e7490\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b3q\",\"roundness\":null,\"seed\":1734886256,\"version\":2,\"versionNonce\":333010832,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Infrastructure Failures\",\"fontSize\":15,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Infrastructure Failures\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s9db\",\"type\":\"text\",\"x\":796,\"y\":7914,\"width\":371.5655517578125,\"height\":260,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b3r\",\"roundness\":null,\"seed\":1422125968,\"version\":2,\"versionNonce\":850766192,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Kafka partition down:\\n  Auto-rebalance — consumers pick up orphaned partitions.\\n  Fan-out lag spikes: alert at consumer_lag > 10K msgs.\\n  No data loss (Kafka replicated x3).\\n\\nDB primary fails:\\n  Automated failover: replica promoted in ~30s.\\n  During failover: writes queue at pool, timeout at 35s.\\n  Feed reads redirect to remaining replicas — unaffected.\\n  RPO <1s (sync replication). RTO ~30s.\\n\\nRedis cache node fails:\\n  Cache miss spike — DB absorbs (autoscaling triggers).\\n  Feed reads degrade to 200-500ms, not failure.\\n  Redis Cluster: surviving nodes serve their key ranges.\\n  Self-heals via cache population on each miss.\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Kafka partition down:\\n  Auto-rebalance — consumers pick up orphaned partitions.\\n  Fan-out lag spikes: alert at consumer_lag > 10K msgs.\\n  No data loss (Kafka replicated x3).\\n\\nDB primary fails:\\n  Automated failover: replica promoted in ~30s.\\n  During failover: writes queue at pool, timeout at 35s.\\n  Feed reads redirect to remaining replicas — unaffected.\\n  RPO <1s (sync replication). RTO ~30s.\\n\\nRedis cache node fails:\\n  Cache miss spike — DB absorbs (autoscaling triggers).\\n  Feed reads degrade to 200-500ms, not failure.\\n  Redis Cluster: surviving nodes serve their key ranges.\\n  Self-heals via cache population on each miss.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s9e\",\"type\":\"rectangle\",\"x\":10,\"y\":8110,\"width\":754,\"height\":198,\"angle\":0,\"strokeColor\":\"#eab308\",\"backgroundColor\":\"#fef9c3\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b3s\",\"roundness\":{\"type\":3},\"seed\":980309360,\"version\":2,\"versionNonce\":1005053328,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s9et\",\"type\":\"text\",\"x\":24,\"y\":8122,\"width\":280.49981689453125,\"height\":18.75,\"angle\":0,\"strokeColor\":\"#713f12\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b3t\",\"roundness\":null,\"seed\":710932880,\"version\":2,\"versionNonce\":1126103920,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Retry Strategy — Exact Specification\",\"fontSize\":15,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Retry Strategy — Exact Specification\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s9eb\",\"type\":\"text\",\"x\":24,\"y\":8146,\"width\":386.78857421875,\"height\":162.5,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b3u\",\"roundness\":null,\"seed\":652355440,\"version\":2,\"versionNonce\":1056224144,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Formula: delay = min(base * 2^attempt + rand(0, jitter), max)\\n  base=100ms, jitter=100ms, max=30000ms\\n  Attempt 1: ~100-200ms\\n  Attempt 2: ~200-400ms\\n  Attempt 3: ~400-800ms  → DLQ after 3 failures\\n\\nRETRYABLE: 503, 429, 500 (idempotent only),\\n  network timeout, Kafka produce timeout\\n\\nNON-RETRYABLE: 400, 401, 403, 409, 404\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Formula: delay = min(base * 2^attempt + rand(0, jitter), max)\\n  base=100ms, jitter=100ms, max=30000ms\\n  Attempt 1: ~100-200ms\\n  Attempt 2: ~200-400ms\\n  Attempt 3: ~400-800ms  → DLQ after 3 failures\\n\\nRETRYABLE: 503, 429, 500 (idempotent only),\\n  network timeout, Kafka produce timeout\\n\\nNON-RETRYABLE: 400, 401, 403, 409, 404\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s9f\",\"type\":\"rectangle\",\"x\":782,\"y\":8110,\"width\":788,\"height\":198,\"angle\":0,\"strokeColor\":\"#86efac\",\"backgroundColor\":\"#f0fdf4\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b3v\",\"roundness\":{\"type\":3},\"seed\":1296713616,\"version\":2,\"versionNonce\":1586367856,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s9ft\",\"type\":\"text\",\"x\":796,\"y\":8122,\"width\":241.63485717773438,\"height\":18.75,\"angle\":0,\"strokeColor\":\"#15803d\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b3w\",\"roundness\":null,\"seed\":957069680,\"version\":2,\"versionNonce\":590856592,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Idempotency — Exact Mechanism\",\"fontSize\":15,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Idempotency — Exact Mechanism\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s9fb\",\"type\":\"text\",\"x\":796,\"y\":8146,\"width\":355.341552734375,\"height\":211.25,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b3x\",\"roundness\":null,\"seed\":2042287504,\"version\":2,\"versionNonce\":508223344,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Post creation dedup:\\n  Hash: SHA256(user_id + content_hash + ts_minute)\\n  Store: SET idem:{hash} {post_id} EX 86400\\n  On retry: GET idem:{hash} → return original post_id\\n\\nLike idempotency:\\n  SADD liked_by:{post_id} {user_id}\\n  Returns 0 if already member → skip INCR, return 200.\\n  SADD is atomic — no race condition.\\n\\nFan-out worker dedup:\\n  ZADD NX feed:{follower_id} score post_id\\n  NX = add only if not exists. Replay-safe.\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Post creation dedup:\\n  Hash: SHA256(user_id + content_hash + ts_minute)\\n  Store: SET idem:{hash} {post_id} EX 86400\\n  On retry: GET idem:{hash} → return original post_id\\n\\nLike idempotency:\\n  SADD liked_by:{post_id} {user_id}\\n  Returns 0 if already member → skip INCR, return 200.\\n  SADD is atomic — no race condition.\\n\\nFan-out worker dedup:\\n  ZADD NX feed:{follower_id} score post_id\\n  NX = add only if not exists. Replay-safe.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s9dlq\",\"type\":\"rectangle\",\"x\":10,\"y\":8318,\"width\":1560,\"height\":120,\"angle\":0,\"strokeColor\":\"#fca5a5\",\"backgroundColor\":\"#fff1f2\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b3y\",\"roundness\":{\"type\":3},\"seed\":875760496,\"version\":2,\"versionNonce\":1743327120,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s9dlqt\",\"type\":\"text\",\"x\":24,\"y\":8330,\"width\":537.629638671875,\"height\":18.75,\"angle\":0,\"strokeColor\":\"#b91c1c\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b3z\",\"roundness\":null,\"seed\":619291536,\"version\":2,\"versionNonce\":849178992,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Dead Letter Queue (DLQ) — What Triggers It + What Ops Does With It\",\"fontSize\":15,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Dead Letter Queue (DLQ) — What Triggers It + What Ops Does With It\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s9dlqb\",\"type\":\"text\",\"x\":24,\"y\":8354,\"width\":1015.5199584960938,\"height\":65,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b40\",\"roundness\":null,\"seed\":849354096,\"version\":2,\"versionNonce\":1698733456,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Triggers DLQ after: 3 retries all fail. Causes: malformed message, permanently unavailable dependency, post_id referencing deleted post.\\nDLQ = Kafka topic fan_out_dlq with 7-day retention.\\nOps process: 1) Alert fires (dlq_count > 0 for 5min)  2) Inspect payload + stack trace  3) Fix root cause  4) Replay via kafka-consumer-groups --reset-offsets\\n5) Monitor fan-out lag returns to 0  |  SLA: DLQ messages replayed within 4 hours of alert.\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Triggers DLQ after: 3 retries all fail. Causes: malformed message, permanently unavailable dependency, post_id referencing deleted post.\\nDLQ = Kafka topic fan_out_dlq with 7-day retention.\\nOps process: 1) Alert fires (dlq_count > 0 for 5min)  2) Inspect payload + stack trace  3) Fix root cause  4) Replay via kafka-consumer-groups --reset-offsets\\n5) Monitor fan-out lag returns to 0  |  SLA: DLQ messages replayed within 4 hours of alert.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s9sum\",\"type\":\"rectangle\",\"x\":10,\"y\":8448,\"width\":1560,\"height\":40,\"angle\":0,\"strokeColor\":\"#4c1d95\",\"backgroundColor\":\"#4c1d95\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b41\",\"roundness\":{\"type\":3},\"seed\":1561244048,\"version\":2,\"versionNonce\":47039344,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s9sumt\",\"type\":\"text\",\"x\":24,\"y\":8461,\"width\":1037.74853515625,\"height\":17.5,\"angle\":0,\"strokeColor\":\"#f5f3ff\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b42\",\"roundness\":null,\"seed\":1167781744,\"version\":2,\"versionNonce\":745958288,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Key patterns: Outbox for Kafka reliability  |  ZADD NX for replay safety  |  Jitter formula: min(100*2^n + rand(100), 30000)ms  |  409 is non-retryable\",\"fontSize\":14,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Key patterns: Outbox for Kafka reliability  |  ZADD NX for replay safety  |  Jitter formula: min(100*2^n + rand(100), 30000)ms  |  409 is non-retryable\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s10bg\",\"type\":\"rectangle\",\"x\":10,\"y\":8540,\"width\":1560,\"height\":1010,\"angle\":0,\"strokeColor\":\"#cbd5e1\",\"backgroundColor\":\"#f8fafc\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b43\",\"roundness\":{\"type\":3},\"seed\":694288272,\"version\":2,\"versionNonce\":1294194032,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s10hd\",\"type\":\"rectangle\",\"x\":10,\"y\":8540,\"width\":1560,\"height\":46,\"angle\":0,\"strokeColor\":\"#134e4a\",\"backgroundColor\":\"#134e4a\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b44\",\"roundness\":{\"type\":3},\"seed\":359367024,\"version\":2,\"versionNonce\":1740798352,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s10tt\",\"type\":\"text\",\"x\":430,\"y\":8553,\"width\":376.59283447265625,\"height\":26.25,\"angle\":0,\"strokeColor\":\"#f0fdf4\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b45\",\"roundness\":null,\"seed\":1780190608,\"version\":2,\"versionNonce\":1189586800,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"STEP 10  —  NFR Coverage Analysis\",\"fontSize\":21,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"STEP 10  —  NFR Coverage Analysis\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s10a\",\"type\":\"rectangle\",\"x\":10,\"y\":8596,\"width\":502,\"height\":195,\"angle\":0,\"strokeColor\":\"#fca5a5\",\"backgroundColor\":\"#fff1f2\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b46\",\"roundness\":{\"type\":3},\"seed\":22664048,\"version\":2,\"versionNonce\":979158928,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s10at\",\"type\":\"text\",\"x\":24,\"y\":8608,\"width\":144.16493225097656,\"height\":18.75,\"angle\":0,\"strokeColor\":\"#b91c1c\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b47\",\"roundness\":null,\"seed\":947084176,\"version\":2,\"versionNonce\":1013004656,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Availability  99.99%\",\"fontSize\":15,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Availability  99.99%\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s10ab\",\"type\":\"text\",\"x\":24,\"y\":8632,\"width\":360.60650634765625,\"height\":97.5,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b48\",\"roundness\":null,\"seed\":1068361072,\"version\":2,\"versionNonce\":545084816,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Covered: multi-AZ API fleet, Redis Cluster auto-failover,\\nKafka replication x3, Aurora Multi-AZ (30s RTO), CDN\\nserves media even if origin is down.\\nViolated by: all three failovers happening simultaneously\\n(cascade). Probability: very low but non-zero.\\nGap: Kafka rebalance creates 10-30s fan-out pause.\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Covered: multi-AZ API fleet, Redis Cluster auto-failover,\\nKafka replication x3, Aurora Multi-AZ (30s RTO), CDN\\nserves media even if origin is down.\\nViolated by: all three failovers happening simultaneously\\n(cascade). Probability: very low but non-zero.\\nGap: Kafka rebalance creates 10-30s fan-out pause.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s10b\",\"type\":\"rectangle\",\"x\":530,\"y\":8596,\"width\":502,\"height\":195,\"angle\":0,\"strokeColor\":\"#fca5a5\",\"backgroundColor\":\"#fff1f2\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b49\",\"roundness\":{\"type\":3},\"seed\":1184983440,\"version\":2,\"versionNonce\":819497840,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s10bt\",\"type\":\"text\",\"x\":544,\"y\":8608,\"width\":240.94483947753906,\"height\":18.75,\"angle\":0,\"strokeColor\":\"#b91c1c\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b4A\",\"roundness\":null,\"seed\":2108667760,\"version\":2,\"versionNonce\":1331438480,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Latency  P50<80ms  P99<500ms\",\"fontSize\":15,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Latency  P50<80ms  P99<500ms\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s10bb\",\"type\":\"text\",\"x\":544,\"y\":8632,\"width\":365.03948974609375,\"height\":97.5,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b4B\",\"roundness\":null,\"seed\":1071495056,\"version\":2,\"versionNonce\":2123734384,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Covered: Redis ZRANGE P50~5ms, CDN for media zero\\nlatency, precomputed ranked feeds, post metadata cache.\\nViolated by: cold cache after mass Redis eviction — all\\nusers hit DB simultaneously (thundering herd).\\nGap: P99 during cache miss storms not fully protected\\nwithout request coalescing (dog-pile prevention lock).\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Covered: Redis ZRANGE P50~5ms, CDN for media zero\\nlatency, precomputed ranked feeds, post metadata cache.\\nViolated by: cold cache after mass Redis eviction — all\\nusers hit DB simultaneously (thundering herd).\\nGap: P99 during cache miss storms not fully protected\\nwithout request coalescing (dog-pile prevention lock).\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s10c\",\"type\":\"rectangle\",\"x\":1058,\"y\":8596,\"width\":512,\"height\":195,\"angle\":0,\"strokeColor\":\"#fca5a5\",\"backgroundColor\":\"#fff1f2\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b4C\",\"roundness\":{\"type\":3},\"seed\":2141669744,\"version\":2,\"versionNonce\":355545488,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s10ct\",\"type\":\"text\",\"x\":1072,\"y\":8608,\"width\":251.18983459472656,\"height\":18.75,\"angle\":0,\"strokeColor\":\"#b91c1c\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b4D\",\"roundness\":null,\"seed\":677397904,\"version\":2,\"versionNonce\":1994420080,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Throughput  232K read QPS peak\",\"fontSize\":15,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Throughput  232K read QPS peak\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s10cb\",\"type\":\"text\",\"x\":1072,\"y\":8632,\"width\":348.4385986328125,\"height\":97.5,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b4E\",\"roundness\":null,\"seed\":1088199536,\"version\":2,\"versionNonce\":959741840,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Covered: 150 API nodes (~300K QPS capacity),\\nRedis cluster ~600K ops\/sec, Kafka handles 115 MB\/s,\\nDB sharding distributes write load across 10 shards.\\nViolated by: single hot shard if author_id not evenly\\ndistributed in hash space.\\nGap: HPA autoscaling config for API tier (CPU >70%).\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Covered: 150 API nodes (~300K QPS capacity),\\nRedis cluster ~600K ops\/sec, Kafka handles 115 MB\/s,\\nDB sharding distributes write load across 10 shards.\\nViolated by: single hot shard if author_id not evenly\\ndistributed in hash space.\\nGap: HPA autoscaling config for API tier (CPU >70%).\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s10d\",\"type\":\"rectangle\",\"x\":10,\"y\":8801,\"width\":502,\"height\":195,\"angle\":0,\"strokeColor\":\"#fcd34d\",\"backgroundColor\":\"#fffbeb\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b4F\",\"roundness\":{\"type\":3},\"seed\":1029772176,\"version\":2,\"versionNonce\":33620336,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s10dt\",\"type\":\"text\",\"x\":24,\"y\":8813,\"width\":155.29490661621094,\"height\":18.75,\"angle\":0,\"strokeColor\":\"#b45309\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b4G\",\"roundness\":null,\"seed\":328707440,\"version\":2,\"versionNonce\":1537084816,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Durability  99.9999%\",\"fontSize\":15,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Durability  99.9999%\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s10db\",\"type\":\"text\",\"x\":24,\"y\":8837,\"width\":379.53460693359375,\"height\":97.5,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b4H\",\"roundness\":null,\"seed\":1427644816,\"version\":2,\"versionNonce\":1061114736,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Covered: sync DB write before 200 ACK, WAL to 2 replicas,\\nS3 for media (11 nines), transactional outbox ensures\\npost + fan-out event committed atomically.\\nViolated by: API returning 200 before DB commit confirmed\\n(async write anti-pattern).\\nGap: like counts in Redis only — needs AOF persistence.\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Covered: sync DB write before 200 ACK, WAL to 2 replicas,\\nS3 for media (11 nines), transactional outbox ensures\\npost + fan-out event committed atomically.\\nViolated by: API returning 200 before DB commit confirmed\\n(async write anti-pattern).\\nGap: like counts in Redis only — needs AOF persistence.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s10e\",\"type\":\"rectangle\",\"x\":530,\"y\":8801,\"width\":502,\"height\":195,\"angle\":0,\"strokeColor\":\"#fcd34d\",\"backgroundColor\":\"#fffbeb\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b4I\",\"roundness\":{\"type\":3},\"seed\":1092648816,\"version\":2,\"versionNonce\":1436933008,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s10et\",\"type\":\"text\",\"x\":544,\"y\":8813,\"width\":252.74984741210938,\"height\":18.75,\"angle\":0,\"strokeColor\":\"#b45309\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b4J\",\"roundness\":null,\"seed\":1052602256,\"version\":2,\"versionNonce\":618882416,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Consistency  (per-operation model)\",\"fontSize\":15,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Consistency  (per-operation model)\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s10eb\",\"type\":\"text\",\"x\":544,\"y\":8837,\"width\":378.3775329589844,\"height\":97.5,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b4K\",\"roundness\":null,\"seed\":700387696,\"version\":2,\"versionNonce\":428075408,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Covered: social graph reads routed to primary (RYOW),\\nfeed content eventual via Redis TTL, follow cache\\ninvalidated synchronously on unfollow event.\\nViolated by: user switches regions mid-session — new region\\nreplica may lag behind home region by up to 500ms.\\nGap: social graph writes need session affinity per user.\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Covered: social graph reads routed to primary (RYOW),\\nfeed content eventual via Redis TTL, follow cache\\ninvalidated synchronously on unfollow event.\\nViolated by: user switches regions mid-session — new region\\nreplica may lag behind home region by up to 500ms.\\nGap: social graph writes need session affinity per user.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s10f\",\"type\":\"rectangle\",\"x\":1058,\"y\":8801,\"width\":512,\"height\":195,\"angle\":0,\"strokeColor\":\"#fcd34d\",\"backgroundColor\":\"#fffbeb\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b4L\",\"roundness\":{\"type\":3},\"seed\":579403152,\"version\":2,\"versionNonce\":540358512,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s10ft\",\"type\":\"text\",\"x\":1072,\"y\":8813,\"width\":59.54994201660156,\"height\":18.75,\"angle\":0,\"strokeColor\":\"#b45309\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b4M\",\"roundness\":null,\"seed\":1690002288,\"version\":2,\"versionNonce\":309344144,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Security\",\"fontSize\":15,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Security\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s10fb\",\"type\":\"text\",\"x\":1072,\"y\":8837,\"width\":343.21258544921875,\"height\":113.75,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b4N\",\"roundness\":null,\"seed\":1639107472,\"version\":2,\"versionNonce\":897370480,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Covered: JWT verified at gateway on every request,\\nprivate-account follow-check in feed service,\\nrate limits 100 reads\/min and 10 posts\/min.\\nViolated by: celebrity read-path merge at V6 must\\nalso enforce private-account visibility — easy to miss.\\nGap: mute\/block lists not applied in celebrity_posts\\nmerge path — a muted celebrity's posts could appear.\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Covered: JWT verified at gateway on every request,\\nprivate-account follow-check in feed service,\\nrate limits 100 reads\/min and 10 posts\/min.\\nViolated by: celebrity read-path merge at V6 must\\nalso enforce private-account visibility — easy to miss.\\nGap: mute\/block lists not applied in celebrity_posts\\nmerge path — a muted celebrity's posts could appear.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s10g\",\"type\":\"rectangle\",\"x\":10,\"y\":9006,\"width\":502,\"height\":180,\"angle\":0,\"strokeColor\":\"#86efac\",\"backgroundColor\":\"#f0fdf4\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b4O\",\"roundness\":{\"type\":3},\"seed\":1616737648,\"version\":2,\"versionNonce\":77776272,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s10gt\",\"type\":\"text\",\"x\":24,\"y\":9018,\"width\":93.53993225097656,\"height\":18.75,\"angle\":0,\"strokeColor\":\"#15803d\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b4P\",\"roundness\":null,\"seed\":1987238288,\"version\":2,\"versionNonce\":537009008,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Observability\",\"fontSize\":15,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Observability\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s10gb\",\"type\":\"text\",\"x\":24,\"y\":9042,\"width\":361.20458984375,\"height\":97.5,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b4Q\",\"roundness\":null,\"seed\":32327536,\"version\":2,\"versionNonce\":1834193808,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Covered: OTEL distributed tracing, Prometheus metrics,\\nKafka consumer lag per partition, structured JSON logs\\nwith trace_id, SLO burn rate alerts.\\nViolated by: fan-out lag tracked at topic level — a single\\nhigh-follower author backing up is invisible in aggregate.\\nGap: need per-author fan-out lag metric.\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Covered: OTEL distributed tracing, Prometheus metrics,\\nKafka consumer lag per partition, structured JSON logs\\nwith trace_id, SLO burn rate alerts.\\nViolated by: fan-out lag tracked at topic level — a single\\nhigh-follower author backing up is invisible in aggregate.\\nGap: need per-author fan-out lag metric.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s10h\",\"type\":\"rectangle\",\"x\":530,\"y\":9006,\"width\":502,\"height\":180,\"angle\":0,\"strokeColor\":\"#86efac\",\"backgroundColor\":\"#f0fdf4\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b4R\",\"roundness\":{\"type\":3},\"seed\":1409361808,\"version\":2,\"versionNonce\":1913466224,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s10ht\",\"type\":\"text\",\"x\":544,\"y\":9018,\"width\":92.05494689941406,\"height\":18.75,\"angle\":0,\"strokeColor\":\"#15803d\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b4S\",\"roundness\":null,\"seed\":1169348976,\"version\":2,\"versionNonce\":1656398224,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Idempotency\",\"fontSize\":15,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Idempotency\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s10hb\",\"type\":\"text\",\"x\":544,\"y\":9042,\"width\":371.13653564453125,\"height\":97.5,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b4T\",\"roundness\":null,\"seed\":1184216464,\"version\":2,\"versionNonce\":887488368,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Covered: post SHA256 content key in Redis (24h TTL),\\nlike SADD atomic dedup, ZADD NX for fan-out,\\nfollows UNIQUE constraint in DB.\\nViolated by: cross-region race — user posts simultaneously\\nfrom two regions (very rare edge case).\\nGap: 24h key expiry is intentional product decision.\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Covered: post SHA256 content key in Redis (24h TTL),\\nlike SADD atomic dedup, ZADD NX for fan-out,\\nfollows UNIQUE constraint in DB.\\nViolated by: cross-region race — user posts simultaneously\\nfrom two regions (very rare edge case).\\nGap: 24h key expiry is intentional product decision.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s10i\",\"type\":\"rectangle\",\"x\":1058,\"y\":9006,\"width\":512,\"height\":180,\"angle\":0,\"strokeColor\":\"#93c5fd\",\"backgroundColor\":\"#eff6ff\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b4U\",\"roundness\":{\"type\":3},\"seed\":1593191280,\"version\":2,\"versionNonce\":1947201424,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s10it\",\"type\":\"text\",\"x\":1072,\"y\":9018,\"width\":89.1749267578125,\"height\":18.75,\"angle\":0,\"strokeColor\":\"#1d4ed8\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b4V\",\"roundness\":null,\"seed\":1399358352,\"version\":2,\"versionNonce\":148148592,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Multi-Region\",\"fontSize\":15,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Multi-Region\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s10ib\",\"type\":\"text\",\"x\":1072,\"y\":9042,\"width\":355.588623046875,\"height\":113.75,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b4W\",\"roundness\":null,\"seed\":1476345200,\"version\":2,\"versionNonce\":160136592,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Covered: active-active reads (3 regions), Route53\\nfailover (RTO 30s), Aurora Global Database (RPO <1s),\\nCDN at edge for media.\\nViolated by: split-brain if both regions believe they\\nare primary during network partition.\\nGap: write region failover should require human approval\\nfor social graph to prevent split-brain.\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Covered: active-active reads (3 regions), Route53\\nfailover (RTO 30s), Aurora Global Database (RPO <1s),\\nCDN at edge for media.\\nViolated by: split-brain if both regions believe they\\nare primary during network partition.\\nGap: write region failover should require human approval\\nfor social graph to prevent split-brain.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s10sum\",\"type\":\"rectangle\",\"x\":10,\"y\":9198,\"width\":1560,\"height\":64,\"angle\":0,\"strokeColor\":\"#134e4a\",\"backgroundColor\":\"#134e4a\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b4X\",\"roundness\":{\"type\":3},\"seed\":414290320,\"version\":2,\"versionNonce\":1159783280,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s10sumt\",\"type\":\"text\",\"x\":24,\"y\":9208,\"width\":169.70782470703125,\"height\":17.5,\"angle\":0,\"strokeColor\":\"#86efac\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b4Y\",\"roundness\":null,\"seed\":840306544,\"version\":2,\"versionNonce\":1147489168,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Honest Production Gaps:\",\"fontSize\":14,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Honest Production Gaps:\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s10sumv\",\"type\":\"text\",\"x\":24,\"y\":9230,\"width\":1408.340087890625,\"height\":16.25,\"angle\":0,\"strokeColor\":\"#f0fdf4\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b4Z\",\"roundness\":null,\"seed\":766042000,\"version\":2,\"versionNonce\":403895664,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"1) Thundering herd on cache miss → request coalescing needed   2) Redis AOF for like count durability   3) Session affinity for social graph writes   4) Per-author fan-out lag metric   5) Mute\/block in celebrity merge path\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"1) Thundering herd on cache miss → request coalescing needed   2) Redis AOF for like count durability   3) Session affinity for social graph writes   4) Per-author fan-out lag metric   5) Mute\/block in celebrity merge path\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s11bg\",\"type\":\"rectangle\",\"x\":10,\"y\":9310,\"width\":1560,\"height\":940,\"angle\":0,\"strokeColor\":\"#cbd5e1\",\"backgroundColor\":\"#f8fafc\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b4a\",\"roundness\":{\"type\":3},\"seed\":92447088,\"version\":2,\"versionNonce\":1591040400,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s11hd\",\"type\":\"rectangle\",\"x\":10,\"y\":9310,\"width\":1560,\"height\":46,\"angle\":0,\"strokeColor\":\"#134e4a\",\"backgroundColor\":\"#134e4a\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b4b\",\"roundness\":{\"type\":3},\"seed\":42364304,\"version\":2,\"versionNonce\":653444976,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s11tt\",\"type\":\"text\",\"x\":440,\"y\":9323,\"width\":363.63580322265625,\"height\":26.25,\"angle\":0,\"strokeColor\":\"#f0fdf4\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b4c\",\"roundness\":null,\"seed\":562885488,\"version\":2,\"versionNonce\":202614672,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"STEP 11  —  Multi-Region Strategy\",\"fontSize\":21,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"STEP 11  —  Multi-Region Strategy\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s11strat\",\"type\":\"rectangle\",\"x\":10,\"y\":9366,\"width\":1560,\"height\":95,\"angle\":0,\"strokeColor\":\"#3b82f6\",\"backgroundColor\":\"#dbeafe\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b4d\",\"roundness\":{\"type\":3},\"seed\":1082276752,\"version\":2,\"versionNonce\":772299120,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s11stratt\",\"type\":\"text\",\"x\":24,\"y\":9378,\"width\":654.9913330078125,\"height\":20,\"angle\":0,\"strokeColor\":\"#1d4ed8\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b4e\",\"roundness\":null,\"seed\":746390896,\"version\":2,\"versionNonce\":1482175888,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Core Decision: Active-Active Reads  +  Active-Passive Writes (per user home region)\",\"fontSize\":16,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Core Decision: Active-Active Reads  +  Active-Passive Writes (per user home region)\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s11stratb\",\"type\":\"text\",\"x\":24,\"y\":9402,\"width\":860.7941284179688,\"height\":48.75,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b4f\",\"roundness\":null,\"seed\":701778320,\"version\":2,\"versionNonce\":547072880,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Read path: ALL 3 regions serve reads from local Redis + DB replicas. Zero cross-region latency on reads.\\nWrite path: each user has a home region. Social graph writes go to that region's primary ONLY. Avoids distributed transactions.\\nWhy not full active-active writes? Follow\/unfollow needs RYOW. Full active-active requires Paxos\/Raft — 200-400ms penalty per write.\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Read path: ALL 3 regions serve reads from local Redis + DB replicas. Zero cross-region latency on reads.\\nWrite path: each user has a home region. Social graph writes go to that region's primary ONLY. Avoids distributed transactions.\\nWhy not full active-active writes? Follow\/unfollow needs RYOW. Full active-active requires Paxos\/Raft — 200-400ms penalty per write.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s11us\",\"type\":\"rectangle\",\"x\":10,\"y\":9471,\"width\":490,\"height\":250,\"angle\":0,\"strokeColor\":\"#3b82f6\",\"backgroundColor\":\"#dbeafe\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b4g\",\"roundness\":{\"type\":3},\"seed\":1134221168,\"version\":2,\"versionNonce\":148571024,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s11ust\",\"type\":\"text\",\"x\":24,\"y\":9483,\"width\":238.04983520507812,\"height\":18.75,\"angle\":0,\"strokeColor\":\"#1d4ed8\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b4h\",\"roundness\":null,\"seed\":2041878416,\"version\":2,\"versionNonce\":1223998832,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"US-East  (Primary Write Region)\",\"fontSize\":15,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"US-East  (Primary Write Region)\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s11usb\",\"type\":\"text\",\"x\":24,\"y\":9507,\"width\":222.84573364257812,\"height\":146.25,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b4i\",\"roundness\":null,\"seed\":456026480,\"version\":2,\"versionNonce\":2077495696,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"API Fleet: 50 nodes\\nRedis Cluster: primary\\nKafka: primary cluster\\nAurora Global DB: PRIMARY writer\\nCassandra: write quorum LOCAL\\nS3: origin for US users\\n\\nHandles all write traffic for\\nUS-region users' social graphs.\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"API Fleet: 50 nodes\\nRedis Cluster: primary\\nKafka: primary cluster\\nAurora Global DB: PRIMARY writer\\nCassandra: write quorum LOCAL\\nS3: origin for US users\\n\\nHandles all write traffic for\\nUS-region users' social graphs.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s11eu\",\"type\":\"rectangle\",\"x\":528,\"y\":9471,\"width\":490,\"height\":250,\"angle\":0,\"strokeColor\":\"#22c55e\",\"backgroundColor\":\"#dcfce7\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b4j\",\"roundness\":{\"type\":3},\"seed\":1146824080,\"version\":2,\"versionNonce\":1750830960,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s11eut\",\"type\":\"text\",\"x\":542,\"y\":9483,\"width\":261.3748779296875,\"height\":18.75,\"angle\":0,\"strokeColor\":\"#15803d\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b4k\",\"roundness\":null,\"seed\":511687536,\"version\":2,\"versionNonce\":142303120,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"EU-West  (GDPR Compliant Region)\",\"fontSize\":15,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"EU-West  (GDPR Compliant Region)\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s11eub\",\"type\":\"text\",\"x\":542,\"y\":9507,\"width\":270.42572021484375,\"height\":146.25,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b4l\",\"roundness\":null,\"seed\":1459614608,\"version\":2,\"versionNonce\":1461199216,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"API Fleet: 50 nodes\\nRedis Cluster: regional\\nKafka: MirrorMaker2 replication\\nAurora: secondary reader\\nCassandra: LOCAL_QUORUM\\nS3: EU-only bucket (GDPR hard boundary)\\n\\nEU user data physically isolated.\\nNO replication to US or APAC.\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"API Fleet: 50 nodes\\nRedis Cluster: regional\\nKafka: MirrorMaker2 replication\\nAurora: secondary reader\\nCassandra: LOCAL_QUORUM\\nS3: EU-only bucket (GDPR hard boundary)\\n\\nEU user data physically isolated.\\nNO replication to US or APAC.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s11ap\",\"type\":\"rectangle\",\"x\":1066,\"y\":9471,\"width\":504,\"height\":250,\"angle\":0,\"strokeColor\":\"#eab308\",\"backgroundColor\":\"#fef9c3\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b4m\",\"roundness\":{\"type\":3},\"seed\":265735536,\"version\":2,\"versionNonce\":1594420624,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s11apt\",\"type\":\"text\",\"x\":1080,\"y\":9483,\"width\":200.99989318847656,\"height\":18.75,\"angle\":0,\"strokeColor\":\"#713f12\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b4n\",\"roundness\":null,\"seed\":400228752,\"version\":2,\"versionNonce\":611480432,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"APAC  (Read-heavy Region)\",\"fontSize\":15,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"APAC  (Read-heavy Region)\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s11apb\",\"type\":\"text\",\"x\":1080,\"y\":9507,\"width\":213.43373107910156,\"height\":146.25,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b4o\",\"roundness\":null,\"seed\":679190384,\"version\":2,\"versionNonce\":1756674960,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"API Fleet: 50 nodes\\nRedis Cluster: regional\\nKafka: MirrorMaker2 replication\\nAurora: secondary reader\\nCassandra: LOCAL_QUORUM\\nS3: APAC-only bucket\\n\\nHigh read volume. Local CDN edge.\\nCross-region write lag ~500ms.\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"API Fleet: 50 nodes\\nRedis Cluster: regional\\nKafka: MirrorMaker2 replication\\nAurora: secondary reader\\nCassandra: LOCAL_QUORUM\\nS3: APAC-only bucket\\n\\nHigh read volume. Local CDN edge.\\nCross-region write lag ~500ms.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s11rep1\",\"type\":\"arrow\",\"x\":500.5,\"y\":9596,\"width\":27,\"height\":0,\"angle\":0,\"strokeColor\":\"#22c55e\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b4p\",\"roundness\":null,\"seed\":1713655696,\"version\":2,\"versionNonce\":917669232,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"points\":[[0,0],[27,0]],\"lastCommittedPoint\":null,\"startBinding\":null,\"endBinding\":null,\"startArrowhead\":null,\"endArrowhead\":\"arrow\",\"elbowed\":false},{\"id\":\"s11rep1l\",\"type\":\"text\",\"x\":504,\"y\":9578,\"width\":71.72390747070312,\"height\":15,\"angle\":0,\"strokeColor\":\"#15803d\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b4q\",\"roundness\":null,\"seed\":951464304,\"version\":2,\"versionNonce\":666290576,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"WAL <300ms\",\"fontSize\":12,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"WAL <300ms\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s11rep2\",\"type\":\"arrow\",\"x\":1056.5,\"y\":9596,\"width\":9,\"height\":0,\"angle\":0,\"strokeColor\":\"#22c55e\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b4r\",\"roundness\":null,\"seed\":2048122256,\"version\":2,\"versionNonce\":1797281648,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"points\":[[0,0],[9,0]],\"lastCommittedPoint\":null,\"startBinding\":null,\"endBinding\":null,\"startArrowhead\":null,\"endArrowhead\":\"arrow\",\"elbowed\":false},{\"id\":\"s11rep2l\",\"type\":\"text\",\"x\":1060,\"y\":9578,\"width\":71.84390258789062,\"height\":15,\"angle\":0,\"strokeColor\":\"#15803d\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b4s\",\"roundness\":null,\"seed\":1204716400,\"version\":2,\"versionNonce\":390535056,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"WAL <500ms\",\"fontSize\":12,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"WAL <500ms\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s11fo\",\"type\":\"rectangle\",\"x\":10,\"y\":9731,\"width\":754,\"height\":200,\"angle\":0,\"strokeColor\":\"#fca5a5\",\"backgroundColor\":\"#fff1f2\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b4t\",\"roundness\":{\"type\":3},\"seed\":1155640208,\"version\":2,\"versionNonce\":906226032,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s11fot\",\"type\":\"text\",\"x\":24,\"y\":9743,\"width\":287.1748046875,\"height\":18.75,\"angle\":0,\"strokeColor\":\"#b91c1c\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b4u\",\"roundness\":null,\"seed\":873239920,\"version\":2,\"versionNonce\":194880912,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Failover Sequence: US-East Goes Down\",\"fontSize\":15,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Failover Sequence: US-East Goes Down\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s11fob\",\"type\":\"text\",\"x\":24,\"y\":9767,\"width\":367.860595703125,\"height\":162.5,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b4v\",\"roundness\":null,\"seed\":1355135376,\"version\":2,\"versionNonce\":1118124912,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"T+0s:   US-East API fleet stops responding\\nT+10s:  Route53 health checks fail (2x5s interval)\\nT+30s:  DNS TTL expires — traffic reroutes to EU-West\\nT+31s:  Aurora Global promotes EU-West replica (<1s)\\nT+35s:  Social graph writes now accepted in EU-West\\nT+60s:  Ops paged — incident declared\\nT+4h:   US-East restored, resyncs from EU-West\\n\\nRPO: <1s  (Aurora Global sync replication to EU-West)\\nRTO: ~30s (DNS propagation + Aurora promote)\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"T+0s:   US-East API fleet stops responding\\nT+10s:  Route53 health checks fail (2x5s interval)\\nT+30s:  DNS TTL expires — traffic reroutes to EU-West\\nT+31s:  Aurora Global promotes EU-West replica (<1s)\\nT+35s:  Social graph writes now accepted in EU-West\\nT+60s:  Ops paged — incident declared\\nT+4h:   US-East restored, resyncs from EU-West\\n\\nRPO: <1s  (Aurora Global sync replication to EU-West)\\nRTO: ~30s (DNS propagation + Aurora promote)\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s11sov\",\"type\":\"rectangle\",\"x\":782,\"y\":9731,\"width\":788,\"height\":200,\"angle\":0,\"strokeColor\":\"#a78bfa\",\"backgroundColor\":\"#f5f3ff\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b4w\",\"roundness\":{\"type\":3},\"seed\":1387816816,\"version\":2,\"versionNonce\":301101968,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s11sovt\",\"type\":\"text\",\"x\":796,\"y\":9743,\"width\":223.45489501953125,\"height\":18.75,\"angle\":0,\"strokeColor\":\"#6d28d9\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b4x\",\"roundness\":null,\"seed\":553125776,\"version\":2,\"versionNonce\":323767664,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Data Sovereignty + Compliance\",\"fontSize\":15,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Data Sovereignty + Compliance\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s11sovb\",\"type\":\"text\",\"x\":796,\"y\":9767,\"width\":375.34857177734375,\"height\":195,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b4y\",\"roundness\":null,\"seed\":270137712,\"version\":2,\"versionNonce\":1350402448,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"GDPR (EU): EU user posts, social graph, profile data must\\nreside in EU-West ONLY. No replication to US or APAC.\\nImplementation: user_home_region field on user record.\\nReplication topology respects regional boundaries.\\n\\nIndia \/ APAC: some countries require local storage.\\nAPAC region stores local user data locally.\\n\\nCross-region fan-out: shares post_id + CDN URL only.\\nNever replicates PII content. CDN serves from home S3.\\n\\nChina: completely separate deployment — out of scope.\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"GDPR (EU): EU user posts, social graph, profile data must\\nreside in EU-West ONLY. No replication to US or APAC.\\nImplementation: user_home_region field on user record.\\nReplication topology respects regional boundaries.\\n\\nIndia \/ APAC: some countries require local storage.\\nAPAC region stores local user data locally.\\n\\nCross-region fan-out: shares post_id + CDN URL only.\\nNever replicates PII content. CDN serves from home S3.\\n\\nChina: completely separate deployment — out of scope.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s11sum\",\"type\":\"rectangle\",\"x\":10,\"y\":9941,\"width\":1560,\"height\":50,\"angle\":0,\"strokeColor\":\"#134e4a\",\"backgroundColor\":\"#134e4a\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b4z\",\"roundness\":{\"type\":3},\"seed\":296785296,\"version\":2,\"versionNonce\":557916016,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s11sumt\",\"type\":\"text\",\"x\":24,\"y\":9954,\"width\":1122.8541259765625,\"height\":17.5,\"angle\":0,\"strokeColor\":\"#f0fdf4\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b50\",\"roundness\":null,\"seed\":259607408,\"version\":2,\"versionNonce\":1719062416,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Active-active reads \/ active-passive writes  |  RTO 30s  |  RPO <1s  |  GDPR: EU data physically isolated  |  Fan-out cross-region shares only post_id + CDN URL\",\"fontSize\":14,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Active-active reads \/ active-passive writes  |  RTO 30s  |  RPO <1s  |  GDPR: EU data physically isolated  |  Fan-out cross-region shares only post_id + CDN URL\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s12bg\",\"type\":\"rectangle\",\"x\":10,\"y\":10050,\"width\":1560,\"height\":1210,\"angle\":0,\"strokeColor\":\"#cbd5e1\",\"backgroundColor\":\"#f8fafc\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b51\",\"roundness\":{\"type\":3},\"seed\":2093724016,\"version\":3,\"versionNonce\":884010265,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748728299,\"link\":null,\"locked\":false},{\"id\":\"s12hd\",\"type\":\"rectangle\",\"x\":10,\"y\":10050,\"width\":1560,\"height\":46,\"angle\":0,\"strokeColor\":\"#78350f\",\"backgroundColor\":\"#78350f\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b52\",\"roundness\":{\"type\":3},\"seed\":1276534160,\"version\":3,\"versionNonce\":1559416055,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748728299,\"link\":null,\"locked\":false},{\"id\":\"s12tt\",\"type\":\"text\",\"x\":420,\"y\":10063,\"width\":349.6078186035156,\"height\":26.25,\"angle\":0,\"strokeColor\":\"#fef3c7\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b53\",\"roundness\":null,\"seed\":1832125296,\"version\":3,\"versionNonce\":975561209,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748728299,\"link\":null,\"locked\":false,\"text\":\"STEP 12  —  Trade-off Decisions\",\"fontSize\":21,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"STEP 12  —  Trade-off Decisions\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s12sub\",\"type\":\"text\",\"x\":420,\"y\":10098,\"width\":449.1053466796875,\"height\":17.5,\"angle\":0,\"strokeColor\":\"#64748b\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b54\",\"roundness\":null,\"seed\":848571280,\"version\":3,\"versionNonce\":1293686295,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748728299,\"link\":null,\"locked\":false,\"text\":\"Format: Decision | Over | Because (3 reasons) | Costs | Revisit if\",\"fontSize\":14,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Format: Decision | Over | Because (3 reasons) | Costs | Revisit if\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s12t1\",\"type\":\"rectangle\",\"x\":10,\"y\":10116,\"width\":754,\"height\":218,\"angle\":0,\"strokeColor\":\"#3b82f6\",\"backgroundColor\":\"#dbeafe\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b55\",\"roundness\":{\"type\":3},\"seed\":281154928,\"version\":3,\"versionNonce\":854145753,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748728299,\"link\":null,\"locked\":false},{\"id\":\"s12t1t\",\"type\":\"text\",\"x\":24,\"y\":10128,\"width\":519.2593994140625,\"height\":17.5,\"angle\":0,\"strokeColor\":\"#1d4ed8\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b56\",\"roundness\":null,\"seed\":1680357776,\"version\":3,\"versionNonce\":931085111,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748728299,\"link\":null,\"locked\":false,\"text\":\"Decision 1 — Posts DB: PostgreSQL (sharded)  over Cassandra \/ MongoDB\",\"fontSize\":14,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Decision 1 — Posts DB: PostgreSQL (sharded)  over Cassandra \/ MongoDB\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s12t1b\",\"type\":\"text\",\"x\":24,\"y\":10152,\"width\":467.531494140625,\"height\":162.5,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b57\",\"roundness\":null,\"seed\":2092820336,\"version\":3,\"versionNonce\":1871607737,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748728300,\"link\":null,\"locked\":false,\"text\":\"Because:\\n1. Cache-miss query: WHERE author_id IN (...) AND created_at > X\\n   Cassandra forces one table per query pattern — too rigid.\\n2. Post schema is well-defined and relational. No flexible-schema benefit.\\n3. Sharded PG gives horizontal scale PLUS full SQL query expressiveness.\\n\\nCosts: Cross-shard queries impossible (app-layer aggregation required).\\nSchema migrations on sharded PG are operationally painful.\\n\\nRevisit if: post schema becomes truly dynamic, or writes exceed 50K\/sec.\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Because:\\n1. Cache-miss query: WHERE author_id IN (...) AND created_at > X\\n   Cassandra forces one table per query pattern — too rigid.\\n2. Post schema is well-defined and relational. No flexible-schema benefit.\\n3. Sharded PG gives horizontal scale PLUS full SQL query expressiveness.\\n\\nCosts: Cross-shard queries impossible (app-layer aggregation required).\\nSchema migrations on sharded PG are operationally painful.\\n\\nRevisit if: post schema becomes truly dynamic, or writes exceed 50K\/sec.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s12t2\",\"type\":\"rectangle\",\"x\":782,\"y\":10116,\"width\":788,\"height\":218,\"angle\":0,\"strokeColor\":\"#eab308\",\"backgroundColor\":\"#fef9c3\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b58\",\"roundness\":{\"type\":3},\"seed\":604669840,\"version\":3,\"versionNonce\":1887485015,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748728300,\"link\":null,\"locked\":false},{\"id\":\"s12t2t\",\"type\":\"text\",\"x\":796,\"y\":10128,\"width\":441.1954345703125,\"height\":17.5,\"angle\":0,\"strokeColor\":\"#713f12\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b59\",\"roundness\":null,\"seed\":1567586672,\"version\":3,\"versionNonce\":1647909017,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748728300,\"link\":null,\"locked\":false,\"text\":\"Decision 2 — Social Graph: Cassandra  over PostgreSQL \/ Neo4j\",\"fontSize\":14,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Decision 2 — Social Graph: Cassandra  over PostgreSQL \/ Neo4j\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s12t2b\",\"type\":\"text\",\"x\":796,\"y\":10152,\"width\":455.75341796875,\"height\":162.5,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b5A\",\"roundness\":null,\"seed\":242423184,\"version\":3,\"versionNonce\":1274354039,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748728300,\"link\":null,\"locked\":false,\"text\":\"Because:\\n1. Only query ever run: get all followees for user X. Cassandra wide-row\\n   (partition=follower_id, cols=followees) is a single partition read, O(1).\\n2. Write throughput: follow\/unfollow events at scale. LSM tree handles\\n   write-heavy workloads natively. PG B-tree struggles here.\\n3. Horizontal scale: add nodes, ranges rebalance automatically.\\n\\nCosts: Eventual consistency by default. No ad-hoc queries.\\n\\nRevisit if: friend-of-friend recommendations needed (Neo4j better).\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Because:\\n1. Only query ever run: get all followees for user X. Cassandra wide-row\\n   (partition=follower_id, cols=followees) is a single partition read, O(1).\\n2. Write throughput: follow\/unfollow events at scale. LSM tree handles\\n   write-heavy workloads natively. PG B-tree struggles here.\\n3. Horizontal scale: add nodes, ranges rebalance automatically.\\n\\nCosts: Eventual consistency by default. No ad-hoc queries.\\n\\nRevisit if: friend-of-friend recommendations needed (Neo4j better).\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s12t3\",\"type\":\"rectangle\",\"x\":10,\"y\":10344,\"width\":754,\"height\":218,\"angle\":0,\"strokeColor\":\"#ef4444\",\"backgroundColor\":\"#fee2e2\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b5B\",\"roundness\":{\"type\":3},\"seed\":371116912,\"version\":3,\"versionNonce\":1822203257,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748728300,\"link\":null,\"locked\":false},{\"id\":\"s12t3t\",\"type\":\"text\",\"x\":24,\"y\":10356,\"width\":447.9715270996094,\"height\":17.5,\"angle\":0,\"strokeColor\":\"#b91c1c\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b5C\",\"roundness\":null,\"seed\":2023351184,\"version\":3,\"versionNonce\":790680215,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748728300,\"link\":null,\"locked\":false,\"text\":\"Decision 3 — Async Fan-out: Kafka  over RabbitMQ \/ SQS \/ sync\",\"fontSize\":14,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Decision 3 — Async Fan-out: Kafka  over RabbitMQ \/ SQS \/ sync\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s12t3b\",\"type\":\"text\",\"x\":24,\"y\":10380,\"width\":468.7403564453125,\"height\":178.75,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b5D\",\"roundness\":null,\"seed\":1628691824,\"version\":3,\"versionNonce\":1845266009,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748728300,\"link\":null,\"locked\":false,\"text\":\"Because:\\n1. Replay: Kafka retains messages — crashed worker catches up from\\n   exact offset. RabbitMQ deletes on ACK. No replay possible.\\n2. Throughput: Kafka handles 69 MB\/s fan-out + 46 MB\/s likes easily.\\n   RabbitMQ struggles above ~50K msg\/sec without significant tuning.\\n3. Consumer groups: adding fan-out workers needs zero producer changes.\\n\\nCosts: Operational complexity — KRaft, rebalancing, lag monitoring.\\nAt-least-once delivery needs idempotent consumers (ZADD NX).\\n\\nRevisit if: fan-out volume drops below 1K posts\/sec — use SQS instead.\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Because:\\n1. Replay: Kafka retains messages — crashed worker catches up from\\n   exact offset. RabbitMQ deletes on ACK. No replay possible.\\n2. Throughput: Kafka handles 69 MB\/s fan-out + 46 MB\/s likes easily.\\n   RabbitMQ struggles above ~50K msg\/sec without significant tuning.\\n3. Consumer groups: adding fan-out workers needs zero producer changes.\\n\\nCosts: Operational complexity — KRaft, rebalancing, lag monitoring.\\nAt-least-once delivery needs idempotent consumers (ZADD NX).\\n\\nRevisit if: fan-out volume drops below 1K posts\/sec — use SQS instead.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s12t4\",\"type\":\"rectangle\",\"x\":782,\"y\":10344,\"width\":788,\"height\":218,\"angle\":0,\"strokeColor\":\"#ec4899\",\"backgroundColor\":\"#fce7f3\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b5E\",\"roundness\":{\"type\":3},\"seed\":1354166672,\"version\":3,\"versionNonce\":1656252343,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748728300,\"link\":null,\"locked\":false},{\"id\":\"s12t4t\",\"type\":\"text\",\"x\":796,\"y\":10356,\"width\":497.5593566894531,\"height\":17.5,\"angle\":0,\"strokeColor\":\"#9d174d\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b5F\",\"roundness\":null,\"seed\":1872146288,\"version\":3,\"versionNonce\":288117561,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748728300,\"link\":null,\"locked\":false,\"text\":\"Decision 4 — Feed Cache: Redis Sorted Set  over Memcached \/ Mat.View\",\"fontSize\":14,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Decision 4 — Feed Cache: Redis Sorted Set  over Memcached \/ Mat.View\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s12t4b\",\"type\":\"text\",\"x\":796,\"y\":10380,\"width\":487.564453125,\"height\":195,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b5G\",\"roundness\":null,\"seed\":2114076560,\"version\":3,\"versionNonce\":618682583,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748728300,\"link\":null,\"locked\":false,\"text\":\"Because:\\n1. Native sorted structure: ZREVRANGEBYSCORE gives stable cursor-based\\n   pagination natively. No equivalent in Memcached.\\n2. Atomic ops: ZADD + ZRANGE are single-command atomic.\\n   No race conditions between feed write and read.\\n3. Latency: Redis P99 ~1ms. Materialized view needs DB round trip\\n   (20-50ms) and expensive refresh on every post write.\\n\\nCosts: Memory-only (35GB — manageable but real cost).\\nEviction causes thundering herd DB fallback.\\n\\nRevisit if: feed cache grows beyond 500GB — consider tiered storage.\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Because:\\n1. Native sorted structure: ZREVRANGEBYSCORE gives stable cursor-based\\n   pagination natively. No equivalent in Memcached.\\n2. Atomic ops: ZADD + ZRANGE are single-command atomic.\\n   No race conditions between feed write and read.\\n3. Latency: Redis P99 ~1ms. Materialized view needs DB round trip\\n   (20-50ms) and expensive refresh on every post write.\\n\\nCosts: Memory-only (35GB — manageable but real cost).\\nEviction causes thundering herd DB fallback.\\n\\nRevisit if: feed cache grows beyond 500GB — consider tiered storage.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s12t5\",\"type\":\"rectangle\",\"x\":10,\"y\":10572,\"width\":754,\"height\":208,\"angle\":0,\"strokeColor\":\"#22c55e\",\"backgroundColor\":\"#dcfce7\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b5H\",\"roundness\":{\"type\":3},\"seed\":166674800,\"version\":3,\"versionNonce\":1519354905,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748728300,\"link\":null,\"locked\":false},{\"id\":\"s12t5t\",\"type\":\"text\",\"x\":24,\"y\":10584,\"width\":398.6915283203125,\"height\":17.5,\"angle\":0,\"strokeColor\":\"#15803d\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b5I\",\"roundness\":null,\"seed\":1085525392,\"version\":3,\"versionNonce\":2066556407,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748728300,\"link\":null,\"locked\":false,\"text\":\"Decision 5 — Consistency: Eventual for Feed  over Strong\",\"fontSize\":14,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Decision 5 — Consistency: Eventual for Feed  over Strong\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s12t5b\",\"type\":\"text\",\"x\":24,\"y\":10608,\"width\":442.16851806640625,\"height\":195,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b5J\",\"roundness\":null,\"seed\":795186032,\"version\":3,\"versionNonce\":1981389049,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748728300,\"link\":null,\"locked\":false,\"text\":\"Because:\\n1. User tolerance: seeing a post 2-5s late is invisible to users.\\n   Seeing 400ms write latency on every post is very visible.\\n2. Cross-region strong consistency costs 200-400ms (network RTT)\\n   on every post create — violates P99 <1s write SLO.\\n3. Throughput: sync cross-region replication serializes all writes,\\n   limiting throughput to slowest region's ACK time.\\n\\nCosts: slight ordering differences across devices, RYOW exception\\nneeded for follow\/unfollow.\\n\\nRevisit if: financial or legal compliance content added to feed.\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Because:\\n1. User tolerance: seeing a post 2-5s late is invisible to users.\\n   Seeing 400ms write latency on every post is very visible.\\n2. Cross-region strong consistency costs 200-400ms (network RTT)\\n   on every post create — violates P99 <1s write SLO.\\n3. Throughput: sync cross-region replication serializes all writes,\\n   limiting throughput to slowest region's ACK time.\\n\\nCosts: slight ordering differences across devices, RYOW exception\\nneeded for follow\/unfollow.\\n\\nRevisit if: financial or legal compliance content added to feed.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s12t6\",\"type\":\"rectangle\",\"x\":782,\"y\":10572,\"width\":788,\"height\":208,\"angle\":0,\"strokeColor\":\"#a78bfa\",\"backgroundColor\":\"#f5f3ff\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b5K\",\"roundness\":{\"type\":3},\"seed\":302226320,\"version\":3,\"versionNonce\":1151553303,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748728300,\"link\":null,\"locked\":false},{\"id\":\"s12t6t\",\"type\":\"text\",\"x\":796,\"y\":10584,\"width\":407.9454345703125,\"height\":17.5,\"angle\":0,\"strokeColor\":\"#6d28d9\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b5L\",\"roundness\":null,\"seed\":910271856,\"version\":3,\"versionNonce\":1162744281,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748728300,\"link\":null,\"locked\":false,\"text\":\"Decision 6 — Hybrid Fan-out  over Pure Write or Pure Read\",\"fontSize\":14,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Decision 6 — Hybrid Fan-out  over Pure Write or Pure Read\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s12t6b\",\"type\":\"text\",\"x\":796,\"y\":10608,\"width\":456.9234313964844,\"height\":178.75,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b5M\",\"roundness\":null,\"seed\":69839248,\"version\":3,\"versionNonce\":196564023,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748728300,\"link\":null,\"locked\":false,\"text\":\"Because:\\n1. Pure write breaks at 10M followers: 10M Redis writes\/post\\n   saturates worker pool, creates 30min Kafka consumer lag spikes.\\n2. Pure read breaks at 232K QPS: every read recomputes merge from\\n   scratch. Twitter abandoned pure pull in 2012 for exactly this reason.\\n3. Hybrid amortizes correctly: 99.9% accounts (<1M followers) get\\n   instant precomputed reads. 0.1% celebrities merge at read time.\\n\\nCosts: two code paths, 1M threshold is a magic number needing tuning.\\n\\nRevisit if: 50%+ users follow >5 celebrities — merge cost dominates.\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Because:\\n1. Pure write breaks at 10M followers: 10M Redis writes\/post\\n   saturates worker pool, creates 30min Kafka consumer lag spikes.\\n2. Pure read breaks at 232K QPS: every read recomputes merge from\\n   scratch. Twitter abandoned pure pull in 2012 for exactly this reason.\\n3. Hybrid amortizes correctly: 99.9% accounts (<1M followers) get\\n   instant precomputed reads. 0.1% celebrities merge at read time.\\n\\nCosts: two code paths, 1M threshold is a magic number needing tuning.\\n\\nRevisit if: 50%+ users follow >5 celebrities — merge cost dominates.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s12t7\",\"type\":\"rectangle\",\"x\":10,\"y\":10790,\"width\":1560,\"height\":180,\"angle\":0,\"strokeColor\":\"#eab308\",\"backgroundColor\":\"#fef9c3\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b5N\",\"roundness\":{\"type\":3},\"seed\":1808496496,\"version\":3,\"versionNonce\":759197369,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748728300,\"link\":null,\"locked\":false},{\"id\":\"s12t7t\",\"type\":\"text\",\"x\":24,\"y\":10802,\"width\":547.38525390625,\"height\":17.5,\"angle\":0,\"strokeColor\":\"#713f12\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b5O\",\"roundness\":null,\"seed\":576583568,\"version\":3,\"versionNonce\":407745879,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748728300,\"link\":null,\"locked\":false,\"text\":\"Decision 7 — Retry Strategy: Exponential Backoff + Jitter  over Fixed Interval\",\"fontSize\":14,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Decision 7 — Retry Strategy: Exponential Backoff + Jitter  over Fixed Interval\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s12t7b\",\"type\":\"text\",\"x\":24,\"y\":10826,\"width\":807.3641357421875,\"height\":146.25,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b5P\",\"roundness\":null,\"seed\":877332848,\"version\":3,\"versionNonce\":613691289,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748728300,\"link\":null,\"locked\":false,\"text\":\"Because:\\n1. Thundering herd prevention: 150 workers that all hit Kafka timeout simultaneously retry at DIFFERENT times due to jitter.\\n   Desynchronized load instead of synchronized retry storm that re-breaks the recovering service.\\n2. Self-healing: exponential backoff gives recovering services time to stabilize before the next retry wave arrives.\\n3. Formula: min(100ms * 2^attempt + rand(0,100ms), 30000ms) — mathematically proven to converge under Poisson load.\\n\\nCosts: users see higher latency on retry path (up to 30s max backoff). DLQ accumulates faster during extended outages.\\n\\nRevisit if: SLA requires <5s recovery — circuit breaker + immediate failover to backup becomes more appropriate.\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Because:\\n1. Thundering herd prevention: 150 workers that all hit Kafka timeout simultaneously retry at DIFFERENT times due to jitter.\\n   Desynchronized load instead of synchronized retry storm that re-breaks the recovering service.\\n2. Self-healing: exponential backoff gives recovering services time to stabilize before the next retry wave arrives.\\n3. Formula: min(100ms * 2^attempt + rand(0,100ms), 30000ms) — mathematically proven to converge under Poisson load.\\n\\nCosts: users see higher latency on retry path (up to 30s max backoff). DLQ accumulates faster during extended outages.\\n\\nRevisit if: SLA requires <5s recovery — circuit breaker + immediate failover to backup becomes more appropriate.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s12sum\",\"type\":\"rectangle\",\"x\":10,\"y\":10980,\"width\":1560,\"height\":50,\"angle\":0,\"strokeColor\":\"#78350f\",\"backgroundColor\":\"#78350f\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b5Q\",\"roundness\":{\"type\":3},\"seed\":1356367248,\"version\":3,\"versionNonce\":1102770807,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748728300,\"link\":null,\"locked\":false},{\"id\":\"s12sumt\",\"type\":\"text\",\"x\":24,\"y\":10993,\"width\":1351.05419921875,\"height\":17.5,\"angle\":0,\"strokeColor\":\"#fef3c7\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b5R\",\"roundness\":null,\"seed\":721967984,\"version\":3,\"versionNonce\":24958073,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748728300,\"link\":null,\"locked\":false,\"text\":\"Posts: PG (query flex)  |  Graph: Cassandra (write throughput)  |  Fan-out: Kafka (replay)  |  Cache: Redis SortedSet (cursors)  |  Consistency: Eventual (speed)  |  Fan-out: Hybrid  |  Retry: Jitter\",\"fontSize\":14,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Posts: PG (query flex)  |  Graph: Cassandra (write throughput)  |  Fan-out: Kafka (replay)  |  Cache: Redis SortedSet (cursors)  |  Consistency: Eventual (speed)  |  Fan-out: Hybrid  |  Retry: Jitter\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s13bg\",\"type\":\"rectangle\",\"x\":10,\"y\":11100,\"width\":1560,\"height\":870,\"angle\":0,\"strokeColor\":\"#cbd5e1\",\"backgroundColor\":\"#f8fafc\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b5S\",\"roundness\":{\"type\":3},\"seed\":751915920,\"version\":3,\"versionNonce\":12815255,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748728300,\"link\":null,\"locked\":false},{\"id\":\"s13hd\",\"type\":\"rectangle\",\"x\":10,\"y\":11100,\"width\":1560,\"height\":46,\"angle\":0,\"strokeColor\":\"#1e3a5f\",\"backgroundColor\":\"#1e3a5f\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b5T\",\"roundness\":{\"type\":3},\"seed\":1112239472,\"version\":3,\"versionNonce\":129883481,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748728300,\"link\":null,\"locked\":false},{\"id\":\"s13tt\",\"type\":\"text\",\"x\":450,\"y\":11113,\"width\":338.60382080078125,\"height\":26.25,\"angle\":0,\"strokeColor\":\"#f1f5f9\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b5U\",\"roundness\":null,\"seed\":1820352912,\"version\":3,\"versionNonce\":1100742839,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748728300,\"link\":null,\"locked\":false,\"text\":\"STEP 13  —  Interview Strategy\",\"fontSize\":21,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"STEP 13  —  Interview Strategy\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s13sum\",\"type\":\"rectangle\",\"x\":10,\"y\":11156,\"width\":1560,\"height\":110,\"angle\":0,\"strokeColor\":\"#93c5fd\",\"backgroundColor\":\"#eff6ff\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b5V\",\"roundness\":{\"type\":3},\"seed\":1666989936,\"version\":3,\"versionNonce\":917162553,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748728300,\"link\":null,\"locked\":false},{\"id\":\"s13sumt\",\"type\":\"text\",\"x\":24,\"y\":11168,\"width\":425.81976318359375,\"height\":18.75,\"angle\":0,\"strokeColor\":\"#1d4ed8\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b5W\",\"roundness\":null,\"seed\":1058910096,\"version\":3,\"versionNonce\":1978192343,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748728300,\"link\":null,\"locked\":false,\"text\":\"30-Second Verbal Summary  (practice saying this out loud)\",\"fontSize\":15,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"30-Second Verbal Summary  (practice saying this out loud)\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s13sumb\",\"type\":\"text\",\"x\":24,\"y\":11192,\"width\":1042.3780517578125,\"height\":65,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b5X\",\"roundness\":null,\"seed\":243454320,\"version\":3,\"versionNonce\":1462180633,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748728300,\"link\":null,\"locked\":false,\"text\":\"\\\"A News Feed aggregates posts from N followed accounts into a personalized ranked stream. The core challenge is fan-out — a celebrity with 10M followers posting\\nonce creates 10M feed-cache update events. We solve this with a hybrid approach: fan-out-on-write via Kafka workers for normal users,\\nfan-out-on-read at merge time for celebrity accounts. Feeds are stored as Redis sorted sets, serving reads in under 5ms. Like counters use Redis INCR\\nwith async DB flush every 30 seconds. The system shards posts by user_id, uses Cassandra for the social graph, and runs active-active reads across 3 regions.\\\"\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"\\\"A News Feed aggregates posts from N followed accounts into a personalized ranked stream. The core challenge is fan-out — a celebrity with 10M followers posting\\nonce creates 10M feed-cache update events. We solve this with a hybrid approach: fan-out-on-write via Kafka workers for normal users,\\nfan-out-on-read at merge time for celebrity accounts. Feeds are stored as Redis sorted sets, serving reads in under 5ms. Like counters use Redis INCR\\nwith async DB flush every 30 seconds. The system shards posts by user_id, uses Cassandra for the social graph, and runs active-active reads across 3 regions.\\\"\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s13q\",\"type\":\"rectangle\",\"x\":10,\"y\":11276,\"width\":1560,\"height\":295,\"angle\":0,\"strokeColor\":\"#fca5a5\",\"backgroundColor\":\"#fff1f2\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b5Y\",\"roundness\":{\"type\":3},\"seed\":752958864,\"version\":3,\"versionNonce\":1723760375,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748728300,\"link\":null,\"locked\":false},{\"id\":\"s13qt\",\"type\":\"text\",\"x\":24,\"y\":11288,\"width\":304.81475830078125,\"height\":18.75,\"angle\":0,\"strokeColor\":\"#b91c1c\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b5Z\",\"roundness\":null,\"seed\":2064065392,\"version\":3,\"versionNonce\":1235636217,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748728300,\"link\":null,\"locked\":false,\"text\":\"3 Hardest Interview Questions + Answers\",\"fontSize\":15,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"3 Hardest Interview Questions + Answers\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s13q1\",\"type\":\"rectangle\",\"x\":24,\"y\":11312,\"width\":490,\"height\":245,\"angle\":0,\"strokeColor\":\"#fca5a5\",\"backgroundColor\":\"#ffffff\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b5a\",\"roundness\":{\"type\":3},\"seed\":1996688272,\"version\":3,\"versionNonce\":1184991255,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748728300,\"link\":null,\"locked\":false},{\"id\":\"s13q1t\",\"type\":\"text\",\"x\":38,\"y\":11324,\"width\":206.82974243164062,\"height\":32.5,\"angle\":0,\"strokeColor\":\"#b91c1c\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b5b\",\"roundness\":null,\"seed\":925971824,\"version\":3,\"versionNonce\":338421977,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748728300,\"link\":null,\"locked\":false,\"text\":\"Q: How do you handle a celebrity\\nwith 100M followers posting?\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Q: How do you handle a celebrity\\nwith 100M followers posting?\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s13q1b\",\"type\":\"text\",\"x\":38,\"y\":11358,\"width\":275.20965576171875,\"height\":146.25,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b5c\",\"roundness\":null,\"seed\":2008750480,\"version\":3,\"versionNonce\":59141431,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748728300,\"link\":null,\"locked\":false,\"text\":\"A: Hybrid fan-out. Do NOT push to 100M\\nRedis caches at write time — worker queue\\nwould saturate for 30+ minutes.\\nInstead: store in celebrity_posts table.\\nAt read time: ZRANGE precomputed feed +\\nSELECT celebrity_posts WHERE author IN\\n(followed celebrities) LIMIT 20.\\nMerge both result sets by ranking score.\\nAdd ~20ms to read latency. Fully worth it.\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"A: Hybrid fan-out. Do NOT push to 100M\\nRedis caches at write time — worker queue\\nwould saturate for 30+ minutes.\\nInstead: store in celebrity_posts table.\\nAt read time: ZRANGE precomputed feed +\\nSELECT celebrity_posts WHERE author IN\\n(followed celebrities) LIMIT 20.\\nMerge both result sets by ranking score.\\nAdd ~20ms to read latency. Fully worth it.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s13q2\",\"type\":\"rectangle\",\"x\":532,\"y\":11312,\"width\":490,\"height\":245,\"angle\":0,\"strokeColor\":\"#fca5a5\",\"backgroundColor\":\"#ffffff\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b5d\",\"roundness\":{\"type\":3},\"seed\":1212745584,\"version\":3,\"versionNonce\":810247609,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748728300,\"link\":null,\"locked\":false},{\"id\":\"s13q2t\",\"type\":\"text\",\"x\":546,\"y\":11324,\"width\":220.58375549316406,\"height\":32.5,\"angle\":0,\"strokeColor\":\"#b91c1c\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b5e\",\"roundness\":null,\"seed\":37840784,\"version\":3,\"versionNonce\":1490136663,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748728300,\"link\":null,\"locked\":false,\"text\":\"Q: How do you paginate a live feed\\nwithout duplicates or skips?\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Q: How do you paginate a live feed\\nwithout duplicates or skips?\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s13q2b\",\"type\":\"text\",\"x\":546,\"y\":11358,\"width\":254.44874572753906,\"height\":162.5,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b5f\",\"roundness\":null,\"seed\":1251383664,\"version\":3,\"versionNonce\":422069913,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748728300,\"link\":null,\"locked\":false,\"text\":\"A: Cursor-based pagination using\\ncursor = base64(ranking_score:post_id).\\nQuery: ZREVRANGEBYSCORE feed:alice\\n(cursor_score -inf LIMIT 0 20.\\nFetch posts BELOW the cursor score.\\nThis is stable — new posts inserted at\\nthe top never shift existing positions.\\nOffset-based (LIMIT 20 OFFSET 100)\\nbreaks because new insertions shift\\nall offsets downward.\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"A: Cursor-based pagination using\\ncursor = base64(ranking_score:post_id).\\nQuery: ZREVRANGEBYSCORE feed:alice\\n(cursor_score -inf LIMIT 0 20.\\nFetch posts BELOW the cursor score.\\nThis is stable — new posts inserted at\\nthe top never shift existing positions.\\nOffset-based (LIMIT 20 OFFSET 100)\\nbreaks because new insertions shift\\nall offsets downward.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s13q3\",\"type\":\"rectangle\",\"x\":1058,\"y\":11312,\"width\":498,\"height\":245,\"angle\":0,\"strokeColor\":\"#fca5a5\",\"backgroundColor\":\"#ffffff\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b5g\",\"roundness\":{\"type\":3},\"seed\":1120794000,\"version\":3,\"versionNonce\":559401847,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748728300,\"link\":null,\"locked\":false},{\"id\":\"s13q3t\",\"type\":\"text\",\"x\":1072,\"y\":11324,\"width\":255.2677001953125,\"height\":32.5,\"angle\":0,\"strokeColor\":\"#b91c1c\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b5h\",\"roundness\":null,\"seed\":291629936,\"version\":3,\"versionNonce\":427166585,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748728300,\"link\":null,\"locked\":false,\"text\":\"Q: A viral post gets 500K likes in 1 hour\\n— how does the system handle it?\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Q: A viral post gets 500K likes in 1 hour\\n— how does the system handle it?\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s13q3b\",\"type\":\"text\",\"x\":1072,\"y\":11358,\"width\":258.01068115234375,\"height\":162.5,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b5i\",\"roundness\":null,\"seed\":513328016,\"version\":3,\"versionNonce\":1767720087,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748728300,\"link\":null,\"locked\":false,\"text\":\"A: Redis INCR on like_count:{post_id}.\\nAtomic, handles 100K+ ops\/sec per node.\\nLike dedup: SADD liked_by:{post_id}.\\nReturns 0 if already liked — idempotent.\\nNo DB write on the critical path.\\nAsync flusher batches to DB every 30s\\n(single UPDATE per post, not per like).\\nIf post crosses 10M likes, switch to\\nHyperLogLog (12KB, 0.81% error).\\nCount is eventually consistent — fine.\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"A: Redis INCR on like_count:{post_id}.\\nAtomic, handles 100K+ ops\/sec per node.\\nLike dedup: SADD liked_by:{post_id}.\\nReturns 0 if already liked — idempotent.\\nNo DB write on the critical path.\\nAsync flusher batches to DB every 30s\\n(single UPDATE per post, not per like).\\nIf post crosses 10M likes, switch to\\nHyperLogLog (12KB, 0.81% error).\\nCount is eventually consistent — fine.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s13miss\",\"type\":\"rectangle\",\"x\":10,\"y\":11581,\"width\":754,\"height\":175,\"angle\":0,\"strokeColor\":\"#fcd34d\",\"backgroundColor\":\"#fffbeb\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b5j\",\"roundness\":{\"type\":3},\"seed\":1190329712,\"version\":3,\"versionNonce\":1501049945,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748728300,\"link\":null,\"locked\":false},{\"id\":\"s13misst\",\"type\":\"text\",\"x\":24,\"y\":11593,\"width\":204.50987243652344,\"height\":18.75,\"angle\":0,\"strokeColor\":\"#b45309\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b5k\",\"roundness\":null,\"seed\":333042064,\"version\":3,\"versionNonce\":1083611575,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748728300,\"link\":null,\"locked\":false,\"text\":\"What Most Candidates Miss\",\"fontSize\":15,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"What Most Candidates Miss\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s13missb\",\"type\":\"text\",\"x\":24,\"y\":11617,\"width\":461.1485290527344,\"height\":97.5,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b5l\",\"roundness\":null,\"seed\":210882416,\"version\":3,\"versionNonce\":755122489,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748728300,\"link\":null,\"locked\":false,\"text\":\"1. Cursor pagination — everyone says OFFSET. Wrong on live feeds.\\n2. BN7 workload isolation — viral post like-spike starves feed reads.\\n3. Idempotency on retry — duplicate posts without dedup keys.\\n4. Media pending state — broken feed thumbnails before transcoding.\\n5. Mute\/block must apply in the celebrity merge path too.\\n6. RYOW consistency for follow\/unfollow (not just eventual everywhere).\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"1. Cursor pagination — everyone says OFFSET. Wrong on live feeds.\\n2. BN7 workload isolation — viral post like-spike starves feed reads.\\n3. Idempotency on retry — duplicate posts without dedup keys.\\n4. Media pending state — broken feed thumbnails before transcoding.\\n5. Mute\/block must apply in the celebrity merge path too.\\n6. RYOW consistency for follow\/unfollow (not just eventual everywhere).\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s13diff\",\"type\":\"rectangle\",\"x\":782,\"y\":11581,\"width\":788,\"height\":175,\"angle\":0,\"strokeColor\":\"#a78bfa\",\"backgroundColor\":\"#f5f3ff\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b5m\",\"roundness\":{\"type\":3},\"seed\":432611216,\"version\":3,\"versionNonce\":1277709015,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748728300,\"link\":null,\"locked\":false},{\"id\":\"s13difft\",\"type\":\"text\",\"x\":796,\"y\":11593,\"width\":168.7498779296875,\"height\":18.75,\"angle\":0,\"strokeColor\":\"#6d28d9\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b5n\",\"roundness\":null,\"seed\":445014384,\"version\":3,\"versionNonce\":561492505,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748728300,\"link\":null,\"locked\":false,\"text\":\"Senior vs Staff Answer\",\"fontSize\":15,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Senior vs Staff Answer\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s13diffb\",\"type\":\"text\",\"x\":796,\"y\":11617,\"width\":516.4635009765625,\"height\":113.75,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b5o\",\"roundness\":null,\"seed\":10399120,\"version\":3,\"versionNonce\":413587447,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748728300,\"link\":null,\"locked\":false,\"text\":\"Senior: adds Redis cache, Kafka fan-out, mentions hybrid fan-out.\\nStaff:\\n  Quantifies every tradeoff with specific thresholds (1M follower boundary).\\n  States exact retry formula with jitter and explains WHY jitter prevents storms.\\n  Identifies honest production gaps (thundering herd, per-author lag metrics).\\n  Walks through the exact failover sequence with real timing numbers.\\n  Notes GDPR boundary — EU data cannot replicate to US, ever.\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Senior: adds Redis cache, Kafka fan-out, mentions hybrid fan-out.\\nStaff:\\n  Quantifies every tradeoff with specific thresholds (1M follower boundary).\\n  States exact retry formula with jitter and explains WHY jitter prevents storms.\\n  Identifies honest production gaps (thundering herd, per-author lag metrics).\\n  Walks through the exact failover sequence with real timing numbers.\\n  Notes GDPR boundary — EU data cannot replicate to US, ever.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s13nums\",\"type\":\"rectangle\",\"x\":10,\"y\":11766,\"width\":1560,\"height\":80,\"angle\":0,\"strokeColor\":\"#1e3a5f\",\"backgroundColor\":\"#1e3a5f\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b5p\",\"roundness\":{\"type\":3},\"seed\":1612231536,\"version\":3,\"versionNonce\":1271662329,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748728300,\"link\":null,\"locked\":false},{\"id\":\"s13numst\",\"type\":\"text\",\"x\":24,\"y\":11778,\"width\":187.4698486328125,\"height\":18.75,\"angle\":0,\"strokeColor\":\"#93c5fd\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b5q\",\"roundness\":null,\"seed\":1368554384,\"version\":3,\"versionNonce\":739688727,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748728300,\"link\":null,\"locked\":false,\"text\":\"Key Numbers to Memorize:\",\"fontSize\":15,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Key Numbers to Memorize:\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s13numsv\",\"type\":\"text\",\"x\":24,\"y\":11802,\"width\":1344.06787109375,\"height\":17.5,\"angle\":0,\"strokeColor\":\"#f1f5f9\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b5r\",\"roundness\":null,\"seed\":596690288,\"version\":3,\"versionNonce\":1451409369,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748728300,\"link\":null,\"locked\":false,\"text\":\"232K peak feed read QPS  |  3.2 GB\/s outbound BW  |  35 GB feed cache  |  69 MB\/s Kafka fan-out  |  Feed P99 < 500ms  |  RTO 30s  |  RPO < 1s  |  Fan-out lag < 5s  |  Like flush every 30s\",\"fontSize\":14,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"232K peak feed read QPS  |  3.2 GB\/s outbound BW  |  35 GB feed cache  |  69 MB\/s Kafka fan-out  |  Feed P99 < 500ms  |  RTO 30s  |  RPO < 1s  |  Fan-out lag < 5s  |  Like flush every 30s\",\"autoResize\":true,\"lineHeight\":1.25}],\"files\":{}}","height":25,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":828021116,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":null,"x":2025.5765769697152,"angle":0,"y":-5759.4815021208788,"width":2985990.25},{"isDeleted":false,"locked":false,"strokeColor":"#cbd5e1","link":null,"roughness":1,"groupIds":[],"index":"bDf","backgroundColor":"#f8fafc","angle":0,"fillStyle":"solid","strokeWidth":1,"version":121,"roundness":{"type":3},"type":"rectangle","updated":1772748823808,"id":"7uz0h_eOlQuxyEGeVih-i","x":1808.8699240820786,"seed":509494652,"boundElements":[],"y":-5833.3457143105743,"opacity":100,"height":680,"width":1560,"frameId":null,"strokeStyle":"solid","versionNonce":1639965052},{"isDeleted":false,"locked":false,"strokeColor":"#1e3a5f","link":null,"roughness":1,"groupIds":[],"index":"bDg","backgroundColor":"#1e3a5f","angle":0,"fillStyle":"solid","strokeWidth":1,"version":121,"roundness":{"type":3},"type":"rectangle","updated":1772748823808,"id":"wO4lT2YfPOseq6yA2gKpN","x":1808.8699240820786,"seed":1777350140,"boundElements":[],"y":-5833.3457143105743,"opacity":100,"height":46,"width":1560,"frameId":null,"strokeStyle":"solid","versionNonce":113136124},{"seed":1055921788,"strokeStyle":"solid","id":"-aEHZ5eKpU11zoR_F3tDl","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":21,"opacity":100,"verticalAlign":"top","updated":1772748823808,"locked":false,"text":"STEP 1  —  Problem Framing: News Feed","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bDh","roundness":null,"containerId":null,"originalText":"STEP 1  —  Problem Framing: News Feed","height":26.25,"link":null,"strokeColor":"#f1f5f9","fillStyle":"solid","groupIds":[],"versionNonce":1402647164,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":2288.8699240820788,"angle":0,"y":-5820.3457143105743,"width":413.53173828125},{"isDeleted":false,"locked":false,"strokeColor":"#93c5fd","link":null,"roughness":1,"groupIds":[],"index":"bDi","backgroundColor":"#eff6ff","angle":0,"fillStyle":"solid","strokeWidth":1,"version":121,"roundness":{"type":3},"type":"rectangle","updated":1772748823808,"id":"8__CoToz58_2wQ8IknvMB","x":1808.8699240820786,"seed":438298364,"boundElements":[],"y":-5777.3457143105743,"opacity":100,"height":222,"width":490,"frameId":null,"strokeStyle":"solid","versionNonce":1997996796},{"seed":268543868,"strokeStyle":"solid","id":"kJTEsIPGqiFM5DHpfvtlr","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":16,"opacity":100,"verticalAlign":"top","updated":1772748823809,"locked":false,"text":"Core Problem","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bDj","roundness":null,"containerId":null,"originalText":"Core Problem","height":20,"link":null,"strokeColor":"#1d4ed8","fillStyle":"solid","groupIds":[],"versionNonce":2008367996,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1822.8699240820786,"angle":0,"y":-5765.3457143105743,"width":99.967910766601562},{"seed":1423398908,"strokeStyle":"solid","id":"l22APVpi79jpzW8juktg8","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772748823809,"locked":false,"text":"Aggregates posts from all followed accounts\ninto one personalized ranked stream.\n\nWithout it: users visit each profile manually.\nThis is how social networks worked pre-2006.\n\nCentral tension: 1 celebrity post triggers\n10M feed-cache updates — the fan-out problem.\nEvery design decision traces back to this.","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bDk","roundness":null,"containerId":null,"originalText":"Aggregates posts from all followed accounts\ninto one personalized ranked stream.\n\nWithout it: users visit each profile manually.\nThis is how social networks worked pre-2006.\n\nCentral tension: 1 celebrity post triggers\n10M feed-cache updates — the fan-out problem.\nEvery design decision traces back to this.","height":157.5,"link":null,"strokeColor":"#334155","fillStyle":"solid","groupIds":[],"versionNonce":1001878524,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1822.8699240820786,"angle":0,"y":-5740.3457143105743,"width":329.51763916015625},{"isDeleted":false,"locked":false,"strokeColor":"#86efac","link":null,"roughness":1,"groupIds":[],"index":"bDl","backgroundColor":"#f0fdf4","angle":0,"fillStyle":"solid","strokeWidth":1,"version":121,"roundness":{"type":3},"type":"rectangle","updated":1772748823809,"id":"s8u25KUbL_6qKk5kEUHbh","x":2316.8699240820788,"seed":1151531132,"boundElements":[],"y":-5777.3457143105743,"opacity":100,"height":222,"width":490,"frameId":null,"strokeStyle":"solid","versionNonce":287282300},{"seed":1797687548,"strokeStyle":"solid","id":"MBJNf8TUgfg45uVH2kyFw","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":16,"opacity":100,"verticalAlign":"top","updated":1772748823809,"locked":false,"text":"User Archetypes","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bDm","roundness":null,"containerId":null,"originalText":"User Archetypes","height":20,"link":null,"strokeColor":"#15803d","fillStyle":"solid","groupIds":[],"versionNonce":900703484,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":2330.8699240820788,"angle":0,"y":-5765.3457143105743,"width":128.28790283203125},{"seed":199494012,"strokeStyle":"solid","id":"tfCmOzLVwzLYcP-mAMt1D","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772748823809,"locked":false,"text":"PRODUCERS — celebrities, brands, creators\n  Post rarely. Millions of followers.\n  Create massive fan-out per write.\n\nCONSUMERS — regular users\n  Read 10x per day. Few followers.\n  Low fan-out writes, high read volume.\n\nRead : Write = 100 : 1\nThis single ratio drives the architecture.","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bDn","roundness":null,"containerId":null,"originalText":"PRODUCERS — celebrities, brands, creators\n  Post rarely. Millions of followers.\n  Create massive fan-out per write.\n\nCONSUMERS — regular users\n  Read 10x per day. Few followers.\n  Low fan-out writes, high read volume.\n\nRead : Write = 100 : 1\nThis single ratio drives the architecture.","height":175,"link":null,"strokeColor":"#334155","fillStyle":"solid","groupIds":[],"versionNonce":1592370556,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":2330.8699240820788,"angle":0,"y":-5740.3457143105743,"width":303.22564697265625},{"isDeleted":false,"locked":false,"strokeColor":"#d8b4fe","link":null,"roughness":1,"groupIds":[],"index":"bDo","backgroundColor":"#fdf4ff","angle":0,"fillStyle":"solid","strokeWidth":1,"version":121,"roundness":{"type":3},"type":"rectangle","updated":1772748823809,"id":"K71XrVxlKoP2dimU1fcDM","x":2824.8699240820783,"seed":706574844,"boundElements":[],"y":-5777.3457143105743,"opacity":100,"height":222,"width":544,"frameId":