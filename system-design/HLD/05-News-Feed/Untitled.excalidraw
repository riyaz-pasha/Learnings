qm4RXE-aFmF8Z0","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772748823812,"locked":false,"text":"JOIN on follows+posts = expensive full index scan per request  |  No caching: every read is a disk I\/O\nSingle writer: post + like + follow writes contend on one instance  |  One slow query blocks the API thread","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bGg","roundness":null,"containerId":null,"originalText":"JOIN on follows+posts = expensive full index scan per request  |  No caching: every read is a disk I\/O\nSingle writer: post + like + follow writes contend on one instance  |  One slow query blocks the API thread","height":32.5,"link":null,"strokeColor":"#334155","fillStyle":"solid","groupIds":[],"versionNonce":911810300,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":2590.8699240820788,"angle":0,"y":-1961.3457143105743,"width":677.67626953125},{"isDeleted":false,"locked":false,"strokeColor":"#1e3a5f","link":null,"roughness":1,"groupIds":[],"index":"bGh","backgroundColor":"#1e3a5f","angle":0,"fillStyle":"solid","strokeWidth":1,"version":121,"roundness":{"type":3},"type":"rectangle","updated":1772748823812,"id":"jT2IonAjooNncbgh4s0t8","x":1808.8699240820786,"seed":48513916,"boundElements":[],"y":-1885.3457143105743,"opacity":100,"height":50,"width":1560,"frameId":null,"strokeStyle":"solid","versionNonce":1079238524},{"seed":151417852,"strokeStyle":"solid","id":"Kl81VGkycvYX8FLyE_3LI","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772748823812,"locked":false,"text":"Say to interviewer: \"Starting simple to establish a baseline and make tradeoffs explicit. This works at startup scale but has a hard ceiling around 50K DAU. Let me identify exactly where it breaks.\"","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bGi","roundness":null,"containerId":null,"originalText":"Say to interviewer: \"Starting simple to establish a baseline and make tradeoffs explicit. This works at startup scale but has a hard ceiling around 50K DAU. Let me identify exactly where it breaks.\"","height":17.5,"link":null,"strokeColor":"#f1f5f9","fillStyle":"solid","groupIds":[],"versionNonce":774017020,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1822.8699240820786,"angle":0,"y":-1872.3457143105743,"width":1352.916015625},{"isDeleted":false,"locked":false,"strokeColor":"#cbd5e1","link":null,"roughness":1,"groupIds":[],"index":"bGj","backgroundColor":"#f8fafc","angle":0,"fillStyle":"solid","strokeWidth":1,"version":121,"roundness":{"type":3},"type":"rectangle","updated":1772748823812,"id":"7ybiBR131shiMj6Qlawqr","x":1808.8699240820786,"seed":1552847996,"boundElements":[],"y":-1793.3457143105743,"opacity":100,"height":1160,"width":1560,"frameId":null,"strokeStyle":"solid","versionNonce":1070018684},{"isDeleted":false,"locked":false,"strokeColor":"#7f1d1d","link":null,"roughness":1,"groupIds":[],"index":"bGk","backgroundColor":"#7f1d1d","angle":0,"fillStyle":"solid","strokeWidth":1,"version":121,"roundness":{"type":3},"type":"rectangle","updated":1772748823812,"id":"jZkH-ftwehR35694XKRfs","x":1808.8699240820786,"seed":993961212,"boundElements":[],"y":-1793.3457143105743,"opacity":100,"height":46,"width":1560,"frameId":null,"strokeStyle":"solid","versionNonce":1694744828},{"seed":1519953276,"strokeStyle":"solid","id":"j2WHHThAaA5Gp-qq_gCIl","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":21,"opacity":100,"verticalAlign":"top","updated":1772748823812,"locked":false,"text":"STEP 6  —  Bottleneck Identification  (be brutal)","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bGl","roundness":null,"containerId":null,"originalText":"STEP 6  —  Bottleneck Identification  (be brutal)","height":26.25,"link":null,"strokeColor":"#fef2f2","fillStyle":"solid","groupIds":[],"versionNonce":1163542908,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":2218.8699240820788,"angle":0,"y":-1780.3457143105743,"width":523.86566162109375},{"isDeleted":false,"locked":false,"strokeColor":"#f87171","link":null,"roughness":1,"groupIds":[],"index":"bGm","backgroundColor":"#fff1f2","angle":0,"fillStyle":"solid","strokeWidth":2,"version":121,"roundness":{"type":3},"type":"rectangle","updated":1772748823812,"id":"-vcVO4xIhmijybvgKmNqM","x":1808.8699240820786,"seed":1876858364,"boundElements":[],"y":-1737.3457143105743,"opacity":100,"height":188,"width":754,"frameId":null,"strokeStyle":"solid","versionNonce":1208791548},{"seed":940734076,"strokeStyle":"solid","id":"pH8K5_Agc6hJSt7gw_uji","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1772748823812,"locked":false,"text":"BN1 — Feed Query JOIN at Read Time  [I\/O-bound + CPU-bound]","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bGn","roundness":null,"containerId":null,"originalText":"BN1 — Feed Query JOIN at Read Time  [I\/O-bound + CPU-bound]","height":18.75,"link":null,"strokeColor":"#b91c1c","fillStyle":"solid","groupIds":[],"versionNonce":471667324,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1822.8699240820786,"angle":0,"y":-1725.3457143105743,"width":489.23968505859375},{"seed":2146846460,"strokeStyle":"solid","id":"Ah8kL1utyFKNZAHe8mRB4","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772748823812,"locked":false,"text":"PostgreSQL fan-in JOIN across posts+follows at 232K QPS.\n500 followees x 232K QPS = 116M index ops\/sec needed.\nPostgreSQL ceiling: ~50K complex reads\/sec on one instance.\nThreshold: breaks at ~500 concurrent users (~50K DAU).\nRoot cause: no precomputed feed — every read recomputes the\nfull merge from scratch, work cannot be amortized across users.","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bGo","roundness":null,"containerId":null,"originalText":"PostgreSQL fan-in JOIN across posts+follows at 232K QPS.\n500 followees x 232K QPS = 116M index ops\/sec needed.\nPostgreSQL ceiling: ~50K complex reads\/sec on one instance.\nThreshold: breaks at ~500 concurrent users (~50K DAU).\nRoot cause: no precomputed feed — every read recomputes the\nfull merge from scratch, work cannot be amortized across users.","height":97.5,"link":null,"strokeColor":"#334155","fillStyle":"solid","groupIds":[],"versionNonce":1078813436,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1822.8699240820786,"angle":0,"y":-1700.3457143105743,"width":406.23638916015625},{"isDeleted":false,"locked":false,"strokeColor":"#f87171","link":null,"roughness":1,"groupIds":[],"index":"bGp","backgroundColor":"#fff1f2","angle":0,"fillStyle":"solid","strokeWidth":2,"version":121,"roundness":{"type":3},"type":"rectangle","updated":1772748823812,"id":"1eEZqJQLf_NSwUF6dQZSP","x":2580.8699240820788,"seed":738985852,"boundElements":[],"y":-1737.3457143105743,"opacity":100,"height":188,"width":788,"frameId":null,"strokeStyle":"solid","versionNonce":186622844},{"seed":1083553788,"strokeStyle":"solid","id":"0eL7vWIzhfZ2vdi5qDYYm","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1772748823812,"locked":false,"text":"BN2 — Single PostgreSQL Writer  [I\/O + Coordination-bound]","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bGq","roundness":null,"containerId":null,"originalText":"BN2 — Single PostgreSQL Writer  [I\/O + Coordination-bound]","height":18.75,"link":null,"strokeColor":"#b91c1c","fillStyle":"solid","groupIds":[],"versionNonce":852874236,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":2594.8699240820788,"angle":0,"y":-1725.3457143105743,"width":456.209716796875},{"seed":1771395196,"strokeStyle":"solid","id":"JG-aWlU7YD2ek0XSRa6oC","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772748823812,"locked":false,"text":"Single writer hits ~5K TPS ceiling under like+post+follow load.\n464K like\/sec as UPDATE posts SET likes=likes+1\n= serialized row-level lock contention on hot post rows.\nThreshold: breaks at ~5K writes\/sec.\nRoot cause: row-level lock on a single hot row serializes ALL\nlike writes. Impossible to shard without app-layer changes.","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bGr","roundness":null,"containerId":null,"originalText":"Single writer hits ~5K TPS ceiling under like+post+follow load.\n464K like\/sec as UPDATE posts SET likes=likes+1\n= serialized row-level lock contention on hot post rows.\nThreshold: breaks at ~5K writes\/sec.\nRoot cause: row-level lock on a single hot row serializes ALL\nlike writes. Impossible to shard without app-layer changes.","height":97.5,"link":null,"strokeColor":"#334155","fillStyle":"solid","groupIds":[],"versionNonce":1433531516,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":2594.8699240820788,"angle":0,"y":-1700.3457143105743,"width":392.8465576171875},{"isDeleted":false,"locked":false,"strokeColor":"#fcd34d","link":null,"roughness":1,"groupIds":[],"index":"bGs","backgroundColor":"#fffbeb","angle":0,"fillStyle":"solid","strokeWidth":2,"version":121,"roundness":{"type":3},"type":"rectangle","updated":1772748823812,"id":"XVk5LyqccxyAUIXmIUjs0","x":1808.8699240820786,"seed":46983420,"boundElements":[],"y":-1537.3457143105743,"opacity":100,"height":178,"width":754,"frameId":null,"strokeStyle":"solid","versionNonce":11928828},{"seed":532572540,"strokeStyle":"solid","id":"wZDG56OCy47nj7i8hAecw","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1772748823812,"locked":false,"text":"BN3 — Zero Cache Layer  [I\/O-bound]","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bGt","roundness":null,"containerId":null,"originalText":"BN3 — Zero Cache Layer  [I\/O-bound]","height":18.75,"link":null,"strokeColor":"#b45309","fillStyle":"solid","groupIds":[],"versionNonce":975439228,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1822.8699240820786,"angle":0,"y":-1525.3457143105743,"width":288.22482299804688},{"seed":330029564,"strokeStyle":"solid","id":"vY3oLx3iCVhaNZtZ_MiQY","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772748823812,"locked":false,"text":"100% of 232K peak QPS hits PostgreSQL disk I\/O directly.\nSSD random read ceiling ~50K-100K IOPS. Need 232K min.\nThreshold: breaks at >5K DAU — any meaningful traffic.\nRoot cause: feeds are highly cacheable (same user sees same\nfeed for 30-60s) but we recompute from scratch every request.\nFeeds are read 100x more than they change — obvious cache target.","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bGu","roundness":null,"containerId":null,"originalText":"100% of 232K peak QPS hits PostgreSQL disk I\/O directly.\nSSD random read ceiling ~50K-100K IOPS. Need 232K min.\nThreshold: breaks at >5K DAU — any meaningful traffic.\nRoot cause: feeds are highly cacheable (same user sees same\nfeed for 30-60s) but we recompute from scratch every request.\nFeeds are read 100x more than they change — obvious cache target.","height":97.5,"link":null,"strokeColor":"#334155","fillStyle":"solid","groupIds":[],"versionNonce":117306876,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1822.8699240820786,"angle":0,"y":-1500.3457143105743,"width":438.4635009765625},{"isDeleted":false,"locked":false,"strokeColor":"#fcd34d","link":null,"roughness":1,"groupIds":[],"index":"bGv","backgroundColor":"#fffbeb","angle":0,"fillStyle":"solid","strokeWidth":2,"version":121,"roundness":{"type":3},"type":"rectangle","updated":1772748823812,"id":"NAVBPWaEjNaGEXoKfa683","x":2580.8699240820788,"seed":2039954044,"boundElements":[],"y":-1537.3457143105743,"opacity":100,"height":178,"width":788,"frameId":null,"strokeStyle":"solid","versionNonce":1950733948},{"seed":1010993916,"strokeStyle":"solid","id":"NeVqt0kkfmNU0WiDncjIJ","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1772748823812,"locked":false,"text":"BN4 — Single API Server  [CPU + Network-bound]","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bGw","roundness":null,"containerId":null,"originalText":"BN4 — Single API Server  [CPU + Network-bound]","height":18.75,"link":null,"strokeColor":"#b45309","fillStyle":"solid","groupIds":[],"versionNonce":515745532,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":2594.8699240820788,"angle":0,"y":-1525.3457143105743,"width":367.60476684570312},{"seed":506448764,"strokeStyle":"solid","id":"RuYr5CpaISaBFq-hmV015","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772748823812,"locked":false,"text":"Single monolith process handles ~2-5K QPS max before\nthread pool exhaustion and GC pressure kick in.\nAt 232K peak QPS we need 100+ API nodes.\nThreshold: breaks at ~5K QPS (~500K DAU).\nRoot cause: no load balancer, no horizontal scaling.\nFeed read spikes starve post-write threads — no isolation.","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bGx","roundness":null,"containerId":null,"originalText":"Single monolith process handles ~2-5K QPS max before\nthread pool exhaustion and GC pressure kick in.\nAt 232K peak QPS we need 100+ API nodes.\nThreshold: breaks at ~5K QPS (~500K DAU).\nRoot cause: no load balancer, no horizontal scaling.\nFeed read spikes starve post-write threads — no isolation.","height":97.5,"link":null,"strokeColor":"#334155","fillStyle":"solid","groupIds":[],"versionNonce":988243836,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":2594.8699240820788,"angle":0,"y":-1500.3457143105743,"width":377.194580078125},{"isDeleted":false,"locked":false,"strokeColor":"#f87171","link":null,"roughness":1,"groupIds":[],"index":"bGy","backgroundColor":"#fff1f2","angle":0,"fillStyle":"solid","strokeWidth":2,"version":121,"roundness":{"type":3},"type":"rectangle","updated":1772748823812,"id":"aycnZqAxqgIhbx2SqzCmj","x":1808.8699240820786,"seed":1101069308,"boundElements":[],"y":-1347.3457143105743,"opacity":100,"height":188,"width":754,"frameId":null,"strokeStyle":"solid","versionNonce":486873084},{"seed":815275132,"strokeStyle":"solid","id":"8XDH9DOiQDwCXeSQ5G2jQ","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1772748823812,"locked":false,"text":"BN5 — Celebrity Fan-out at Read Time  [Dependency-bound]","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bGz","roundness":null,"containerId":null,"originalText":"BN5 — Celebrity Fan-out at Read Time  [Dependency-bound]","height":18.75,"link":null,"strokeColor":"#b91c1c","fillStyle":"solid","groupIds":[],"versionNonce":1092139132,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1822.8699240820786,"angle":0,"y":-1335.3457143105743,"width":449.39974975585938},{"seed":1691823356,"strokeStyle":"solid","id":"BNehGmMlmnfE74PzoSoCB","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772748823812,"locked":false,"text":"No precomputed feeds: every one of celebrity's 10M followers\nrecomputes the full merge independently at their read time.\n10M followers x 10 opens\/day = 100M DB queries\/day per celebrity.\nThreshold: breaks at >100K followers on any single account.\nRoot cause: work is not amortized. Fan-out-on-write does the merge\nONCE at post time. Pull model repeats it 100M times per day.","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bH0","roundness":null,"containerId":null,"originalText":"No precomputed feeds: every one of celebrity's 10M followers\nrecomputes the full merge independently at their read time.\n10M followers x 10 opens\/day = 100M DB queries\/day per celebrity.\nThreshold: breaks at >100K followers on any single account.\nRoot cause: work is not amortized. Fan-out-on-write does the merge\nONCE at post time. Pull model repeats it 100M times per day.","height":97.5,"link":null,"strokeColor":"#334155","fillStyle":"solid","groupIds":[],"versionNonce":1390692604,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1822.8699240820786,"angle":0,"y":-1310.3457143105743,"width":437.69647216796875},{"isDeleted":false,"locked":false,"strokeColor":"#fcd34d","link":null,"roughness":1,"groupIds":[],"index":"bH1","backgroundColor":"#fffbeb","angle":0,"fillStyle":"solid","strokeWidth":2,"version":121,"roundness":{"type":3},"type":"rectangle","updated":1772748823812,"id":"TXkUfVGjD2nXR8YC_Vo5t","x":2580.8699240820788,"seed":1340091772,"boundElements":[],"y":-1347.3457143105743,"opacity":100,"height":188,"width":788,"frameId":null,"strokeStyle":"solid","versionNonce":904513916},{"seed":1660231164,"strokeStyle":"solid","id":"81OKj5jnrEo-JaFpETiYJ","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1772748823812,"locked":false,"text":"BN6 — Sync Media Upload in API Thread  [I\/O + Network-bound]","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bH2","roundness":null,"containerId":null,"originalText":"BN6 — Sync Media Upload in API Thread  [I\/O + Network-bound]","height":18.75,"link":null,"strokeColor":"#b45309","fillStyle":"solid","groupIds":[],"versionNonce":225131004,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":2594.8699240820788,"angle":0,"y":-1335.3457143105743,"width":485.11468505859375},{"seed":387448444,"strokeStyle":"solid","id":"ykwE63reGQXGE7YKyxhv0","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772748823812,"locked":false,"text":"API thread held open during full media upload to S3.\n10MB video on 5Mbps mobile = 16 seconds of blocking.\nWith 100-thread pool: 7 concurrent uploads starve all traffic.\nThreshold: breaks at 10-20 simultaneous uploads.\nRoot cause: slow synchronous I\/O in the request hot path.\nFix: presigned S3 URLs — client uploads direct, API just stores URL.","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bH3","roundness":null,"containerId":null,"originalText":"API thread held open during full media upload to S3.\n10MB video on 5Mbps mobile = 16 seconds of blocking.\nWith 100-thread pool: 7 concurrent uploads starve all traffic.\nThreshold: breaks at 10-20 simultaneous uploads.\nRoot cause: slow synchronous I\/O in the request hot path.\nFix: presigned S3 URLs — client uploads direct, API just stores URL.","height":97.5,"link":null,"strokeColor":"#334155","fillStyle":"solid","groupIds":[],"versionNonce":1147837052,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":2594.8699240820788,"angle":0,"y":-1310.3457143105743,"width":442.51959228515625},{"isDeleted":false,"locked":false,"strokeColor":"#a78bfa","link":null,"roughness":1,"groupIds":[],"index":"bH4","backgroundColor":"#f5f3ff","angle":0,"fillStyle":"solid","strokeWidth":2,"version":121,"roundness":{"type":3},"type":"rectangle","updated":1772748823812,"id":"OhfNaJYDqv5xLebnNMvuq","x":1808.8699240820786,"seed":1963642620,"boundElements":[],"y":-1147.3457143105743,"opacity":100,"height":168,"width":1560,"frameId":null,"strokeStyle":"solid","versionNonce":363457276},{"seed":491753340,"strokeStyle":"solid","id":"IukyW8d1yjrDiev9PdPiT","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1772748823812,"locked":false,"text":"BN7 — No Workload Isolation: All Traffic Competes on One DB  [State-bound + Coordination-bound]","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bH5","roundness":null,"containerId":null,"originalText":"BN7 — No Workload Isolation: All Traffic Competes on One DB  [State-bound + Coordination-bound]","height":18.75,"link":null,"strokeColor":"#6d28d9","fillStyle":"solid","groupIds":[],"versionNonce":329984892,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1822.8699240820786,"angle":0,"y":-1135.3457143105743,"width":738.95965576171875},{"seed":1344815100,"strokeStyle":"solid","id":"DG6hJ3kLUgufprPOlLzYY","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772748823812,"locked":false,"text":"Follow\/unfollow, feed reads, like writes, post writes all compete for the same PostgreSQL connection pool (100-200 conns)\nand same disk I\/O budget. A viral post causing like spikes starves feed read connections entirely.\nUnfollow needs strong consistency (must read primary) but competes with eventual-ok feed reads on same instance.\nThreshold: visible at ~50K DAU. Critical at ~500K DAU.\nRoot cause: different workloads need different infra — OLTP writes, graph traversal, and cache-population\nhave completely different access patterns. One DB cannot serve all optimally.","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bH6","roundness":null,"containerId":null,"originalText":"Follow\/unfollow, feed reads, like writes, post writes all compete for the same PostgreSQL connection pool (100-200 conns)\nand same disk I\/O budget. A viral post causing like spikes starves feed read connections entirely.\nUnfollow needs strong consistency (must read primary) but competes with eventual-ok feed reads on same instance.\nThreshold: visible at ~50K DAU. Critical at ~500K DAU.\nRoot cause: different workloads need different infra — OLTP writes, graph traversal, and cache-population\nhave completely different access patterns. One DB cannot serve all optimally.","height":97.5,"link":null,"strokeColor":"#334155","fillStyle":"solid","groupIds":[],"versionNonce":816864252,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1822.8699240820786,"angle":0,"y":-1110.3457143105743,"width":783.45703125},{"isDeleted":false,"locked":false,"strokeColor":"#1e3a5f","link":null,"roughness":1,"groupIds":[],"index":"bH7","backgroundColor":"#1e3a5f","angle":0,"fillStyle":"solid","strokeWidth":1,"version":121,"roundness":{"type":3},"type":"rectangle","updated":1772748823812,"id":"77lY_h-OU-lyArcflrtjv","x":1808.8699240820786,"seed":1972822140,"boundElements":[],"y":-967.34571431057429,"opacity":100,"height":80,"width":1560,"frameId":null,"strokeStyle":"solid","versionNonce":1186692220},{"seed":626880764,"strokeStyle":"solid","id":"ML7sB-Yl0DxOm8DH8p9ES","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1772748823812,"locked":false,"text":"Fix Priority Order  (Step 7 addresses these one by one):","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bH8","roundness":null,"containerId":null,"originalText":"Fix Priority Order  (Step 7 addresses these one by one):","height":18.75,"link":null,"strokeColor":"#93c5fd","fillStyle":"solid","groupIds":[],"versionNonce":529435900,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1822.8699240820786,"angle":0,"y":-955.34571431057429,"width":418.57470703125},{"seed":788394364,"strokeStyle":"solid","id":"mf5uuiUE3n-jTrAnxvdCR","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772748823812,"locked":false,"text":"1) Redis feed cache (fixes BN1+BN3)   2) Horizontal API + LB (BN4)   3) Kafka + fan-out workers (BN5)   4) Redis INCR for likes (BN2)   5) Presigned S3 URLs (BN6)   6) Separate social graph store (BN7)","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bH9","roundness":null,"containerId":null,"originalText":"1) Redis feed cache (fixes BN1+BN3)   2) Horizontal API + LB (BN4)   3) Kafka + fan-out workers (BN5)   4) Redis INCR for likes (BN2)   5) Presigned S3 URLs (BN6)   6) Separate social graph store (BN7)","height":17.5,"link":null,"strokeColor":"#f1f5f9","fillStyle":"solid","groupIds":[],"versionNonce":2091617660,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1822.8699240820786,"angle":0,"y":-931.34571431057429,"width":1425.855712890625},{"isDeleted":false,"locked":false,"strokeColor":"#cbd5e1","link":null,"roughness":1,"groupIds":[],"index":"bHA","backgroundColor":"#f8fafc","angle":0,"fillStyle":"solid","strokeWidth":1,"version":121,"roundness":{"type":3},"type":"rectangle","updated":1772748823812,"id":"M5j3Tose-yT1TPqy4tugy","x":1808.8699240820786,"seed":565862908,"boundElements":[],"y":-853.34571431057429,"opacity":100,"height":1220,"width":1560,"frameId":null,"strokeStyle":"solid","versionNonce":525630972},{"isDeleted":false,"locked":false,"strokeColor":"#7f1d1d","link":null,"roughness":1,"groupIds":[],"index":"bHB","backgroundColor":"#7f1d1d","angle":0,"fillStyle":"solid","strokeWidth":1,"version":121,"roundness":{"type":3},"type":"rectangle","updated":1772748823812,"id":"Y5bDlvMeietIZ2RqC5rgU","x":1808.8699240820786,"seed":1419035260,"boundElements":[],"y":-853.34571431057429,"opacity":100,"height":46,"width":1560,"frameId":null,"strokeStyle":"solid","versionNonce":1351310972},{"seed":1850675964,"strokeStyle":"solid","id":"YygVeD7_qV0EC080-wW3j","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":21,"opacity":100,"verticalAlign":"top","updated":1772748823812,"locked":false,"text":"STEP 7  —  Progressive Architecture Evolution  (V1 to V7)","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bHC","roundness":null,"containerId":null,"originalText":"STEP 7  —  Progressive Architecture Evolution  (V1 to V7)","height":26.25,"link":null,"strokeColor":"#fef2f2","fillStyle":"solid","groupIds":[],"versionNonce":1762799356,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":2188.8699240820788,"angle":0,"y":-840.34571431057429,"width":610.74273681640625},{"isDeleted":false,"locked":false,"strokeColor":"#93c5fd","link":null,"roughness":1,"groupIds":[],"index":"bHD","backgroundColor":"#eff6ff","angle":0,"fillStyle":"solid","strokeWidth":1,"version":121,"roundness":{"type":3},"type":"rectangle","updated":1772748823812,"id":"WkLXzZO6QuxUz9cWg_QHW","x":1808.8699240820786,"seed":1835750268,"boundElements":[],"y":-797.34571431057429,"opacity":100,"height":148,"width":1560,"frameId":null,"strokeStyle":"solid","versionNonce":1500180348},{"seed":808158204,"strokeStyle":"solid","id":"xf80ey35zzWaaKhG_kyvm","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1772748823812,"locked":false,"text":"V1 — Read Replicas + Connection Pooling   [ceiling: ~100K DAU]","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bHE","roundness":null,"containerId":null,"originalText":"V1 — Read Replicas + Connection Pooling   [ceiling: ~100K DAU]","height":18.75,"link":null,"strokeColor":"#1d4ed8","fillStyle":"solid","groupIds":[],"versionNonce":836214780,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1822.8699240820786,"angle":0,"y":-785.34571431057429,"width":467.009765625},{"seed":2089919612,"strokeStyle":"solid","id":"9bsYgGzppPkFXT3F28Ngd","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772748823812,"locked":false,"text":"Fixes BN3+BN4 (partial). Added: 2 PostgreSQL read replicas + PgBouncer. Route all SELECTs to replicas, writes to primary.\nAPI servers now pooled behind nginx\/HAProxy round-robin. PgBouncer multiplexes 1000s of app connections into 100 DB connections.\nNew tradeoff: replica lag (~10-50ms) means unfollow may not be reflected immediately on replica reads (RYOW violation).","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bHF","roundness":null,"containerId":null,"originalText":"Fixes BN3+BN4 (partial). Added: 2 PostgreSQL read replicas + PgBouncer. Route all SELECTs to replicas, writes to primary.\nAPI servers now pooled behind nginx\/HAProxy round-robin. PgBouncer multiplexes 1000s of app connections into 100 DB connections.\nNew tradeoff: replica lag (~10-50ms) means unfollow may not be reflected immediately on replica reads (RYOW violation).","height":48.75,"link":null,"strokeColor":"#334155","fillStyle":"solid","groupIds":[],"versionNonce":710557820,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1822.8699240820786,"angle":0,"y":-761.34571431057429,"width":850.10821533203125},{"seed":140489980,"strokeStyle":"solid","id":"qK2-kCHCxEHvAQSC8_ucP","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772748823812,"locked":false,"text":"New failure: replica lag spike during\nprimary write burst causes stale feed.","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bHG","roundness":null,"containerId":null,"originalText":"New failure: replica lag spike during\nprimary write burst causes stale feed.","height":32.5,"link":null,"strokeColor":"#64748b","fillStyle":"solid","groupIds":[],"versionNonce":716493052,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":2998.8699240820783,"angle":0,"y":-785.34571431057429,"width":241.78668212890625},{"isDeleted":false,"locked":false,"strokeColor":"#86efac","link":null,"roughness":1,"groupIds":[],"index":"bHH","backgroundColor":"#f0fdf4","angle":0,"fillStyle":"solid","strokeWidth":1,"version":121,"roundness":{"type":3},"type":"rectangle","updated":1772748823812,"id":"Ofb0LGprNlEmMun_9SC4S","x":1808.8699240820786,"seed":18331004,"boundElements":[],"y":-639.34571431057429,"opacity":100,"height":158,"width":1560,"frameId":null,"strokeStyle":"solid","versionNonce":1382633852},{"seed":335259132,"strokeStyle":"solid","id":"Eng11bTYUKmyWBkEUMURB","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1772748823812,"locked":false,"text":"V2 — Redis Feed Cache + Horizontal Stateless API Fleet   [ceiling: ~1M DAU]","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bHI","roundness":null,"containerId":null,"originalText":"V2 — Redis Feed Cache + Horizontal Stateless API Fleet   [ceiling: ~1M DAU]","height":18.75,"link":null,"strokeColor":"#15803d","fillStyle":"solid","groupIds":[],"versionNonce":12173820,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1822.8699240820786,"angle":0,"y":-627.34571431057429,"width":573.1947021484375},{"seed":1980597884,"strokeStyle":"solid","id":"knFXKHtpjx6DnKestJp3y","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772748823812,"locked":false,"text":"Fixes BN1+BN3+BN4. Added: Redis cluster (6 nodes). On post create, API writes post_id into each follower's\nfeed sorted set in Redis (ZADD). Feed read = ZREVRANGEBYSCORE — pure O(1) Redis lookup.\nAPI tier now 50+ stateless nodes. Cache miss falls through to DB and populates Redis.\nNew tradeoff: fan-out still synchronous in API thread — celebrity post (10M followers) = 10M Redis writes inline. Blocks for seconds.","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bHJ","roundness":null,"containerId":null,"originalText":"Fixes BN1+BN3+BN4. Added: Redis cluster (6 nodes). On post create, API writes post_id into each follower's\nfeed sorted set in Redis (ZADD). Feed read = ZREVRANGEBYSCORE — pure O(1) Redis lookup.\nAPI tier now 50+ stateless nodes. Cache miss falls through to DB and populates Redis.\nNew tradeoff: fan-out still synchronous in API thread — celebrity post (10M followers) = 10M Redis writes inline. Blocks for seconds.","height":65,"link":null,"strokeColor":"#334155","fillStyle":"solid","groupIds":[],"versionNonce":1554522748,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1822.8699240820786,"angle":0,"y":-603.34571431057429,"width":849.61419677734375},{"seed":1812944636,"strokeStyle":"solid","id":"blnv6njmtnqTAhPVsOnI3","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772748823812,"locked":false,"text":"New failure: Redis cluster eviction\nunder memory pressure spikes DB\nload as all cache misses hit at once.","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bHK","roundness":null,"containerId":null,"originalText":"New failure: Redis cluster eviction\nunder memory pressure spikes DB\nload as all cache misses hit at once.","height":48.75,"link":null,"strokeColor":"#64748b","fillStyle":"solid","groupIds":[],"versionNonce":1559655164,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":2998.8699240820783,"angle":0,"y":-627.34571431057429,"width":229.39768981933594},{"isDeleted":false,"locked":false,"strokeColor":"#eab308","link":null,"roughness":1,"groupIds":[],"index":"bHL","backgroundColor":"#fef9c3","angle":0,"fillStyle":"solid","strokeWidth":1,"version":121,"roundness":{"type":3},"type":"rectangle","updated":1772748823812,"id":"pxTdYhs8xBKHPTGY9Rbb4","x":1808.8699240820786,"seed":1384322940,"boundElements":[],"y":-471.34571431057429,"opacity":100,"height":158,"width":1560,"frameId":null,"strokeStyle":"solid","versionNonce":1344713596},{"seed":631949308,"strokeStyle":"solid","id":"6uH6i2Km6HtOXLkow_Snk","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1772748823813,"locked":false,"text":"V3 — Kafka + Async Fan-out Workers   [ceiling: ~10M DAU]","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bHM","roundness":null,"containerId":null,"originalText":"V3 — Kafka + Async Fan-out Workers   [ceiling: ~10M DAU]","height":18.75,"link":null,"strokeColor":"#713f12","fillStyle":"solid","groupIds":[],"versionNonce":1685775356,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1822.8699240820786,"angle":0,"y":-459.34571431057429,"width":433.90472412109375},{"seed":159934588,"strokeStyle":"solid","id":"avcpquLQ_ABqTcW0BBI6C","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772748823813,"locked":false,"text":"Fixes BN5. Added: Kafka cluster (post_created topic). On post create, API publishes ONE event to Kafka and returns 200 immediately.\n150 fan-out workers consume from Kafka, look up follower list in Cassandra, write to each follower Redis feed sorted set.\nMechanism: post creation is O(1) from API perspective. Workers partitioned by author user_id for ordering guarantee.\nNew tradeoff: feed propagation now eventually consistent — follower may not see new post for up to 30 seconds.","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bHN","roundness":null,"containerId":null,"originalText":"Fixes BN5. Added: Kafka cluster (post_created topic). On post create, API publishes ONE event to Kafka and returns 200 immediately.\n150 fan-out workers consume from Kafka, look up follower list in Cassandra, write to each follower Redis feed sorted set.\nMechanism: post creation is O(1) from API perspective. Workers partitioned by author user_id for ordering guarantee.\nNew tradeoff: feed propagation now eventually consistent — follower may not see new post for up to 30 seconds.","height":65,"link":null,"strokeColor":"#334155","fillStyle":"solid","groupIds":[],"versionNonce":804586620,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1822.8699240820786,"angle":0,"y":-435.34571431057429,"width":866.3321533203125},{"seed":1373501692,"strokeStyle":"solid","id":"w8vxfllqbvUCMaog6vn-4","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772748823813,"locked":false,"text":"New failure: Kafka consumer lag\nbuilds under traffic spike — delayed\nfeed. DLQ needed for poison pills.","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bHO","roundness":null,"containerId":null,"originalText":"New failure: Kafka consumer lag\nbuilds under traffic spike — delayed\nfeed. DLQ needed for poison pills.","height":48.75,"link":null,"strokeColor":"#64748b","fillStyle":"solid","groupIds":[],"versionNonce":945231100,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":2998.8699240820783,"angle":0,"y":-459.34571431057429,"width":226.771728515625},{"isDeleted":false,"locked":false,"strokeColor":"#d8b4fe","link":null,"roughness":1,"groupIds":[],"index":"bHP","backgroundColor":"#fdf4ff","angle":0,"fillStyle":"solid","strokeWidth":1,"version":121,"roundness":{"type":3},"type":"rectangle","updated":1772748823813,"id":"T6pUlV32-ABoizLOESQiP","x":1808.8699240820786,"seed":170752380,"boundElements":[],"y":-303.34571431057429,"opacity":100,"height":148,"width":1560,"frameId":null,"strokeStyle":"solid","versionNonce":2065896828},{"seed":2109270524,"strokeStyle":"solid","id":"PnVmn1MpRAIdgOjRk7Flk","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1772748823813,"locked":false,"text":"V4 — Redis INCR for Like Counters + Async DB Flush   [ceiling: ~50M DAU]","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bHQ","roundness":null,"containerId":null,"originalText":"V4 — Redis INCR for Like Counters + Async DB Flush   [ceiling: ~50M DAU]","height":18.75,"link":null,"strokeColor":"#7e22ce","fillStyle":"solid","groupIds":[],"versionNonce":1973093884,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1822.8699240820786,"angle":0,"y":-291.34571431057429,"width":560.21966552734375},{"seed":1065503356,"strokeStyle":"solid","id":"LGxmmCHwYhsIP8NYllnYY","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772748823813,"locked":false,"text":"Fixes BN2. Like events go to Redis INCR on key like_count:{post_id} instead of DB UPDATE.\nLike flusher service consumes in batches every 30s and writes aggregated counts to DB.\nLike dedup: SADD liked_by:{post_id} {user_id} — returns 0 if already liked. Atomic, no race condition.\nNew tradeoff: like counts in DB stale by up to 30s. Redis node failure loses recent counts since last flush.","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bHR","roundness":null,"containerId":null,"originalText":"Fixes BN2. Like events go to Redis INCR on key like_count:{post_id} instead of DB UPDATE.\nLike flusher service consumes in batches every 30s and writes aggregated counts to DB.\nLike dedup: SADD liked_by:{post_id} {user_id} — returns 0 if already liked. Atomic, no race condition.\nNew tradeoff: like counts in DB stale by up to 30s. Redis node failure loses recent counts since last flush.","height":65,"link":null,"strokeColor":"#334155","fillStyle":"solid","groupIds":[],"versionNonce":750839420,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1822.8699240820786,"angle":0,"y":-267.34571431057429,"width":681.97930908203125},{"seed":843815676,"strokeStyle":"solid","id":"jcBmeBVfRxsum2zSgYkgA","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772748823813,"locked":false,"text":"New failure: Redis node failure loses\nlike counts since last DB flush.\nNeeds Redis AOF persistence.","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bHS","roundness":null,"containerId":null,"originalText":"New failure: Redis node failure loses\nlike counts since last DB flush.\nNeeds Redis AOF persistence.","height":48.75,"link":null,"strokeColor":"#64748b","fillStyle":"solid","groupIds":[],"versionNonce":894875388,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":2998.8699240820783,"angle":0,"y":-291.34571431057429,"width":227.95469665527344},{"isDeleted":false,"locked":false,"strokeColor":"#06b6d4","link":null,"roughness":1,"groupIds":[],"index":"bHT","backgroundColor":"#cffafe","angle":0,"fillStyle":"solid","strokeWidth":1,"version":121,"roundness":{"type":3},"type":"rectangle","updated":1772748823813,"id":"RpXsoQV0H66X9v7P7SrOF","x":1808.8699240820786,"seed":278322044,"boundElements":[],"y":-145.34571431057429,"opacity":100,"height":148,"width":1560,"frameId":null,"strokeStyle":"solid","versionNonce":1004435324},{"seed":1957039100,"strokeStyle":"solid","id":"yVuyXMcdqVpxyclYx7iA3","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1772748823813,"locked":false,"text":"V5 — Presigned S3 URLs + Async Media Transcoding   [ceiling: ~100M DAU]","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bHU","roundness":null,"containerId":null,"originalText":"V5 — Presigned S3 URLs + Async Media Transcoding   [ceiling: ~100M DAU]","height":18.75,"link":null,"strokeColor":"#0e7490","fillStyle":"solid","groupIds":[],"versionNonce":211429372,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1822.8699240820786,"angle":0,"y":-133.34571431057429,"width":555.1947021484375},{"seed":1618685052,"strokeStyle":"solid","id":"ldP35Ik2gHOXhdVPolnnJ","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772748823813,"locked":false,"text":"Fixes BN6. Client requests presigned S3 URL from API (fast, <10ms). Client uploads directly to S3 — API thread freed immediately.\nMedia upload triggers S3 event → SQS → transcoding workers (FFmpeg). Post stored with status=media_pending.\nPost moves from media_pending to published once transcoder writes CDN URLs back. Feed filters media_pending posts.\nNew tradeoff: post publish delayed by transcoding (5-60s for video). User sees processing state. More moving parts.","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bHV","roundness":null,"containerId":null,"originalText":"Fixes BN6. Client requests presigned S3 URL from API (fast, <10ms). Client uploads directly to S3 — API thread freed immediately.\nMedia upload triggers S3 event → SQS → transcoding workers (FFmpeg). Post stored with status=media_pending.\nPost moves from media_pending to published once transcoder writes CDN URLs back. Feed filters media_pending posts.\nNew tradeoff: post publish delayed by transcoding (5-60s for video). User sees processing state. More moving parts.","height":65,"link":null,"strokeColor":"#334155","fillStyle":"solid","groupIds":[],"versionNonce":462145660,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1822.8699240820786,"angle":0,"y":-109.34571431057429,"width":839.65618896484375},{"isDeleted":false,"locked":false,"strokeColor":"#fca5a5","link":null,"roughness":1,"groupIds":[],"index":"bHW","backgroundColor":"#fff1f2","angle":0,"fillStyle":"solid","strokeWidth":1,"version":121,"roundness":{"type":3},"type":"rectangle","updated":1772748823813,"id":"riLHEGA1FK206XmuQKHLz","x":1808.8699240820786,"seed":1171799292,"boundElements":[],"y":12.654285689425706,"opacity":100,"height":158,"width":1560,"frameId":null,"strokeStyle":"solid","versionNonce":209017084},{"seed":239025532,"strokeStyle":"solid","id":"jved8dxcI-kEKBtXKS-Cx","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1772748823813,"locked":false,"text":"V6 — Hybrid Fan-out: Write for Normals, Read for Celebrities   [ceiling: ~500M DAU]","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bHX","roundness":null,"containerId":null,"originalText":"V6 — Hybrid Fan-out: Write for Normals, Read for Celebrities   [ceiling: ~500M DAU]","height":18.75,"link":null,"strokeColor":"#b91c1c","fillStyle":"solid","groupIds":[],"versionNonce":987289980,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1822.8699240820786,"angle":0,"y":24.654285689425706,"width":619.91961669921875},{"seed":586296828,"strokeStyle":"solid","id":"YA3ZldK7y8o3RwLqzJV1y","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772748823813,"locked":false,"text":"Fixes BN5 at mega-scale. Fan-out workers check follower count. If author <1M followers: fan-out-on-write (push to caches).\nIf author >1M followers: skip fan-out. Store post in celebrity_posts table only.\nAt read time: fetch precomputed Redis cache AND query celebrity_posts for all celebrities followed, merge by ranking score.\nNew tradeoff: read path has conditional complexity. Must maintain celebrity_list per user. 1M threshold is a tunable magic number.","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bHY","roundness":null,"containerId":null,"originalText":"Fixes BN5 at mega-scale. Fan-out workers check follower count. If author <1M followers: fan-out-on-write (push to caches).\nIf author >1M followers: skip fan-out. Store post in celebrity_posts table only.\nAt read time: fetch precomputed Redis cache AND query celebrity_posts for all celebrities followed, merge by ranking score.\nNew tradeoff: read path has conditional complexity. Must maintain celebrity_list per user. 1M threshold is a tunable magic number.","height":65,"link":null,"strokeColor":"#334155","fillStyle":"solid","groupIds":[],"versionNonce":1106790908,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1822.8699240820786,"angle":0,"y":48.654285689425706,"width":819.3111572265625},{"seed":1962086012,"strokeStyle":"solid","id":"NRZkQHwPUxpTMI9q8DVst","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772748823813,"locked":false,"text":"New failure: celebrity_posts query\nat read time must also enforce\nprivate-account visibility rules.","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bHZ","roundness":null,"containerId":null,"originalText":"New failure: celebrity_posts query\nat read time must also enforce\nprivate-account visibility rules.","height":48.75,"link":null,"strokeColor":"#64748b","fillStyle":"solid","groupIds":[],"versionNonce":81111676,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":2998.8699240820783,"angle":0,"y":24.654285689425706,"width":214.03170776367188},{"isDeleted":false,"locked":false,"strokeColor":"#a78bfa","link":null,"roughness":1,"groupIds":[],"index":"bHa","backgroundColor":"#f5f3ff","angle":0,"fillStyle":"solid","strokeWidth":1,"version":121,"roundness":{"type":3},"type":"rectangle","updated":1772748823813,"id":"me41A32p3HpIeSxkp1iKu","x":1808.8699240820786,"seed":84139772,"boundElements":[],"y":180.65428568942571,"opacity":100,"height":148,"width":1560,"frameId":null,"strokeStyle":"solid","versionNonce":909310716},{"seed":1806081916,"strokeStyle":"solid","id":"lpvj2bRFdCg-UjKqZC0WQ","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1772748823813,"locked":false,"text":"V7 — Social Graph Isolation + DB Sharding by user_id   [ceiling: 1B+ DAU]","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bHb","roundness":null,"containerId":null,"originalText":"V7 — Social Graph Isolation + DB Sharding by user_id   [ceiling: 1B+ DAU]","height":18.75,"link":null,"strokeColor":"#6d28d9","fillStyle":"solid","groupIds":[],"versionNonce":1620196220,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1822.8699240820786,"angle":0,"y":192.65428568942571,"width":547.25970458984375},{"seed":1629310972,"strokeStyle":"solid","id":"umHV7Cx_f5RKTornwZrJI","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772748823813,"locked":false,"text":"Fixes BN7. Social graph moved to dedicated Cassandra cluster (wide-row: partition=follower_id, cols=followees).\nPosts DB sharded by user_id (10 shards x 1 primary + 2 replicas = 30 nodes). Likes DB sharded by post_id.\nCassandra 'get all followees for user X' = single partition read in ~1ms. No hot-partition on posts table.\nNew tradeoff: cross-shard transactions eliminated. No JOINs across services. App layer handles all aggregation.","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bHc","roundness":null,"containerId":null,"originalText":"Fixes BN7. Social graph moved to dedicated Cassandra cluster (wide-row: partition=follower_id, cols=followees).\nPosts DB sharded by user_id (10 shards x 1 primary + 2 replicas = 30 nodes). Likes DB sharded by post_id.\nCassandra 'get all followees for user X' = single partition read in ~1ms. No hot-partition on posts table.\nNew tradeoff: cross-shard transactions eliminated. No JOINs across services. App layer handles all aggregation.","height":65,"link":null,"strokeColor":"#334155","fillStyle":"solid","groupIds":[],"versionNonce":1848994812,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1822.8699240820786,"angle":0,"y":216.65428568942571,"width":709.0321044921875},{"isDeleted":false,"locked":false,"strokeColor":"#7f1d1d","link":null,"roughness":1,"groupIds":[],"index":"bHd","backgroundColor":"#7f1d1d","angle":0,"fillStyle":"solid","strokeWidth":1,"version":121,"roundness":{"type":3},"type":"rectangle","updated":1772748823813,"id":"1Q0AKYjZ7yKyMF-N1nHae","x":1808.8699240820786,"seed":1164570748,"boundElements":[],"y":338.65428568942571,"opacity":100,"height":50,"width":1560,"frameId":null,"strokeStyle":"solid","versionNonce":824085628},{"seed":676233468,"strokeStyle":"solid","id":"2ZA5kB9alK4G_m-ZTSGYN","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772748823813,"locked":false,"text":"V1(100K)→V2(1M)→V3(10M)→V4(50M)→V5(100M)→V6(500M)→V7(1B+)  |  Each version fixes one bottleneck and introduces one new tradeoff","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bHe","roundness":null,"containerId":null,"originalText":"V1(100K)→V2(1M)→V3(10M)→V4(50M)→V5(100M)→V6(500M)→V7(1B+)  |  Each version fixes one bottleneck and introduces one new tradeoff","height":17.5,"link":null,"strokeColor":"#fef2f2","fillStyle":"solid","groupIds":[],"versionNonce":1796185340,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1822.8699240820786,"angle":0,"y":352.65428568942571,"width":971.598876953125},{"isDeleted":false,"locked":false,"strokeColor":"#cbd5e1","link":null,"roughness":1,"groupIds":[],"index":"bHf","backgroundColor":"#f8fafc","angle":0,"fillStyle":"solid","strokeWidth":1,"version":121,"roundness":{"type":3},"type":"rectangle","updated":1772748823813,"id":"4qyQ3uOnL96U4btN4zCNX","x":1808.8699240820786,"seed":1364001148,"boundElements":[],"y":426.65428568942571,"opacity":100,"height":2050,"width":1560,"frameId":null,"strokeStyle":"solid","versionNonce":1435147644},{"isDeleted":false,"locked":false,"strokeColor":"#4c1d95","link":null,"roughness":1,"groupIds":[],"index":"bHg","backgroundColor":"#4c1d95","angle":0,"fillStyle":"solid","strokeWidth":1,"version":121,"roundness":{"type":3},"type":"rectangle","updated":1772748823813,"id":"_tJ49BJ_6Sf4gsj-GedtO","x":1808.8699240820786,"seed":1202156028,"boundElements":[],"y":426.65428568942571,"opacity":100,"height":46,"width":1560,"frameId":null,"strokeStyle":"solid","versionNonce":701599228},{"seed":1516229244,"strokeStyle":"solid","id":"NMOhNpQBPDhl30TmdDjF_","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":21,"opacity":100,"verticalAlign":"top","updated":1772748823813,"locked":false,"text":"STEP 8  —  Deep Dives  (FR2, FR3, FR5)","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bHh","roundness":null,"containerId":null,"originalText":"STEP 8  —  Deep Dives  (FR2, FR3, FR5)","height":26.25,"link":null,"strokeColor":"#f5f3ff","fillStyle":"solid","groupIds":[],"versionNonce":686190204,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":2228.8699240820788,"angle":0,"y":439.65428568942571,"width":439.92877197265625},{"isDeleted":false,"locked":false,"strokeColor":"#b91c1c","link":null,"roughness":1,"groupIds":[],"index":"bHi","backgroundColor":"#b91c1c","angle":0,"fillStyle":"solid","strokeWidth":1,"version":121,"roundness":{"type":3},"type":"rectangle","updated":1772748823813,"id":"pD4jGUNb3wTsAmy6HmYXI","x":1808.8699240820786,"seed":674767612,"boundElements":[],"y":482.65428568942571,"opacity":100,"height":40,"width":1560,"frameId":null,"strokeStyle":"solid","versionNonce":596328188},{"seed":666002300,"strokeStyle":"solid","id":"VbXNPSxHqGyp4hCInHD-a","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":17,"opacity":100,"verticalAlign":"top","updated":1772748823813,"locked":false,"text":"Deep Dive 1 — FR2: Feed Generation (Fan-out on Write)","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bHj","roundness":null,"containerId":null,"originalText":"Deep Dive 1 — FR2: Feed Generation (Fan-out on Write)","height":21.25,"link":null,"strokeColor":"#fff1f2","fillStyle":"solid","groupIds":[],"versionNonce":37879676,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1822.8699240820786,"angle":0,"y":495.65428568942571,"width":470.5086669921875},{"isDeleted":false,"locked":false,"strokeColor":"#fdba74","link":null,"roughness":1,"groupIds":[],"index":"bHk","backgroundColor":"#fff7ed","angle":0,"fillStyle":"solid","strokeWidth":1,"version":121,"roundness":{"type":3},"type":"rectangle","updated":1772748823813,"id":"57YDN1d37Xj9aLQg5YFhm","x":1808.8699240820786,"seed":789615612,"boundElements":[],"y":532.65428568942571,"opacity":100,"height":310,"width":490,"frameId":null,"strokeStyle":"solid","versionNonce":1296871420},{"seed":2085926012,"strokeStyle":"solid","id":"gCqunxwgMEWTe5NKwP_cL","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772748823813,"locked":false,"text":"A. User Journey + Latency Budget","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bHl","roundness":null,"containerId":null,"originalText":"A. User Journey + Latency Budget","height":17.5,"link":null,"strokeColor":"#c2410c","fillStyle":"solid","groupIds":[],"versionNonce":883773564,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1822.8699240820786,"angle":0,"y":544.65428568942571,"width":234.80775451660156},{"seed":1027654908,"strokeStyle":"solid","id":"FkVPa8f1Cm2ZNNhap8Yv9","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772748823813,"locked":false,"text":"1. User taps Post with text or photo\n2. Client sends POST \/posts + idempotency_key\n3. Server responds 200 in <200ms\n4. Client shows post in own feed immediately\n5. Followers see post within 5-30 seconds\n\nDuring failure:\n  Kafka down: post saved, fan-out queued\n  in DB outbox table. Publishes on recovery.\n  Worker crash mid-fan-out: retries from\n  last Kafka offset. ZADD is idempotent.\n\nLatency budget:\n  API write (save + Kafka publish): <200ms\n  Fan-out normal user (500 followers): <5s\n  Fan-out celeb (1M followers): <30s","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bHm","roundness":null,"containerId":null,"originalText":"1. User taps Post with text or photo\n2. Client sends POST \/posts + idempotency_key\n3. Server responds 200 in <200ms\n4. Client shows post in own feed immediately\n5. Followers see post within 5-30 seconds\n\nDuring failure:\n  Kafka down: post saved, fan-out queued\n  in DB outbox table. Publishes on recovery.\n  Worker crash mid-fan-out: retries from\n  last Kafka offset. ZADD is idempotent.\n\nLatency budget:\n  API write (save + Kafka publish): <200ms\n  Fan-out normal user (500 followers): <5s\n  Fan-out celeb (1M followers): <30s","height":260,"link":null,"strokeColor":"#334155","fillStyle":"solid","groupIds":[],"versionNonce":405135612,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1822.8699240820786,"angle":0,"y":568.65428568942571,"width":309.12664794921875},{"isDeleted":false,"locked":false,"strokeColor":"#86efac","link":null,"roughness":1,"groupIds":[],"index":"bHn","backgroundColor":"#f0fdf4","angle":0,"fillStyle":"solid","strokeWidth":1,"version":121,"roundness":{"type":3},"type":"rectangle","updated":1772748823813,"id":"F1vEJKafAEzzcFAj981ba","x":2316.8699240820788,"seed":391562620,"boundElements":[],"y":532.65428568942571,"opacity":100,"height":310,"width":620,"frameId":null,"strokeStyle":"solid","versionNonce":255353212},{"seed":802731516,"strokeStyle":"solid","id":"JiHHYk0ynpBb5S_gNaJ_a","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772748823813,"locked":false,"text":"B. Internal Flow (step by step)","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bHo","roundness":null,"containerId":null,"originalText":"B. Internal Flow (step by step)","height":17.5,"link":null,"strokeColor":"#15803d","fillStyle":"solid","groupIds":[],"versionNonce":1898369532,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":2330.8699240820788,"angle":0,"y":544.65428568942571,"width":215.34776306152344},{"seed":868783740,"strokeStyle":"solid","id":"h5SHFZx50Yl5fWSWUkiPo","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772748823813,"locked":false,"text":"1.  API receives POST \/posts {content, idem_key}\n2.  Check Redis: GET idem:{hash} — duplicate? Return cached.\n3.  INSERT into posts table (sync write to primary)\n4.  Publish ONE event to Kafka post_created topic\n5.  Return 200 to client  ← API is done here\n\n[Async — fan-out workers]\n6.  Worker consumes from Kafka post_created\n7.  Fetch follower list from Cassandra\n    (partition key = author_id, O(1) lookup)\n8.  For each follower: ZADD NX feed:{follower_id}\n    score=timestamp member=post_id\n    ZADD NX is idempotent — replay-safe\n9.  Commit Kafka offset after batch completes\n\nCritical path (latency): steps 1-5 only\nAsync path: steps 6-9 (not on P99 budget)","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bHp","roundness":null,"containerId":null,"originalText":"1.  API receives POST \/posts {content, idem_key}\n2.  Check Redis: GET idem:{hash} — duplicate? Return cached.\n3.  INSERT into posts table (sync write to primary)\n4.  Publish ONE event to Kafka post_created topic\n5.  Return 200 to client  ← API is done here\n\n[Async — fan-out workers]\n6.  Worker consumes from Kafka post_created\n7.  Fetch follower list from Cassandra\n    (partition key = author_id, O(1) lookup)\n8.  For each follower: ZADD NX feed:{follower_id}\n    score=timestamp member=post_id\n    ZADD NX is idempotent — replay-safe\n9.  Commit Kafka offset after batch completes\n\nCritical path (latency): steps 1-5 only\nAsync path: steps 6-9 (not on P99 budget)","height":276.25,"link":null,"strokeColor":"#334155","fillStyle":"solid","groupIds":[],"versionNonce":1559442044,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":2330.8699240820788,"angle":0,"y":568.65428568942571,"width":400.9195556640625},{"isDeleted":false,"locked":false,"strokeColor":"#93c5fd","link":null,"roughness":1,"groupIds":[],"index":"bHq","backgroundColor":"#eff6ff","angle":0,"fillStyle":"solid","strokeWidth":1,"version":121,"roundness":{"type":3},"type":"rectangle","updated":1772748823813,"id":"q2tesuUtgWnZ8ztpOXUZE","x":2954.8699240820783,"seed":1609066236,"boundElements":[],"y":532.65428568942571,"opacity":100,"height":310,"width":414,"frameId":null,"strokeStyle":"solid","versionNonce":1096778492},{"seed":146417532,"strokeStyle":"solid","id":"VCklfJkGfgPqIyE9zRFq5","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772748823813,"locked":false,"text":"C. Data Model","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bHr","roundness":null,"containerId":null,"originalText":"C. Data Model","height":17.5,"link":null,"strokeColor":"#1d4ed8","fillStyle":"solid","groupIds":[],"versionNonce":1693303676,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":2968.8699240820783,"angle":0,"y":544.65428568942571,"width":96.8939208984375},{"seed":578803708,"strokeStyle":"solid","id":"iy1dkqTe9PIREFSdykQUo","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772748823813,"locked":false,"text":"posts table:\n  post_id    UUID  PK\n  author_id  UUID  IDX\n  content    TEXT\n  media_url  TEXT\n  status     ENUM\n  created_at TIMESTAMPTZ\n  IDX: (author_id, created_at DESC)\n\nRedis feed cache:\n  Key:  feed:{user_id}\n  Type: Sorted Set\n  Member: post_id\n  Score: unix_timestamp\n  TTL:  7 days\n\nKey operations:\n  ZADD NX feed:alice 1709123 post:xyz\n  ZREVRANGEBYSCORE feed:alice\n    +inf 0 LIMIT 0 20","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bHs","roundness":null,"containerId":null,"originalText":"posts table:\n  post_id    UUID  PK\n  author_id  UUID  IDX\n  content    TEXT\n  media_url  TEXT\n  status     ENUM\n  created_at TIMESTAMPTZ\n  IDX: (author_id, created_at DESC)\n\nRedis feed cache:\n  Key:  feed:{user_id}\n  Type: Sorted Set\n  Member: post_id\n  Score: unix_timestamp\n  TTL:  7 days\n\nKey operations:\n  ZADD NX feed:alice 1709123 post:xyz\n  ZREVRANGEBYSCORE feed:alice\n    +inf 0 LIMIT 0 20","height":325,"link":null,"strokeColor":"#334155","fillStyle":"solid","groupIds":[],"versionNonce":1843393532,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":2968.8699240820783,"angle":0,"y":568.65428568942571,"width":252.94073486328125},{"isDeleted":false,"locked":false,"strokeColor":"#5b21b6","link":null,"roughness":1,"groupIds":[],"index":"bHt","backgroundColor":"#5b21b6","angle":0,"fillStyle":"solid","strokeWidth":1,"version":121,"roundness":{"type":3},"type":"rectangle","updated":1772748823813,"id":"eJLtPtOMmSOkW0FaNrlky","x":1808.8699240820786,"seed":1228634236,"boundElements":[],"y":854.65428568942571,"opacity":100,"height":40,"width":1560,"frameId":null,"strokeStyle":"solid","versionNonce":1782060156},{"seed":1219430652,"strokeStyle":"solid","id":"f9hhtFLoobu5K3R16XcXj","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":17,"opacity":100,"verticalAlign":"top","updated":1772748823813,"locked":false,"text":"Deep Dive 2 — FR3: Feed Retrieval (Hybrid Read Merge)","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bHu","roundness":null,"containerId":null,"originalText":"Deep Dive 2 — FR3: Feed Retrieval (Hybrid Read Merge)","height":21.25,"link":null,"strokeColor":"#f5f3ff","fillStyle":"solid","groupIds":[],"versionNonce":1471685884,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1822.8699240820786,"angle":0,"y":867.65428568942571,"width":469.52264404296875},{"isDeleted":false,"locked":false,"strokeColor":"#fdba74","link":null,"roughness":1,"groupIds":[],"index":"bHv","backgroundColor":"#fff7ed","angle":0,"fillStyle":"solid","strokeWidth":1,"version":121,"roundness":{"type":3},"type":"rectangle","updated":1772748823813,"id":"iqRA6KkqUt-kJdj0bn8Dc","x":1808.8699240820786,"seed":610044284,"boundElements":[],"y":904.65428568942571,"opacity":100,"height":340,"width":490,"frameId":null,"strokeStyle":"solid","versionNonce":736241020},{"seed":528873980,"strokeStyle":"solid","id":"vddT2efdPxkFgg7Eme2Wb","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772748823813,"locked":false,"text":"A. User Journey + Latency Budget","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bHw","roundness":null,"containerId":null,"originalText":"A. User Journey + Latency Budget","height":17.5,"link":null,"strokeColor":"#c2410c","fillStyle":"solid","groupIds":[],"versionNonce":1542985212,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1822.8699240820786,"angle":0,"y":916.65428568942571,"width":234.80775451660156},{"seed":1160600188,"strokeStyle":"solid","id":"2_39F_21QR1PfEAYL0SqN","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772748823813,"locked":false,"text":"1. User opens app or pulls to refresh\n2. Client: GET \/feed?cursor=null&limit=20\n3. Server checks Redis cache:\n   HIT:  return in <30ms\n   MISS: compute from DB, return in <200ms\n4. Client renders 20 posts\n5. Scroll: GET \/feed?cursor=<score:post_id>\n\nDuring failure:\n  Redis down: fallback to DB query.\n  Latency spikes to 200-500ms.\n  Celebrity DB slow: serve precomputed\n  feed without celebrity posts (degrade gracefully).\n\nLatency budget (P99 < 500ms):\n  Redis ZRANGE:            5ms\n  Celebrity DB query:     20ms\n  Merge + rank 40 posts:   5ms\n  Metadata hydration:     15ms\n  Network + serial:       20ms\n  Total P50:           ~65ms\n  Total P99:          ~500ms (cache miss)","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bHx","roundness":null,"containerId":null,"originalText":"1. User opens app or pulls to refresh\n2. Client: GET \/feed?cursor=null&limit=20\n3. Server checks Redis cache:\n   HIT:  return in <30ms\n   MISS: compute from DB, return in <200ms\n4. Client renders 20 posts\n5. Scroll: GET \/feed?cursor=<score:post_id>\n\nDuring failure:\n  Redis down: fallback to DB query.\n  Latency spikes to 200-500ms.\n  Celebrity DB slow: serve precomputed\n  feed without celebrity posts (degrade gracefully).\n\nLatency budget (P99 < 500ms):\n  Redis ZRANGE:            5ms\n  Celebrity DB query:     20ms\n  Merge + rank 40 posts:   5ms\n  Metadata hydration:     15ms\n  Network + serial:       20ms\n  Total P50:           ~65ms\n  Total P99:          ~500ms (cache miss)","height":357.5,"link":null,"strokeColor":"#334155","fillStyle":"solid","groupIds":[],"versionNonce":1694234236,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1822.8699240820786,"angle":0,"y":940.65428568942571,"width":326.29959106445312},{"isDeleted":false,"locked":false,"strokeColor":"#86efac","link":null,"roughness":1,"groupIds":[],"index":"bHy","backgroundColor":"#f0fdf4","angle":0,"fillStyle":"solid","strokeWidth":1,"version":121,"roundness":{"type":3},"type":"rectangle","updated":1772748823813,"id":"DkeBG9AekK7I4y3sb1XEx","x":2316.8699240820788,"seed":1880402684,"boundElements":[],"y":904.65428568942571,"opacity":100,"height":340,"width":620,"frameId":null,"strokeStyle":"solid","versionNonce":1404028668},{"seed":1388178300,"strokeStyle":"solid","id":"3nU-k_JHa1tH7s0SkGpxN","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772748823813,"locked":false,"text":"B. Internal Flow","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bHz","roundness":null,"containerId":null,"originalText":"B. Internal Flow","height":17.5,"link":null,"strokeColor":"#15803d","fillStyle":"solid","groupIds":[],"versionNonce":1284867964,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":2330.8699240820788,"angle":0,"y":916.65428568942571,"width":110.7958984375},{"seed":2137725948,"strokeStyle":"solid","id":"nsp-aaRstZOCnOF1LY6Ox","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772748823813,"locked":false,"text":"1.  GET \/feed — JWT verified at API gateway\n2.  Redis: ZREVRANGEBYSCORE feed:{uid}\n    +inf (cursor_score) LIMIT 0 20\n    HIT  → skip to step 6\n    MISS → continue to step 3\n3.  [MISS] Fetch followees from Cassandra\n4.  [MISS] SELECT posts WHERE author_id\n    IN (followees) AND created_at > since\n    ORDER BY created_at DESC LIMIT 20 per shard\n5.  [MISS] ZADD feed:{uid} to populate cache\n6.  Fetch celebrity list: SMEMBERS celeb_follows:{uid}\n7.  If not empty: SELECT FROM celebrity_posts\n    WHERE author_id IN (celeb_ids)\n    AND created_at > cursor LIMIT 20\n8.  Merge: interleave precomputed + celebrity\n    posts sorted by ranking_score\n9.  Apply mute\/block filter list\n10. Return top 20, cursor = lowest score seen\n11. Hydrate author metadata from cache","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bI0","roundness":null,"containerId":null,"originalText":"1.  GET \/feed — JWT verified at API gateway\n2.  Redis: ZREVRANGEBYSCORE feed:{uid}\n    +inf (cursor_score) LIMIT 0 20\n    HIT  → skip to step 6\n    MISS → continue to step 3\n3.  [MISS] Fetch followees from Cassandra\n4.  [MISS] SELECT posts WHERE author_id\n    IN (followees) AND created_at > since\n    ORDER BY created_at DESC LIMIT 20 per shard\n5.  [MISS] ZADD feed:{uid} to populate cache\n6.  Fetch celebrity list: SMEMBERS celeb_follows:{uid}\n7.  If not empty: SELECT FROM celebrity_posts\n    WHERE author_id IN (celeb_ids)\n    AND created_at > cursor LIMIT 20\n8.  Merge: interleave precomputed + celebrity\n    posts sorted by ranking_score\n9.  Apply mute\/block filter list\n10. Return top 20, cursor = lowest score seen\n11. Hydrate author metadata from cache","height":308.75,"link":null,"strokeColor":"#334155","fillStyle":"solid","groupIds":[],"versionNonce":334444540,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":2330.8699240820788,"angle":0,"y":940.65428568942571,"width":349.03656005859375},{"isDeleted":false,"locked":false,"strokeColor":"#93c5fd","link":null,"roughness":1,"groupIds":[],"index":"bI1","backgroundColor":"#eff6ff","angle":0,"fillStyle":"solid","strokeWidth":1,"version":121,"roundness":{"type":3},"type":"rectangle","updated":1772748823813,"id":"ob4Osh5370Jjin6neUnFz","x":2954.8699240820783,"seed":1881029756,"boundElements":[],"y":904.65428568942571,"opacity":100,"height":340,"width":414,"frameId":null,"strokeStyle":"solid","versionNonce":364828796},{"seed":244927740,"strokeStyle":"solid","id":"4aPEENY5aGHZIjku1KS85","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772748823813,"locked":false,"text":"C. Data Model","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bI2","roundness":null,"containerId":null,"originalText":"C. Data Model","height":17.5,"link":null,"strokeColor":"#1d4ed8","fillStyle":"solid","groupIds":[],"versionNonce":1841719548,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":2968.8699240820783,"angle":0,"y":916.65428568942571,"width":96.8939208984375},{"seed":1012813180,"strokeStyle":"solid","id":"tBXfwYv7vWqGtAGaXQ062","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772748823813,"locked":false,"text":"Redis feed cache:\n  Key:  feed:{user_id}\n  Type: Sorted Set\n  Score: ranking_score (float)\n  Member: post_id\n\nCursor design:\n  cursor = base64(score:post_id)\n  Stable — new posts inserted at top\n  don't affect the cursor position.\n  No offset shifting on live feed.\n\nCelebrity follows:\n  Key:  celeb_follows:{user_id}\n  Type: Redis Set\n  Member: author_id\n  Set if followee count > 1M\n\nPost hydration:\n  Key:  post:{post_id}\n  Type: Redis Hash\n  TTL:  1 hour\n  Fields: author, content,\n    media_url, like_count\n\nCommon query (cache miss):\n  SELECT p.* FROM posts p\n  WHERE p.author_id = ANY(:ids)\n  AND p.created_at > :since\n  ORDER BY created_at DESC\n  LIMIT 20","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bI3","roundness":null,"containerId":null,"originalText":"Redis feed cache:\n  Key:  feed:{user_id}\n  Type: Sorted Set\n  Score: ranking_score (float)\n  Member: post_id\n\nCursor design:\n  cursor = base64(score:post_id)\n  Stable — new posts inserted at top\n  don't affect the cursor position.\n  No offset shifting on live feed.\n\nCelebrity follows:\n  Key:  celeb_follows:{user_id}\n  Type: Redis Set\n  Member: author_id\n  Set if followee count > 1M\n\nPost hydration:\n  Key:  post:{post_id}\n  Type: Redis Hash\n  TTL:  1 hour\n  Fields: author, content,\n    media_url, like_count\n\nCommon query (cache miss):\n  SELECT p.* FROM posts p\n  WHERE p.author_id = ANY(:ids)\n  AND p.created_at > :since\n  ORDER BY created_at DESC\n  LIMIT 20","height":503.75,"link":null,"strokeColor":"#334155","fillStyle":"solid","groupIds":[],"versionNonce":1871178108,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":2968.8699240820783,"angle":0,"y":940.65428568942571,"width":241.03274536132812},{"isDeleted":false,"locked":false,"strokeColor":"#0e7490","link":null,"roughness":1,"groupIds":[],"index":"bI4","backgroundColor":"#0e7490","angle":0,"fillStyle":"solid","strokeWidth":1,"version":121,"roundness":{"type":3},"type":"rectangle","updated":1772748823813,"id":"j13p-QKLI5vGtcgjTErmC","x":1808.8699240820786,"seed":1521434108,"boundElements":[],"y":1256.6542856894257,"opacity":100,"height":40,"width":1560,"frameId":null,"strokeStyle":"solid","versionNonce":776296956},{"seed":1385045628,"strokeStyle":"solid","id":"k6Q6jF4oskZFTebBE5sI-","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":17,"opacity":100,"verticalAlign":"top","updated":1772748823813,"locked":false,"text":"Deep Dive 3 — FR5: Like \/ React (Counter Aggregation at Scale)","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bI5","roundness":null,"containerId":null,"originalText":"Deep Dive 3 — FR5: Like \/ React (Counter Aggregation at Scale)","height":21.25,"link":null,"strokeColor":"#cffafe","fillStyle":"solid","groupIds":[],"versionNonce":83933820,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1822.8699240820786,"angle":0,"y":1269.6542856894257,"width":543.7105712890625},{"isDeleted":false,"locked":false,"strokeColor":"#fdba74","link":null,"roughness":1,"groupIds":[],"index":"bI6","backgroundColor":"#fff7ed","angle":0,"fillStyle":"solid","strokeWidth":1,"version":121,"roundness":{"type":3},"type":"rectangle","updated":1772748823813,"id":"yBDAD_6kVu_zDnfS_h-fA","x":1808.8699240820786,"seed":482143996,"boundElements":[],"y":1306.6542856894257,"opacity":100,"height":330,"width":490,"frameId":null,"strokeStyle":"solid","versionNonce":511445756},{"seed":1237167996,"strokeStyle":"solid","id":"TMnGioNT3Ca1dZ5eaUpPs","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772748823813,"locked":false,"text":"A. User Journey + Latency Budget","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bI7","roundness":null,"containerId":null,"originalText":"A. User Journey + Latency Budget","height":17.5,"link":null,"strokeColor":"#c2410c","fillStyle":"solid","groupIds":[],"versionNonce":2100906876,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1822.8699240820786,"angle":0,"y":1318.6542856894257,"width":234.80775451660156},{"seed":164782076,"strokeStyle":"solid","id":"qvGfEnhQRA74d4r8vRdIX","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772748823813,"locked":false,"text":"1. User double-taps post (Instagram style)\n2. Client OPTIMISTICALLY updates UI —\n   shows heart filled, +1 count immediately\n3. Client sends POST \/likes {post_id}\n4. Server responds 200 in <50ms\n5. Like count updates for all viewers\n   within ~30 seconds (eventual consistency)\n\nDuring failure:\n  Server 5xx: client rolls back optimistic\n  update, shows error toast, user retries.\n  Redis fails: like queued in Kafka for\n  async retry. Count eventually correct.\n\nLatency budget (P99 < 200ms):\n  JWT auth check:         2ms\n  Idempotency check:      3ms\n  Redis SADD liked_by:    3ms\n  Redis INCR like_count:  2ms\n  Kafka publish:          5ms\n  Return 200:             5ms\n  Total P50:          ~20ms\n  Total P99:         ~150ms","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bI8","roundness":null,"containerId":null,"originalText":"1. User double-taps post (Instagram style)\n2. Client OPTIMISTICALLY updates UI —\n   shows heart filled, +1 count immediately\n3. Client sends POST \/likes {post_id}\n4. Server responds 200 in <50ms\n5. Like count updates for all viewers\n   within ~30 seconds (eventual consistency)\n\nDuring failure:\n  Server 5xx: client rolls back optimistic\n  update, shows error toast, user retries.\n  Redis fails: like queued in Kafka for\n  async retry. Count eventually correct.\n\nLatency budget (P99 < 200ms):\n  JWT auth check:         2ms\n  Idempotency check:      3ms\n  Redis SADD liked_by:    3ms\n  Redis INCR like_count:  2ms\n  Kafka publish:          5ms\n  Return 200:             5ms\n  Total P50:          ~20ms\n  Total P99:         ~150ms","height":373.75,"link":null,"strokeColor":"#334155","fillStyle":"solid","groupIds":[],"versionNonce":58358780,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1822.8699240820786,"angle":0,"y":1342.6542856894257,"width":284.77767944335938},{"isDeleted":false,"locked":false,"strokeColor":"#86efac","link":null,"roughness":1,"groupIds":[],"index":"bI9","backgroundColor":"#f0fdf4","angle":0,"fillStyle":"solid","strokeWidth":1,"version":121,"roundness":{"type":3},"type":"rectangle","updated":1772748823813,"id":"KM9gQUUhedtRejRqLVrAI","x":2316.8699240820788,"seed":888995964,"boundElements":[],"y":1306.6542856894257,"opacity":100,"height":330,"width":620,"frameId":null,"strokeStyle":"solid","versionNonce":2067897468},{"seed":1392480508,"strokeStyle":"solid","id":"0NVhznaHEmZG5xs2vjcX0","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772748823813,"locked":false,"text":"B. Internal Flow","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bIA","roundness":null,"containerId":null,"originalText":"B. Internal Flow","height":17.5,"link":null,"strokeColor":"#15803d","fillStyle":"solid","groupIds":[],"versionNonce":508603644,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":2330.8699240820788,"angle":0,"y":1318.6542856894257,"width":110.7958984375},{"seed":593236348,"strokeStyle":"solid","id":"I_GAC6Lg4i_coh6KwXJ4Y","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772748823813,"locked":false,"text":"LIKE PATH:\n1.  POST \/likes {post_id, reaction_type}\n2.  JWT auth (API gateway)\n3.  SISMEMBER liked_by:{post_id} {uid}\n    Already liked? Return 200 (idempotent no-op)\n4.  SADD liked_by:{post_id} {user_id}\n5.  INCR like_count:{post_id}\n6.  Publish like_event to Kafka (async notify)\n7.  Return {post_id, new_count} 200\n\nUNLIKE PATH:\n3b. SREM liked_by:{post_id} {user_id}\n5b. DECR like_count:{post_id}\n\nASYNC DB FLUSH (every 30 seconds):\n  Like Flusher reads like_count:{post_id}\n  for all dirty post_ids in Redis.\n  UPDATE posts SET like_count = :n\n  WHERE post_id = :id\n  (single query per post, not per like)\n\nHOT POST HANDLING:\n  liked_by set capped at 10M members.\n  For counts >10M: switch to HyperLogLog.\n  Redis HLL = ~0.81% error, 12KB memory.","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bIB","roundness":null,"containerId":null,"originalText":"LIKE PATH:\n1.  POST \/likes {post_id, reaction_type}\n2.  JWT auth (API gateway)\n3.  SISMEMBER liked_by:{post_id} {uid}\n    Already liked? Return 200 (idempotent no-op)\n4.  SADD liked_by:{post_id} {user_id}\n5.  INCR like_count:{post_id}\n6.  Publish like_event to Kafka (async notify)\n7.  Return {post_id, new_count} 200\n\nUNLIKE PATH:\n3b. SREM liked_by:{post_id} {user_id}\n5b. DECR like_count:{post_id}\n\nASYNC DB FLUSH (every 30 seconds):\n  Like Flusher reads like_count:{post_id}\n  for all dirty post_ids in Redis.\n  UPDATE posts SET like_count = :n\n  WHERE post_id = :id\n  (single query per post, not per like)\n\nHOT POST HANDLING:\n  liked_by set capped at 10M members.\n  For counts >10M: switch to HyperLogLog.\n  Redis HLL = ~0.81% error, 12KB memory.","height":406.25,"link":null,"strokeColor":"#334155","fillStyle":"solid","groupIds":[],"versionNonce":506047868,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":2330.8699240820788,"angle":0,"y":1342.6542856894257,"width":311.51864624023438},{"isDeleted":false,"locked":false,"strokeColor":"#93c5fd","link":null,"roughness":1,"groupIds":[],"index":"bIC","backgroundColor":"#eff6ff","angle":0,"fillStyle":"solid","strokeWidth":1,"version":121,"roundness":{"type":3},"type":"rectangle","updated":1772748823813,"id":"QzyN7qV18cPIZhkHN9W47","x":2954.8699240820783,"seed":626295292,"boundElements":[],"y":1306.6542856894257,"opacity":100,"height":330,"width":414,"frameId":null,"strokeStyle":"solid","versionNonce":739155452},{"seed":535487100,"strokeStyle":"solid","id":"I9jKxvWgJeDfSekpmQnZP","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772748823813,"locked":false,"text":"C. Data Model","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bID","roundness":null,"containerId":null,"originalText":"C. Data Model","height":17.5,"link":null,"strokeColor":"#1d4ed8","fillStyle":"solid","groupIds":[],"versionNonce":16875132,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":2968.8699240820783,"angle":0,"y":1318.6542856894257,"width":96.8939208984375},{"seed":702624508,"strokeStyle":"solid","id":"liShjnJ-EwrFQ1sDZPRsE","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772748823813,"locked":false,"text":"Redis (source of truth for counts):\n  like_count:{post_id}\n    Type: String (integer)\n    INCR \/ DECR  — no TTL\n\n  liked_by:{post_id}\n    Type: Set\n    SADD \/ SREM \/ SISMEMBER\n    Cap: 10M  |  TTL: 90 days\n\n  liked_posts:{user_id}\n    Type: Set — 'did I like this?'\n    TTL: 30 days\n\nDB (durable, slightly stale):\n  likes table:\n    post_id  UUID  IDX\n    user_id  UUID  IDX\n    created_at TIMESTAMPTZ\n    UNIQUE (post_id, user_id)\n\n  posts.like_count INT\n    Updated by async flusher\n\nWhy Redis SET not DB table:\n  'Did I like this?' is hot-path <5ms.\n  DB join would add 20-50ms per feed load.\n  DB likes table = analytics + recovery only.","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bIE","roundness":null,"containerId":null,"originalText":"Redis (source of truth for counts):\n  like_count:{post_id}\n    Type: String (integer)\n    INCR \/ DECR  — no TTL\n\n  liked_by:{post_id}\n    Type: Set\n    SADD \/ SREM \/ SISMEMBER\n    Cap: 10M  |  TTL: 90 days\n\n  liked_posts:{user_id}\n    Type: Set — 'did I like this?'\n    TTL: 30 days\n\nDB (durable, slightly stale):\n  likes table:\n    post_id  UUID  IDX\n    user_id  UUID  IDX\n    created_at TIMESTAMPTZ\n    UNIQUE (post_id, user_id)\n\n  posts.like_count INT\n    Updated by async flusher\n\nWhy Redis SET not DB table:\n  'Did I like this?' is hot-path <5ms.\n  DB join would add 20-50ms per feed load.\n  DB likes table = analytics + recovery only.","height":455,"link":null,"strokeColor":"#334155","fillStyle":"solid","groupIds":[],"versionNonce":1707364092,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":2968.8699240820783,"angle":0,"y":1342.6542856894257,"width":279.51266479492188},{"isDeleted":false,"locked":false,"strokeColor":"#4c1d95","link":null,"roughness":1,"groupIds":[],"index":"bIF","backgroundColor":"#4c1d95","angle":0,"fillStyle":"solid","strokeWidth":1,"version":121,"roundness":{"type":3},"type":"rectangle","updated":1772748823813,"id":"FEVkg9ETEI-d2Ilxv23oz","x":1808.8699240820786,"seed":834237308,"boundElements":[],"y":1648.6542856894257,"opacity":100,"height":70,"width":1560,"frameId":null,"strokeStyle":"solid","versionNonce":987303804},{"seed":95790076,"strokeStyle":"solid","id":"o0pAXgdgO2uKG3TjhqqOb","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1772748823813,"locked":false,"text":"Deep Dive Key Patterns:","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bIG","roundness":null,"containerId":null,"originalText":"Deep Dive Key Patterns:","height":18.75,"link":null,"strokeColor":"#e9d5ff","fillStyle":"solid","groupIds":[],"versionNonce":8503292,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1822.8699240820786,"angle":0,"y":1660.6542856894257,"width":179.08486938476562},{"seed":1540867196,"strokeStyle":"solid","id":"CGDEhzV7jBh2JGrBRfCLL","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772748823814,"locked":false,"text":"Fan-out: Kafka decouples write from propagation. ZADD NX = replay-safe.  |  Feed Read: cursor=(score:post_id) stable on live feed. Hybrid merge under 500ms P99.\nLikes: Redis INCR as hot counter. SADD set = idempotent dedup. Async flush to DB every 30s. Optimistic UI with rollback on failure.","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bIH","roundness":null,"containerId":null,"originalText":"Fan-out: Kafka decouples write from propagation. ZADD NX = replay-safe.  |  Feed Read: cursor=(score:post_id) stable on live feed. Hybrid merge under 500ms P99.\nLikes: Redis INCR as hot counter. SADD set = idempotent dedup. Async flush to DB every 30s. Optimistic UI with rollback on failure.","height":35,"link":null,"strokeColor":"#f5f3ff","fillStyle":"solid","groupIds":[],"versionNonce":1589665916,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1822.8699240820786,"angle":0,"y":1684.6542856894257,"width":1123.2745361328125},{"isDeleted":false,"locked":false,"strokeColor":"#cbd5e1","link":null,"roughness":1,"groupIds":[],"index":"bII","backgroundColor":"#f8fafc","angle":0,"fillStyle":"solid","strokeWidth":1,"version":121,"roundness":{"type":3},"type":"rectangle","updated":1772748823814,"id":"qRjaGpK1InMWfA3TaQIbI","x":1808.8699240820786,"seed":1507972348,"boundElements":[],"y":1776.6542856894257,"opacity":100,"height":940,"width":1560,"frameId":null,"strokeStyle":"solid","versionNonce":760672508},{"isDeleted":false,"locked":false,"strokeColor":"#4c1d95","link":null,"roughness":1,"groupIds":[],"index":"bIJ","backgroundColor":"#4c1d95","angle":0,"fillStyle":"solid","strokeWidth":1,"version":121,"roundness":{"type":3},"type":"rectangle","updated":1772748823814,"id":"rGt88x1A04tcMLO8gCQs6","x":1808.8699240820786,"seed":492164476,"boundElements":[],"y":1776.6542856894257,"opacity":100,"height":46,"width":1560,"frameId":null,"strokeStyle":"solid","versionNonce":2076668284},{"seed":1131791868,"strokeStyle":"solid","id":"BQMu9Uy7Z7utyC082VAVO","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":21,"opacity":100,"verticalAlign":"top","updated":1772748823814,"locked":false,"text":"STEP 9  —  Failure Handling","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bIK","roundness":null,"containerId":null,"originalText":"STEP 9  —  Failure Handling","height":26.25,"link":null,"strokeColor":"#f5f3ff","fillStyle":"solid","groupIds":[],"versionNonce":424927740,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":2258.8699240820788,"angle":0,"y":1789.6542856894257,"width":290.03082275390625},{"isDeleted":false,"locked":false,"strokeColor":"#f87171","link":null,"roughness":1,"groupIds":[],"index":"bIL","backgroundColor":"#fff1f2","angle":0,"fillStyle":"solid","strokeWidth":1,"version":121,"roundness":{"type":3},"type":"rectangle","updated":1772748823814,"id":"-HeZqJHH841HcL1KH0ZJN","x":1808.8699240820786,"seed":1900258940,"boundElements":[],"y":1832.6542856894257,"opacity":100,"height":192,"width":754,"frameId":null,"strokeStyle":"solid","versionNonce":486425212},{"seed":1535211260,"strokeStyle":"solid","id":"qIXxIl5nMDHFvIdIrjYTw","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1772748823814,"locked":false,"text":"Client Errors (4xx) — Validate Early, Fail Fast","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bIM","roundness":null,"containerId":null,"originalText":"Client Errors (4xx) — Validate Early, Fail Fast","height":18.75,"link":null,"strokeColor":"#b91c1c","fillStyle":"solid","groupIds":[],"versionNonce":1837667068,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1822.8699240820786,"angle":0,"y":1844.6542856894257,"width":339.73480224609375},{"seed":1320236924,"strokeStyle":"solid","id":"01K20frN37Hdea8Wcl6v0","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772748823814,"locked":false,"text":"Validate AT: API gateway before ANY downstream call.\nNever let invalid data reach Kafka or the DB.\n\n400 Bad Request:   missing content, invalid media type\n401 Unauthorized:  missing\/expired JWT — no retry\n403 Forbidden:     posting to group you are not in\n409 Conflict:      duplicate idempotency_key — return cached\n413 Too Large:     content >10KB, video >500MB\n\nClient behavior: show error, NO automatic retry.\nNO message queued. NO worker triggered. NO DB touched.","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bIN","roundness":null,"containerId":null,"originalText":"Validate AT: API gateway before ANY downstream call.\nNever let invalid data reach Kafka or the DB.\n\n400 Bad Request:   missing content, invalid media type\n401 Unauthorized:  missing\/expired JWT — no retry\n403 Forbidden:     posting to group you are not in\n409 Conflict:      duplicate idempotency_key — return cached\n413 Too Large:     content >10KB, video >500MB\n\nClient behavior: show error, NO automatic retry.\nNO message queued. NO worker triggered. NO DB touched.","height":178.75,"link":null,"strokeColor":"#334155","fillStyle":"solid","groupIds":[],"versionNonce":1232393084,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1822.8699240820786,"angle":0,"y":1868.6542856894257,"width":389.36251831054688},{"isDeleted":false,"locked":false,"strokeColor":"#fcd34d","link":null,"roughness":1,"groupIds":[],"index":"bIO","backgroundColor":"#fffbeb","angle":0,"fillStyle":"solid","strokeWidth":1,"version":121,"roundness":{"type":3},"type":"rectangle","updated":1772748823814,"id":"0iaigUNOrfgd2NwnxhXc9","x":2580.8699240820788,"seed":924116988,"boundElements":[],"y":1832.6542856894257,"opacity":100,"height":192,"width":788,"frameId":null,"strokeStyle":"solid","versionNonce":1325728764},{"seed":682526844,"strokeStyle":"solid","id":"imcXSpkh5MlgRwZUVzydz","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1772748823814,"locked":false,"text":"External \/ Provider Failures","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bIP","roundness":null,"containerId":null,"originalText":"External \/ Provider Failures","height":18.75,"link":null,"strokeColor":"#b45309","fillStyle":"solid","groupIds":[],"versionNonce":70984828,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":2594.8699240820788,"angle":0,"y":1844.6542856894257,"width":203.95484924316406},{"seed":1732253948,"strokeStyle":"solid","id":"vb2pZjB_-kKSHgr84eU6e","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772748823814,"locked":false,"text":"S3 upload fails:\n  Circuit breaker opens after 5 failures in 10s.\n  Return presigned URL to client anyway.\n  Client retries upload directly — server not in loop.\n\nCDN origin unreachable:\n  Serve stale cached media from edge (extend TTL).\n  Alert if origin down >60 seconds.\n\nKafka broker unavailable:\n  Producer: retry with backoff (3 attempts: 500ms\/1s\/2s).\n  Fallback: write fan-out task to DB outbox table.\n  Outbox poller publishes when Kafka recovers.","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bIQ","roundness":null,"containerId":null,"originalText":"S3 upload fails:\n  Circuit breaker opens after 5 failures in 10s.\n  Return presigned URL to client anyway.\n  Client retries upload directly — server not in loop.\n\nCDN origin unreachable:\n  Serve stale cached media from edge (extend TTL).\n  Alert if origin down >60 seconds.\n\nKafka broker unavailable:\n  Producer: retry with backoff (3 attempts: 500ms\/1s\/2s).\n  Fallback: write fan-out task to DB outbox table.\n  Outbox poller publishes when Kafka recovers.","height":211.25,"link":null,"strokeColor":"#334155","fillStyle":"solid","groupIds":[],"versionNonce":1591293180,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":2594.8699240820788,"angle":0,"y":1868.6542856894257,"width":375.99853515625},{"isDeleted":false,"locked":false,"strokeColor":"#a78bfa","link":null,"roughness":1,"groupIds":[],"index":"bIR","backgroundColor":"#f5f3ff","angle":0,"fillStyle":"solid","strokeWidth":1,"version":121,"roundness":{"type":3},"type":"rectangle","updated":1772748823814,"id":"GfvZwgtjd6Iloj6P9lGg2","x":1808.8699240820786,"seed":1850448252,"boundElements":[],"y":2034.6542856894257,"opacity":100,"height":222,"width":754,"frameId":null,"strokeStyle":"solid","versionNonce":1281439100},{"seed":2031290876,"strokeStyle":"solid","id":"CK5p28FZh55DI1WqcRrXu","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1772748823814,"locked":false,"text":"Internal Service Failures — Outbox + Saga","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bIS","roundness":null,"containerId":null,"originalText":"Internal Service Failures — Outbox + Saga","height":18.75,"link":null,"strokeColor":"#6d28d9","fillStyle":"solid","groupIds":[],"versionNonce":974464508,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1822.8699240820786,"angle":0,"y":2046.6542856894257,"width":311.47479248046875},{"seed":177760892,"strokeStyle":"solid","id":"pPXlpUKHGQ33fvQyLWGx4","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772748823814,"locked":false,"text":"Fan-out worker crash mid-fan-out:\n  Kafka offset NOT committed until batch completes.\n  Worker restarts and reprocesses from last offset.\n  ZADD NX is idempotent — same post_id added twice\n  to same feed = no-op. Safe to replay any time.\n\nPost created but Kafka publish fails:\n  Transactional outbox pattern:\n  1. INSERT post + INSERT outbox_event in same DB txn.\n  2. Outbox poller reads unflushed events, publishes.\n  3. Marks event as published. Guarantees no lost fan-outs.\n\nFeed hydration service down:\n  Return Redis cache without metadata hydration.\n  Degrade: show post_ids + names from cache, skip\n  real-time like counts. Stale is better than empty.","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bIT","roundness":null,"containerId":null,"originalText":"Fan-out worker crash mid-fan-out:\n  Kafka offset NOT committed until batch completes.\n  Worker restarts and reprocesses from last offset.\n  ZADD NX is idempotent — same post_id added twice\n  to same feed = no-op. Safe to replay any time.\n\nPost created but Kafka publish fails:\n  Transactional outbox pattern:\n  1. INSERT post + INSERT outbox_event in same DB txn.\n  2. Outbox poller reads unflushed events, publishes.\n  3. Marks event as published. Guarantees no lost fan-outs.\n\nFeed hydration service down:\n  Return Redis cache without metadata hydration.\n  Degrade: show post_ids + names from cache, skip\n  real-time like counts. Stale is better than empty.","height":260,"link":null,"strokeColor":"#334155","fillStyle":"solid","groupIds":[],"versionNonce":485951100,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1822.8699240820786,"angle":0,"y":2070.6542856894257,"width":382.60272216796875},{"isDeleted":false,"locked":false,"strokeColor":"#06b6d4","link":null,"roughness":1,"groupIds":[],"index":"bIU","backgroundColor":"#cffafe","angle":0,"fillStyle":"solid","strokeWidth":1,"version":121,"roundness":{"type":3},"type":"rectangle","updated":1772748823814,"id":"xul5h260XGFwIFW6rTagl","x":2580.8699240820788,"seed":1973271292,"boundElements":[],"y":2034.6542856894257,"opacity":100,"height":222,"width":788,"frameId":null,"strokeStyle":"solid","versionNonce":2043205372},{"seed":1688533884,"strokeStyle":"solid","id":"_k76ubIT4AinV8elq6r86","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1772748823814,"locked":false,"text":"Infrastructure Failures","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bIV","roundness":null,"containerId":null,"originalText":"Infrastructure Failures","height":18.75,"link":null,"strokeColor":"#0e7490","fillStyle":"solid","groupIds":[],"versionNonce":1829541756,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":2594.8699240820788,"angle":0,"y":2046.6542856894257,"width":167.72982788085938},{"seed":1643129852,"strokeStyle":"solid","id":"8865ZAvHk_VaR2N63wm-l","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772748823814,"locked":false,"text":"Kafka partition down:\n  Auto-rebalance — consumers pick up orphaned partitions.\n  Fan-out lag spikes: alert at consumer_lag > 10K msgs.\n  No data loss (Kafka replicated x3).\n\nDB primary fails:\n  Automated failover: replica promoted in ~30s.\n  During failover: writes queue at pool, timeout at 35s.\n  Feed reads redirect to remaining replicas — unaffected.\n  RPO <1s (sync replication). RTO ~30s.\n\nRedis cache node fails:\n  Cache miss spike — DB absorbs (autoscaling triggers).\n  Feed reads degrade to 200-500ms, not failure.\n  Redis Cluster: surviving nodes serve their key ranges.\n  Self-heals via cache population on each miss.","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bIW","roundness":null,"containerId":null,"originalText":"Kafka partition down:\n  Auto-rebalance — consumers pick up orphaned partitions.\n  Fan-out lag spikes: alert at consumer_lag > 10K msgs.\n  No data loss (Kafka replicated x3).\n\nDB primary fails:\n  Automated failover: replica promoted in ~30s.\n  During failover: writes queue at pool, timeout at 35s.\n  Feed reads redirect to remaining replicas — unaffected.\n  RPO <1s (sync replication). RTO ~30s.\n\nRedis cache node fails:\n  Cache miss spike — DB absorbs (autoscaling triggers).\n  Feed reads degrade to 200-500ms, not failure.\n  Redis Cluster: surviving nodes serve their key ranges.\n  Self-heals via cache population on each miss.","height":260,"link":null,"strokeColor":"#334155","fillStyle":"solid","groupIds":[],"versionNonce":855918588,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":2594.8699240820788,"angle":0,"y":2070.6542856894257,"width":371.5655517578125},{"isDeleted":false,"locked":false,"strokeColor":"#eab308","link":null,"roughness":1,"groupIds":[],"index":"bIX","backgroundColor":"#fef9c3","angle":0,"fillStyle":"solid","strokeWidth":1,"version":121,"roundness":{"type":3},"type":"rectangle","updated":1772748823814,"id":"lSgv93_I_I6uW_VrRkieO","x":1808.8699240820786,"seed":1602309244,"boundElements":[],"y":2266.6542856894257,"opacity":100,"height":198,"width":754,"frameId":null,"strokeStyle":"solid","versionNonce":800188540},{"seed":1058692348,"strokeStyle":"solid","id":"ftM37lOCRXYgV1uoXJEDR","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1772748823814,"locked":false,"text":"Retry Strategy — Exact Specification","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bIY","roundness":null,"containerId":null,"originalText":"Retry Strategy — Exact Specification","height":18.75,"link":null,"strokeColor":"#713f12","fillStyle":"solid","groupIds":[],"versionNonce":1993832700,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1822.8699240820786,"angle":0,"y":2278.6542856894257,"width":280.49981689453125},{"seed":1513971068,"strokeStyle":"solid","id":"bq-m9xseGSkWBD20jgptB","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772748823814,"locked":false,"text":"Formula: delay = min(base * 2^attempt + rand(0, jitter), max)\n  base=100ms, jitter=100ms, max=30000ms\n  Attempt 1: ~100-200ms\n  Attempt 2: ~200-400ms\n  Attempt 3: ~400-800ms  → DLQ after 3 failures\n\nRETRYABLE: 503, 429, 500 (idempotent only),\n  network timeout, Kafka produce timeout\n\nNON-RETRYABLE: 400, 401, 403, 409, 404","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bIZ","roundness":null,"containerId":null,"originalText":"Formula: delay = min(base * 2^attempt + rand(0, jitter), max)\n  base=100ms, jitter=100ms, max=30000ms\n  Attempt 1: ~100-200ms\n  Attempt 2: ~200-400ms\n  Attempt 3: ~400-800ms  → DLQ after 3 failures\n\nRETRYABLE: 503, 429, 500 (idempotent only),\n  network timeout, Kafka produce timeout\n\nNON-RETRYABLE: 400, 401, 403, 409, 404","height":162.5,"link":null,"strokeColor":"#334155","fillStyle":"solid","groupIds":[],"versionNonce":1408694652,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1822.8699240820786,"angle":0,"y":2302.6542856894257,"width":386.78857421875},{"isDeleted":false,"locked":false,"strokeColor":"#86efac","link":null,"roughness":1,"groupIds":[],"index":"bIa","backgroundColor":"#f0fdf4","angle":0,"fillStyle":"solid","strokeWidth":1,"version":121,"roundness":{"type":3},"type":"rectangle","updated":1772748823814,"id":"8wgzYQ5tV1qhcSfz5C4iP","x":2580.8699240820788,"seed":170675708,"boundElements":[],"y":2266.6542856894257,"opacity":100,"height":198,"width":788,"frameId":null,"strokeStyle":"solid","versionNonce":1381132796},{"seed":803810940,"strokeStyle":"solid","id":"JEJHitxzWEPSoFMNkrLZO","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1772748823814,"locked":false,"text":"Idempotency — Exact Mechanism","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bIb","roundness":null,"containerId":null,"originalText":"Idempotency — Exact Mechanism","height":18.75,"link":null,"strokeColor":"#15803d","fillStyle":"solid","groupIds":[],"versionNonce":1156303484,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":2594.8699240820788,"angle":0,"y":2278.6542856894257,"width":241.63485717773438},{"seed":1010171644,"strokeStyle":"solid","id":"Lbpf-_1o-n813m3rD1B-i","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772748823814,"locked":false,"text":"Post creation dedup:\n  Hash: SHA256(user_id + content_hash + ts_minute)\n  Store: SET idem:{hash} {post_id} EX 86400\n  On retry: GET idem:{hash} → return original post_id\n\nLike idempotency:\n  SADD liked_by:{post_id} {user_id}\n  Returns 0 if already member → skip INCR, return 200.\n  SADD is atomic — no race condition.\n\nFan-out worker dedup:\n  ZADD NX feed:{follower_id} score post_id\n  NX = add only if not exists. Replay-safe.","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bIc","roundness":null,"containerId":null,"originalText":"Post creation dedup:\n  Hash: SHA256(user_id + content_hash + ts_minute)\n  Store: SET idem:{hash} {post_id} EX 86400\n  On retry: GET idem:{hash} → return original post_id\n\nLike idempotency:\n  SADD liked_by:{post_id} {user_id}\n  Returns 0 if already member → skip INCR, return 200.\n  SADD is atomic — no race condition.\n\nFan-out worker dedup:\n  ZADD NX feed:{follower_id} score post_id\n  NX = add only if not exists. Replay-safe.","height":211.25,"link":null,"strokeColor":"#334155","fillStyle":"solid","groupIds":[],"versionNonce":1317346044,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":2594.8699240820788,"angle":0,"y":2302.6542856894257,"width":355.341552734375},{"isDeleted":false,"locked":false,"strokeColor":"#fca5a5","link":null,"roughness":1,"groupIds":[],"index":"bId","backgroundColor":"#fff1f2","angle":0,"fillStyle":"solid","strokeWidth":1,"version":121,"roundness":{"type":3},"type":"rectangle","updated":1772748823814,"id":"SMZPbpvT6PAgnZdLz-t3-","x":1808.8699240820786,"seed":932495228,"boundElements":[],"y":2474.6542856894257,"opacity":100,"height":120,"width":1560,"frameId":null,"strokeStyle":"solid","versionNonce":1772116860},{"seed":1246195708,"strokeStyle":"solid","id":"OT9bvx8SfesLCBguiO7gX","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1772748823814,"locked":false,"text":"Dead Letter Queue (DLQ) — What Triggers It + What Ops Does With It","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bIe","roundness":null,"containerId":null,"originalText":"Dead Letter Queue (DLQ) — What Triggers It + What Ops Does With It","height":18.75,"link":null,"strokeColor":"#b91c1c","fillStyle":"solid","groupIds":[],"versionNonce":1887407100,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1822.8699240820786,"angle":0,"y":2486.6542856894257,"width":537.629638671875},{"seed":1146097788,"strokeStyle":"solid","id":"QMJXG3BFxNd46Ai1pxYnS","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772748823814,"locked":false,"text":"Triggers DLQ after: 3 retries all fail. Causes: malformed message, permanently unavailable dependency, post_id referencing deleted post.\nDLQ = Kafka topic fan_out_dlq with 7-day retention.\nOps process: 1) Alert fires (dlq_count > 0 for 5min)  2) Inspect payload + stack trace  3) Fix root cause  4) Replay via kafka-consumer-groups --reset-offsets\n5) Monitor fan-out lag returns to 0  |  SLA: DLQ messages replayed within 4 hours of alert.","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bIf","roundness":null,"containerId":null,"originalText":"Triggers DLQ after: 3 retries all fail. Causes: malformed message, permanently unavailable dependency, post_id referencing deleted post.\nDLQ = Kafka topic fan_out_dlq with 7-day retention.\nOps process: 1) Alert fires (dlq_count > 0 for 5min)  2) Inspect payload + stack trace  3) Fix root cause  4) Replay via kafka-consumer-groups --reset-offsets\n5) Monitor fan-out lag returns to 0  |  SLA: DLQ messages replayed within 4 hours of alert.","height":65,"link":null,"strokeColor":"#334155","fillStyle":"solid","groupIds":[],"versionNonce":623160444,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1822.8699240820786,"angle":0,"y":2510.6542856894257,"width":1015.5199584960938},{"isDeleted":false,"locked":false,"strokeColor":"#4c1d95","link":null,"roughness":1,"groupIds":[],"index":"bIg","backgroundColor":"#4c1d95","angle":0,"fillStyle":"solid","strokeWidth":1,"version":121,"roundness":{"type":3},"type":"rectangle","updated":1772748823814,"id":"ihch3L7jI9jL6m94-Pldn","x":1808.8699240820786,"seed":628138236,"boundElements":[],"y":2604.6542856894257,"opacity":100,"height":40,"width":1560,"frameId":null,"strokeStyle":"solid","versionNonce":961658108},{"seed":623583612,"strokeStyle":"solid","id":"nlE_xfotnSJG3mSZ4eUCy","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772748823814,"locked":false,"text":"Key patterns: Outbox for Kafka reliability  |  ZADD NX for replay safety  |  Jitter formula: min(100*2^n + rand(100), 30000)ms  |  409 is non-retryable","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bIh","roundness":null,"containerId":null,"originalText":"Key patterns: Outbox for Kafka reliability  |  ZADD NX for replay safety  |  Jitter formula: min(100*2^n + rand(100), 30000)ms  |  409 is non-retryable","height":17.5,"link":null,"strokeColor":"#f5f3ff","fillStyle":"solid","groupIds":[],"versionNonce":1451801980,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1822.8699240820786,"angle":0,"y":2617.6542856894257,"width":1037.74853515625},{"isDeleted":false,"locked":false,"strokeColor":"#cbd5e1","link":null,"roughness":1,"groupIds":[],"index":"bIi","backgroundColor":"#f8fafc","angle":0,"fillStyle":"solid","strokeWidth":1,"version":121,"roundness":{"type":3},"type":"rectangle","updated":1772748823814,"id":"UB6gz_9ikVox-2gPwtkKG","x":1808.8699240820786,"seed":985764348,"boundElements":[],"y":2696.6542856894257,"opacity":100,"height":1010,"width":1560,"frameId":null,"strokeStyle":"solid","versionNonce":638299644},{"isDeleted":false,"locked":false,"strokeColor":"#134e4a","link":null,"roughness":1,"groupIds":[],"index":"bIj","backgroundColor":"#134e4a","angle":0,"fillStyle":"solid","strokeWidth":1,"version":121,"roundness":{"type":3},"type":"rectangle","updated":1772748823814,"id":"c0YfznrP1Wpt007uwIEGY","x":1808.8699240820786,"seed":624292476,"boundElements":[],"y":2696.6542856894257,"opacity":100,"height":46,"width":1560,"frameId":null,"strokeStyle":"solid","versionNonce":1490849404},{"seed":1934246652,"strokeStyle":"solid","id":"NHpwh8EvbyXhCXTSCnSMO","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":21,"opacity":100,"verticalAlign":"top","updated":1772748823814,"locked":false,"text":"STEP 10  —  NFR Coverage Analysis","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bIk","roundness":null,"containerId":null,"originalText":"STEP 10  —  NFR Coverage Analysis","height":26.25,"link":null,"strokeColor":"#f0fdf4","fillStyle":"solid","groupIds":[],"versionNonce":800939772,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":2228.8699240820788,"angle":0,"y":2709.6542856894257,"width":376.59283447265625},{"isDeleted":false,"locked":false,"strokeColor":"#fca5a5","link":null,"roughness":1,"groupIds":[],"index":"bIl","backgroundColor":"#fff1f2","angle":0,"fillStyle":"solid","strokeWidth":1,"version":121,"roundness":{"type":3},"type":"rectangle","updated":1772748823814,"id":"jIXBbrdwgJC-o3fv6aVsn","x":1808.8699240820786,"seed":192971644,"boundElements":[],"y":2752.6542856894257,"opacity":100,"height":195,"width":502,"frameId":null,"strokeStyle":"solid","versionNonce":53485436},{"seed":874165244,"strokeStyle":"solid","id":"ljKi9X8wftCaXERWDghU1","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1772748823814,"locked":false,"text":"Availability  99.99%","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bIm","roundness":null,"containerId":null,"originalText":"Availability  99.99%","height":18.75,"link":null,"strokeColor":"#b91c1c","fillStyle":"solid","groupIds":[],"versionNonce":1266077692,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1822.8699240820786,"angle":0,"y":2764.6542856894257,"width":144.16493225097656},{"seed":454743164,"strokeStyle":"solid","id":"gieXLWVhjXDyThhnSy_JT","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772748823814,"locked":false,"text":"Covered: multi-AZ API fleet, Redis Cluster auto-failover,\nKafka replication x3, Aurora Multi-AZ (30s RTO), CDN\nserves media even if origin is down.\nViolated by: all three failovers happening simultaneously\n(cascade). Probability: very low but non-zero.\nGap: Kafka rebalance creates 10-30s fan-out pause.","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bIn","roundness":null,"containerId":null,"originalText":"Covered: multi-AZ API fleet, Redis Cluster auto-failover,\nKafka replication x3, Aurora Multi-AZ (30s RTO), CDN\nserves media even if origin is down.\nViolated by: all three failovers happening simultaneously\n(cascade). Probability: very low but non-zero.\nGap: Kafka rebalance creates 10-30s fan-out pause.","height":97.5,"link":null,"strokeColor":"#334155","fillStyle":"solid","groupIds":[],"versionNonce":680751228,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1822.8699240820786,"angle":0,"y":2788.6542856894257,"width":360.60650634765625},{"isDeleted":false,"locked":false,"strokeColor":"#fca5a5","link":null,"roughness":1,"groupIds":[],"index":"bIo","backgroundColor":"#fff1f2","angle":0,"fillStyle":"solid","strokeWidth":1,"version":121,"roundness":{"type":3},"type":"rectangle","updated":1772748823814,"id":"lyJRdo06o2-PE07T9stSw","x":2328.8699240820788,"seed":1581442300,"boundElements":[],"y":2752.6542856894257,"opacity":100,"height":195,"width":502,"frameId":null,"strokeStyle":"solid","versionNonce":1783103740},{"seed":320136572,"strokeStyle":"solid","id":"cW3o4BM2FQ49Di9ufhcDS","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1772748823814,"locked":false,"text":"Latency  P50<80ms  P99<500ms","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bIp","roundness":null,"containerId":null,"originalText":"Latency  P50<80ms  P99<500ms","height":18.75,"link":null,"strokeColor":"#b91c1c","fillStyle":"solid","groupIds":[],"versionNonce":404128124,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":2342.8699240820788,"angle":0,"y":2764.6542856894257,"width":240.94483947753906},{"seed":1322440188,"strokeStyle":"solid","id":"BI-ER03T2ZLpSthsg8vdh","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772748823814,"locked":false,"text":"Covered: Redis ZRANGE P50~5ms, CDN for media zero\nlatency, precomputed ranked feeds, post metadata cache.\nViolated by: cold cache after mass Redis eviction — all\nusers hit DB simultaneously (thundering herd).\nGap: P99 during cache miss storms not fully protected\nwithout request coalescing (dog-pile prevention lock).","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bIq","roundness":null,"containerId":null,"originalText":"Covered: Redis ZRANGE P50~5ms, CDN for media zero\nlatency, precomputed ranked feeds, post metadata cache.\nViolated by: cold cache after mass Redis eviction — all\nusers hit DB simultaneously (thundering herd).\nGap: P99 during cache miss storms not fully protected\nwithout request coalescing (dog-pile prevention lock).","height":97.5,"link":null,"strokeColor":"#334155","fillStyle":"solid","groupIds":[],"versionNonce":2034299388,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":2342.8699240820788,"angle":0,"y":2788.6542856894257,"width":365.03948974609375},{"isDeleted":false,"locked":false,"strokeColor":"#fca5a5","link":null,"roughness":1,"groupIds":[],"index":"bIr","backgroundColor":"#fff1f2","angle":0,"fillStyle":"solid","strokeWidth":1,"version":121,"roundness":{"type":3},"type":"rectangle","updated":1772748823814,"id":"OR03hKp8RNFlr-daFUyw_","x":2856.8699240820783,"seed":780056188,"boundElements":[],"y":2752.6542856894257,"opacity":100,"height":195,"width":512,"frameId":null,"strokeStyle":"solid","versionNonce":482955900},{"seed":1591379708,"strokeStyle":"solid","id":"hMVYMJVqkLumY21Cm3TlK","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1772748823814,"locked":false,"text":"Throughput  232K read 