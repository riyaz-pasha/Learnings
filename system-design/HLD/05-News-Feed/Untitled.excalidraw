mple: Friend posts photo — slides in\nat top of your feed within 3 seconds.\nHidden: Millions of persistent WS\/SSE\nconnections are expensive. Push all\nupdates vs ping-then-pull tradeoff.","version":7,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"at","roundness":null,"containerId":"T8tB7PyIubqaVY4zWqbXq","originalText":"FR7 — Real-time Feed Updates [P1]\nNew posts appear without refresh.\nExample: Friend posts photo — slides in\nat top of your feed within 3 seconds.\nHidden: Millions of persistent WS\/SSE\nconnections are expensive. Push all\nupdates vs ping-then-pull tradeoff.","height":122.5,"link":null,"strokeColor":"#f59e0b","fillStyle":"solid","groupIds":[],"versionNonce":389107708,"textAlign":"center","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-143.19970703125,"angle":0,"y":-4529.75,"width":273.280029296875},{"isDeleted":false,"locked":false,"strokeColor":"#f59e0b","link":null,"roughness":1,"groupIds":[],"index":"au","backgroundColor":"#fff3bf","angle":0,"fillStyle":"solid","strokeWidth":2,"version":5,"roundness":{"type":3},"type":"rectangle","updated":1772747707441,"id":"3B0kVX9AZawfSkGFi9H3a","x":268.4403076171875,"seed":830369348,"boundElements":[{"type":"text","id":"uFz57t-dUAiYKNZT3fXL7"}],"y":-4546,"opacity":100,"height":155,"width":490,"frameId":null,"strokeStyle":"solid","versionNonce":1770022908},{"seed":2006975940,"strokeStyle":"solid","id":"uFz57t-dUAiYKNZT3fXL7","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"middle","updated":1772747707447,"locked":false,"text":"FR8 — Feed Ranking [P1]\nPosts ranked by relevance not just time.\nExample: BFF's post ranks above old\nbrand follow using engagement signals.\nHidden: ML inference at read time adds\n10-50ms. Must precompute scores or\ncache ranked results per user.","version":7,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"av","roundness":null,"containerId":"3B0kVX9AZawfSkGFi9H3a","originalText":"FR8 — Feed Ranking [P1]\nPosts ranked by relevance not just time.\nExample: BFF's post ranks above old\nbrand follow using engagement signals.\nHidden: ML inference at read time adds\n10-50ms. Must precompute scores or\ncache ranked results per user.","height":122.5,"link":null,"strokeColor":"#f59e0b","fillStyle":"solid","groupIds":[],"versionNonce":419295356,"textAlign":"center","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":374.89630126953125,"angle":0,"y":-4529.75,"width":277.0880126953125},{"isDeleted":false,"locked":false,"strokeColor":"#f59e0b","link":null,"roughness":1,"groupIds":[],"index":"aw","backgroundColor":"#fff3bf","angle":0,"fillStyle":"solid","strokeWidth":2,"version":5,"roundness":{"type":3},"type":"rectangle","updated":1772747707441,"id":"xDkRwco0FT7dNbq427XWo","x":788.4403076171875,"seed":1151511876,"boundElements":[{"type":"text","id":"KIv7l8RyIryz47zeY1FFi"}],"y":-4546,"opacity":100,"height":155,"width":490,"frameId":null,"strokeStyle":"solid","versionNonce":27920508},{"seed":971269316,"strokeStyle":"solid","id":"KIv7l8RyIryz47zeY1FFi","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"middle","updated":1772747707447,"locked":false,"text":"FR9 — Infinite Scroll \/ Pagination [P0]\nOlder posts load as user scrolls.\nExample: User is 200 posts deep — next\n20 load with no duplicates or gaps.\nHidden: Cursor-based pagination on a\nLIVE ranked feed is hard — new posts\nshift offsets, breaking page-based cursors.","version":7,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"ax","roundness":null,"containerId":"xDkRwco0FT7dNbq427XWo","originalText":"FR9 — Infinite Scroll \/ Pagination [P0]\nOlder posts load as user scrolls.\nExample: User is 200 posts deep — next\n20 load with no duplicates or gaps.\nHidden: Cursor-based pagination on a\nLIVE ranked feed is hard — new posts\nshift offsets, breaking page-based cursors.","height":122.5,"link":nu