{"type":3},"type":"rectangle","updated":1772747707441,"id":"SEoEannLIZ7SiqTQT2wQp","x":-251.5596923828125,"seed":1030534724,"boundElements":[],"y":5111,"opacity":100,"height":215,"width":740,"frameId":null,"strokeStyle":"solid","versionNonce":1648329724},{"seed":2122665412,"strokeStyle":"solid","id":"o7qH0HDQZzBNVXcbYJ5vO","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":18,"opacity":100,"verticalAlign":"top","updated":1772747707441,"locked":false,"text":"Data Consistency Model Per Data Type","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b5r","roundness":null,"containerId":null,"originalText":"Data Consistency Model Per Data Type","height":22.5,"link":null,"strokeColor":"#b45309","fillStyle":"solid","groupIds":[],"versionNonce":107465156,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-241.5596923828125,"angle":0,"y":5119,"width":350.02780151367188},{"seed":1335817540,"strokeStyle":"solid","id":"mWmxoT9TwWZ6dspCLeCwK","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772747707441,"locked":false,"text":"Posts content:        Eventual  |  Lag: <500ms  |  OK: user sees post ~500ms after publish\nSocial graph (follows): Eventual  |  Lag: <500ms  |  RYOW via session affinity (sticky 2s)\nFeed cache (Redis):   Per-region  |  Populated by local fan-out workers\nLike counts:          Eventual  |  Lag: 30s  |  Cosmetic — users tolerate stale counts\nUser auth \/ JWT:      Local verify |  No cross-region call — JWT signed with shared key\nUser account status:  Strong  |  Sync replication — deleted\/suspended must be immediate\nIdempotency keys:     Per-region  |  Cross-region duplicate possible but rare (acceptable)","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b5s","roundness":null,"containerId":null,"originalText":"Posts content:        Eventual  |  Lag: <500ms  |  OK: user sees post ~500ms after publish\nSocial graph (follows): Eventual  |  Lag: <500ms  |  RYOW via session affinity (sticky 2s)\nFeed cache (Redis):   Per-region  |  Populated by local fan-out workers\nLike counts:          Eventual  |  Lag: 30s  |  Cosmetic — users tolerate stale counts\nUser auth \/ JWT:      Local verify |  No cross-region call — JWT signed with shared key\nUser account status:  Strong  |  Sync replication — deleted\/suspended must be immediate\nIdempotency keys:     Per-region  |  Cross-region duplicate possible but rare (acceptable)","height":122.5,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":1277535356,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-241.5596923828125,"angle":0,"y":5145,"width":625.757080078125},{"isDeleted":false,"locked":false,"strokeColor":"#ef4444","link":null,"roughness":1,"groupIds":[],"index":"b5t","backgroundColor":"#ffc9c9","angle":0,"fillStyle":"solid","strokeWidth":2,"version":5,"roundness":{"type":3},"type":"rectangle","updated":1772747707441,"id":"FJNLLG_yxMC2NeC8zTkOx","x":508.4403076171875,"seed":773303492,"boundElements":[],"y":5111,"opacity":100,"height":215,"width":770,"frameId":null,"strokeStyle":"solid","versionNonce":768733508},{"seed":999126084,"strokeStyle":"solid","id":"k12gXqJNn-xBSYLFwPCv1","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":18,"opacity":100,"verticalAlign":"top","updated":1772747707441,"locked":false,"text":"Failover Sequence: Region A (US-East) Dies","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b5u","roundness":null,"containerId":null,"originalText":"Failover Sequence: Region A (US-East) Dies","height":22.5,"link":null,"strokeColor":"#b91c1c","fillStyle":"solid","groupIds":[],"versionNonce":1165210876,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":518.4403076171875,"angle":0,"y":5119,"width":383.52578735351562},{"seed":903760836,"strokeStyle":"solid","id":"GBy7WkvV1gzYx7j4IxGqK","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772747707441,"locked":false,"text":"T+0s:   US-East API fleet stops responding\nT+10s:  Route53 health checks fail (2x5s interval)\nT+30s:  DNS TTL expires — traffic reroutes to EU-West\nT+31s:  Aurora Global promotes EU-West replica (<1s)\nT+32s:  EU-West becomes new primary writer\nT+35s:  Social graph writes now accepted in EU-West\nT+60s:  Ops paged — incident declared\nT+4h:   US-East restored, resyncs from EU-West\nT+8h:   Traffic gradually re-routed back to US-East\n\nRPO: <1s (Aurora Global sync replication to EU-West)\nRTO: ~30s (DNS propagation + Aurora promote)","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b5v","roundness":null,"containerId":null,"originalText":"T+0s:   US-East API fleet stops responding\nT+10s:  Route53 health checks fail (2x5s interval)\nT+30s:  DNS TTL expires — traffic reroutes to EU-West\nT+31s:  Aurora Global promotes EU-West replica (<1s)\nT+32s:  EU-West becomes new primary writer\nT+35s:  Social graph writes now accepted in EU-West\nT+60s:  Ops paged — incident declared\nT+4h:   US-East restored, resyncs from EU-West\nT+8h:   Traffic gradually re-routed back to US-East\n\nRPO: <1s (Aurora Global sync replication to EU-West)\nRTO: ~30s (DNS propagation + Aurora promote)","height":210,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":1149970628,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":518.4403076171875,"angle":0,"y":5145,"width":396.157470703125},{"isDeleted":false,"locked":false,"strokeColor":"#8b5cf6","link":null,"roughness":1,"groupIds":[],"index":"b5w","backgroundColor":"#d0bfff","angle":0,"fillStyle":"solid","strokeWidth":2,"version":5,"roundness":{"type":3},"type":"rectangle","updated":1772747707441,"id":"87huh_XTfWVcBaop9Krtv","x":-251.5596923828125,"seed":1864905540,"boundElements":[],"y":5341,"opacity":100,"height":150,"width":1530,"frameId":null,"strokeStyle":"solid","versionNonce":2074850684},{"seed":1170811588,"strokeStyle":"solid","id":"P_0MxfMsga0g6zNAlXPpG","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":18,"opacity":100,"verticalAlign":"top","updated":1772747707441,"locked":false,"text":"Data Sovereignty + Compliance","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b5x","roundness":null,"containerId":null,"originalText":"Data Sovereignty + Compliance","height":22.5,"link":null,"strokeColor":"#5b21b6","fillStyle":"solid","groupIds":[],"versionNonce":774991940,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-241.5596923828125,"angle":0,"y":5349,"width":268.14581298828125},{"seed":476000836,"strokeStyle":"solid","id":"YH9H2LvFqEOvMvrjuG17S","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772747707441,"locked":false,"text":"GDPR (EU): EU user posts, social graph, and profile data must reside in EU-West ONLY. No replication to US or APAC.\n  Implementation: user_home_region field on user record. Replication topology respects regional boundaries.\n  EU users' data physically isolated in EU-West S3 bucket + Aurora EU instance + Cassandra EU rack.\n\nIndia \/ APAC Data Localization: Some countries require local storage. APAC region stores local user data locally.\nChina: Separate deployment entirely (different legal entity, no cross-border data flow). Not in scope for this design.\n\nImplication: Cannot freely replicate ALL posts globally. Cross-region fan-out for EU->APAC followers only replicates\nthe post_id and CDN URL — not PII content. PII stays in home region. CDN serves content from home region S3.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b5y","roundness":null,"containerId":null,"originalText":"GDPR (EU): EU user posts, social graph, and profile data must reside in EU-West ONLY. No replication to US or APAC.\n  Implementation: user_home_region field on user record. Replication topology respects regional boundaries.\n  EU users' data physically isolated in EU-West S3 bucket + Aurora EU instance + Cassandra EU rack.\n\nIndia \/ APAC Data Localization: Some countries require local storage. APAC region stores local user data locally.\nChina: Separate deployment entirely (different legal entity, no cross-border data flow). Not in scope for this design.\n\nImplication: Cannot freely replicate ALL posts globally. Cross-region fan-out for EU->APAC followers only replicates\nthe post_id and CDN URL — not PII content. PII stays in home region. CDN serves content from home region S3.","height":157.5,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":470787580,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-241.5596923828125,"angle":0,"y":5375,"width":812.62884521484375},{"seed":1372080580,"strokeStyle":"solid","id":"0UOqGaxokSnWE10KtNdbL","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":26,"opacity":100,"verticalAlign":"top","updated":1772747707439,"locked":false,"text":"NEWS FEED — Step 12: Trade-off Decisions","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b5z","roundness":null,"containerId":null,"originalText":"NEWS FEED — Step 12: Trade-off Decisions","height":32.5,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":1158489212,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":108.4403076171875,"angle":0,"y":5597,"width":568.85369873046875},{"seed":958558532,"strokeStyle":"solid","id":"C40P2ylHToZw6kqLzpwDj","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":16,"opacity":100,"verticalAlign":"top","updated":1772747707439,"locked":false,"text":"Decision | Over | Because (3 reasons) | Costs | Revisit if","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b60","roundness":null,"containerId":null,"originalText":"Decision | Over | Because (3 reasons) | Costs | Revisit if","height":20,"link":null,"strokeColor":"#757575","fillStyle":"solid","groupIds":[],"versionNonce":896218364,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":108.4403076171875,"angle":0,"y":5631,"width":447.6795654296875},{"isDeleted":false,"locked":false,"strokeColor":"#4a9eed","link":null,"roughness":1,"groupIds":[],"index":"b61","backgroundColor":"#a5d8ff","angle":0,"fillStyle":"solid","strokeWidth":2,"version":5,"roundness":{"type":3},"type":"rectangle","updated":1772747707439,"id":"U106H541WXzGqUgE163Nx","x":-251.5596923828125,"seed":298559684,"boundElements":[],"y":5657,"opacity":100,"height":220,"width":740,"frameId":null,"strokeStyle":"solid","versionNonce":11744636},{"seed":2137124932,"strokeStyle":"solid","id":"WF_EOf2PP9fW_DgU62LKI","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":18,"opacity":100,"verticalAlign":"top","updated":1772747707439,"locked":false,"text":"Decision 1 — DB for Posts: PostgreSQL (sharded)","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b62","roundness":null,"containerId":null,"originalText":"Decision 1 — DB for Posts: PostgreSQL (sharded)","height":22.5,"link":null,"strokeColor":"#1d4ed8","fillStyle":"solid","groupIds":[],"versionNonce":338109948,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-241.5596923828125,"angle":0,"y":5665,"width":446.93966674804688},{"seed":29575108,"strokeStyle":"solid","id":"79h50OlMil9Ac1xZ_Z_7z","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772747707439,"locked":false,"text":"Over: Cassandra, MongoDB","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b63","roundness":null,"containerId":null,"originalText":"Over: Cassandra, MongoDB","height":17.5,"link":null,"strokeColor":"#374151","fillStyle":"solid","groupIds":[],"versionNonce":1690895996,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-241.5596923828125,"angle":0,"y":5691,"width":183.34384155273438},{"seed":1829613380,"strokeStyle":"solid","id":"HFbLKweYNrQG3jbRvpFb8","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772747707439,"locked":false,"text":"Because:\n1. Cache-miss feed query needs WHERE author_id IN (...) AND\n   created_at > X — Cassandra forces one table per query pattern\n2. Post schema is well-defined and relational — no flexible-schema benefit\n3. PostgreSQL sharded by user_id gives horizontal scale PLUS\n   full SQL expressiveness for ranking and filtering","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b64","roundness":null,"containerId":null,"originalText":"Because:\n1. Cache-miss feed query needs WHERE author_id IN (...) AND\n   created_at > X — Cassandra forces one table per query pattern\n2. Post schema is well-defined and relational — no flexible-schema benefit\n3. PostgreSQL sharded by user_id gives horizontal scale PLUS\n   full SQL expressiveness for ranking and filtering","height":105,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":2002441980,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-241.5596923828125,"angle":0,"y":5711,"width":504.55938720703125},{"seed":1637820100,"strokeStyle":"solid","id":"foa6G_I-zKI7nID7eTRcq","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772747707439,"locked":false,"text":"Costs: Cross-shard queries impossible (must be app-layer aggregation).\nSchema migrations on sharded PG are operationally painful.\nNo built-in multi-region replication (need Aurora Global Database).","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b65","roundness":null,"containerId":null,"originalText":"Costs: Cross-shard queries impossible (must be app-layer aggregation).\nSchema migrations on sharded PG are operationally painful.\nNo built-in multi-region replication (need Aurora Global Database).","height":52.5,"link":null,"strokeColor":"#b45309","fillStyle":"solid","groupIds":[],"versionNonce":1751029628,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-241.5596923828125,"angle":0,"y":5807,"width":481.17938232421875},{"seed":1142271556,"strokeStyle":"solid","id":"o1KTlcaG52RxCQ-4u4j3C","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772747707439,"locked":false,"text":"Revisit if: Post schema becomes truly dynamic (user-defined fields),\nor write throughput exceeds 50K posts\/sec sustained.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b66","roundness":null,"containerId":null,"originalText":"Revisit if: Post schema becomes truly dynamic (user-defined fields),\nor write throughput exceeds 50K posts\/sec sustained.","height":35,"link":null,"strokeColor":"#6b7280","fillStyle":"solid","groupIds":[],"versionNonce":1947617276,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-241.5596923828125,"angle":0,"y":5849,"width":461.285400390625},{"isDeleted":false,"locked":false,"strokeColor":"#f59e0b","link":null,"roughness":1,"groupIds":[],"index":"b67","backgroundColor":"#ffd8a8","angle":0,"fillStyle":"solid","strokeWidth":2,"version":5,"roundness":{"type":3},"type":"rectangle","updated":1772747707439,"id":"ikLSvXwKvmOj9m4ELBlxI","x":508.4403076171875,"seed":894387652,"boundElements":[],"y":5657,"opacity":100,"height":220,"width":770,"frameId":null,"strokeStyle":"solid","versionNonce":2122573948},{"seed":174714180,"strokeStyle":"solid","id":"k117JY5_TzEhF8Gorp8Ux","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":18,"opacity":100,"verticalAlign":"top","updated":1772747707439,"locked":false,"text":"Decision 2 — Social Graph: Cassandra","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b68","roundness":null,"containerId":null,"originalText":"Decision 2 — Social Graph: Cassandra","height":22.5,"link":null,"strokeColor":"#b45309","fillStyle":"solid","groupIds":[],"versionNonce":459897084,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":518.4403076171875,"angle":0,"y":5665,"width":331.66775512695312},{"seed":1153672388,"strokeStyle":"solid","id":"IJfrrCfdTGSz87Ome4_SO","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772747707439,"locked":false,"text":"Over: PostgreSQL, Neo4j, Redis","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b69","roundness":null,"containerId":null,"originalText":"Over: PostgreSQL, Neo4j, Redis","height":17.5,"link":null,"strokeColor":"#374151","fillStyle":"solid","groupIds":[],"versionNonce":373881212,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":518.4403076171875,"angle":0,"y":5691,"width":215.13772583007812},{"seed":167406660,"strokeStyle":"solid","id":"pgmAjtRCo3vQpMbSijY1o","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772747707439,"locked":false,"text":"Because:\n1. Only query ever run: get all followees for user X — Cassandra\n   wide-row (partition=follower_id, cols=followees) is O(1)\n2. Write throughput: 500M users x follow\/unfollow events —\n   Cassandra's LSM tree handles write-heavy workloads natively\n3. Horizontal scale: add nodes, range rebalances automatically.\n   No manual sharding logic needed unlike PostgreSQL","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b6A","roundness":null,"containerId":null,"originalText":"Because:\n1. Only query ever run: get all followees for user X — Cassandra\n   wide-row (partition=follower_id, cols=followees) is O(1)\n2. Write throughput: 500M users x follow\/unfollow events —\n   Cassandra's LSM tree handles write-heavy workloads natively\n3. Horizontal scale: add nodes, range rebalances automatically.\n   No manual sharding logic needed unlike PostgreSQL","height":122.5,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":2053401084,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":518.4403076171875,"angle":0,"y":5711,"width":434.8675537109375},{"seed":468468676,"strokeStyle":"solid","id":"qFLP_a99T3eoCIwcTiBu7","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772747707439,"locked":false,"text":"Costs: Eventual consistency by default — RYOW needs\nLOCAL_QUORUM write + read (2x latency vs eventual).\nNo ad-hoc queries — must design schema around access patterns.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b6B","roundness":null,"containerId":null,"originalText":"Costs: Eventual consistency by default — RYOW needs\nLOCAL_QUORUM write + read (2x latency vs eventual).\nNo ad-hoc queries — must design schema around access patterns.","height":52.5,"link":null,"strokeColor":"#b45309","fillStyle":"solid","groupIds":[],"versionNonce":448645756,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":518.4403076171875,"angle":0,"y":5807,"width":449.427490234375},{"seed":1354181444,"strokeStyle":"solid","id":"34gnrYCerTof3iG0pUEPN","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772747707439,"locked":false,"text":"Revisit if: Graph traversal queries needed (friend-of-friend\nrecommendations at depth >1) — Neo4j becomes compelling.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b6C","roundness":null,"containerId":null,"originalText":"Revisit if: Graph traversal queries needed (friend-of-friend\nrecommendations at depth >1) — Neo4j becomes compelling.","height":35,"link":null,"strokeColor":"#6b7280","fillStyle":"solid","groupIds":[],"versionNonce":437721852,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":518.4403076171875,"angle":0,"y":5849,"width":401.89743041992188},{"isDeleted":false,"locked":false,"strokeColor":"#ef4444","link":null,"roughness":1,"groupIds":[],"index":"b6D","backgroundColor":"#ffc9c9","angle":0,"fillStyle":"solid","strokeWidth":2,"version":5,"roundness":{"type":3},"type":"rectangle","updated":1772747707439,"id":"MIqRFTC0POARiIa06oB1p","x":-251.5596923828125,"seed":179905220,"boundElements":[],"y":5894,"opacity":100,"height":220,"width":740,"frameId":null,"strokeStyle":"solid","versionNonce":1928485756},{"seed":814754372,"strokeStyle":"solid","id":"0LGxbZz28eR1maC7RD3IX","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":18,"opacity":100,"verticalAlign":"top","updated":1772747707439,"locked":false,"text":"Decision 3 — Async Fan-out: Kafka over RabbitMQ \/ sync","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b6E","roundness":null,"containerId":null,"originalText":"Decision 3 — Async Fan-out: Kafka over RabbitMQ \/ sync","height":22.5,"link":null,"strokeColor":"#b91c1c","fillStyle":"solid","groupIds":[],"versionNonce":2140244988,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-241.5596923828125,"angle":0,"y":5902,"width":508.0496826171875},{"seed":622477764,"strokeStyle":"solid","id":"tJo8FeBBcMmRbLdqF4J_q","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772747707439,"locked":false,"text":"Over: RabbitMQ, SQS, synchronous Redis fan-out","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b6F","roundness":null,"containerId":null,"originalText":"Over: RabbitMQ, SQS, synchronous Redis fan-out","height":17.5,"link":null,"strokeColor":"#374151","fillStyle":"solid","groupIds":[],"versionNonce":32943228,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-241.5596923828125,"angle":0,"y":5928,"width":336.82568359375},{"seed":1064659268,"strokeStyle":"solid","id":"ewFaDPofwG-pM4n4FMxMz","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772747707439,"locked":false,"text":"Because:\n1. Replay: Kafka retains messages — crashed worker catches up\n   from exact offset. RabbitMQ deletes on ACK, no replay.\n2. Throughput: Kafka handles 69 MB\/s fan-out + 46 MB\/s likes.\n   RabbitMQ struggles above ~50K msg\/sec without tuning.\n3. Consumer groups: adding fan-out worker partitions requires\n   zero producer changes. Horizontal scale is operational, not code.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b6G","roundness":null,"containerId":null,"originalText":"Because:\n1. Replay: Kafka retains messages — crashed worker catches up\n   from exact offset. RabbitMQ deletes on ACK, no replay.\n2. Throughput: Kafka handles 69 MB\/s fan-out + 46 MB\/s likes.\n   RabbitMQ struggles above ~50K msg\/sec without tuning.\n3. Consumer groups: adding fan-out worker partitions requires\n   zero producer changes. Horizontal scale is operational, not code.","height":122.5,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":736345340,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-241.5596923828125,"angle":0,"y":5948,"width":456.8614501953125},{"seed":1124049092,"strokeStyle":"solid","id":"W2BaPO0zyr_42QtAlkalD","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772747707439,"locked":false,"text":"Costs: Operational complexity — ZooKeeper\/KRaft, partition\nrebalancing, consumer lag monitoring. Kafka is not trivial to run.\nAt-least-once delivery requires idempotent consumers (ZADD NX).","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b6H","roundness":null,"containerId":null,"originalText":"Costs: Operational complexity — ZooKeeper\/KRaft, partition\nrebalancing, consumer lag monitoring. Kafka is not trivial to run.\nAt-least-once delivery requires idempotent consumers (ZADD NX).","height":52.5,"link":null,"strokeColor":"#b45309","fillStyle":"solid","groupIds":[],"versionNonce":651869564,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-241.5596923828125,"angle":0,"y":6044,"width":449.04953002929688},{"seed":1465313348,"strokeStyle":"solid","id":"4somQjFnODrkS6wQBVraS","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772747707439,"locked":false,"text":"Revisit if: Fan-out volume drops below 1K posts\/sec — SQS is\nsimpler to operate for modest throughput requirements.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b6I","roundness":null,"containerId":null,"originalText":"Revisit if: Fan-out volume drops below 1K posts\/sec — SQS is\nsimpler to operate for modest throughput requirements.","height":35,"link":null,"strokeColor":"#6b7280","fillStyle":"solid","groupIds":[],"versionNonce":471707132,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-241.5596923828125,"angle":0,"y":6086,"width":424.36746215820312},{"isDeleted":false,"locked":false,"strokeColor":"#ec4899","link":null,"roughness":1,"groupIds":[],"index":"b6J","backgroundColor":"#eebefa","angle":0,"fillStyle":"solid","strokeWidth":2,"version":5,"roundness":{"type":3},"type":"rectangle","updated":1772747707439,"id":"sNuqW1ekHtjkHHWkRzSOr","x":508.4403076171875,"seed":5849028,"boundElements":[],"y":5894,"opacity":100,"height":220,"width":770,"frameId":null,"strokeStyle":"solid","versionNonce":1018072700},{"seed":371500868,"strokeStyle":"solid","id":"wo3WwLg7vMWrLZGUXEYXo","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":18,"opacity":100,"verticalAlign":"top","updated":1772747707439,"locked":false,"text":"Decision 4 — Feed Cache: Redis Sorted Set","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b6K","roundness":null,"containerId":null,"originalText":"Decision 4 — Feed Cache: Redis Sorted Set","height":22.5,"link":null,"strokeColor":"#9d174d","fillStyle":"solid","groupIds":[],"versionNonce":1229938428,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":518.4403076171875,"angle":0,"y":5902,"width":385.3978271484375},{"seed":1024925380,"strokeStyle":"solid","id":"F76UEh5mQh1KZpTct-dsT","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772747707439,"locked":false,"text":"Over: Memcached, PostgreSQL materialized view, Elasticsearch","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b6L","roundness":null,"containerId":null,"originalText":"Over: Memcached, PostgreSQL materialized view, Elasticsearch","height":17.5,"link":null,"strokeColor":"#374151","fillStyle":"solid","groupIds":[],"versionNonce":444735356,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":518.4403076171875,"angle":0,"y":5928,"width":424.38153076171875},{"seed":1573824068,"strokeStyle":"solid","id":"Du2DjFNyne-68ALGnb-gj","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772747707439,"locked":false,"text":"Because:\n1. Native sorted data structure: ZREVRANGEBYSCORE gives\n   cursor-based pagination with stable ordering — no equivalent in Memcached\n2. Atomic operations: ZADD + ZRANGE are single-command, atomic.\n   No race conditions between write and read on the same feed.\n3. Latency: Redis P99 ~1ms at any scale. Materialized view\n   requires DB round trip (20-50ms) and expensive refresh logic.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b6M","roundness":null,"containerId":null,"originalText":"Because:\n1. Native sorted data structure: ZREVRANGEBYSCORE gives\n   cursor-based pagination with stable ordering — no equivalent in Memcached\n2. Atomic operations: ZADD + ZRANGE are single-command, atomic.\n   No race conditions between write and read on the same feed.\n3. Latency: Redis P99 ~1ms at any scale. Materialized view\n   requires DB round trip (20-50ms) and expensive refresh logic.","height":122.5,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":680054780,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":518.4403076171875,"angle":0,"y":5948,"width":529.3392333984375},{"seed":489242052,"strokeStyle":"solid","id":"fNykjydGzW26mtg1Jx5zG","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772747707439,"locked":false,"text":"Costs: Memory-only (35GB feed cache — manageable but real cost).\nEviction under memory pressure causes thundering herd DB fallback.\nRedis Cluster adds operational complexity vs single Redis instance.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b6N","roundness":null,"containerId":null,"originalText":"Costs: Memory-only (35GB feed cache — manageable but real cost).\nEviction under memory pressure causes thundering herd DB fallback.\nRedis Cluster adds operational complexity vs single Redis instance.","height":52.5,"link":null,"strokeColor":"#b45309","fillStyle":"solid","groupIds":[],"versionNonce":325415036,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":518.4403076171875,"angle":0,"y":6044,"width":463.9034423828125},{"seed":1413801284,"strokeStyle":"solid","id":"qqy6AMfnQjy9wzaWvY9hn","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772747707439,"locked":false,"text":"Revisit if: Feed cache grows beyond 500GB (too expensive for Redis).\nConsider tiered storage: hot users in Redis, warm in disk-backed cache.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b6O","roundness":null,"containerId":null,"originalText":"Revisit if: Feed cache grows beyond 500GB (too expensive for Redis).\nConsider tiered storage: hot users in Redis, warm in disk-backed cache.","height":35,"link":null,"strokeColor":"#6b7280","fillStyle":"solid","groupIds":[],"versionNonce":718930172,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":518.4403076171875,"angle":0,"y":6086,"width":485.11334228515625},{"isDeleted":false,"locked":false,"strokeColor":"#22c55e","link":null,"roughness":1,"groupIds":[],"index":"b6P","backgroundColor":"#b2f2bb","angle":0,"fillStyle":"solid","strokeWidth":2,"version":5,"roundness":{"type":3},"type":"rectangle","updated":1772747707439,"id":"cXsi0D6d5bXv4djbv8SoG","x":-251.5596923828125,"seed":142580932,"boundElements":[],"y":6131,"opacity":100,"height":215,"width":740,"frameId":null,"strokeStyle":"solid","versionNonce":1986560380},{"seed":1668768836,"strokeStyle":"solid","id":"OU-zJMLzgVuA8IkrBFE0d","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":18,"opacity":100,"verticalAlign":"top","updated":1772747707439,"locked":false,"text":"Decision 5 — Consistency Model: Eventual for Feed","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b6Q","roundness":null,"containerId":null,"originalText":"Decision 5 — Consistency Model: Eventual for Feed","height":22.5,"link":null,"strokeColor":"#15803d","fillStyle":"solid","groupIds":[],"versionNonce":1028846076,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-241.5596923828125,"angle":0,"y":6139,"width":451.24172973632812},{"seed":722090948,"strokeStyle":"solid","id":"53fHezBKWEq9RxUdjtAmF","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772747707439,"locked":false,"text":"Over: Strong consistency (sync replication), causal consistency","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b6R","roundness":null,"containerId":null,"originalText":"Over: Strong consistency (sync replication), causal consistency","height":17.5,"link":null,"strokeColor":"#374151","fillStyle":"solid","groupIds":[],"versionNonce":245060220,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-241.5596923828125,"angle":0,"y":6165,"width":427.08355712890625},{"seed":961946436,"strokeStyle":"solid","id":"huvl1VA159x0BQ9lthMTc","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772747707439,"locked":false,"text":"Because:\n1. User tolerance: seeing a post 2-5s late is invisible to users.\n   Seeing a 400ms write latency penalty on every post is very visible.\n2. Cross-region strong consistency costs 200-400ms (network RTT)\n   on every post creation — violates P99 < 1s write SLO.\n3. Throughput: sync cross-region replication serializes writes —\n   throughput limited by slowest region's acknowledgment time.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b6S","roundness":null,"containerId":null,"originalText":"Because:\n1. User tolerance: seeing a post 2-5s late is invisible to users.\n   Seeing a 400ms write latency penalty on every post is very visible.\n2. Cross-region strong consistency costs 200-400ms (network RTT)\n   on every post creation — violates P99 < 1s write SLO.\n3. Throughput: sync cross-region replication serializes writes —\n   throughput limited by slowest region's acknowledgment time.","height":122.5,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":1224975100,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-241.5596923828125,"angle":0,"y":6185,"width":476.18148803710938},{"seed":1958288068,"strokeStyle":"solid","id":"TYfU3DfYcqYOHsqGFjYe1","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772747707439,"locked":false,"text":"Costs: Users may see slightly different feed orderings across devices.\nFollow\/unfollow requires special treatment (RYOW — must be stronger).\nDebug complexity: eventual consistency bugs are hard to reproduce.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b6T","roundness":null,"containerId":null,"originalText":"Costs: Users may see slightly different feed orderings across devices.\nFollow\/unfollow requires special treatment (RYOW — must be stronger).\nDebug complexity: eventual consistency bugs are hard to reproduce.","height":52.5,"link":null,"strokeColor":"#b45309","fillStyle":"solid","groupIds":[],"versionNonce":588112764,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-241.5596923828125,"angle":0,"y":6281,"width":488.02545166015625},{"seed":1204888132,"strokeStyle":"solid","id":"to5s9Bq0Sr3CbzeJEh_8n","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772747707439,"locked":false,"text":"Revisit if: Financial transactions or legal-compliance content added\nto the feed requiring audit trail with strong consistency guarantees.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b6U","roundness":null,"containerId":null,"originalText":"Revisit if: Financial transactions or legal-compliance content added\nto the feed requiring audit trail with strong consistency guarantees.","height":35,"link":null,"strokeColor":"#6b7280","fillStyle":"solid","groupIds":[],"versionNonce":855380988,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-241.5596923828125,"angle":0,"y":6319,"width":469.72735595703125},{"isDeleted":false,"locked":false,"strokeColor":"#8b5cf6","link":null,"roughness":1,"groupIds":[],"index":"b6V","backgroundColor":"#d0bfff","angle":0,"fillStyle":"solid","strokeWidth":2,"version":5,"roundness":{"type":3},"type":"rectangle","updated":1772747707439,"id":"MeK1Fx9L1ikCMnYZk3Jwh","x":508.4403076171875,"seed":427571652,"boundElements":[],"y":6131,"opacity":100,"height":215,"width":770,"frameId":null,"strokeStyle":"solid","versionNonce":1993356412},{"seed":1155031364,"strokeStyle":"solid","id":"IQUphUfs6Nkz7bsK8GOdE","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":18,"opacity":100,"verticalAlign":"top","updated":1772747707439,"locked":false,"text":"Decision 6 — Hybrid Fan-out over Pure Write or Pure Read","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b6W","roundness":null,"containerId":null,"originalText":"Decision 6 — Hybrid Fan-out over Pure Write or Pure Read","height":22.5,"link":null,"strokeColor":"#5b21b6","fillStyle":"solid","groupIds":[],"versionNonce":1548502268,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":518.4403076171875,"angle":0,"y":6139,"width":517.30169677734375},{"seed":289642692,"strokeStyle":"solid","id":"p2PLic29Xq0CwJO8XoLyO","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772747707439,"locked":false,"text":"Over: Pure fan-out-on-write (push) or pure fan-out-on-read (pull)","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b6X","roundness":null,"containerId":null,"originalText":"Over: Pure fan-out-on-write (push) or pure fan-out-on-read (pull)","height":17.5,"link":null,"strokeColor":"#374151","fillStyle":"solid","groupIds":[],"versionNonce":1223837052,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":518.4403076171875,"angle":0,"y":6165,"width":445.32553100585938},{"seed":710664260,"strokeStyle":"solid","id":"tP_AIKs7lC3aOyjLf_Csc","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772747707439,"locked":false,"text":"Because:\n1. Pure write breaks at 10M followers: 10M Redis writes\/post\n   saturates worker pool, creates 30min Kafka consumer lag spikes.\n2. Pure read breaks at 232K QPS: every read recomputes merge\n   from scratch — Twitter abandoned pure pull in 2012 for this reason.\n3. Hybrid amortizes correctly: 99.9% of accounts (<1M followers)\n   get instant precomputed reads. 0.1% (celebrities) merge at read\n   time with only 20 celebrity posts to merge — O(1) per celebrity.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b6Y","roundness":null,"containerId":null,"originalText":"Because:\n1. Pure write breaks at 10M followers: 10M Redis writes\/post\n   saturates worker pool, creates 30min Kafka consumer lag spikes.\n2. Pure read breaks at 232K QPS: every read recomputes merge\n   from scratch — Twitter abandoned pure pull in 2012 for this reason.\n3. Hybrid amortizes correctly: 99.9% of accounts (<1M followers)\n   get instant precomputed reads. 0.1% (celebrities) merge at read\n   time with only 20 celebrity posts to merge — O(1) per celebrity.","height":140,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":570701308,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":518.4403076171875,"angle":0,"y":6185,"width":488.38934326171875},{"seed":402601924,"strokeStyle":"solid","id":"VO2T_W1-Leh5D9VVYr3Q_","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772747707439,"locked":false,"text":"Costs: Two code paths to maintain. 1M follower threshold is a magic\nnumber requiring tuning. Borderline accounts (900K followers) create\nedge cases. Celebrity list per user adds Redis memory overhead.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b6Z","roundness":null,"containerId":null,"originalText":"Costs: Two code paths to maintain. 1M follower threshold is a magic\nnumber requiring tuning. Borderline accounts (900K followers) create\nedge cases. Celebrity list per user adds Redis memory overhead.","height":52.5,"link":null,"strokeColor":"#b45309","fillStyle":"solid","groupIds":[],"versionNonce":1417942652,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":518.4403076171875,"angle":0,"y":6281,"width":468.2294921875},{"seed":910925636,"strokeStyle":"solid","id":"Hq_-JTfP1LX3WXk_GW9Km","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772747707439,"locked":false,"text":"Revisit if: 50%+ of users follow >5 celebrities — merge cost at\nread time dominates and pure precomputation becomes worthwhile.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b6a","roundness":null,"containerId":null,"originalText":"Revisit if: 50%+ of users follow >5 celebrities — merge cost at\nread time dominates and pure precomputation becomes worthwhile.","height":35,"link":null,"strokeColor":"#6b7280","fillStyle":"solid","groupIds":[],"versionNonce":1563682556,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":518.4403076171875,"angle":0,"y":6319,"width":450.50543212890625},{"isDeleted":false,"locked":false,"strokeColor":"#06b6d4","link":null,"roughness":1,"groupIds":[],"index":"b6b","backgroundColor":"#c3fae8","angle":0,"fillStyle":"solid","strokeWidth":2,"version":5,"roundness":{"type":3},"type":"rectangle","updated":1772747707439,"id":"rbOxBJ_jX_22DwDsNmyNp","x":-251.5596923828125,"seed":765400772,"boundElements":[],"y":6362,"opacity":100,"height":185,"width":1530,"frameId":null,"strokeStyle":"solid","versionNonce":1351985020},{"seed":1788321348,"strokeStyle":"solid","id":"p7N16DdXfKj_Gg_iDH10Z","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":18,"opacity":100,"verticalAlign":"top","updated":1772747707439,"locked":false,"text":"Decision 7 — Retry Strategy: Exponential Backoff + Jitter over Fixed Interval","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b6c","roundness":null,"containerId":null,"originalText":"Decision 7 — Retry Strategy: Exponential Backoff + Jitter over Fixed Interval","height":22.5,"link":null,"strokeColor":"#0e7490","fillStyle":"solid","groupIds":[],"versionNonce":1659590652,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-241.5596923828125,"angle":0,"y":6370,"width":696.58160400390625},{"seed":370357700,"strokeStyle":"solid","id":"kcraHA7bqRWcqDrZLhT43","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772747707439,"locked":false,"text":"Over: Fixed retry interval, linear backoff, no retry (fail-fast)","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b6d","roundness":null,"containerId":null,"originalText":"Over: Fixed retry interval, linear backoff, no retry (fail-fast)","height":17.5,"link":null,"strokeColor":"#374151","fillStyle":"solid","groupIds":[],"versionNonce":1882650748,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-241.5596923828125,"angle":0,"y":6396,"width":413.76943969726562},{"seed":221240644,"strokeStyle":"solid","id":"OcaPd7lzRH-3CQWJ6XD9A","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772747707439,"locked":false,"text":"Because:\n1. Thundering herd prevention: 150 fan-out workers that all hit Kafka timeout simultaneously will retry at DIFFERENT times\n   due to jitter — desynchronized load instead of synchronized retry storm that re-breaks the recovering service.\n2. Self-healing: exponential backoff gives recovering services time to stabilize before next retry wave.\n   Fixed 500ms retry under sustained failure hammers the recovering service every 500ms across all workers.\n3. Formula: min(100ms * 2^attempt + rand(0,100ms), 30000ms) — mathematically proven to converge under Poisson load.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b6e","roundness":null,"containerId":null,"originalText":"Because:\n1. Thundering herd prevention: 150 fan-out workers that all hit Kafka timeout simultaneously will retry at DIFFERENT times\n   due to jitter — desynchronized load instead of synchronized retry storm that re-breaks the recovering service.\n2. Self-healing: exponential backoff gives recovering services time to stabilize before next retry wave.\n   Fixed 500ms retry under sustained failure hammers the recovering service every 500ms across all workers.\n3. Formula: min(100ms * 2^attempt + rand(0,100ms), 30000ms) — mathematically proven to converge under Poisson load.","height":105,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":70945020,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-241.5596923828125,"angle":0,"y":6416,"width":855.6649169921875},{"seed":1498125508,"strokeStyle":"solid","id":"3vtOTwjU-MBy3H09Ufwaa","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772747707439,"locked":false,"text":"Costs: Users experience higher latency on retry path (up to 30s max backoff).\nMessages accumulate in DLQ faster during extended outages.\nRequires careful max_attempts tuning — too few = data loss, too many = resource waste.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b6f","roundness":null,"containerId":null,"originalText":"Costs: Users experience higher latency on retry path (up to 30s max backoff).\nMessages accumulate in DLQ faster during extended outages.\nRequires careful max_attempts tuning — too few = data loss, too many = resource waste.","height":52.5,"link":null,"strokeColor":"#b45309","fillStyle":"solid","groupIds":[],"versionNonce":1652033916,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-241.5596923828125,"angle":0,"y":6504,"width":618.54736328125},{"seed":671374404,"strokeStyle":"solid","id":"lqF6T58AfQ9bymTZf7jQg","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772747707439,"locked":false,"text":"Revisit if: SLA requires <5s recovery for all operations — circuit breaker + immediate failover to backup becomes more appropriate than retry.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b6g","roundness":null,"containerId":null,"originalText":"Revisit if: SLA requires <5s recovery for all operations — circuit breaker + immediate failover to backup becomes more appropriate than retry.","height":17.5,"link":null,"strokeColor":"#6b7280","fillStyle":"solid","groupIds":[],"versionNonce":238123516,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-241.5596923828125,"angle":0,"y":6526,"width":966.04071044921875},{"isDeleted":false,"locked":false,"strokeColor":"#4a9eed","link":null,"roughness":1,"groupIds":[],"index":"b6h","backgroundColor":"#1e1e2e","angle":0,"fillStyle":"solid","strokeWidth":2,"version":5,"roundness":{"type":3},"type":"rectangle","updated":1772747707439,"id":"I1aGMI2qtAdIht5D-QWkd","x":-251.5596923828125,"seed":1127756740,"boundElements":[],"y":6564,"opacity":100,"height":95,"width":1530,"frameId":null,"strokeStyle":"solid","versionNonce":1382603388},{"seed":151329604,"strokeStyle":"solid","id":"4hkVFjVaBSsGCl2pmY_Mq","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":17,"opacity":100,"verticalAlign":"top","updated":1772747707439,"locked":false,"text":"Trade-off Decision Matrix:","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b6i","roundness":null,"containerId":null,"originalText":"Trade-off Decision Matrix:","height":21.25,"link":null,"strokeColor":"#a5d8ff","fillStyle":"solid","groupIds":[],"versionNonce":1239427836,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-241.5596923828125,"angle":0,"y":6574,"width":220.74482727050781},{"seed":1674121924,"strokeStyle":"solid","id":"DPcazb9iQ_M7rFSyC72j2","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1772747707439,"locked":false,"text":"Posts: PG for query flex  |  Graph: Cassandra for write throughput  |  Fan-out: Kafka for replay  |  Cache: Redis SortedSet for cursors\nConsistency: Eventual for feed speed (RYOW only for graph writes)  |  Fan-out: Hybrid (write for normals, read for celebs)  |  Retry: jitter backoff","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b6j","roundness":null,"containerId":null,"originalText":"Posts: PG for query flex  |  Graph: Cassandra for write throughput  |  Fan-out: Kafka for replay  |  Cache: Redis SortedSet for cursors\nConsistency: Eventual for feed speed (RYOW only for graph writes)  |  Fan-out: Hybrid (write for normals, read for celebs)  |  Retry: jitter backoff","height":37.5,"link":null,"strokeColor":"#e5e5e5","fillStyle":"solid","groupIds":[],"versionNonce":1729719164,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-241.5596923828125,"angle":0,"y":6600,"width":1077.059326171875},{"seed":732218876,"strokeStyle":"solid","id":"T5QPufTDaD_K8cSOL1-fX","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":20,"opacity":100,"verticalAlign":"top","updated":1772748802889,"locked":false,"text":"{\"type\":\"excalidraw\/clipboard\",\"elements\":[{\"id\":\"s1bg\",\"type\":\"rectangle\",\"x\":10,\"y\":10,\"width\":1560,\"height\":680,\"angle\":0,\"strokeColor\":\"#cbd5e1\",\"backgroundColor\":\"#f8fafc\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"a0\",\"roundness\":{\"type\":3},\"seed\":1321236336,\"version\":2,\"versionNonce\":942105488,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s1hd\",\"type\":\"rectangle\",\"x\":10,\"y\":10,\"width\":1560,\"height\":46,\"angle\":0,\"strokeColor\":\"#1e3a5f\",\"backgroundColor\":\"#1e3a5f\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"a1\",\"roundness\":{\"type\":3},\"seed\":1429796752,\"version\":2,\"versionNonce\":1260281200,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s1tt\",\"type\":\"text\",\"x\":490,\"y\":23,\"width\":413.53173828125,\"height\":26.25,\"angle\":0,\"strokeColor\":\"#f1f5f9\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"a2\",\"roundness\":null,\"seed\":1889536368,\"version\":2,\"versionNonce\":1117024656,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"STEP 1  —  Problem Framing: News Feed\",\"fontSize\":21,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"STEP 1  —  Problem Framing: News Feed\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s1a\",\"type\":\"rectangle\",\"x\":10,\"y\":66,\"width\":490,\"height\":222,\"angle\":0,\"strokeColor\":\"#93c5fd\",\"backgroundColor\":\"#eff6ff\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"a3\",\"roundness\":{\"type\":3},\"seed\":1884521872,\"version\":2,\"versionNonce\":877735792,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s1at\",\"type\":\"text\",\"x\":24,\"y\":78,\"width\":99.96791076660156,\"height\":20,\"angle\":0,\"strokeColor\":\"#1d4ed8\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"a4\",\"roundness\":null,\"seed\":347954032,\"version\":2,\"versionNonce\":1479524240,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Core Problem\",\"fontSize\":16,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Core Problem\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s1ab\",\"type\":\"text\",\"x\":24,\"y\":103,\"width\":329.51763916015625,\"height\":157.5,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"a5\",\"roundness\":null,\"seed\":619467664,\"version\":2,\"versionNonce\":1398391152,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Aggregates posts from all followed accounts\\ninto one personalized ranked stream.\\n\\nWithout it: users visit each profile manually.\\nThis is how social networks worked pre-2006.\\n\\nCentral tension: 1 celebrity post triggers\\n10M feed-cache updates — the fan-out problem.\\nEvery design decision traces back to this.\",\"fontSize\":14,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Aggregates posts from all followed accounts\\ninto one personalized ranked stream.\\n\\nWithout it: users visit each profile manually.\\nThis is how social networks worked pre-2006.\\n\\nCentral tension: 1 celebrity post triggers\\n10M feed-cache updates — the fan-out problem.\\nEvery design decision traces back to this.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s1b\",\"type\":\"rectangle\",\"x\":518,\"y\":66,\"width\":490,\"height\":222,\"angle\":0,\"strokeColor\":\"#86efac\",\"backgroundColor\":\"#f0fdf4\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"a6\",\"roundness\":{\"type\":3},\"seed\":761294192,\"version\":2,\"versionNonce\":2033274256,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s1bt\",\"type\":\"text\",\"x\":532,\"y\":78,\"width\":128.28790283203125,\"height\":20,\"angle\":0,\"strokeColor\":\"#15803d\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"a7\",\"roundness\":null,\"seed\":691757456,\"version\":2,\"versionNonce\":1736446832,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"User Archetypes\",\"fontSize\":16,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"User Archetypes\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s1bb\",\"type\":\"text\",\"x\":532,\"y\":103,\"width\":303.22564697265625,\"height\":175,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"a8\",\"roundness\":null,\"seed\":600915824,\"version\":2,\"versionNonce\":1590762384,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"PRODUCERS — celebrities, brands, creators\\n  Post rarely. Millions of followers.\\n  Create massive fan-out per write.\\n\\nCONSUMERS — regular users\\n  Read 10x per day. Few followers.\\n  Low fan-out writes, high read volume.\\n\\nRead : Write = 100 : 1\\nThis single ratio drives the architecture.\",\"fontSize\":14,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"PRODUCERS — celebrities, brands, creators\\n  Post rarely. Millions of followers.\\n  Create massive fan-out per write.\\n\\nCONSUMERS — regular users\\n  Read 10x per day. Few followers.\\n  Low fan-out writes, high read volume.\\n\\nRead : Write = 100 : 1\\nThis single ratio drives the architecture.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s1c\",\"type\":\"rectangle\",\"x\":1026,\"y\":66,\"width\":544,\"height\":222,\"angle\":0,\"strokeColor\":\"#d8b4fe\",\"backgroundColor\":\"#fdf4ff\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"a9\",\"roundness\":{\"type\":3},\"seed\":746106768,\"version\":2,\"versionNonce\":118236528,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s1ct\",\"type\":\"text\",\"x\":1040,\"y\":78,\"width\":262.83172607421875,\"height\":20,\"angle\":0,\"strokeColor\":\"#7e22ce\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"aA\",\"roundness\":null,\"seed\":2019021168,\"version\":2,\"versionNonce\":1531390352,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Operations + Real-World Examples\",\"fontSize\":16,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Operations + Real-World Examples\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s1cb\",\"type\":\"text\",\"x\":1040,\"y\":103,\"width\":333.9695739746094,\"height\":140,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"aB\",\"roundness\":null,\"seed\":920403344,\"version\":2,\"versionNonce\":1061549936,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"READS   ~58K QPS  feed, scroll, story views\\nWRITES  ~580 QPS  posts, follows, comments\\nEVENTS ~116K QPS  likes, reactions, notifs\\n\\nFacebook  3B DAU — invented news feed 2006\\nTwitter\/X 250M DAU — real-time public firehose\\nLinkedIn  1B users — professional ranked feed\\nTikTok    FYP adds ML recommendation on top\",\"fontSize\":14,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"READS   ~58K QPS  feed, scroll, story views\\nWRITES  ~580 QPS  posts, follows, comments\\nEVENTS ~116K QPS  likes, reactions, notifs\\n\\nFacebook  3B DAU — invented news feed 2006\\nTwitter\/X 250M DAU — real-time public firehose\\nLinkedIn  1B users — professional ranked feed\\nTikTok    FYP adds ML recommendation on top\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s1fo\",\"type\":\"rectangle\",\"x\":10,\"y\":298,\"width\":1560,\"height\":382,\"angle\":0,\"strokeColor\":\"#fdba74\",\"backgroundColor\":\"#fff7ed\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"aC\",\"roundness\":{\"type\":3},\"seed\":1648108400,\"version\":2,\"versionNonce\":969635728,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s1foh\",\"type\":\"t