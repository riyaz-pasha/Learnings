le\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"ab\",\"roundness\":null,\"seed\":537605008,\"version\":2,\"versionNonce\":2129715568,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"On post create, push to follower feed caches.\\nExample: user with 500 followers posts — all 500\\nRedis feed entries updated within 5 seconds.\\nHidden: celebrity with 10M followers breaks sync\\nfan-out. Hybrid write\/read strategy required.\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"On post create, push to follower feed caches.\\nExample: user with 500 followers posts — all 500\\nRedis feed entries updated within 5 seconds.\\nHidden: celebrity with 10M followers breaks sync\\nfan-out. Hybrid write\/read strategy required.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s2r3\",\"type\":\"rectangle\",\"x\":1058,\"y\":790,\"width\":512,\"height\":178,\"angle\":0,\"strokeColor\":\"#f87171\",\"backgroundColor\":\"#fff1f2\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"ac\",\"roundness\":{\"type\":3},\"seed\":538938736,\"version\":2,\"versionNonce\":1310469520,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s2r3t\",\"type\":\"text\",\"x\":1072,\"y\":802,\"width\":207.83985900878906,\"height\":18.75,\"angle\":0,\"strokeColor\":\"#b91c1c\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"ad\",\"roundness\":null,\"seed\":494813584,\"version\":2,\"versionNonce\":1395864432,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"FR3 — Feed Retrieval  [P0]\",\"fontSize\":