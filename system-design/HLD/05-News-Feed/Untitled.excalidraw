],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s11stratt\",\"type\":\"text\",\"x\":24,\"y\":9378,\"width\":654.9913330078125,\"height\":20,\"angle\":0,\"strokeColor\":\"#1d4ed8\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b4e\",\"roundness\":null,\"seed\":746390896,\"version\":2,\"versionNonce\":1482175888,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Core Decision: Active-Active Reads  +  Active-Passive Writes (per user home region)\",\"fontSize\":16,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Core Decision: Active-Active Reads  +  Active-Passive Writes (per user home region)\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s11stratb\",\"type\":\"text\",\"x\":24,\"y\":9402,\"width\":860.7941284179688,\"height\":48.75,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b4f\",\"roundness\":null,\"seed\":701778320,\"version\":2,\"versionNonce\":547072880,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Read path: ALL 3 regions serve reads from local Redis + DB replicas. Zero cross-region latency on reads.\\nWrite path: each user has a home region. Social graph writes go to that region's primary ONLY. Avoids distributed transactions.\\nWhy not full active-active writes? Follow\/unfollow needs RYOW. Full active-active requires Paxos\/Raft — 200-400ms penalty per write.\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Read path: ALL 3 regions serve reads from local Redis + DB replicas. Zero cross-region latency on reads.\\nWrite path: each user has a home region. Social graph writes go to that region's primary ONLY. Avoids distributed transactions.\\nWhy not full active-active writes? Follow\/unfollow needs RYOW. Full active-active requires Paxos\/Raft — 200-400ms penalty per write.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s11us\",\"type\":\"rectangle\",\"x\":10,\"y\":9471,\"width\":490,\"height\":250,\"angle\":0,\"strokeColor\":\"#3b82f6\",\"backgroundColor\":\"#dbeafe\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b4g\",\"roundness\":{\"type\":3},\"seed\":1134221168,\"version\":2,\"versionNonce\":148571024,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s11ust\",\"type\":\"text\",\"x\":24,\"y\":9483,\"width\":238.04983520507812,\"height\":18.75,\"angle\":0,\"strokeColor\":\"#1d4ed8\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b4h\",\"roundness\":null,\"seed\":2041878416,\"version\":2,\"versionNonce\":1223998832,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"US-East  (Primary Write Region)\",\"fontSize\":15,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"US-East  (Primary Write Region)\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s11usb\",\"type\":\"text\",\"x\":24,\"y\":9507,\"width\":222.84573364257812,\"height\":146.25,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b4i\",\"roundness\":null,\"seed\":456026480,\"version\":2,\"versionNonce\":20774