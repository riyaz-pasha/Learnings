":2094049732,"strokeStyle":"solid","id":"EHLSv9IzKO_byrQl8W0cQ","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772747707441,"locked":false,"text":"Fixes: BN6 (sync media upload blocking API threads)","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b2t","roundness":null,"containerId":null,"originalText":"Fixes: BN6 (sync media upload blocking API threads)","height":17.5,"link":null,"strokeColor":"#06b6d4","fillStyle":"solid","groupIds":[],"versionNonce":1533999044,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-241.5596923828125,"angle":0,"y":407,"width":360.48556518554688},{"seed":605999428,"strokeStyle":"solid","id":"AUoj9rwq3k78WF8GmATld","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772747707441,"locked":false,"text":"Added: Client requests presigned S3 URL from API (fast, <10ms). Client uploads directly to S3 — API thread freed immediately.\nMedia upload triggers S3 event -> SQS -> transcoding workers (FFmpeg fleet). Post stored with status=media_pending.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b2u","roundness":null,"containerId":null,"originalText":"Added: Client requests presigned S3 URL from API (fast, <10ms). Client uploads directly to S3 — API thread freed immediately.\nMedia upload triggers S3 event -> SQS -> transcoding workers (FFmpeg fleet). Post stored with status=media_pending.","height":35,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":284186236,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-241.5596923828125,"angle":0,"y":427,"width":876.65069580078125},{"seed":507250884,"strokeStyle":"solid","id":"SiARa2en9SVbt0C7gg-6g","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772747707441,"locked":false,"text":"Mechanism: Post moves from media_pending to published once transcoder completes and writes CDN URLs back to DB.\nFeed service filters out media_pending posts. CDN caches transcoded media at edge, eliminating origin load.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b2v","roundness":null,"containerId":null,"originalText":"Mechanism: Post moves from media_pending to published once transcoder completes and writes CDN URLs back to DB.\nFeed service filters out media_pending posts. CDN caches transcoded media at edge, eliminating origin load.","height":35,"link":null,"strokeColor":"#374151","fillStyle":"solid","groupIds":[],"versionNonce":1975738180,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-241.5596923828125,"angle":0,"y":467,"width":810.10894775390625},{"seed":1590054980,"strokeStyle":"solid","id":"ag6Tu__5U5gVt6yUAUi2X","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772747707441,"locked":false,"text":"New tradeoff: Post publish is now delayed by transcoding time (5-60s for video). User sees 'processing' state.\nMore moving parts: SQS + transcoding workers + status state machine adds operational complexity.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b2w","roundness":null,"containerId":null,"originalText":"New tradeoff: Post publish is now delayed by transcoding time (5-60s for video). User sees 'processing' state.\nMore moving parts: SQS + transcoding workers + status state machine adds operational complexity.","height":35,"link":null,"strokeColor":"#b45309","fillStyle":"solid","groupIds":[],"versionNonce":1108879100,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-241.5596923828125,"angle":0,"y":505,"width":756.27899169921875},{"seed":899393476,"strokeStyle":"solid","id":"p-lK1QJbF8Z1TF6yHL_ak",