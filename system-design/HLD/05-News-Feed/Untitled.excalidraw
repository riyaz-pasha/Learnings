"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"aX\",\"roundness\":null,\"seed\":1351604112,\"version\":2,\"versionNonce\":201162096,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"FR1 — Post Creation  [P0]\",\"fontSize\":15,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"FR1 — Post Creation  [P0]\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s2r1b\",\"type\":\"text\",\"x\":24,\"y\":826,\"width\":325.753662109375,\"height\":81.25,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"aY\",\"roundness\":null,\"seed\":581380464,\"version\":2,\"versionNonce\":1521963408,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"User writes post; stored durably before ACK.\\nExample: @celebrity posts album art, stored once,\\nfan-out propagates to 100M followers.\\nHidden: idempotency on retry — network drop after\\nDB write = duplicate post without a dedup key.\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"User writes post; stored durably before ACK.\\nExample: @celebrity posts album art, stored once,\\nfan-out propagates to 100M followers.\\nHidden: idempotency on retry — network drop after\\nDB write = duplicate post without a dedup key.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s2r2\",\"type\":\"rectangle\",\"x\":530,\"y\":790,\"width\":502,\"height\":178,\"angle\":0,\"strokeColor\":\"#f87171\",\"backgroundColor\":\"#fff1f2\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"aZ\",\"roundness\":{\"type\":3},\"seed\":5000656