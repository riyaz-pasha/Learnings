":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"aK\",\"roundness\":null,\"seed\":907471728,\"version\":2,\"versionNonce\":1942695824,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"points\":[[0,0],[89,0]],\"lastCommittedPoint\":null,\"startBinding\":null,\"endBinding\":null,\"startArrowhead\":null,\"endArrowhead\":\"arrow\",\"elbowed\":false},{\"id\":\"s1rd\",\"type\":\"rectangle\",\"x\":585,\"y\":337,\"width\":215,\"height\":95,\"angle\":0,\"strokeColor\":\"#ec4899\",\"backgroundColor\":\"#fce7f3\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"aL\",\"roundness\":{\"type\":3},\"seed\":196330384,\"version\":2,\"versionNonce\":1701663088,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s1rdt\",\"type\":\"text\",\"x\":600,\"y\":353,\"width\":118.02687072753906,\"height\":65,\"angle\":0,\"strokeColor\":\"#9d174d\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"aM\",\"roundness\":null,\"seed\":218627440,\"version\":2,\"versionNonce\":1876868496,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"10M Feed Caches\\nRedis Sorted Sets\\nAll receive post_id\\nin their feed list\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"10M Feed Caches\\nRedis Sorted Sets\\nAll receive post_id\\nin their feed list\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s1ex\",\"type\":\"rectangle\",\"x\":820,\"y\":337,\"width\":730,\"height\":220,\"angle\":0,\"strokeColor\":\"#e2e8f0\",\"backgroundColor\":\"#ffffff\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"aN\",\"roundness\":{\"type\":3},\"seed\":630509968,\"version\":2,\"versionNonce\":279028592,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s1exh\",\"type\":\"text\",\"x\":836,\"y\":350,\"width\":255.97482299804688,\"height\":18.75,\"angle\":0,\"strokeColor\":\"#1e3a5f\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"aO\",\"roundness\":null,\"seed\":1208405872,\"version\":2,\"versionNonce\":2119207824,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Why Naive Breaks + The Hybrid Fix\",\"fontSize\":15,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Why Naive Breaks + The Hybrid Fix\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s1exb\",\"type\":\"text\",\"x\":836,\"y\":375,\"width\":356.55157470703125,\"height\":192.5,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"aP\",\"roundness\":null,\"seed\":1009000336,\"version\":2,\"versionNonce\":897299824,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"NAIVE (breaks): Sync fan-out — API writes to 10M\\nRedis entries inline. Thread blocks for seconds.\\nSystem collapses completely at celebrity scale.\\n\\nFIX — Hybrid Fan-out (the production approach):\\n  Normal users (<1M followers): fan-out-on-write.\\n  Kafka async workers propagate within 30 seconds.\\n\\n  Celebrities (>1M followers): fan-out-on-read.\\n  Posts not pushed to caches at write time.\\n  Merged with precomputed feed at read time.\",\"fontSize\":14,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"NAIVE (breaks): Sync fan-out — API writes to 10M\\nRedis entries inline. Thread blocks for seconds.\\nSystem collapses completely at celebrity scale.\\n\\nFIX — Hybrid Fan-out (the production approach):\\n  Normal users (<1M followers): fan-out-on-write.\\n  Kafka async workers propagate within 30 seconds.\\n\\n  Celebrities (>1M followers): fan-out-on-read.\\n  Posts not pushed to caches at write time.\\n  Merged with precomputed feed at read time.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s1tip\",\"type\":\"rectangle\",\"x\":820,\"y\":566,\"width\":730,\"height\":38,\"angle\":0,\"strokeColor\":\"#6ee7b7\",\"backgroundColor\":\"#ecfdf5\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"aQ\",\"roundness\":{\"type\":3},\"seed\":526082416,\"version\":2,\"versionNonce\":962107792,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s1tipt\",\"type\":\"text\",\"x\":836,\"y\":579,\"width\":615.120361328125,\"height\":16.25,\"angle\":0,\"strokeColor\":\"#065f46\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"aR\",\"roundness\":null,\"seed\":530165136,\"version\":2,\"versionNonce\":423855984,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Interview tip: state the hybrid approach — neither pure push nor pure pull scales to 500M+ DAU\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Interview tip: state the hybrid approach — neither pure push nor pure pull scales to 500M+ DAU\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s2bg\",\"type\":\"rectangle\",\"x\":10,\"y\":710,\"width\":1560,\"height\":890,\"angle\":0,\"strokeColor\":\"#cbd5e1\",\"backgroundColor\":\"#f8fafc\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"aS\",\"roundness\":{\"type\":3},\"seed\":38646640,\"version\":2,\"versionNonce\":875489168,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s2hd\",\"type\":\"rectangle\",\"x\":10,\"y\":710,\"width\":1560,\"height\":46,\"angle\":0,\"strokeColor\":\"#1e3a5f\",\"backgroundColor\":\"#1e3a5f\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"aT\",\"roundness\":{\"type\":3},\"seed\":1496152976,\"version\":2,\"versionNonce\":406919536,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s2tt\",\"type\":\"text\",\"x\":410,\"y\":723,\"width\":490.2867431640625,\"height\":26.25,\"angle\":0,\"strokeColor\":\"#f1f5f9\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"aU\",\"roundness\":null,\"seed\":925222256,\"version\":2,\"versionNonce\":1527477648,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"STEP 2  —  Functional Requirements  (12 FRs)\",\"fontSize\":21,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"STEP 2  —  Functional Requirements  (12 FRs)\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s2leg\",\"type\":\"text\",\"x\":24,\"y\":767,\"width\":577.45703125,\"height\":17.5,\"angle\":0,\"strokeColor\":\"#64748b\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"aV\",\"roundness\":null,\"seed\":186091920,\"version\":2,\"versionNonce\":1169976176,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"P0 = system breaks without it   |   P1 = degrades without it   |   P2 = nice to have\",\"fontSize\":14,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"P0 = system breaks without it   |   P1 = degrades without it   |   P2 = nice to have\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s2r1\",\"type\":\"rectangle\",\"x\":10,\"y\":790,\"width\":502,\"height\":178,\"angle\":0,\"strokeColor\":\"#f87171\",\"backgroundColor\":\"#fff1f2\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"aW\",\"roundness\":{\"type\":3},\"seed\":2066454384,\"version\":2,\"versionNonce\":1395016592,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s2r1t\",\"type\":\"text\",\"x\":24,\"y\":802,\"width\":201.9148712158203,\"height\":18.75,\"angle\":0,\"strokeColor\":\"#b91c1c\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"aX\",\"roundness\":null,\"seed\":1351604112,\"version\":2,\"versionNonce\":201162096,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"FR1 — Post Creation  [P0]\",\"fontSize\":15,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"FR1 — Post Creation  [P0]\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s2r1b\",\"type\":\"text\",\"x\":24,\"y\":826,\"width\":325.753662109375,\"height\":81.25,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"aY\",\"roundness\":null,\"seed\":581380464,\"version\":2,\"versionNonce\":1521963408,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"User writes post; stored durably before ACK.\\nExample: @celebrity posts album art, stored once,\\nfan-out propagates to 100M followers.\\nHidden: idempotency on retry — network drop after\\nDB write = duplicate post without a dedup key.\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"User writes post; stored durably before ACK.\\nExample: @celebrity posts album art, stored once,\\nfan-out propagates to 100M followers.\\nHidden: idempotency on retry — network drop after\\nDB write = duplicate post without a dedup key.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s2r2\",\"type\":\"rectangle\",\"x\":530,\"y\":790,\"width\":502,\"height\":178,\"angle\":0,\"strokeColor\":\"#f87171\",\"backgroundColor\":\"#fff1f2\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"aZ\",\"roundness\":{\"type\":3},\"seed\":500065680,\"version\":2,\"versionNonce\":1280069488,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s2r2t\",\"type\":\"text\",\"x\":544,\"y\":802,\"width\":300.74981689453125,\"height\":18.75,\"angle\":0,\"strokeColor\":\"#b91c1c\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"aa\",\"roundness\":null,\"seed\":954235760,\"version\":2,\"versionNonce\":687251344,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"FR2 — Feed Generation \/ Fan-out  [P0]\",\"fontSize\":15,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"FR2 — Feed Generation \/ Fan-out  [P0]\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s2r2b\",\"type\":\"text\",\"x\":544,\"y\":826,\"width\":316.39361572265625,\"height\":81.25,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"ab\",\"roundness\":null,\"seed\":537605008,\"version\":2,\"versionNonce\":2129715568,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"On post create, push to follower feed caches.\\nExample: user with 500 followers posts — all 500\\nRedis feed entries updated within 5 seconds.\\nHidden: celebrity with 10M followers breaks sync\\nfan-out. Hybrid write\/read strategy required.\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"On post create, push to follower feed caches.\\nExample: user with 500 followers posts — all 500\\nRedis feed entries updated within 5 seconds.\\nHidden: celebrity with 10M followers breaks sync\\nfan-out. Hybrid write\/read strategy required.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s2r3\",\"type\":\"rectangle\",\"x\":1058,\"y\":790,\"width\":512,\"height\":178,\"angle\":0,\"strokeColor\":\"#f87171\",\"backgroundColor\":\"#fff1f2\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"ac\",\"roundness\":{\"type\":3},\"seed\":538938736,\"version\":2,\"versionNonce\":1310469520,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s2r3t\",\"type\":\"text\",\"x\":1072,\"y\":802,\"width\":207.83985900878906,\"height\":18.75,\"angle\":0,\"strokeColor\":\"#b91c1c\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"ad\",\"roundness\":null,\"seed\":494813584,\"version\":2,\"versionNonce\":1395864432,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"FR3 — Feed Retrieval  [P0]\",\"fontSize\":15,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"FR3 — Feed Retrieval  [P0]\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s2r3b\",\"type\":\"text\",\"x\":1072,\"y\":826,\"width\":321.7106018066406,\"height\":81.25,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"ae\",\"roundness\":null,\"seed\":833380208,\"version\":2,\"versionNonce\":325057424,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"User opens app; returns ranked paginated feed.\\nExample: Instagram loads top 20 posts from 300\\nfollowed accounts in under 200ms.\\nHidden: merging celebrity fan-on-read with\\nprecomputed cache at read time under 500ms P99.\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"User opens app; returns ranked paginated feed.\\nExample: Instagram loads top 20 posts from 300\\nfollowed accounts in under 200ms.\\nHidden: merging celebrity fan-on-read with\\nprecomputed cache at read time under 500ms P99.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s2r4\",\"type\":\"rectangle\",\"x\":10,\"y\":982,\"width\":502,\"height\":178,\"angle\":0,\"strokeColor\":\"#f87171\",\"backgroundColor\":\"#fff1f2\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"af\",\"roundness\":{\"type\":3},\"seed\":1432326032,\"version\":2,\"versionNonce\":1331381616,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s2r4t\",\"type\":\"text\",\"x\":24,\"y\":994,\"width\":228.43487548828125,\"height\":18.75,\"angle\":0,\"strokeColor\":\"#b91c1c\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"ag\",\"roundness\":null,\"seed\":1573843312,\"version\":2,\"versionNonce\":1526335888,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"FR4 — Follow \/ Unfollow  [P0]\",\"fontSize\":15,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"FR4 — Follow \/ Unfollow  [P0]\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s2r4b\",\"type\":\"text\",\"x\":24,\"y\":1018,\"width\":298.3885498046875,\"height\":81.25,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"ah\",\"roundness\":null,\"seed\":1608981904,\"version\":2,\"versionNonce\":1890654064,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"User follows or unfollows an account.\\nExample: Alice unfollows Bob — his posts must\\ndisappear from her feed immediately.\\nHidden: unfollow invalidates feed cache. New\\nfollow needs historical post backfill into cache.\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"User follows or unfollows an account.\\nExample: Alice unfollows Bob — his posts must\\ndisappear from her feed immediately.\\nHidden: unfollow invalidates feed cache. New\\nfollow needs historical post backfill into cache.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s2r5\",\"type\":\"rectangle\",\"x\":530,\"y\":982,\"width\":502,\"height\":178,\"angle\":0,\"strokeColor\":\"#fbbf24\",\"backgroundColor\":\"#fffbeb\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"ai\",\"roundness\":{\"type\":3},\"seed\":1271874416,\"version\":2,\"versionNonce\":2250640,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s2r5t\",\"type\":\"text\",\"x\":544,\"y\":994,\"width\":191.51986694335938,\"height\":18.75,\"angle\":0,\"strokeColor\":\"#b45309\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"aj\",\"roundness\":null,\"seed\":239922064,\"version\":2,\"versionNonce\":1266461040,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"FR5 — Like \/ React  [P1]\",\"fontSize\":15,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"FR5 — Like \/ React  [P1]\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s2r5b\",\"type\":\"text\",\"x\":544,\"y\":1018,\"width\":314.37860107421875,\"height\":81.25,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"ak\",\"roundness\":null,\"seed\":2046121328,\"version\":2,\"versionNonce\":923854224,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"User likes a post; count updates visibly.\\nExample: viral tweet 500K likes\/hr = ~140\/sec,\\nspiking to 2,000\/sec on hot content.\\nHidden: row-level DB increment serializes at scale.\\nUse Redis INCR + async batch flush to DB.\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"User likes a post; count updates visibly.\\nExample: viral tweet 500K likes\/hr = ~140\/sec,\\nspiking to 2,000\/sec on hot content.\\nHidden: row-level DB increment serializes at scale.\\nUse Redis INCR + async batch flush to DB.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s2r6\",\"type\":\"rectangle\",\"x\":1058,\"y\":982,\"width\":512,\"height\":178,\"angle\":0,\"strokeColor\":\"#fbbf24\",\"backgroundColor\":\"#fffbeb\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"al\",\"roundness\":{\"type\":3},\"seed\":1254685072,\"version\":2,\"versionNonce\":721812336,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s2r6t\",\"type\":\"text\",\"x\":1072,\"y\":994,\"width\":170.69989013671875,\"height\":18.75,\"angle\":0,\"strokeColor\":\"#b45309\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"am\",\"roundness\":null,\"seed\":1569269616,\"version\":2,\"versionNonce\":1828565904,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"FR6 — Comments  [P1]\",\"fontSize\":15,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"FR6 — Comments  [P1]\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s2r6b\",\"type\":\"text\",\"x\":1072,\"y\":1018,\"width\":311.5706481933594,\"height\":81.25,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"an\",\"roundness\":null,\"seed\":2022918032,\"version\":2,\"versionNonce\":831851888,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"User adds comment; visible to all viewers.\\nExample: hot post gets 10K comments in 5 min\\n— thread must stay ordered and paginated.\\nHidden: threaded replies need recursive model.\\nHot post = write hotspot on single DB partition.\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"User adds comment; visible to all viewers.\\nExample: hot post gets 10K comments in 5 min\\n— thread must stay ordered and paginated.\\nHidden: threaded replies need recursive model.\\nHot post = write hotspot on single DB partition.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s2r7\",\"type\":\"rectangle\",\"x\":10,\"y\":1174,\"width\":502,\"height\":178,\"angle\":0,\"strokeColor\":\"#fbbf24\",\"backgroundColor\":\"#fffbeb\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"ao\",\"roundness\":{\"type\":3},\"seed\":47364464,\"version\":2,\"versionNonce\":673235344,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s2r7t\",\"type\":\"text\",\"x\":24,\"y\":1186,\"width\":273.704833984375,\"height\":18.75,\"angle\":0,\"strokeColor\":\"#b45309\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"ap\",\"roundness\":null,\"seed\":1407440272,\"version\":2,\"versionNonce\":2020728688,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"FR7 — Real-time Feed Updates  [P1]\",\"fontSize\":15,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"FR7 — Real-time Feed Updates  [P1]\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s2r7b\",\"type\":\"text\",\"x\":24,\"y\":1210,\"width\":315.75665283203125,\"height\":81.25,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"aq\",\"roundness\":null,\"seed\":756681584,\"version\":2,\"versionNonce\":1739722640,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"New posts appear without manual refresh.\\nExample: friend posts photo — slides into your\\nfeed within 3 seconds, no page reload needed.\\nHidden: millions of persistent WS\/SSE connections\\nare costly. Push all vs ping-then-pull tradeoff.\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"New posts appear without manual refresh.\\nExample: friend posts photo — slides into your\\nfeed within 3 seconds, no page reload needed.\\nHidden: millions of persistent WS\/SSE connections\\nare costly. Push all vs ping-then-pull tradeoff.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s2r8\",\"type\":\"rectangle\",\"x\":530,\"y\":1174,\"width\":502,\"height\":178,\"angle\":0,\"strokeColor\":\"#fbbf24\",\"backgroundColor\":\"#fffbeb\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"ar\",\"roundness\":{\"type\":3},\"seed\":1374856080,\"version\":2,\"versionNonce\":803500400,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s2r8t\",\"type\":\"text\",\"x\":544,\"y\":1186,\"width\":195.869873046875,\"height\":18.75,\"angle\":0,\"strokeColor\":\"#b45309\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"as\",\"roundness\":null,\"seed\":1990663536,\"version\":2,\"versionNonce\":65641872,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"FR8 — Feed Ranking  [P1]\",\"fontSize\":15,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"FR8 — Feed Ranking  [P1]\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s2r8b\",\"type\":\"text\",\"x\":544,\"y\":1210,\"width\":320.04656982421875,\"height\":81.25,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"at\",\"roundness\":null,\"seed\":16232848,\"version\":2,\"versionNonce\":1060422512,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Posts ranked by relevance, not just recency.\\nExample: BFF's post ranks above old brand follow\\nusing engagement + recency signals.\\nHidden: ML inference at read adds 10-50ms.\\nMust precompute or cache per-user ranked results.\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Posts ranked by relevance, not just recency.\\nExample: BFF's post ranks above old brand follow\\nusing engagement + recency signals.\\nHidden: ML inference at read adds 10-50ms.\\nMust precompute or cache per-user ranked results.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s2r9\",\"type\":\"rectangle\",\"x\":1058,\"y\":1174,\"width\":512,\"height\":178,\"angle\":0,\"strokeColor\":\"#f87171\",\"backgroundColor\":\"#fff1f2\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"au\",\"roundness\":{\"type\":3},\"seed\":1891757936,\"version\":2,\"versionNonce\":234843024,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s2r9t\",\"type\":\"text\",\"x\":1072,\"y\":1186,\"width\":298.8148193359375,\"height\":18.75,\"angle\":0,\"strokeColor\":\"#b91c1c\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"av\",\"roundness\":null,\"seed\":1747648400,\"version\":2,\"versionNonce\":1688917360,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"FR9 — Infinite Scroll \/ Pagination  [P0]\",\"fontSize\":15,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"FR9 — Infinite Scroll \/ Pagination  [P0]\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s2r9b\",\"type\":\"text\",\"x\":1072,\"y\":1210,\"width\":314.274658203125,\"height\":81.25,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"aw\",\"roundness\":null,\"seed\":1135772016,\"version\":2,\"versionNonce\":808155536,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Older posts load seamlessly as user scrolls.\\nExample: user 200 posts deep — next 20 load\\nwith no duplicates or gaps in the feed.\\nHidden: cursor-based pagination on a LIVE ranked\\nfeed — new posts shift all offset-based cursors.\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Older posts load seamlessly as user scrolls.\\nExample: user 200 posts deep — next 20 load\\nwith no duplicates or gaps in the feed.\\nHidden: cursor-based pagination on a LIVE ranked\\nfeed — new posts shift all offset-based cursors.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s2r10\",\"type\":\"rectangle\",\"x\":10,\"y\":1366,\"width\":502,\"height\":178,\"angle\":0,\"strokeColor\":\"#fbbf24\",\"backgroundColor\":\"#fffbeb\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"ax\",\"roundness\":{\"type\":3},\"seed\":1740934544,\"version\":2,\"versionNonce\":1435412336,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s2r10t\",\"type\":\"text\",\"x\":24,\"y\":1378,\"width\":247.43984985351562,\"height\":18.75,\"angle\":0,\"strokeColor\":\"#b45309\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"ay\",\"roundness\":null,\"seed\":1321259888,\"version\":2,\"versionNonce\":228968336,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"FR10 — Media Attachments  [P1]\",\"fontSize\":15,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"FR10 — Media Attachments  [P1]\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s2r10b\",\"type\":\"text\",\"x\":24,\"y\":1402,\"width\":334.13861083984375,\"height\":81.25,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"az\",\"roundness\":null,\"seed\":419191696,\"version\":2,\"versionNonce\":1579694448,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"User attaches images or video to posts.\\nExample: 4K video upload — transcoded to\\nmulti-res, served globally via CDN.\\nHidden: post created BEFORE media is ready.\\nNeed media_pending state; filter from feed until live.\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"User attaches images or video to posts.\\nExample: 4K video upload — transcoded to\\nmulti-res, served globally via CDN.\\nHidden: post created BEFORE media is ready.\\nNeed media_pending state; filter from feed until live.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s2r11\",\"type\":\"rectangle\",\"x\":530,\"y\":1366,\"width\":502,\"height\":178,\"angle\":0,\"strokeColor\":\"#a78bfa\",\"backgroundColor\":\"#f5f3ff\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b00\",\"roundness\":{\"type\":3},\"seed\":1211426160,\"version\":2,\"versionNonce\":581326224,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s2r11t\",\"type\":\"text\",\"x\":544,\"y\":1378,\"width\":272.89483642578125,\"height\":18.75,\"angle\":0,\"strokeColor\":\"#6d28d9\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b01\",\"roundness\":null,\"seed\":772434320,\"version\":2,\"versionNonce\":29330288,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"FR11 — Cold Start \/ New User  [P2]\",\"fontSize\":15,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"FR11 — Cold Start \/ New User  [P2]\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s2r11b\",\"type\":\"text\",\"x\":544,\"y\":1402,\"width\":329.47161865234375,\"height\":81.25,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b02\",\"roundness\":null,\"seed\":1565964144,\"version\":2,\"versionNonce\":610608016,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"New user with no follows gets a useful feed.\\nExample: signup picks Sports — immediately\\nsees trending sports posts before following anyone.\\nHidden: collaborative filtering fails with no history.\\nUse topic graphs and popularity-based fallbacks.\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"New user with no follows gets a useful feed.\\nExample: signup picks Sports — immediately\\nsees trending sports posts before following anyone.\\nHidden: collaborative filtering fails with no history.\\nUse topic graphs and popularity-based fallbacks.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s2r12\",\"type\":\"rectangle\",\"x\":1058,\"y\":1366,\"width\":512,\"height\":178,\"angle\":0,\"strokeColor\":\"#a78bfa\",\"backgroundColor\":\"#f5f3ff\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b03\",\"roundness\":{\"type\":3},\"seed\":1378269072,\"version\":2,\"versionNonce\":446471536,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s2r12t\",\"type\":\"text\",\"x\":1072,\"y\":1378,\"width\":267.1048583984375,\"height\":18.75,\"angle\":0,\"strokeColor\":\"#6d28d9\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b04\",\"roundness\":null,\"seed\":1382959472,\"version\":2,\"versionNonce\":1629106576,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"FR12 — Mute \/ Block \/ Filter  [P2]\",\"fontSize\":15,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"FR12 — Mute \/ Block \/ Filter  [P2]\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s2r12b\",\"type\":\"text\",\"x\":1072,\"y\":1402,\"width\":317.17364501953125,\"height\":81.25,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b05\",\"roundness\":null,\"seed\":159991184,\"version\":2,\"versionNonce\":2047307632,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Hide specific accounts or keywords from feed.\\nExample: Alice mutes Bob — zero of his posts\\nappear, even through celebrity reshares.\\nHidden: filter must run POST fan-out, not before.\\nKeyword filters need near-real-time NLP tagging.\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Hide specific accounts or keywords from feed.\\nExample: Alice mutes Bob — zero of his posts\\nappear, even through celebrity reshares.\\nHidden: filter must run POST fan-out, not before.\\nKeyword filters need near-real-time NLP tagging.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s2sum\",\"type\":\"rectangle\",\"x\":10,\"y\":1557,\"width\":1560,\"height\":38,\"angle\":0,\"strokeColor\":\"#1e3a5f\",\"backgroundColor\":\"#1e3a5f\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b06\",\"roundness\":{\"type\":3},\"seed\":583244656,\"version\":2,\"versionNonce\":536706960,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s2sumt\",\"type\":\"text\",\"x\":24,\"y\":1570,\"width\":1059.3782958984375,\"height\":17.5,\"angle\":0,\"strokeColor\":\"#f1f5f9\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b07\",\"roundness\":null,\"seed\":292164496,\"version\":2,\"versionNonce\":138936688,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"P0 FRs to nail: FR1 Post Creation  |  FR2 Fan-out  |  FR3 Feed Read  |  FR4 Follow  |  FR9 Pagination  —  the system does not function without these\",\"fontSize\":14,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"P0 FRs to nail: FR1 Post Creation  |  FR2 Fan-out  |  FR3 Feed Read  |  FR4 Follow  |  FR9 Pagination  —  the system does not function without these\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s3bg\",\"type\":\"rectangle\",\"x\":10,\"y\":1610,\"width\":1560,\"height\":870,\"angle\":0,\"strokeColor\":\"#cbd5e1\",\"backgroundColor\":\"#f8fafc\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b08\",\"roundness\":{\"type\":3},\"seed\":547270000,\"version\":2,\"versionNonce\":21433744,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s3hd\",\"type\":\"rectangle\",\"x\":10,\"y\":1610,\"width\":1560,\"height\":46,\"angle\":0,\"strokeColor\":\"#134e4a\",\"backgroundColor\":\"#134e4a\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b09\",\"roundness\":{\"type\":3},\"seed\":1073815952,\"version\":2,\"versionNonce\":1688621936,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s3tt\",\"type\":\"text\",\"x\":430,\"y\":1623,\"width\":645.9175415039062,\"height\":26.25,\"angle\":0,\"strokeColor\":\"#f0fdf4\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b0A\",\"roundness\":null,\"seed\":357007216,\"version\":2,\"versionNonce\":1580129168,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"STEP 3  —  Non-Functional Requirements  (with hard numbers)\",\"fontSize\":21,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"STEP 3  —  Non-Functional Requirements  (with hard numbers)\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s3a\",\"type\":\"rectangle\",\"x\":10,\"y\":1666,\"width\":502,\"height\":205,\"angle\":0,\"strokeColor\":\"#fca5a5\",\"backgroundColor\":\"#fff1f2\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b0B\",\"roundness\":{\"type\":3},\"seed\":1686531984,\"version\":2,\"versionNonce\":90858864,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s3at\",\"type\":\"text\",\"x\":24,\"y\":1678,\"width\":82.28790283203125,\"height\":20,\"angle\":0,\"strokeColor\":\"#b91c1c\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b0C\",\"roundness\":null,\"seed\":1627787632,\"version\":2,\"versionNonce\":686614928,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Availability\",\"fontSize\":16,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Availability\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s3ab\",\"type\":\"text\",\"x\":24,\"y\":1703,\"width\":321.859619140625,\"height\":140,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b0D\",\"roundness\":null,\"seed\":657587600,\"version\":2,\"versionNonce\":1474049904,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Target: 99.99% = 52 min downtime per year\\nRead path: 99.99%  |  Write path: 99.9%\\n(users tolerate post-fail more than feed-down)\\n\\nViolated by: single-AZ DB, no read replicas,\\nno circuit breakers on downstream services.\\nResponsible: multi-AZ fleet, cache fallback\\n(stale feed is always better than no feed).\",\"fontSize\":14,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Target: 99.99% = 52 min downtime per year\\nRead path: 99.99%  |  Write path: 99.9%\\n(users tolerate post-fail more than feed-down)\\n\\nViolated by: single-AZ DB, no read replicas,\\nno circuit breakers on downstream services.\\nResponsible: multi-AZ fleet, cache fallback\\n(stale feed is always better than no feed).\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s3b\",\"type\":\"rectangle\",\"x\":530,\"y\":1666,\"width\":502,\"height\":205,\"angle\":0,\"strokeColor\":\"#fca5a5\",\"backgroundColor\":\"#fff1f2\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b0E\",\"roundness\":{\"type\":3},\"seed\":455238512,\"version\":2,\"versionNonce\":1287206800,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s3bt\",\"type\":\"text\",\"x\":544,\"y\":1678,\"width\":60.303955078125,\"height\":20,\"angle\":0,\"strokeColor\":\"#b91c1c\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b0F\",\"roundness\":null,\"seed\":1765526416,\"version\":2,\"versionNonce\":1615055216,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Latency\",\"fontSize\":16,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Latency\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s3bb\",\"type\":\"text\",\"x\":544,\"y\":1703,\"width\":320.235595703125,\"height\":140,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b0G\",\"roundness\":null,\"seed\":837055856,\"version\":2,\"versionNonce\":231458192,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Feed Read:   P50 < 80ms    P99 < 500ms\\nPost Write:  P50 < 200ms   P99 < 1000ms\\nLike\/React:  P50 < 50ms    P99 < 200ms\\n\\nViolated by: cache miss forcing DB query,\\nN+1 fetches hydrating post metadata per item.\\nResponsible: Redis feed cache, CDN for media,\\nprecomputed ranked feeds, connection pooling.\",\"fontSize\":14,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Feed Read:   P50 < 80ms    P99 < 500ms\\nPost Write:  P50 < 200ms   P99 < 1000ms\\nLike\/React:  P50 < 50ms    P99 < 200ms\\n\\nViolated by: cache miss forcing DB query,\\nN+1 fetches hydrating post metadata per item.\\nResponsible: Redis feed cache, CDN for media,\\nprecomputed ranked feeds, connection pooling.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s3c\",\"type\":\"rectangle\",\"x\":1058,\"y\":1666,\"width\":512,\"height\":205,\"angle\":0,\"strokeColor\":\"#fca5a5\",\"backgroundColor\":\"#fff1f2\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b0H\",\"roundness\":{\"type\":3},\"seed\":618387856,\"version\":2,\"versionNonce\":1508449136,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s3ct\",\"type\":\"text\",\"x\":1072,\"y\":1678,\"width\":91.90391540527344,\"height\":20,\"angle\":0,\"strokeColor\":\"#b91c1c\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b0I\",\"roundness\":null,\"seed\":177489776,\"version\":2,\"versionNonce\":1767674768,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Throughput\",\"fontSize\":16,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Throughput\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s3cb\",\"type\":\"text\",\"x\":1072,\"y\":1703,\"width\":320.48760986328125,\"height\":140,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b0J\",\"roundness\":null,\"seed\":1296705424,\"version\":2,\"versionNonce\":1460940144,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Feed reads:   50K QPS avg   200K QPS peak\\nPost writes:  500 QPS avg   2K QPS peak\\nLike events:  50K QPS avg   500K QPS peak\\n\\nViolated by: no horizontal scaling, DB as\\nbottleneck for all reads, single Kafka partition.\\nResponsible: horizontally scaled API tier,\\nKafka partitioned by user_id, Redis cluster.\",\"fontSize\":14,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Feed reads:   50K QPS avg   200K QPS peak\\nPost writes:  500 QPS avg   2K QPS peak\\nLike events:  50K QPS avg   500K QPS peak\\n\\nViolated by: no horizontal scaling, DB as\\nbottleneck for all reads, single Kafka partition.\\nResponsible: horizontally scaled API tier,\\nKafka partitioned by user_id, Redis cluster.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s3d\",\"type\":\"rectangle\",\"x\":10,\"y\":1882,\"width\":502,\"height\":200,\"angle\":0,\"strokeColor\":\"#fcd34d\",\"backgroundColor\":\"#fffbeb\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b0K\",\"roundness\":{\"type\":3},\"seed\":561633648,\"version\":2,\"versionNonce\":1973658000,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s3dt\",\"type\":\"text\",\"x\":24,\"y\":1894,\"width\":74.03192138671875,\"height\":20,\"angle\":0,\"strokeColor\":\"#b45309\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b0L\",\"roundness\":null,\"seed\":784250256,\"version\":2,\"versionNonce\":1628241776,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Durability\",\"fontSize\":16,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Durability\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s3db\",\"type\":\"text\",\"x\":24,\"y\":1919,\"width\":330.8336181640625,\"height\":122.5,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b0M\",\"roundness\":null,\"seed\":702360432,\"version\":2,\"versionNonce\":1104736144,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Target: 99.9999% (6 nines) — zero post loss\\nMedia: S3-class object storage (11 nines)\\n\\nViolated by: write-to-cache-only, async DB write\\nthat fails silently, no WAL replication.\\nResponsible: sync write to DB primary before\\nACK, WAL to 2+ replicas, cross-region backup.\",\"fontSize\":14,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Target: 99.9999% (6 nines) — zero post loss\\nMedia: S3-class object storage (11 nines)\\n\\nViolated by: write-to-cache-only, async DB write\\nthat fails silently, no WAL replication.\\nResponsible: sync write to DB primary before\\nACK, WAL to 2+ replicas, cross-region backup.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s3e\",\"type\":\"rectangle\",\"x\":530,\"y\":1882,\"width\":502,\"height\":200,\"angle\":0,\"strokeColor\":\"#fcd34d\",\"backgroundColor\":\"#fffbeb\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b0N\",\"roundness\":{\"type\":3},\"seed\":1316062096,\"version\":2,\"versionNonce\":404459888,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s3et\",\"type\":\"text\",\"x\":544,\"y\":1894,\"width\":141.8878936767578,\"height\":20,\"angle\":0,\"strokeColor\":\"#b45309\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b0O\",\"roundness\":null,\"seed\":772160880,\"version\":2,\"versionNonce\":909409680,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Consistency Model\",\"fontSize\":16,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Consistency Model\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s3eb\",\"type\":\"text\",\"x\":544,\"y\":1919,\"width\":331.715576171875,\"height\":140,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b0P\",\"roundness\":null,\"seed\":1251643792,\"version\":2,\"versionNonce\":1401414512,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Feed content:     Eventual  (2-5s lag OK)\\nFollow\/Unfollow:  Read-your-writes (strong)\\nLike counts:      Eventual  (delta of 20 fine)\\n\\nViolated by: reading replica after unfollow —\\nuser sees the unfollowed person's posts again.\\nResponsible: route social graph reads to primary;\\nfeed content from replica is fine.\",\"fontSize\":14,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Feed content:     Eventual  (2-5s lag OK)\\nFollow\/Unfollow:  Read-your-writes (strong)\\nLike counts:      Eventual  (delta of 20 fine)\\n\\nViolated by: reading replica after unfollow —\\nuser sees the unfollowed person's posts again.\\nResponsible: route social graph reads to primary;\\nfeed content from replica is fine.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s3f\",\"type\":\"rectangle\",\"x\":1058,\"y\":1882,\"width\":512,\"height\":200,\"angle\":0,\"strokeColor\":\"#fcd34d\",\"backgroundColor\":\"#fffbeb\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b0Q\",\"roundness\":{\"type\":3},\"seed\":792530800,\"version\":2,\"versionNonce\":1944996752,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s3ft\",\"type\":\"text\",\"x\":1072,\"y\":1894,\"width\":98.19192504882812,\"height\":20,\"angle\":0,\"strokeColor\":\"#b45309\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b0R\",\"roundness\":null,\"seed\":980541328,\"version\":2,\"versionNonce\":1100608880,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Idempotency\",\"fontSize\":16,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Idempotency\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s3fb\",\"type\":\"text\",\"x\":1072,\"y\":1919,\"width\":336.2095947265625,\"height\":140,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b0S\",\"roundness\":null,\"seed\":1170841968,\"version\":2,\"versionNonce\":893278608,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Post creation: client sends UUID idem_key.\\nLike: set-based (liked_by table), not counter.\\nDouble-like = upsert, never double-count.\\nFan-out worker: dedup by (post_id, user_id).\\n\\nViolated by: retry POST \/posts without key\\n= duplicate post published to feed.\\nResponsible: API checks key in Redis (TTL 24h).\",\"fontSize\":14,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Post creation: client sends UUID idem_key.\\nLike: set-based (liked_by table), not counter.\\nDouble-like = upsert, never double-count.\\nFan-out worker: dedup by (post_id, user_id).\\n\\nViolated by: retry POST \/posts without key\\n= duplicate post published to feed.\\nResponsible: API checks key in Redis (TTL 24h).\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s3g\",\"type\":\"rectangle\",\"x\":10,\"y\":2093,\"width\":502,\"height\":192,\"angle\":0,\"strokeColor\":\"#86efac\",\"backgroundColor\":\"#f0fdf4\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b0T\",\"roundness\":{\"type\":3},\"seed\":237989264,\"version\":2,\"versionNonce\":127518576,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s3gt\",\"type\":\"text\",\"x\":24,\"y\":2105,\"width\":63.51995849609375,\"height\":20,\"angle\":0,\"strokeColor\":\"#15803d\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b0U\",\"roundness\":null,\"seed\":1089729392,\"version\":2,\"versionNonce\":761046928,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Security\",\"fontSize\":16,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Security\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s3gb\",\"type\":\"text\",\"x\":24,\"y\":2130,\"width\":327.02557373046875,\"height\":140,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b0V\",\"roundness\":null,\"seed\":1863007120,\"version\":2,\"versionNonce\":1640978800,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Auth: JWT \/ OAuth2 on every API call.\\nPrivate accounts: follow-check before returning\\nany content from private profiles.\\nRate limits: 100 reads\/min, 10 posts\/min.\\n\\nViolated by: missing auth on feed endpoint\\nexposes private posts. No rate limit = DDoS.\\nResponsible: API gateway (auth + rate limiting).\",\"fontSize\":14,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Auth: JWT \/ OAuth2 on every API call.\\nPrivate accounts: follow-check before returning\\nany content from private profiles.\\nRate limits: 100 reads\/min, 10 posts\/min.\\n\\nViolated by: missing auth on feed endpoint\\nexposes private posts. No rate limit = DDoS.\\nResponsible: API gateway (auth + rate limiting).\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s3h\",\"type\":\"rectangle\",\"x\":530,\"y\":2093,\"width\":502,\"height\":192,\"angle\":0,\"strokeColor\":\"#86efac\",\"backgroundColor\":\"#f0fdf4\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b0W\",\"roundness\":{\"type\":3},\"seed\":1191445872,\"version\":2,\"versionNonce\":1753298320,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s3ht\",\"type\":\"text\",\"x\":544,\"y\":2105,\"width\":99.77589416503906,\"height\":20,\"angle\":0,\"strokeColor\":\"#15803d\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b0X\",\"roundness\":null,\"seed\":524110224,\"version\":2,\"versionNonce\":1132637040,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Observability\",\"fontSize\":16,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Observability\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s3hb\",\"type\":\"text\",\"x\":544,\"y\":2130,\"width\":309.59564208984375,\"height\":122.5,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b0Y\",\"roundness\":null,\"seed\":1967249264,\"version\":2,\"versionNonce\":736363408,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Key metrics: feed_p99_ms, cache_hit_ratio,\\nfan_out_lag_s, like_event_lag_ms.\\nDistributed traces: OTEL per request\\n(API → cache → DB → ranker → response).\\nAlerts: p99 > 500ms for 2 min → page oncall.\\nViolated by: no tracing makes it impossible\\nto debug which step caused a P99 spike.\",\"fontSize\":14,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Key metrics: feed_p99_ms, cache_hit_ratio,\\nfan_out_lag_s, like_event_lag_ms.\\nDistributed traces: OTEL per request\\n(API → cache → DB → ranker → response).\\nAlerts: p99 > 500ms for 2 min → page oncall.\\nViolated by: no tracing makes it impossible\\nto debug which step caused a P99 spike.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s3i\",\"type\":\"rectangle\",\"x\":1058,\"y\":2093,\"width\":512,\"height\":192,\"angle\":0,\"strokeColor\":\"#93c5fd\",\"backgroundColor\":\"#eff6ff\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b0Z\",\"roundness\":{\"type\":3},\"seed\":1509791632,\"version\":2,\"versionNonce\":1996209520,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s3it\",\"type\":\"text\",\"x\":1072,\"y\":2105,\"width\":95.11990356445312,\"height\":20,\"angle\":0,\"strokeColor\":\"#1d4ed8\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b0a\",\"roundness\":null,\"seed\":2146789744,\"version\":2,\"versionNonce\":1438454160,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Multi-Region\",\"fontSize\":16,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Multi-Region\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s3ib\",\"type\":\"text\",\"x\":1072,\"y\":2130,\"width\":318.03759765625,\"height\":140,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b0b\",\"roundness\":null,\"seed\":864298384,\"version\":2,\"versionNonce\":1031966576,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Strategy: active-active reads,\\nactive-passive writes (per home region).\\nReplication lag: <500ms graph, <5s feed cache.\\nRTO: 30s (Route53 DNS failover).\\nRPO: <1s (Aurora Global sync replication).\\n\\nViolated by: single-region DB = 30+ min RTO\\nduring a region outage.\",\"fontSize\":14,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Strategy: active-active reads,\\nactive-passive writes (per home region).\\nReplication lag: <500ms graph, <5s feed cache.\\nRTO: 30s (Route53 DNS failover).\\nRPO: <1s (Aurora Global sync replication).\\n\\nViolated by: single-region DB = 30+ min RTO\\nduring a region outage.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s3sum\",\"type\":\"rectangle\",\"x\":10,\"y\":2297,\"width\":1560,\"height\":50,\"angle\":0,\"strokeColor\":\"#134e4a\",\"backgroundColor\":\"#134e4a\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b0c\",\"roundness\":{\"type\":3},\"seed\":1382464368,\"version\":2,\"versionNonce\":1027891088,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s3sumt\",\"type\":\"text\",\"x\":24,\"y\":2310,\"width\":1220.174072265625,\"height\":18.75,\"angle\":0,\"strokeColor\":\"#f0fdf4\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",