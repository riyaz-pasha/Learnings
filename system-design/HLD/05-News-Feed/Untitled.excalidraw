cked":false,"strokeColor":"#adb5bd","link":null,"roughness":1,"groupIds":[],"index":"b3K","backgroundColor":"#f8f9fa","angle":0,"fillStyle":"solid","strokeWidth":1,"version":5,"roundness":{"type":3},"type":"rectangle","updated":1772747707441,"id":"I7k1IPXiKyEd2Wvi87MhE","x":-251.5596923828125,"seed":196854852,"boundElements":[],"y":1224,"opacity":100,"height":215,"width":490,"frameId":null,"strokeStyle":"solid","versionNonce":1596525820},{"seed":197303236,"strokeStyle":"solid","id":"9S_FxE1W9jVQ_WBIQAIvj","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":17,"opacity":100,"verticalAlign":"top","updated":1772747707441,"locked":false,"text":"A. User Journey","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b3L","roundness":null,"containerId":null,"originalText":"A. User Journey","height":21.25,"link":null,"strokeColor":"#2563eb","fillStyle":"solid","groupIds":[],"versionNonce":1299665092,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-241.5596923828125,"angle":0,"y":1232,"width":130.79788208007812},{"seed":604144452,"strokeStyle":"solid","id":"YVfSuVmBlwHz2kHOMd7do","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772747707441,"locked":false,"text":"1. User taps Post button with text + photo\n2. Client sends POST \/posts with idempotency_key\n3. Server responds 200 in <200ms (post saved)\n4. Client shows post in own feed immediately\n5. Followers see post appear within 5-30s\n\nDuring failure:\n- Kafka down: post saved, fan-out queued in DB\n  fallback table. Propagates when Kafka recovers.\n- Worker crash mid-fan-out: partial update.\n  Some followers see post, others don't yet.\n  Worker retries from last committed offset.\n\nLatency budget:\n  API write (save + publish Kafka): <200ms\n  Fan-out propagation (normal user): <5s\n  Fan-out propagation (1M followers): <30s","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b3M","roundness":null,"containerId":null,"originalText":"1. User taps Post button with text + photo\n2. Client sends POST \/posts with idempotency_key\n3. Server responds 200 in <200ms (post saved)\n4. Client shows post in own feed immediately\n5. Followers see post appear within 5-30s\n\nDuring failure:\n- Kafka down: post saved, fan-out queued in DB\n  fallback table. Propagates when Kafka recovers.\n- Worker crash mid-fan-out: partial update.\n  Some followers see post, others don't yet.\n  Worker retries from last committed offset.\n\nLatency budget:\n  API write (save + publish Kafka): <200ms\n  Fan-out propagation (normal user): <5s\n  Fan-out propagation (1M followers): <30s","height":297.5,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":1693846908,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-241.5596923828125,"angle":0,"y":1257,"width":354.00360107421875},{"isDeleted":false,"locked":false,"strokeColor":"#adb5bd","link":null,"roughness":1,"groupIds":[],"index":"b3N","backgroundColor":"#f8f9fa","angle":0,"fillStyle":"solid","strokeWidth":1,"version":5,"roundness":{"type":3},"type":"rectangle","updated":1772747707441,"id":"BZscqcvabE7bwE1jR4uWI","x":258.4403076171875,"seed":182024900,"boundElements":[],"y":1224,"opacity":100,"height":215,"width":670,"frameId":null,"strokeStyle":"solid","versionNonce":391682116},{"seed":2061861444,"strokeStyle":"solid","id":"brVr-BeC7F2P07n4-cEAd","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":17,"opacity":100,"verticalAlign":"top","updated":1772747707441,"locked":false,"text":"B. Internal Flow","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b3O","roundness":null,"containerId":null,"originalText":"B. Internal Flow","height":21.25,"link":null,"strokeColor":"#2563eb","fillStyle":"solid","groupIds":[],"versionNonce":441384444,"textAlign":"left","fontFamily":5,"lineHeig