ess\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"av\",\"roundness\":null,\"seed\":1747648400,\"version\":2,\"versionNonce\":1688917360,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"FR9 — Infinite Scroll \/ Pagination  [P0]\",\"fontSize\":15,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"FR9 — Infinite Scroll \/ Pagination  [P0]\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s2r9b\",\"type\":\"text\",\"x\":1072,\"y\":1210,\"width\":314.274658203125,\"height\":81.25,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"aw\",\"roundness\":null,\"seed\":1135772016,\"version\":2,\"versionNonce\":808155536,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Older posts load seamlessly as user scrolls.\\nExample: user 200 posts deep — next 20 load\\nwith no duplicates or gaps in the feed.\\nHidden: cursor-based pagination on a LIVE ranked\\nfeed — new posts shift all offset-based cursors.\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Older posts load seamlessly as user scrolls.\\nExample: user 200 posts deep — next 20 load\\nwith no duplicates or gaps in the feed.\\nHidden: cursor-based pagination on a LIVE ranked\\nfeed — new posts shift all offset-based cursors.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s2r10\",\"type\":\"rectangle\",\"x\":10,\"y\":1366,\"width\":502,\"height\":178,\"angle\":0,\"strokeColor\":\"#fbbf24\",\"backgroundColor\":\"#fffbeb\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"ax\",\"roundness\":{\"ty