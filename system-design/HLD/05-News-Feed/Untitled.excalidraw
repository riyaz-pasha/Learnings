},{\"id\":\"s2r1t\",\"type\":\"text\",\"x\":24,\"y\":802,\"width\":201.9148712158203,\"height\":18.75,\"angle\":0,\"strokeColor\":\"#b91c1c\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"aX\",\"roundness\":null,\"seed\":1351604112,\"version\":2,\"versionNonce\":201162096,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"FR1 — Post Creation  [P0]\",\"fontSize\":15,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"FR1 — Post Creation  [P0]\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s2r1b\",\"type\":\"text\",\"x\":24,\"y\":826,\"width\":325.753662109375,\"height\":81.25,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"aY\",\"roundness\":null,\"seed\":581380464,\"version\":2,\"versionNonce\":1521963408,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"User writes post; stored durably before ACK.\\nExample: @celebrity posts album art, stored once,\\nfan-out propagates to 100M followers.\\nHidden: idempotency on retry — network drop after\\nDB write = duplicate post without a dedup key.\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"User writes post; stored durably before ACK.\\nExample: @celebrity posts album art, stored once,\\nfan-out propagates to 100M followers.\\nHidden: idempotency on retry — network drop after\\nDB write = duplicate post without a dedup key.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s2r2\",\"type\":\"rectangle\",\"x\":530,\"y\":790,\"width\":502,\"height\":178,\"angle\":0,\"strokeColor\":\"#f87171\",\"backgroundColor\":\"#fff1f2\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"aZ\",\"roundness\":{\"type\":3},\"seed\":500065680,\"version\":2,\"versionNonce\":1280069488,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s2r2t\",\"type\":\"text\",\"x\":544,\"y\":802,\"width\":300.74981689453125,\"height\":18.75,\"angle\":0,\"strokeColor\":\"#b91c1c\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"aa\",\"roundness\":null,\"seed\":954235760,\"version\":2,\"versionNonce\":687251344,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"FR2 — Feed Generation \/ Fan-out  [P0]\",\"fontSize\":15,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"FR2 — Feed Generation \/ Fan-out  [P0]\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s2r2b\",\"type\":\"text\",\"x\":544,\"y\":826,\"width\":316.39361572265625,\"height\":81.25,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"ab\",\"roundness\":null,\"seed\":537605008,\"version\":2,\"versionNonce\":2129715568,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"On post create, push to follower feed caches.\\nExample: user with 500 followers posts — all 500\\nRedis feed entries updated within 5 seconds.\\nHidden: celebrity with 10M followers breaks sync\\nfan-out. Hybrid write\/read strategy required.\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"On post create, push to follower feed caches.\\nExample: user with 500 followers posts — all 500\\nRedis feed entries updated within 5 seconds.\\nHidden: celebrity with 10M followers breaks sync\\nfan-out. Hybrid write\/read strategy required.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s2r3\",\"type\":\"rectangle\",\"x\":1058,\"y\":790,\"width\":512,\"height\":178,\"angle\":0,\"strokeColor\":\"#f87171\",\"backgroundColor\":\"#fff1f2\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"ac\",\"roundness\":{\"type\":3},\"seed\":538938736,\"version\":2,\"versionNonce\":1310469520,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s2r3t\",\"type\":\"text\",\"x\":1072,\"y\":802,\"width\":207.83985900878906,\"height\":18.75,\"angle\":0,\"strokeColor\":\"#b91c1c\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"ad\",\"roundness\":null,\"seed\":494813584,\"version\":2,\"versionNonce\":1395864432,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"FR3 — Feed Retrieval  [P0]\",\"fontSize\":15,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"FR3 — Feed Retrieval  [P0]\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s2r3b\",\"type\":\"text\",\"x\":1072,\"y\":826,\"width\":321.7106018066406,\"height\":81.25,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"ae\",\"roundness\":null,\"seed\":833380208,\"version\":2,\"versionNonce\":325057424,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"User opens app; returns ranked paginated feed.\\nExample: Instagram loads top 20 posts from 300\\nfollowed accounts in under 200ms.\\nHidden: merging celebrity fan-on-read with\\nprecomputed cache at read time under 500ms P99.\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"User opens app; returns ranked paginated feed.\\nExample: Instagram loads top 20 posts from 300\\nfollowed accounts in under 200ms.\\nHidden: merging celebrity fan-on-read with\\nprecomputed cache at read time under 500ms P99.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s2r4\",\"type\":\"rectangle\",\"x\":10,\"y\":982,\"width\":502,\"height\":178,\"angle\":0,\"strokeColor\":\"#f87171\",\"backgroundColor\":\"#fff1f2\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"af\",\"roundness\":{\"type\":3},\"seed\":1432326032,\"version\":2,\"versionNonce\":1331381616,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s2r4t\",\"type\":\"text\",\"x\":24,\"y\":994,\"width\":228.43487548828125,\"height\":18.75,\"angle\":0,\"strokeColor\":\"#b91c1c\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"ag\",\"roundness\":null,\"seed\":1573843312,\"version\":2,\"versionNonce\":1526335888,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"FR4 — Follow \/ Unfollow  [P0]\",\"fontSize\":15,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"FR4 — Follow \/ Unfollow  [P0]\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s2r4b\",\"type\":\"text\",\"x\":24,\"y\":1018,\"width\":298.3885498046875,\"height\":81.25,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"ah\",\"roundness\":null,\"seed\":1608981904,\"version\":2,\"versionNonce\":1890654064,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"User follows or unfollows an account.\\nExample: Alice unfollows Bob — his posts must\\ndisappear from her feed immediately.\\nHidden: unfollow invalidates feed cache. New\\nfollow needs historical post backfill into cache.\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"User follows or unfollows an account.\\nExample: Alice unfollows Bob — his posts must\\ndisappear from her feed immediately.\\nHidden: unfollow invalidates feed cache. New\\nfollow needs historical post backfill into cache.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s2r5\",\"type\":\"rectangle\",\"x\":530,\"y\":982,\"width\":502,\"height\":178,\"angle\":0,\"strokeColor\":\"#fbbf24\",\"backgroundColor\":\"#fffbeb\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"ai\",\"roundness\":{\"type\":3},\"seed\":1271874416,\"version\":2,\"versionNonce\":2250640,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s2r5t\",\"type\":\"text\",\"x\":544,\"y\":994,\"width\":191.51986694335938,\"height\":18.75,\"angle\":0,\"strokeColor\":\"#b45309\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"aj\",\"roundness\":null,\"seed\":239922064,\"version\":2,\"versionNonce\":1266461040,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"FR5 — Like \/ React  [P1]\",\"fontSize\":15,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"FR5 — Like \/ React  [P1]\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s2r5b\",\"type\":\"text\",\"x\":544,\"y\":1018,\"width\":314.37860107421875,\"height\":81.25,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"ak\",\"roundness\":null,\"seed\":2046121328,\"version\":2,\"versionNonce\":923854224,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"User likes a post; count updates visibly.\\nExample: viral tweet 500K likes\/hr = ~140\/sec,\\nspiking to 2,000\/sec on hot content.\\nHidden: row-level DB increment serializes at scale.\\nUse Redis INCR + async batch flush to DB.\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"User likes a post; count updates visibly.\\nExample: viral tweet 500K likes\/hr = ~140\/sec,\\nspiking to 2,000\/sec on hot content.\\nHidden: row-level DB increment serializes at scale.\\nUse Redis INCR + async batch flush to DB.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s2r6\",\"type\":\"rectangle\",\"x\":1058,\"y\":982,\"width\":512,\"height\":178,\"angle\":0,\"strokeColor\":\"#fbbf24\",\"backgroundColor\":\"#fffbeb\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"al\",\"roundness\":{\"type\":3},\"seed\":1254685072,\"version\":2,\"versionNonce\":721812336,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s2r6t\",\"type\":\"text\",\"x\":1072,\"y\":994,\"width\":170.69989013671875,\"height\":18.75,\"angle\":0,\"strokeColor\":\"#b45309\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"am\",\"roundness\":null,\"seed\":1569269616,\"version\":2,\"versionNonce\":1828565904,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"FR6 — Comments  [P1]\",\"fontSize\":15,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"FR6 — Comments  [P1]\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s2r6b\",\"type\":\"text\",\"x\":1072,\"y\":1018,\"width\":311.5706481933594,\"height\":81.25,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"an\",\"roundness\":null,\"seed\":2022918032,\"version\":2,\"versionNonce\":831851888,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"User adds comment; visible to all viewers.\\nExample: hot post gets 10K comments in 5 min\\n— thread must stay ordered and paginated.\\nHidden: threaded replies need recursive model.\\nHot post = write hotspot on single DB partition.\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"User adds comment; visible to all viewers.\\nExample: hot post gets 10K comments in 5 min\\n— thread must stay ordered and paginated.\\nHidden: threaded replies need recursive model.\\nHot post = write hotspot on single DB partition.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s2r7\",\"type\":\"rectangle\",\"x\":10,\"y\":1174,\"width\":502,\"height\":178,\"angle\":0,\"strokeColor\":\"#fbbf24\",\"backgroundColor\":\"#fffbeb\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"ao\",\"roundness\":{\"type\":3},\"seed\":47364464,\"version\":2,\"versionNonce\":673235344,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s2r7t\",\"type\":\"text\",\"x\":24,\"y\":1186,\"width\":273.704833984375,\"height\":18.75,\"angle\":0,\"strokeColor\":\"#b45309\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"ap\",\"roundness\":null,\"seed\":1407440272,\"version\":2,\"versionNonce\":2020728688,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"FR7 — Real-time Feed Updates  [P1]\",\"fontSize\":15,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"FR7 — Real-time Feed Updates  [P1]\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s2r7b\",\"type\":\"text\",\"x\":24,\"y\":1210,\"width\":315.75665283203125,\"height\":81.25,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"aq\",\"roundness\":null,\"seed\":756681584,\"version\":2,\"versionNonce\":1739722640,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"New posts appear without manual refresh.\\nExample: friend posts photo — slides into your\\nfeed within 3 seconds, no page reload needed.\\nHidden: millions of persistent WS\/SSE connections\\nare costly. Push all vs ping-then-pull tradeoff.\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"New posts appear without manual refresh.\\nExample: friend posts photo — slides into your\\nfeed within 3 seconds, no page reload needed.\\nHidden: millions of persistent WS\/SSE connections\\nare costly. Push all vs ping-then-pull tradeoff.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s2r8\",\"type\":\"rectangle\",\"x\":530,\"y\":1174,\"width\":502,\"height\":178,\"angle\":0,\"strokeColor\":\"#fbbf24\",\"backgroundColor\":\"#fffbeb\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"ar\",\"roundness\":{\"type\":3},\"seed\":1374856080,\"version\":2,\"versionNonce\":803500400,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s2r8t\",\"type\":\"text\",\"x\":544,\"y\":1186,\"width\":195.869873046875,\"height\":18.75,\"angle\":0,\"strokeColor\":\"#b45309\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"as\",\"roundness\":null,\"seed\":1990663536,\"version\":2,\"versionNonce\":65641872,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"FR8 — Feed Ranking  [P1]\",\"fontSize\":15,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"FR8 — Feed Ranking  [P1]\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s2r8b\",\"type\":\"text\",\"x\":544,\"y\":1210,\"width\":320.04656982421875,\"height\":81.25,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"at\",\"roundness\":null,\"seed\":16232848,\"version\":2,\"versionNonce\":1060422512,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Posts ranked by relevance, not just recency.\\nExample: BFF's post ranks above old brand follow\\nusing engagement + recency signals.\\nHidden: ML inference at read adds 10-50ms.\\nMust precompute or cache per-user ranked results.\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Posts ranked by relevance, not just recency.\\nExample: BFF's post ranks above old brand follow\\nusing engagement + recency signals.\\nHidden: ML inference at read adds 10-50ms.\\nMust precompute or cache per-user ranked results.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s2r9\",\"type\":\"rectangle\",\"x\":1058,\"y\":1174,\"width\":512,\"height\":178,\"angle\":0,\"strokeColor\":\"#f87171\",\"backgroundColor\":\"#fff1f2\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"au\",\"roundness\":{\"type\":3},\"seed\":1891757936,\"version\":2,\"versionNonce\":234843024,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s2r9t\",\"type\":\"text\",\"x\":1072,\"y\":1186,\"width\":298.8148193359375,\"height\":18.75,\"angle\":0,\"strokeColor\":\"#b91c1c\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"av\",\"roundness\":null,\"seed\":1747648400,\"version\":2,\"versionNonce\":1688917360,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"FR9 — Infinite Scroll \/ Pagination  [P0]\",\"fontSize\":15,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"FR9 — Infinite Scroll \/ Pagination  [P0]\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s2r9b\",\"type\":\"text\",\"x\":1072,\"y\":1210,\"width\":314.274658203125,\"height\":81.25,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"aw\",\"roundness\":null,\"seed\":1135772016,\"version\":2,\"versionNonce\":808155536,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Older posts load seamlessly as user scrolls.\\nExample: user 200 posts deep — next 20 load\\nwith no duplicates or gaps in the feed.\\nHidden: cursor-based pagination on a LIVE ranked\\nfeed — new posts shift all offset-based cursors.\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Older posts load seamlessly as user scrolls.\\nExample: user 200 posts deep — next 20 load\\nwith no duplicates or gaps in the feed.\\nHidden: cursor-based pagination on a LIVE ranked\\nfeed — new posts shift all offset-based cursors.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s2r10\",\"type\":\"rectangle\",\"x\":10,\"y\":1366,\"width\":502,\"height\":178,\"angle\":0,\"strokeColor\":\"#fbbf24\",\"backgroundColor\":\"#fffbeb\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"ax\",\"roundness\":{\"type\":3},\"seed\":1740934544,\"version\":2,\"versionNonce\":1435412336,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s2r10t\",\"type\":\"text\",\"x\":24,\"y\":1378,\"width\":247.43984985351562,\"height\":18.75,\"angle\":0,\"strokeColor\":\"#b45309\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"ay\",\"roundness\":null,\"seed\":1321259888,\"version\":2,\"versionNonce\":228968336,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"FR10 — Media Attachments  [P1]\",\"fontSize\":15,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"FR10 — Media Attachments  [P1]\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s2r10b\",\"type\":\"text\",\"x\":24,\"y\":1402,\"width\":334.13861083984375,\"height\":81.25,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"az\",\"roundness\":null,\"seed\":419191696,\"version\":2,\"versionNonce\":1579694448,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"User attaches images or video to posts.\\nExample: 4K video upload — transcoded to\\nmulti-res, served globally via CDN.\\nHidden: post created BEFORE media is ready.\\nNeed media_pending state; filter from feed until live.\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"User attaches images or video to posts.\\nExample: 4K video upload — transcoded to\\nmulti-res, served globally via CDN.\\nHidden: post created BEFORE media is ready.\\nNeed media_pending state; filter from feed until live.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s2r11\",\"type\":\"rectangle\",\"x\":530,\"y\":1366,\"width\":502,\"height\":178,\"angle\":0,\"strokeColor\":\"#a78bfa\",\"backgroundColor\":\"#f5f3ff\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b00\",\"roundness\":{\"type\":3},\"seed\":1211426160,\"version\":2,\"versionNonce\":581326224,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s2r11t\",\"type\":\"text\",\"x\":544,\"y\":1378,\"width\":272.89483642578125,\"height\":18.75,\"angle\":0,\"strokeColor\":\"#6d28d9\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b01\",\"roundness\":null,\"seed\":772434320,\"version\":2,\"versionNonce\":29330288,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"FR11 — Cold Start \/ New User  [P2]\",\"fontSize\":15,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"FR11 — Cold Start \/ New User  [P2]\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s2r11b\",\"type\":\"text\",\"x\":544,\"y\":1402,\"width\":329.47161865234375,\"height\":81.25,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b02\",\"roundness\":null,\"seed\":1565964144,\"version\":2,\"versionNonce\":610608016,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"New user with no follows gets a useful feed.\\nExample: signup picks Sports — immediately\\nsees trending sports posts before following anyone.\\nHidden: collaborative filtering fails with no history.\\nUse topic graphs and popularity-based fallbacks.\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"New user with no follows gets a useful feed.\\nExample: signup picks Sports — immediately\\nsees trending sports posts before following anyone.\\nHidden: collaborative filtering fails with no history.\\nUse topic graphs and popularity-based fallbacks.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s2r12\",\"type\":\"rectangle\",\"x\":1058,\"y\":1366,\"width\":512,\"height\":178,\"angle\":0,\"strokeColor\"