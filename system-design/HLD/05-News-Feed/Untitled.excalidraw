50B\n\nSocial graph edge:  follower_id(8)+followee_id(8)+ts(8) = 24B\n\nTotal (with 3x replication):\n  Posts:      50M\/day x 1KB x 365 x 3  =  55 TB\/yr\n  Media:      50M x 30% x 500KB x 3    =  22 TB\/DAY  → S3\n  Soc.Graph:  500M x 300 x 24B x 3     =  11 TB total\n  Feed cache: 100M active users x 350B  =  35 GB  ← fits Redis!","height":243.75,"link":null,"strokeColor":"#334155","fillStyle":"solid","groupIds":[],"versionNonce":730553596,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1822.8699240820786,"angle":0,"y":-3061.3457143105743,"width":421.589599609375},{"isDeleted":false,"locked":false,"strokeColor":"#d8b4fe","link":null,"roughness":1,"groupIds":[],"index":"bFb","backgroundColor":"#fdf4ff","angle":0,"fillStyle":"solid","strokeWidth":1,"version":121,"roundness":{"type":3},"type":"rectangle","updated":1772748823811,"id":"78vswY7PSzmW-Zx6i7WEP","x":2576.8699240820788,"seed":1720762748,"boundElements":[],"y":-3098.3457143105743,"opacity":100,"height":268,"width":792,"frameId":null,"strokeStyle":"solid","versionNonce":277765500},{"seed":2121478652,"strokeStyle":"solid","id":"bjx5f58ECGhCt3uCEVAvO","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":16,"opacity":100,"verticalAlign":"top","updated":1772748823811,"locked":false,"text":"Bandwidth  +  Kafka Throughput","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bFc","roundness":null,"containerId":null,"originalText":"Bandwidth  +  Kafka Throughput","height":20,"link":null,"strokeColor":"#7e22ce","fillStyle":"solid","groupIds":[],"versionNonce":1314737660,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":2590.8699240820788,"angle":0,"y":-3086.3457143105743,"width":258.70379638671875},{"seed":1102287484,"strokeStyle":"solid","id":"JYht_iN1PoO-abPr0AEWH","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772748823811,"locked":false,"text":"Feed payload per response:\n  20 posts x 700B (content+meta+CDN URL) = 14KB\n\nOutbound bandwidth (peak):\n  232K QPS x 14KB = 3.2 GB\/s outbound\n  Inbound writes: 2.3K x 2KB = 4.6 MB\/s (trivial)\n\nKafka fan-out messages:\n  2.3K posts\/sec x 300 followers x 100B = 69 MB\/s\n\nKafka like events:\n  464K likes\/sec x 100B = 46 MB\/s\n\nTotal Kafka throughput:  ~115 MB\/s\n\nCDN media egress:  22 TB\/day = ~255 MB\/s","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bFd","roundness":null,"containerId":null,"originalText":"Feed payload per response:\n  20 posts x 700B (content+meta+CDN URL) = 14KB\n\nOutbound bandwidth (peak):\n  232K QPS x 14KB = 3.2 GB\/s outbound\n  Inbound writes: 2.3K x 2KB = 4.6 MB\/s (trivial)\n\nKafka fan-out messages:\n  2.3K posts\/sec x 300 followers x 100B = 69 MB\/s\n\nKafka like events:\n  464K likes\/sec x 100B = 46 MB\/s\n\nTotal Kafka throughput:  ~115 MB\/s\n\nCDN media egress:  22 TB\/day = ~255 MB\/s","height":260,"link":null,"strokeColor":"#334155","fillStyle":"solid","groupIds":[],"versionNonce":1174023804,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":2590.8699240820788,"angle":0,"y":-3061.3457143105743,"width":337.93466186523438},{"isDeleted":false,"locked":false,"strokeColor":"#f59e0b","link":null,"roughness":1,"groupIds":[],"index":"bFe","backgroundColor":"#fef3c7","angle":0,"fillStyle":"solid","strokeWidth":1,"version":121,"roundness":{"type":3},"type":"rectangle","updated":1772748823811,"id":"cEe2vtnzt2PRpymlQRUs9","x":1808.8699240820786,"seed":1863574268,"boundElements":[],"y":-2818.3457143105743,"opacity":100,"height":220,"width":1560,"frameId":null,"strokeStyle":"solid","versionNonce":1747386108},{"seed":487990140,"strokeStyle":"solid","id":"IF2MYfmCdupMZB_rPKEsb","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":16,"opacity":100,"verticalAlign":"top","updated":1772748823811,"locked":false,"text":"Infrastructure Sizi