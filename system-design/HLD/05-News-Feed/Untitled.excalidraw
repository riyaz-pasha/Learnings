lated by: retry POST \/posts without key\n= duplicate post published to feed.\nResponsible: API checks key in Redis (TTL 24h).","height":140,"link":null,"strokeColor":"#334155","fillStyle":"solid","groupIds":[],"versionNonce":1822367356,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":2870.8699240820783,"angle":0,"y":-3924.3457143105743,"width":336.2095947265625},{"isDeleted":false,"locked":false,"strokeColor":"#86efac","link":null,"roughness":1,"groupIds":[],"index":"bF8","backgroundColor":"#f0fdf4","angle":0,"fillStyle":"solid","strokeWidth":1,"version":121,"roundness":{"type":3},"type":"rectangle","updated":1772748823810,"id":"FrvrV1LyfFRShq7kbrIzz","x":1808.8699240820786,"seed":1412092668,"boundElements":[],"y":-3750.3457143105743,"opacity":100,"height":192,"width":502,"frameId":null,"strokeStyle":"solid","versionNonce":1286467324},{"seed":567219068,"strokeStyle":"solid","id":"T25DdBmhwQPpzqDVrF4pQ","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":16,"opacity":100,"verticalAlign":"top","updated":1772748823810,"locked":false,"text":"Security","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bF9","roundness":null,"containerId":null,"originalText":"Security","height":20,"link":null,"strokeColor":"#15803d","fillStyle":"solid","groupIds":[],"versionNonce":1401859964,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1822.8699240820786,"angle":0,"y":-3738.3457143105743,"width":63.51995849609375},{"seed":571950076,"strokeStyle":"solid","id":"6SDap6lVD3EeYrNIPs8d7","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772748823810,"locked":false,"text":"Auth: JWT \/ OAuth2 on every API call.\nPrivate accounts: follow-check before returning\nany content from private profiles.\nRate limits: 100 reads\/min, 10 posts\/min.\n\nViolated by: missing auth on feed endpoint\nexposes private posts. No rate limit = DDoS.\nResponsible: API gateway (auth + rate limiting).","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bFA","roundness":null,"containerId":null,"originalText":"Auth: JWT \/ OAuth2 on every API call.\nPrivate accounts: follow-check before returning\nany content from private profiles.\nRate limits: 100 reads\/min, 10 posts\/min.\n\nViolated by: missing auth on feed endpoint\nexposes private posts. No rate limit = DDoS.\nResponsible: API gateway (auth + rate limiting).","height":140,"link":null,"strokeColor":"#334155","fillStyle":"solid","groupIds":[],"versionNonce":830693372,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1822.8699240820786,"angle":0,"y":-3713.3457143105743,"width":327.02557373046875},{"isDeleted":false,"locked":false,"strokeColor":"#86efac","link":null,"roughness":1,"groupIds":[],"index":"bFB","backgroundColor":"#f0fdf4","angle":0,"fillStyle":"solid","strokeWidth":1,"version":121,"roundness":{"type":3},"type":"rectangle","updated":1772748823810,"id":"aHL5L9D7pA4hJsOzyRyzZ","x":2328.8699240820788,"seed":990209148,"boundElements":[],"y":-3750.3457143105743,"opacity":100,"height":192,"width":502,"frameId":null,"strokeStyle":"solid","versionNonce":1049493628},{"seed":1113289980,"strokeStyle":"solid","id":"JcKDLTU7KArYVwoHI6zcR","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":16,"opacity":100,"verticalAlign":"top","updated":1772748823810,"locked":false,"text":"Observability","version":121,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bFC","roundness":null,"containerId":null,"originalText":"Observability","height":20,"link":null,"strokeColor":"#15803d","fillStyle":"solid","groupIds":[],"versionNonce":40931580,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":2342.8699240820788,"angle":0,"y":-3738.3457143105743,"width":99.775894165039062},{"seed":94074236,"strokeStyle":"solid","id":"zk