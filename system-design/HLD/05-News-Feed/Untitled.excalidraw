,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"10M Feed Caches\\nRedis Sorted Sets\\nAll receive post_id\\nin their feed list\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"10M Feed Caches\\nRedis Sorted Sets\\nAll receive post_id\\nin their feed list\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s1ex\",\"type\":\"rectangle\",\"x\":820,\"y\":337,\"width\":730,\"height\":220,\"angle\":0,\"strokeColor\":\"#e2e8f0\",\"backgroundColor\":\"#ffffff\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"aN\",\"roundness\":{\"type\":3},\"seed\":630509968,\"version\":2,\"versionNonce\":279028592,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s1exh\",\"type\":\"text\",\"x\":836,\"y\":350,\"width\":255.97482299804688,\"height\":18.75,\"angle\":0,\"strokeColor\":\"#1e3a5f\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"aO\",\"roundness\":null,\"seed\":1208405872,\"version\":2,\"versionNonce\":2119207824,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Why Naive Breaks + The Hybrid Fix\",\"fontSize\":15,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Why Naive Breaks + The Hybrid Fix\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s1exb\",\"type\":\"text\",\"x\":836,\"y\":375,\"width\":356.55157470703125,\"height\":192.5,\"angle\":0,\"strokeColor\":\"#334155\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"aP\",\"roundness\":null,\"seed\":1009000336,\"version\":2,\"versionNonce\":897299824,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"NAIVE (breaks): Sync fan-out — API writes to 10M\\nRedis entries inline. Thread blocks for seconds.\\nSystem collapses completely at celebrity scale.\\n\\nFIX — Hybrid Fan-out (the production approach):\\n  Normal users (<1M followers): fan-out-on-write.\\n  Kafka async workers propagate within 30 seconds.\\n\\n  Celebrities (>1M followers): fan-out-on-read.\\n  Posts not pushed to caches at write time.\\n  Merged with precomputed feed at read time.\",\"fontSize\":14,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"NAIVE (breaks): Sync fan-out — API writes to 10M\\nRedis entries inline. Thread blocks for seconds.\\nSystem collapses completely at celebrity scale.\\n\\nFIX — Hybrid Fan-out (the production approach):\\n  Normal users (<1M followers): fan-out-on-write.\\n  Kafka async workers propagate within 30 seconds.\\n\\n  Celebrities (>1M followers): fan-out-on-read.\\n  Posts not pushed to caches at write time.\\n  Merged with precomputed feed at read time.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s1tip\",\"type\":\"rectangle\",\"x\":820,\"y\":566,\"width\":730,\"height\":38,\"angle\":0,\"strokeColor\":\"#6ee7b7\",\"backgroundColor\":\"#ecfdf5\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"aQ\",\"roundness\":{\"type\":3},\"seed\":526082416,\"version\":2,\"versionNonce\":962107792,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s1tipt\",\"type\":\"text\",\"x\":836,\"y\":579,\"width\":615.120361328125,\"height\":16.25,\"angle\":0,\"strokeColor\":\"#065f46\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"aR\",\"roundness\":null,\"seed\":530165136,\"version\":2,\"versionNonce\":423855984,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Interview tip: state the hybrid approach — neither pure push nor pure pull scales to 500M+ DAU\",\"fontSize\":13,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"Interview tip: state the hybrid approach — neither pure push nor pure pull scales to 500M+ DAU\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s2bg\",\"type\":\"rectangle\",\"x\":10,\"y\":710,\"width\":1560,\"height\":890,\"angle\":0,\"strokeColor\":\"#cbd5e1\",\"backgroundColor\":\"#f8fafc\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"aS\",\"roundness\":{\"type\":3},\"seed\":38646640,\"version\":2,\"versionNonce\":875489168,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s2hd\",\"type\":\"rectangle\",\"x\":10,\"y\":710,\"width\":1560,\"height\":46,\"angle\":0,\"strokeColor\":\"#1e3a5f\",\"backgroundColor\":\"#1e3a5f\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"aT\",\"roundness\":{\"type\":3},\"seed\":1496152976,\"version\":2,\"versionNonce\":406919536,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s2tt\",\"type\":\"text\",\"x\":410,\"y\":723,\"width\":490.2867431640625,\"height\":26.25,\"angle\":0,\"strokeColor\":\"#f1f5f9\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"aU\",\"roundness\":null,\"seed\":9252222