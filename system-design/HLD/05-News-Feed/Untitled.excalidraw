ness\":null,\"seed\":744508272,\"version\":2,\"versionNonce\":37736336,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"58K reads QPS \/ 580 write QPS  =  100 : 1\\n\\nWhy? Users consume far more than they create.\\nEven active users post once a week but open\\nthe feed 10+ times daily.\\n\\nThis ratio drives the core design principle:\\nOPTIMISE AGGRESSIVELY FOR THE READ PATH.\",\"fontSize\":14,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"top\",\"containerId\":null,\"originalText\":\"58K reads QPS \/ 580 write QPS  =  100 : 1\\n\\nWhy? Users consume far more than they create.\\nEven active users post once a week but open\\nthe feed 10+ times daily.\\n\\nThis ratio drives the core design principle:\\nOPTIMISE AGGRESSIVELY FOR THE READ PATH.\",\"autoResize\":true,\"lineHeight\":1.25},{\"id\":\"s4stor\",\"type\":\"rectangle\",\"x\":10,\"y\":2745,\"width\":750,\"height\":268,\"angle\":0,\"strokeColor\":\"#93c5fd\",\"backgroundColor\":\"#eff6ff\",\"fillStyle\":\"solid\",\"strokeWidth\":1,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b0t\",\"roundness\":{\"type\":3},\"seed\":19948432,\"version\":2,\"versionNonce\":504541552,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false},{\"id\":\"s4stort\",\"type\":\"text\",\"x\":24,\"y\":2757,\"width\":299.3917236328125,\"height\":20,\"angle\":0,\"strokeColor\":\"#1d4ed8\",\"backgroundColor\":\"transparent\",\"fillStyle\":\"solid\",\"strokeWidth\":2,\"strokeStyle\":\"solid\",\"roughness\":1,\"opacity\":100,\"groupIds\":[],\"frameId\":null,\"index\":\"b0u\",\"roundness\":null,\"seed\":858086768,\"version\":2,\"versionNonce\":113204624,\"isDeleted\":false,\"boundElements\":[],\"updated\":1772748707483,\"link\":null,\"locked\":false,\"text\":\"Storage Per Record  +  Total Storage\",\"fontSize\":16,\"fontFamily\":5,\"textAlign\":\"left\",\"verticalAlign\":\"to