ity":100,"updated":1772978201421,"locked":false,"points":[[0,0],[0,530]],"polygon":false,"version":5,"type":"line","backgroundColor":"transparent","index":"b4w","roundness":null,"lastCommittedPoint":null,"height":530,"link":null,"startArrowhead":null,"strokeColor":"#2A2D3A","fillStyle":"solid","groupIds":[],"endBinding":null,"versionNonce":338715673,"frameId":null,"boundElements":[],"x":36,"angle":0,"y":-1018.9119973887227,"width":0},{"isDeleted":false,"locked":false,"strokeColor":"#2A2D3A","link":null,"roughness":0,"groupIds":[],"index":"b4x","backgroundColor":"#1E2030","angle":0,"fillStyle":"solid","strokeWidth":1,"version":5,"roundness":null,"type":"rectangle","updated":1772978201421,"id":"DU1CleqvenynWsX3K5Ckd","x":56,"seed":26454713,"boundElements":[],"y":-1018.9119973887227,"opacity":100,"height":510,"width":740,"frameId":null,"strokeStyle":"solid","versionNonce":1351239159},{"seed":52423577,"strokeStyle":"solid","id":"bK5kFJFPNR5-7-WxPHglT","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":17,"opacity":100,"verticalAlign":"top","updated":1772978201421,"locked":false,"text":"The Two Most Critical Bottlenecks","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b4y","roundness":null,"containerId":null,"originalText":"The Two Most Critical Bottlenecks","height":21.25,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":144603385,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":72,"angle":0,"y":-1002.9119973887227,"width":295.49374389648438},{"seed":254873721,"strokeStyle":"solid","id":"p3ykSVUHKmDf9MgdCuGCr","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1772978201421,"locked":false,"text":"BN1 — DB Connection Pool","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b4z","roundness":null,"containerId":null,"originalText":"BN1 — DB Connection Pool","height":18.75,"link":null,"strokeColor":"#C45C5C","fillStyle":"solid","groupIds":[],"versionNonce":828141335,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":72,"angle":0,"y":-974.91199738872274,"width":198.50993347167969},{"seed":1267374425,"strokeStyle":"solid","id":"DeLSw6KjCAv4d_5TSb6Lp","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772978201421,"locked":false,"text":"PostgreSQL's process-per-connection model means each\nopen connection consumes ~5-10MB of RAM and a full OS\nprocess. At 500 connections the server runs out of both.\nWhat makes this catastrophic is the retry amplification:\nclients time out after 5s and retry immediately, so 3,000\nusers become 9,000-15,000 queued requests within seconds.\nThe DB, already at capacity, now receives 5x the load\nthat broke it. Recovery requires a full restart — there\nis no self-healing path from this state.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b50","roundness":null,"containerId":null,"originalText":"PostgreSQL's process-per-connection model means each\nopen connection consumes ~5-10MB of RAM and a full OS\nprocess. At 500 connections the server runs out of both.\nWhat makes this catastrophic is the retry amplification:\nclients time out after 5s and retry immediately, so 3,000\nusers become 9,000-15,000 queued requests within seconds.\nThe DB, already at capacity, now receives 5x the load\nthat broke it. Recovery requires a full restart — there\nis no self-healing path from this state.","height":157.5,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":1949757913,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":72,"angle":0,"y":-950.91199738872274,"width":411.55755615234375},{"seed":1501562425,"strokeStyle":"solid","id":"AglkFvLNnXra7WPuYqcAA","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1772978201421,"locked":false,"text":"BN2 — Stateful Upload Sessions","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b51","roundness":null,"containerId":null,"originalText":"BN2 — Stateful Upload Sessions","height":18.75,"link":null,"strokeColor":"#C45C5C","fillStyle":"solid","groupIds":[],"versionNonce":1145861175,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":72,"angle":0,"y":-800.91199738872274,"width":242.54985046386719},{"seed":1676990233,"strokeStyle":"solid","id":"u0Sofaewl4PkNMrfsjoFd","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772978201421,"locked":false,"text":"In-memory upload state makes the API server impossible\nto scale horizontally without session affinity. Sticky\nload balancing means a single hot node becomes the\nbottleneck for all large uploads. If that node restarts\n— for a deploy, OOM kill, or crash — every in-flight\nupload above 5MB is silently lost. The user sees no\nerror until they check the file and find it truncated.\nThis is the worst class of failure: data loss without\nan error signal.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b52","roundness":null,"containerId":null,"originalText":"In-memory upload state makes the API server impossible\nto scale horizontally without session affinity. Sticky\nload balancing means a single hot node becomes the\nbottleneck for all large uploads. If that node restarts\n— for a deploy, OOM kill, or crash — every in-flight\nupload above 5MB is silently lost. The user sees no\nerror until they check the file and find it truncated.\nThis is the worst class of failure: data loss without\nan error signal.","height":157.5,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":1275940537,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":72,"angle":0,"y":-776.91199738872274,"width":386.74951171875},{"isDeleted":false,"locked":false,"strokeColor":"#C45C5C","link":null,"roughness":0,"groupIds":[],"index":"b53","backgroundColor":"#252838","angle":0,"fillStyle":"solid","strokeWidth":1,"version":5,"roundness":null,"type":"rectangle","updated":1772978201421,"id":"vI2xq_0iWluhG-ufr8Qzt","x":56,"seed":1834781689,"boundElements":[],"y":-594.91199738872274,"opacity":100,"height":70,"width":740,"frameId":null,"strokeStyle":"solid","versionNonce":1094636887},{"seed":1572512985,"strokeStyle":"solid","id":"Npg1qtEvUDJA2FhxWGIAp","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772978201421,"locked":false,"text":"Key insight: BN1 and BN2 combine lethally. DB exhaustion","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b54","roundness":null,"containerId":null,"originalText":"Key insight: BN1 and BN2 combine lethally. DB exhaustion","height":17.5,"link":null,"strokeColor":"#9AA0B4","fillStyle":"solid","groupIds":[],"versionNonce":382013337,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":72,"angle":0,"y":-580.91199738872274,"width":393.7215576171875},{"seed":1352835513,"strokeStyle":"solid","id":"U_aZEczAm-fOF87M_LkIq","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772978201421,"locked":false,"text":"triggers retries that cause BN2 in-flight upload losses —","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b55","roundness":null,"containerId":null,"originalText":"triggers retries that cause BN2 in-flight upload losses —","height":17.5,"link":null,"strokeColor":"#9AA0B4","fillStyle":"solid","groupIds":[],"versionNonce":1871188599,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":72,"angle":0,"y":-560.91199738872274,