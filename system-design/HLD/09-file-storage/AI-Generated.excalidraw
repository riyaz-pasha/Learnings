le":"solid","id":"eyTfDx3OBHjEOfU-l5kJW","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":17,"opacity":100,"verticalAlign":"top","updated":1772978201421,"locked":false,"text":"Why These Numbers Matter","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b2z","roundness":null,"containerId":null,"originalText":"Why These Numbers Matter","height":21.25,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":1541082455,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":72,"angle":0,"y":-2280.9119973887227,"width":227.98683166503906},{"seed":1347761369,"strokeStyle":"solid","id":"hb8uFUNsa1aA4WlmFw-tT","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772978201421,"locked":false,"text":"The 70% dedup rate is the single biggest lever in this\nsystem. Without it, 50 TB\/day of raw uploads would\nrequire 27+ PB\/year — a 3x cost difference. Content-\naddressed chunking (SHA-256 per 5MB block) makes\ndedup possible but introduces ref-count complexity\non deletion, as no chunk can be freed until its last\nreferring file is purged from all version chains.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b30","roundness":null,"containerId":null,"originalText":"The 70% dedup rate is the single biggest lever in this\nsystem. Without it, 50 TB\/day of raw uploads would\nrequire 27+ PB\/year — a 3x cost difference. Content-\naddressed chunking (SHA-256 per 5MB block) makes\ndedup possible but introduces ref-count complexity\non deletion, as no chunk can be freed until its last\nreferring file is purged from all version chains.","height":122.5,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":757618585,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":72,"angle":0,"y":-2254.9119973887227,"width":371.7835693359375},{"seed":829108665,"strokeStyle":"solid","id":"DsEMkEiqf6e6aBbJzkgYT","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":17,"opacity":100,"verticalAlign":"top","updated":1772978201421,"locked":false,"text":"Peak vs Average","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b31","roundness":null,"containerId":null,"originalText":"Peak vs Average","height":21.25,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":1507674743,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":72,"angle":0,"y":-2144.9119973887227,"width":135.31990051269531},{"seed":2087621273,"strokeStyle":"solid","id":"1QQSl5d4aFW_GLRc0G2d5","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772978201421,"locked":false,"text":"The 3x peak multiplier reflects morning sync storms:\nwhen US\/EU business hours overlap, millions of clients\nresume uploads and request delta-syncs simultaneously.\nSystems sized only for average load fail predictably\nevery Monday morning and after holiday weekends.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b32","roundness":null,"containerId":null,"originalText":"The 3x peak multiplier reflects morning sync storms:\nwhen US\/EU business hours overlap, millions of clients\nresume uploads and request delta-syncs simultaneously.\nSystems sized only for average load fail predictably\nevery Monday morning and after holiday weekends.","height":87.5,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":894172281,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":72,"angle":0,"y":-2118.9119973887227,"width":376.57159423828125},{"seed":1444075385,"strokeStyle":"solid","id":"l5cL91d-Fek50dm_gdTfy","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":17,"opacity":100,"verticalAlign":"top","upd