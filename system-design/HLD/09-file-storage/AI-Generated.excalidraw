,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-1828,"angle":0,"y":1025.0880026112773,"width":872.66302490234375},{"seed":917858009,"strokeStyle":"dashed","id":"30XLHTlO39AoL9EbwB7Er","strokeWidth":1,"roughness":0,"isDeleted":false,"startBinding":null,"endArrowhead":null,"opacity":100,"updated":1772978201421,"locked":false,"points":[[0,0],[0,1360]],"polygon":false,"version":5,"type":"line","backgroundColor":"transparent","index":"b6s","roundness":null,"lastCommittedPoint":null,"height":1360,"link":null,"startArrowhead":null,"strokeColor":"#2A2D3A","fillStyle":"solid","groupIds":[],"endBinding":null,"versionNonce":2103357593,"frameId":null,"boundElements":[],"x":36,"angle":0,"y":-276.91199738872274,"width":0},{"isDeleted":false,"locked":false,"strokeColor":"#2A2D3A","link":null,"roughness":0,"groupIds":[],"index":"b6t","backgroundColor":"#1E2030","angle":0,"fillStyle":"solid","strokeWidth":1,"version":5,"roundness":null,"type":"rectangle","updated":1772978201421,"id":"x4d0xeuvj0v877dc5AT_u","x":56,"seed":16065465,"boundElements":[],"y":-276.91199738872274,"opacity":100,"height":1260,"width":740,"frameId":null,"strokeStyle":"solid","versionNonce":294977911},{"seed":1776960665,"strokeStyle":"solid","id":"LxoLzYRCNmzCWlntHtiJm","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1772978201421,"locked":false,"text":"V1 to V2 — Externalizing Upload State","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b6u","roundness":null,"containerId":null,"originalText":"V1 to V2 — Externalizing Upload State","height":18.75,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":1062155641,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":72,"angle":0,"y":-260.91199738872274,"width":287.71484375},{"seed":1028147577,"strokeStyle":"solid","id":"XGGBcKBYkp7wawp2RThyk","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772978201421,"locked":false,"text":"The trigger was node restarts silently losing uploads.\nAny durable key-value store would fix BN2, but Redis\nwas chosen over a relational table because chunk state\nis ephemeral (gone after upload completes) and requires\nsub-millisecond reads per incoming chunk.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b6v","roundness":null,"containerId":null,"originalText":"The trigger was node restarts silently losing uploads.\nAny durable key-value store would fix BN2, but Redis\nwas chosen over a relational table because chunk state\nis ephemeral (gone after upload completes) and requires\nsub-millisecond reads per incoming chunk.","height":87.5,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":142850711,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":72,"angle":0,"y":-236.91199738872274,"width":378.68560791015625},{"seed":72528473,"strokeStyle":"solid","id":"D7kri42l3a2DcVIaRaNt1","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1772978201421,"locked":false,"text":"V2 to V3 — Pooling Before Sharding","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b6w","roundness":null,"containerId":null,"originalText":"V2 to V3 — Pooling Before Sharding","height":18.75,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":2124160601,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":72,"angle":0,"y":-146.91199738872274,"width":267.43484497070312},{"seed":1406992185,"strokeStyle":"solid","id":"KMn3RwGz_2ly0XevaOcy_","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772978201421,"locked":false,"text":"PgBouncer was chosen over immediate sharding because\nit fixes 80% of the connection exhaustion problem with\nzero schema changes. Sharding was deferred until V5\nbecause it is irreversible and expensive — you exhaust\nevery cheaper option first.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b6x","roundness":null,"containerId":null,"originalText":"PgBouncer was chosen over immediate sharding because\nit fixes 80% of the connection exhaustion problem with\nzero schema changes. Sharding was deferred until V5\nbecause it is irreversible and expensive — you exhaust\nevery cheaper option first.","height":87.5,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":1602113463,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":72,"angle":0,"y":-122.91199738872274,"width":383.3475341796875},{"seed":1514844185,"strokeStyle":"solid","id":"HspyatK4myoQYkjNgfrry","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1772978201421,"locked":false,"text":"V3 to V4 — Removing the Bandwidth Proxy","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b6y","roundness":null,"containerId":null,"originalText":"V3 to V4 — Removing the Bandwidth Proxy","height":18.75,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":437840697,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":72,"angle":0,"y":-32.911997388722739,"width":318.73480224609375},{"seed":764364025,"strokeStyle":"solid","id":"_OgNeTrG1dtmNdiJF7XAr","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772978201421,"locked":false,"text":"Client-direct upload was rejected early because it moves\nerror handling to the client SDK. It was accepted at V4\nbecause the alternative — scaling API nodes purely for\nbandwidth — is pure waste. Every major cloud storage\nplatform (S3, GCS, Azure Blob) uses this pattern.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b6z","roundness":null,"containerId":null,"originalText":"Client-direct upload was rejected early because it moves\nerror handling to the client SDK. It was accepted at V4\nbecause the alternative — scaling API nodes purely for\nbandwidth — is pure waste. Every major cloud storage\nplatform (S3, GCS, Azure Blob) uses this pattern.","height":87.5,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":1621704919,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":72,"angle":0,"y":-8.9119973887227388,"width":383.37548828125},{"seed":1496202713,"strokeStyle":"solid","id":"JP8TvdLyaklx3LdpljNzL","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1772978201421,"locked":false,"text":"V4 to V5 — Sharding as Last Resort","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b70","roundness":null,"containerId":null,"originalText":"V4 to V5 — Sharding as Last Resort","height":18.75,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":1244208153,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":72,"angle":0,"y":81.088002611277261,"width":271.90484619140625},{"seed":742070969,"strokeStyle":"solid","id":"3kYu-Ol-pehxchumOh4eW","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772978201421,"locked":false,"text":"Sharding by user_id was chosen over consistent hashing\nbecause user_id is the dominant query predicate — 95%\nof queries are single-user. Cross-user shared folder\nqueries accepted scatter-gather latency (~40ms extra)\nas a deliberate trade-off for operational simplicity.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b71","roundness":null,"containerId":null,"originalText":"Sharding by user_id was chosen over consistent hashing\nbecause user_id is the dominant query predicate — 95%\nof queries are single-user. Cross-user shared folder\nqueries accepted scatter-gather latency (~40ms extra)\nas a deliberate trade-off for operational simplicity.","height":87.5,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":496569847,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":72,"angle":0,"y":105.08800261127726,"width":384.39755249023438},{"seed":1197038489,"strokeStyle":"solid","id":"s72U1tlR5ccekNsI-o6Ux","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1772978201421,"locked":false,"text":"V5 to V6 — Decoupling Sync from Write Path","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b72","roundness":null,"containerId":null,"originalText":"V5 to V6 — Decoupling Sync from Write Path","height":18.75,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":1858089209,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":72,"angle":0,"y":195.08800261127726,"width":330.38980102539062},{"seed":1790738553,"strokeStyle":"solid","id":"pWQ63UTCISg8eugzI21a-","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772978201421,"locked":false,"text":"Long-polling was rejected because it holds a connection\nper client — 1M active users = 1M open sockets on the\nAPI tier. Kafka fan-out decouples the write path from\nclient notification entirely, and the offset cursor gives\nevery client a reliable catch-up mechanism after offline.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b73","roundness":null,"containerId":null,"originalText":"Long-polling was rejected because it holds a connection\nper client — 1M active users = 1M open sockets on the\nAPI tier. Kafka fan-out decouples the write path from\nclient notification entirely, and the offset cursor gives\nevery client a reliable catch-up mechanism after offline.","height":87.5,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":22165271,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":72,"angle":0,"y":219.08800261127726,"width":377.36956787109375},{"seed":69732697,"strokeStyle":"solid","id":"1rbi7srS24toTRKK2vM-J","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1772978201421,"locked":false,"text":"The Pattern","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b74","roundness":null,"containerId":null,"originalText":"The Pattern","height":18.75,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":492939737,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":72,"angle":0,"y":309.08800261127726,"width":92.639938354492188},{"seed":2096068153,"strokeStyle":"solid","id":"CeSWxpkpQ4VSvSoD4sfPv","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772978201421,"locked":false,"text":"Every bottleneck in this system was a form of coupling:\nstate coupled to process, reads coupled to writes, blobs\ncoupled to API bandwidth, metadata coupled to a single\nnode, and sync events coupled to the write path. Each\nevolution decoupled exactly one thing. This is the\nuniversal pattern in distributed storage evolution.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b75","roundness":null,"containerId":null,"originalText":"Every bottleneck in this system was a form of coupling:\nstate coupled to process, reads coupled to writes, blobs\ncoupled to API bandwidth, metadata coupled to a single\nnode, and sync events coupled to the write path. Each\nevolution decoupled exactly one thing. This is the\nuniversal pattern in distributed storage evolution.","height":105,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":575224887,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":72,"angle":0,"y":333.08800261127726,"width":387.8414306640625},{"isDeleted":false,"locked":false,"strokeColor":"#3A9E8E","link":null,"roughness":0,"groupIds":[],"index":"b76","backgroundColor":"#252838","angle":0,"fillStyle":"solid","strokeWidth":1,"version":5,"roundness":null,"type":"rectangle","updated":1772978201421,"id":"_01X5bgJQ4WWxFbUYKDG9","x":56,"seed":1207322393,"boundElements":[],"y":443.08800261127726,"opacity":100,"height":70,"width":740,"frameId":null,"strokeStyle":"solid","versionNonce":1864435385},{"seed":800062457,"strokeStyle":"solid","id":"Np7UsSiZNu2fVZ_i3hwZq","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772978201421,"locked":false,"text":"Key insight: Each version decoupled exactly one thing.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b77","roundness":null,"containerId":null,"originalText":"Key insight: Each version decoupled exactly one thing.","height":17.5,"link":null,"strokeColor":"#9AA0B4","fillStyle":"solid","groupIds":[],"versionNonce":1415748951,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":72,"angle":0,"y":457.08800261127726,"width":367.54153442382812},{"seed":1679824089,"strokeStyle":"solid","id":"u12R0U2dD3hFgTPbjPW40","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772978201421,"locked":false,"text":"State, connections, bandwidth, data, events — in that order.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b78","roundness":null,"containerId":null,"originalText":"State, connections, bandwidth, data, events — in that order.","height":17.5,"link":null,"strokeColor":"#9AA0B4","fillStyle":"solid","groupIds":[],"versionNonce":245483417,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":72,"angle":0,"y":477.08800261127726,"width":418.89346313476562},{"seed":1222250937,"strokeStyle":"solid","id":"ZXxn43SQxI30cxeN49IqO","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772978201421,"locked":false,"text":"Reversing the order at any step would have caused rework.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b79","roundness":null,"containerId":null,"originalText":"Reversing the order at any step would have caused rework.","height":17.5,"link":null,"strokeColor":"#9AA0B4","fillStyle":"solid","groupIds":[],"versionNonce":2062735991,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":72,"angle":0,"y":497.08800261127726,"width":405.98553466796875},{"seed":50426521,"strokeStyle":"dashed","id":"rsptz5BDHwO-zl8OCmffz","strokeWidth":1,"roughness":0,"isDeleted":false,"startBinding":null,"endArrowhead":null,"opacity":100,"updated":1772978201421,"locked":false,"points":[[0,0],[3000,0]],"polygon":false,"version":5,"type":"line","backgroundColor":"transparent","index":"b7A","roundness":null,"lastCommittedPoint":null,"height":0,"link":null,"startArrowhead":null,"strokeColor":"#2A2D3A","fillStyle":"solid","groupIds":[],"endBinding":null,"versionNonce":102198393,"frameId":null,"boundElements":[],"x":-1924,"angle":0,"y":1163.0880026112773,"width":3000},{"isDeleted":false,"locked":false,"strokeColor":"#C47B3A","link":null,"roughness":0,"groupIds":[],"index":"b7B","backgroundColor":"#C47B3A","angle":0,"fillStyle":"solid","strokeWidth":2,"version":5,"roundness":null,"type":"ellipse","updated":1772978201421,"id":"MJe6ium2jkvgKnUbuGwub","x":-1896,"seed":1196013433,"boundEle