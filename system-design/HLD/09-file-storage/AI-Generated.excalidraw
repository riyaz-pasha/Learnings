boundElements":[],"x":72,"angle":0,"y":-1622.9119973887227,"width":140.36888122558594},{"seed":765457081,"strokeStyle":"solid","id":"zT547U9mvCtxoEQ_b6ACg","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772978201421,"locked":false,"text":"A baseline forces you to identify which component\nbecomes load-bearing first. In file storage, that is\nalmost always the metadata database — not the blob\nstorage layer. S3 scales elastically, but PostgreSQL\nhas hard connection limits baked into its process model.\nThe baseline makes this visible before adding complexity.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b3v","roundness":null,"containerId":null,"originalText":"A baseline forces you to identify which component\nbecomes load-bearing first. In file storage, that is\nalmost always the metadata database — not the blob\nstorage layer. S3 scales elastically, but PostgreSQL\nhas hard connection limits baked into its process model.\nThe baseline makes this visible before adding complexity.","height":105,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":1244324343,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":72,"angle":0,"y":-1596.9119973887227,"width":386.72149658203125},{"seed":1986212761,"strokeStyle":"solid","id":"YvQVUPiIuv12KRuRARAwH","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":17,"opacity":100,"verticalAlign":"top","updated":1772978201421,"locked":false,"text":"The Failure Cascade","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b3w","roundness":null,"containerId":null,"originalText":"The Failure Cascade","height":21.25,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":1810210041,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":72,"angle":0,"y":-1486.9119973887227,"width":167.68788146972656},{"seed":1254840441,"strokeStyle":"solid","id":"mt0lbqoab8ssFW7QJdRCH","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772978201421,"locked":false,"text":"At ~3,000 concurrent users the PostgreSQL connection\npool (default 500 connections) exhausts. The API server\nbegins queuing requests. Clients hit timeouts and retry\nautomatically — tripling the effective load in seconds.\nThe DB becomes fully unavailable. ACL checks for even\ncached downloads now fail. The CDN cannot validate new\ntokens. The entire service goes dark within 60-90 seconds\nof hitting the threshold — not a graceful degradation.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b3x","roundness":null,"containerId":null,"originalText":"At ~3,000 concurrent users the PostgreSQL connection\npool (default 500 connections) exhausts. The API server\nbegins queuing requests. Clients hit timeouts and retry\nautomatically — tripling the effective load in seconds.\nThe DB becomes fully unavailable. ACL checks for even\ncached downloads now fail. The CDN cannot validate new\ntokens. The entire service goes dark within 60-90 seconds\nof hitting the threshold — not a graceful degradation.","height":140,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":1686735639,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":72,"angle":0,"y":-1460.9119973887227,"width":404.20751953125},{"seed":748413273,"strokeStyle":"solid","id":"LNA891-NZiIHxuRjnokJZ","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":17,"opacity":100,"verticalAlign":"top","updated":1772978201421,"locked":false,"text":"The Most Fragile Point","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b3y","roundness":null,"containerId":null,"originalText":"The Most Fragile Point","height":21.25,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":720999897,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":72,"angle":0,"y":-1308.9119973887227,"width":193.52786254882812},{"seed":422071865,"strokeStyle":"solid","id":"KcHIhRM-5HdDoTLa-aU3C","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772978201421,"locked":false,"text":"The API monolith is also a single point of failure for\nall upload state. A process crash mid-upload orphans\nall in-flight chunks with no resumption mechanism.\nThis is why the evolved design (Section 6) introduces\na dedicated Upload Service with durable chunk state.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b3z","roundness":null,"containerId":null,"originalText":"The API monolith is also a single point of failure for\nall upload state. A process crash mid-upload orphans\nall in-flight chunks with no resumption mechanism.\nThis is why the evolved design (Section 6) introduces\na dedicated Upload Service with durable chunk state.","height":87.5,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":1266028599,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":72,"angle":0,"y":-1282.9119973887227,"width":368.8995361328125},{"isDeleted":false,"locked":false,"strokeColor":"#6BA3D6","link":null,"roughness":0,"groupIds":[],"index":"b40","backgroundColor":"#252838","angle":0,"fillStyle":"solid","strokeWidth":1,"version":5,"roundness":null,"type":"rectangle","updated":1772978201421,"id":"NjFwI8Ioqsd-a0HzfQkRQ","x":56,"seed":391388953,"boundElements":[],"y":-1216.9119973887227,"opacity":100,"height":56,"width":740,"frameId":null,"strokeStyle":"solid","versionNonce":1524331193},{"seed":93508601,"strokeStyle":"solid","id":"2dUeEsrW-1-B9kjlANZq6","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772978201421,"locked":false,"text":"Key insight: The DB connection pool — not the blob store —","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b41","roundness":null,"containerId":null,"originalText":"Key insight: The DB connection pool — not the blob store —","height":17.5,"link":null,"strokeColor":"#9AA0B4","fillStyle":"solid","groupIds":[],"versionNonce":1758785879,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":72,"angle":0,"y":-1202.9119973887227,"width":418.40347290039062},{"seed":669510873,"strokeStyle":"solid","id":"WAIqNGoAuuCwm2gug6KcE","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772978201421,"locked":false,"text":"is the first failure point. Every fix from here targets that.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b42","roundness":null,"containerId":null,"originalText":"is the first failure point. Every fix from here targets that.","height":17.5,"link":null,"strokeColor":"#9AA0B4","fillStyle":"solid","groupIds":[],"versionNonce":1882108825,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":72,"angle":0,"y":-1182.9119973887227,"width":404.68341064453125},{"seed":1978067385,"strokeStyle":"dashed","id":"E_TdCBNgLKcGwhCxu8OaQ","strokeWidth":1,"roughness":0,"isDeleted":false,"startBinding":null,"endArrowhead":null,"opacity":100,"updated":1772978201421,"locked":false,"points":[[0,0],[3000,0]],"polygon":false,"version":5,"type":"line","backgroundColor":"transparent","index":"b43","roundness":null,"lastCommittedPoint":null,"height":0,"link":null,"startArrowhead":null,"strokeColor":"#2A2D3A","fillStyle":"solid","groupIds":[],"endBinding":null,"versionNonce":1979362935,"frameId":null,"boundElements":[],"x":-1924,"angle":0,"y":-1116.9119973887227,"width":3000},{"isDeleted":false,"locked":false,"strokeColor":"#C45C5C","link":null,