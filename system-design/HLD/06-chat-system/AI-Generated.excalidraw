erfYCPtQ4bV","originalText":"<100ms P99\nLatency","height":45,"link":null,"strokeColor":"#F8F8F2","fillStyle":"solid","groupIds":[],"versionNonce":1577060533,"textAlign":"center","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":330.19700241088867,"angle":0,"y":-4811.5,"width":105.60599517822266},{"isDeleted":false,"locked":false,"strokeColor":"#44475A","link":null,"roughness":1,"groupIds":[],"index":"aS","backgroundColor":"#161B22","angle":0,"fillStyle":"solid","strokeWidth":2,"version":6,"roundness":{"type":3},"type":"rectangle","updated":1772977438387,"id":"hdHTi84JHC1ByhQ97CIQ7","x":1013,"seed":1838126645,"boundElements":[],"y":-5041,"opacity":100,"height":350,"width":900,"frameId":null,"strokeStyle":"solid","versionNonce":1648432533},{"seed":1141442453,"strokeStyle":"solid","id":"y7Si4fnjHG41xSrxTBlca","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":16,"opacity":100,"verticalAlign":"top","updated":1772977438387,"locked":false,"text":"What This System Does","version":6,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"aT","roundness":null,"containerId":null,"originalText":"What This System Does","height":20,"link":null,"strokeColor":"#58A6FF","fillStyle":"solid","groupIds":[],"versionNonce":775191099,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1037,"angle":0,"y":-5021,"width":188.81582641601562},{"seed":1628261621,"strokeStyle":"solid","id":"dm8hIQgLy_zPzmerjyW2o","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772977438387,"locked":false,"text":"A real-time chat app enables instant messaging across\n1-on-1, group, and channel contexts. The core challenge\ncombines real-time push delivery with durable persistence:\nevery message must be pushed immediately to online\nrecipients AND stored reliably for later retrieval.\n\nAt scale, fan-out dominates: one message to a 1,000-member\ngroup triggers 999 simultaneous delivery events across\nmany servers. Users span consumer (WhatsApp), enterprise\n(Slack), and gaming (Discord) contexts.","version":6,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"aU","roundness":null,"containerId":null,"originalText":"A real-time chat app enables instant messaging across\n1-on-1, group, and channel contexts. The core challenge\ncombines real-time push delivery with durable persistence:\nevery message must be pushed immediately to online\nrecipients AND stored reliably for later retrieval.\n\nAt scale, fan-out dominates: one message to a 1,000-member\ngroup triggers 999 simultaneous delivery events across\nmany servers. Users span consumer (WhatsApp), enterprise\n(Slack), and gaming (Discord) contexts.","height":175,"link":null,"strokeColor":"#F8F8F2","fillStyle":"solid","groupIds":[],"versionNonce":1494457077,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1037,"angle":0,"y":-4993,"width":415.7015380859375},{"seed":1411507797,"strokeStyle":"solid","id":"OOn-FwXjXFDIXriZiKm3o","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":16,"opacity":100,"verticalAlign":"top","updated":1772977438387,"locked":false,"text":"Key Challenges","version":6,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"aV","roundness":null,"containerId":null,"originalText":"Key Challenges","height":20,"link":null,"strokeColor":"#58A6FF","fillStyle":"solid","groupIds":[],"versionNonce":666860251,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1037,"angle":0,"y":-4811,"width":111.35990905761719},{"seed":538727349,"strokeStyle":"solid","id":"huqQjsLnLgAjNg60azHtw","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772977438387,"locked":false,"text":"1. WebSockets at scale: 10M+ stateful connections per server\n2. Fan-out: O(N) delivery events per message in large groups\n3. Ordering: consistent sequence without distributed locks\n4. Presence: 333K writes\/sec from 30-second heartbeats alone\n5. Offline replay: in-order, deduplicated msgs on reconnect","version":6,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"aW","roundness":null,"containerId":null,"originalText":"1. WebSockets at scale: 10M+ stateful connections per server\n2. Fan-out: O(N) delivery events per message in large groups\n3. Ordering: consistent sequence without distributed locks\n4. Presence: 333K writes\/sec from 30-second heartbeats alone\n5. Offline replay: in-order, deduplicated msgs on reconnect","height":87.5,"link":null,"strokeColor":"#F8F8F2","fillStyle":"solid","groupIds":[],"versionNonce":1378776149,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1037,"angle":0,"y":-4785,"width":431.95550537109375},{"isDeleted":false,"locked":false,"strokeColor":"transparent","link":null,"roughness":1,"groupIds":[],"index":"aX","backgroundColor":"#111827","angle":0,"fillStyle":"solid","strokeWidth":2,"version":6,"roundness":null,"type":"rectangle","updated":1772977438387,"id":"k2Lt5TqmGZFgeQUeYmNt2","x":-1007,"seed":1361188117,"boundElements":[],"y":-4601,"opacity":100,"height":100,"width":3000,"frameId":null,"strokeStyle":"solid","versionNonce":90269563},{"isDeleted":false,"locked":false,"strokeColor":"transparent","link":null,"roughness":1,"groupIds":[],"index":"aY","backgroundColor":"#0D1117","angle":0,"fillStyle":"solid","strokeWidth":2,"version":7,"roundness":null,"type":"rectangle","updated":1772977438387,"id":"9hk7e25z-kME4K49d-8iW","x":-1007,"seed":1386785397,"boundElements":[],"y":-4501,"opacity":100,"height":820,"width":3000,"frameId":null,"strokeStyle":"solid","versionNonce":157753781},{"isDeleted":false,"locked":false,"strokeColor":"transparent","link":null,"roughness":1,"groupIds":[],"index":"aZ","backgroundColor":"#111827","angle":0,"fillStyle":"solid","strokeWidth":2,"version":6,"roundness":null,"typ