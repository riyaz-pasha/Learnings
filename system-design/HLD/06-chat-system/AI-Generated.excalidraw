Ci9pJCeg7diTqpSdHW","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":16,"opacity":100,"verticalAlign":"top","updated":1772977438387,"locked":false,"text":"Complete Request Lifecycle","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bEP","roundness":null,"containerId":null,"originalText":"Complete Request Lifecycle","height":20,"link":null,"strokeColor":"#58A6FF","fillStyle":"solid","groupIds":[],"versionNonce":341272475,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1048,"angle":0,"y":3117,"width":211.11981201171875},{"seed":1424118325,"strokeStyle":"solid","id":"1luXKJz_vwVhoGJ-zBCk_","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772977438387,"locked":false,"text":"1.  Alice taps Send -> GeoDNS resolves nearest GLB\n2.  GLB consistent-hashes user_id -> WS Gateway A3\n3.  WS frame -> Auth Service validates JWT [5ms]\n4.  Chat Service generates Snowflake ID (globally unique)\n5.  PUBLISH Kafka messages.send [10ms] -> ACK to Alice\n     (blue tick returned — Kafka confirm is the ACK gate)\n6.  Fan-out Worker consumes messages.fanout partition\n7.  SELECT conv_members (Cassandra) [20ms]\n8.  GET ws_server:{uid} from Redis for each member\n9.  Route delivery events to each owning WS Gateway\n10. Each Gateway pushes via WebSocket to members\n11. Cassandra INSERT fires async — off critical path\n12. Offline members -> notifications.push -> APNs\/FCM","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bEQ","roundness":null,"containerId":null,"originalText":"1.  Alice taps Send -> GeoDNS resolves nearest GLB\n2.  GLB consistent-hashes user_id -> WS Gateway A3\n3.  WS frame -> Auth Service validates JWT [5ms]\n4.  Chat Service generates Snowflake ID (globally unique)\n5.  PUBLISH Kafka messages.send [10ms] -> ACK to Alice\n     (blue tick returned — Kafka confirm is the ACK gate)\n6.  Fan-out Worker consumes messages.fanout partition\n7.  SELECT conv_members (Cassandra) [20ms]\n8.  GET ws_server:{uid} from Redis for each member\n9.  Route delivery events to each owning WS Gateway\n10. Each Gateway pushes via WebSocket to members\n11. Cassandra INSERT fires async — off critical path\n12. Offline members -> notifications.push -> APNs\/FCM","height":227.5,"link":null,"strokeColor":"#F8F8F2","fillStyle":"solid","groupIds":[],"versionNonce":216576917,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1048,"angle":0,"y":3141,"width":394.449462890625},{"seed":698631061,"strokeStyle":"solid","id":"vccD2DEwSOY_ci5yyyMaH","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":16,"opacity":100,"verticalAlign":"top","updated":1772977438387,"locked":false,"text":"Failover Runbook — When Region A Dies","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bER","roundness":null,"containerId":null,"originalText":"Failover Runbook — When Region A Dies","height":20,"link":null,"strokeColor":"#FF7B72","fillStyle":"solid","groupIds":[],"versionNonce":433962043,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1048,"angle":0,"y":3357,"width":312.9117431640625},{"seed":1742801141,"strokeStyle":"solid","id":"8KpnCzuJ4jcQ-WzqpXchU","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772977438387,"locked":false,"text":"T+0s:   Region A unreachable (AZ failure)\nT+10s:  GLB health probes fail (3 probes x 3s)\nT+15s:  GLB stops routing new connections to A\nT+30s:  Existing WS timeout; mass reconnect to B\nT+45s:  Cassandra B promoted to primary\nT+45s:  MirrorMaker offsets resume B consumers\nT+60s:  All in-flight mirrored messages consumed\nT+60s:  Redis TTLs (35s) expired; B Redis authoritative\nT+90s:  Full recovery — all clients on Region B\n\nRTO: ~90s  |  RPO: ~100ms (Cassandra async lag)","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bES","roundness":null,"containerId":null,"originalText":"T+0s:   Region A unreachable (AZ failure)\nT+10s:  GLB health probes fail (3 probes x 3s)\nT+15s:  GLB stops routing new connections to A\nT+30s:  Existing WS timeout; mass reconnect to B\nT+45s:  Cassandra B promoted to primary\nT+45s:  MirrorMaker offsets resume B consumers\nT+60s:  All in-flight mirrored messages consumed\nT+60s:  Redis TTLs (35s) expired; B Redis authoritative\nT+90s:  Full recovery — all clients on Region B\n\nRTO: ~90s  |  RPO: ~100ms (Cassandra async lag)","height":192.5,"link":null,"strokeColor":"#F8F8F2","fillStyle":"solid","groupIds":[],"versionNonce":1226275061,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1048,"angle":0,"y":3381,"width":397.73944091796875},{"seed":1092493909,"strokeStyle":"solid","id":"v5jkU69hLipasLHxNw02f","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":16,"opacity":100,"verticalAlign":"top","updated":1772977438387,"locked":false,"text":"Most Latency-Sensitive Path","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bET","roundness":null,"containerId":null,"originalText":"Most Latency-Sensitive Path","height":20,"link":null,"strokeColor":"#3FB950","fillStyle":"solid","groupIds":[],"versionNonce":284196059,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1048,"angle":0,"y":3569,"width":226.03181457519531},{"seed":439422901,"strokeStyle":"solid","id":"lSJusvR7cjZj_vPkEKXC4","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772977438387,"locked":false,"text":"Chat Service -> Kafka PUBLISH [10ms] is the\nirreducible latency floor. It cannot be async:\nif Chat Server ACKs Alice before Kafka confirms,\na server crash causes silent data loss — blue tick\nbut message gone forever. The PUBLISH must\nblock until Kafka acks.\n\nSecond: Fan-out Worker -> Cassandra SELECT\nconv_members [20ms]. Cannot cache aggressively;\ngroup membership changes, stale cache causes\nmissed deliveries. This is the fan-out tax.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bEU","roundness":null,"containerId":null,"originalText":"Chat Service -> Kafka PUBLISH [10ms] is the\nirreducible latency floor. It cannot be async:\nif Chat Server ACKs Alice before Kafka confirms,\na server crash causes silent data loss — blue tick\nbut message gone forever. The PUBLISH must\nblock until Kafka acks.\n\nSecond: Fan-out Worker -> Cassandra SELECT\nconv_members [20ms]. Cannot cache aggressively;\ngroup membership changes, stale cache causes\nmissed deliveries. This is the fan-out tax.","height":192.5,"link":null,"strokeColor":"#F8F8F2","fillStyle":"solid","groupIds":[],"versionNonce":302420565,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1048,"angle":0,"y":3593,"width":342.131591796875},{"isDeleted":false,"locked":false,"strokeColor":"#30363D","link":null,"roughness":1,"groupIds":[],"index":"bEV","backgroundColor":"#0d0d1a","angle":0,"fillStyle":"solid","strokeWidth":1,"version":5,"roundness":{"type":3},"type":"rectangle","updated":1772977438387,"id":"0R11eGtXvxFEZnFhf-gjZ","x":1028,"seed":557797653,"boundElements":[],"y":3785,"opacity":100,"height":168,"width":840,"frameId":null,"strokeStyle":"solid","versionNonce":1696737659},{"seed":599680629,"strokeStyle":"solid","id":"NrQM2hUUKzTKD_mey0LSm","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1772977438387,"locked":false,"text":"Arrow Legend","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bEW","roundness":null,"containerId":null,"originalText":"Arrow Legend","height":18.75,"link":null,"strokeColor":"#8B949E","fillStyle":"solid","groupIds":[],"versionNonce":344686517,"textAlign":"left","f