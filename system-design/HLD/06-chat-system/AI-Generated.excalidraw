s":[],"versionNonce":596089499,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-432,"angle":0,"y":5165,"width":250.04171752929688},{"isDeleted":false,"locked":false,"strokeColor":"#8B949E","link":null,"roughness":1,"groupIds":[],"index":"bGI","backgroundColor":"#0a0e0a","angle":0,"fillStyle":"solid","strokeWidth":2,"version":6,"roundness":{"type":3},"type":"rectangle","updated":1772977438387,"id":"Eohf3p0BFArNdhDr35BRC","x":28,"seed":1442924981,"boundElements":[],"y":5127,"opacity":100,"height":210,"width":450,"frameId":null,"strokeStyle":"solid","versionNonce":1850290325},{"seed":720915221,"strokeStyle":"solid","id":"YVEcDH87yzK8esN_s-0N8","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772977438387,"locked":false,"text":"Why Active-Passive over Active-Active?","version":6,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bGJ","roundness":null,"containerId":null,"originalText":"Why Active-Passive over Active-Active?","height":17.5,"link":null,"strokeColor":"#8B949E","fillStyle":"solid","groupIds":[],"versionNonce":1519357755,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":48,"angle":0,"y":5141,"width":268.0716552734375},{"seed":1078468725,"strokeStyle":"solid","id":"wzHSyFAfuI0Htp4ITTeRW","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772977438387,"locked":false,"text":"Chose:   Active-passive (RTO ~90s)\nOver:    Active-active multi-region\nBecause: Simple conflict model; no\n         vector clocks or CRDTs needed\nCosts:   90s RTO vs <1s; failover\n         requires manual promotion\nRevisit: SLA tightens to 99.999%","version":6,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bGK","roundness":null,"containerId":null,"originalText":"Chose:   Active-passive (RTO ~90s)\nOver:    Active-active multi-region\nBecause: Simple conflict model; no\n         vector clocks or CRDTs needed\nCosts:   90s RTO vs <1s; failover\n         requires manual promotion\nRevisit: SLA tightens to 99.999%","height":113.75,"link":null,"strokeColor":"#F8F8F2","fillStyle":"solid","groupIds":[],"versionNonce":56645109,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":48,"angle":0,"y":5165,"width":247.96170043945312},{"isDeleted":false,"locked":false,"strokeColor":"#44475A","link":null,"roughness":1,"groupIds":[],"index":"bGL","backgroundColor":"#161B22","angle":0,"fillStyle":"solid","strokeWidth":2,"version":6,"roundness":{"type":3},"type":"rectangle","updated":1772977438387,"id":"leLGJR4eFiNuoCQBlL27R","x":1023,"seed":1001802197,"boundElements":[],"y":4881,"opacity":100,"height":448,"width":850,"frameId":null,"strokeStyle":"solid","versionNonce":569372635},{"seed":1851279157,"strokeStyle":"solid","id":"sCabwtVt9evFvoXhZVVxZ","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1772977438387,"locked":false,"text":"The Hardest Trade-off","version":6,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bGM","roundness":null,"containerId":null,"originalText":"The Hardest Trade-off","height":18.75,"link":null,"strokeColor":"#FF7B72","fillStyle":"solid","groupIds":[],"versionNonce":690736981,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1048,"angle":0,"y":4899,"width":170.11488342285156},{"seed":1788057749,"strokeStyle":"solid","id":"QQcFhQCvo7NE6nWvXGvZ-","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772977438387,"locked":false,"text":"Active-passive vs active-active is the hardest\ncall. Active-active would give near-zero RTO but\nrequires CRDTs or vector clocks to resolve\nsimultaneous sends across two regions — a\nfundamentally different data model that changes\nCassandra schema, application conflict logic, and\nthe entire fan-out pipeline. We accepted 90s RTO\nin exchange for a comprehensible consistency story\nthat an ops team can reason about at 3am.","version":6,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bGN","roundness":null,"containerId":null,"originalText":"Active-passive vs active-active is the hardest\ncall. Active-active would give near-zero RTO but\nrequires CRDTs or vector clocks to resolve\nsimultaneous sends across two regions — a\nfundamentally different data model that changes\nCassandra schema, application conflict logic, and\nthe entire fan-out pipeline. We accepted 90s RTO\nin exchange for a comprehensible consistency story\nthat an ops team can reason about at 3am.","height":157.5,"link":null,"strokeColor":"#F8F8F2","fillStyle":"solid","groupIds":[],"versionNonce":733691003,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1048,"angle":0,"y":4923,"width":348.08160400390625},{"seed":1511898613,"strokeStyle":"solid","id":"kANjHrcPvjQSiKcpRoNiS","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1772977438387,"locked":false,"text":"What Most Designs Get Wrong","version":6,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bGO","roundness":null,"containerId":null,"originalText":"What Most Designs Get Wrong","height":18.75,"link":null,"strokeColor":"#D29922","fillStyle":"solid","groupIds":[],"versionNonce":1845566645,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1048,"angle":0,"y":5075,"width":225.01487731933594},{"seed":335296341,"strokeStyle":"solid","id":"yl3VedZbHlK4YLVvL6ueT","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772977438387,"locked":false,"text":"Treating fan-out as synchronous. Junior designs\nloop over all group members inside the Chat Server\nhot path — O(N) latency for large groups. At 500\nmembers that is 500 sequential operations in the\ncritical path. The fix: fire-and-forget to Kafka;\nfan-out workers handle distribution asynchronously.\nThe Chat Server's only job is to confirm Kafka\nreceived the message — nothing else.\n\nSecond mistake: using round-robin LB for WebSockets.\nThis silently loses session state on every scale-out\nor reconnect. Consistent hashing is not optional\nfor stateful long-lived connections.","version":6,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bGP","roundness":null,"containerId":null,"originalText":"Treating fan-out as synchronous. Junior designs\nloop over all group members inside the Chat Server\nhot path — O(N) latency for large groups. At 500\nmembers that is 500 sequential operations in the\ncritical path. The fix: fire-and-forget to Kafka;\nfan-out workers handle distribution asynchronously.\nThe Chat Server's only job is to confirm Kafka\nreceived the message — nothing else.\n\nSecond mistake: using round-robin LB for WebSockets.\nThis silently loses session state on every scale-out\nor reconnect. Consistent hashing is not optional\nfor stateful long-lived connections.","height":227.5,"link":null,"strokeColor":"#F8F8F2","fillStyle":"solid","groupIds":[],"versionNonce":1135867163,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1048,"angle":0,"y":5099,"width":369.44561767578125},{"isDeleted":false,"locked":false,"strokeColor":"transparent","link":null,"roughness":1,"groupIds":[],"index":"bGQ","backgroundColor":"#0D1117","angle":0,"fillStyle":"solid","strokeWidth":2,"version":6,"roundness":null,"type":"rectangle","updated":1772977438387,"id":"crOKj3Z60sunJo8aUcSuZ","x":-1007,"seed":1921287349,"boundElements":[],"y":5429,"opacity":100,"height":600,"width":3000,"frameId":null,"strokeStyle":"solid","versionNonce":2038808085},{"isDeleted":false,"locked":false,"strokeColor":"transparent","link":null,"roughness":1,"groupIds"