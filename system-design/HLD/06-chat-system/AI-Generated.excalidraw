ndColor":"transparent","index":"b3l","roundness":null,"containerId":null,"originalText":"6","height":17.5,"link":null,"strokeColor":"#F8F8F2","fillStyle":"solid","groupIds":[],"versionNonce":831325531,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-609,"angle":0,"y":-2749,"width":8.959991455078125},{"seed":1005383349,"strokeStyle":"solid","id":"ktDpwdLTBO_i7dF4B2M5g","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772977438387,"locked":false,"text":"HA pair × 3 zones; consistent-hash routing for WebSockets","version":6,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b3m","roundness":null,"containerId":null,"originalText":"HA pair × 3 zones; consistent-hash routing for WebSockets","height":17.5,"link":null,"strokeColor":"#F8F8F2","fillStyle":"solid","groupIds":[],"versionNonce":1035260373,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-452,"angle":0,"y":-2749,"width":405.04754638671875},{"seed":2116505621,"strokeStyle":"solid","id":"5j5ayhbGwLDF8m2D1CJev","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":16,"opacity":100,"verticalAlign":"top","updated":1772977438387,"locked":false,"text":"5 Numbers to Remember","version":6,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b3n","roundness":null,"containerId":null,"originalText":"5 Numbers to Remember","height":20,"link":null,"strokeColor":"#8B949E","fillStyle":"solid","groupIds":[],"versionNonce":1108976123,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-927,"angle":0,"y":-2703,"width":184.01582336425781},{"isDeleted":false,"locked":false,"strokeColor":"#44475A","link":null,"roughness":1,"groupIds":[],"index":"b3o","backgroundColor":"#161B22","angle":0,"fillStyle":"solid","strokeWidth":2,"version":6,"roundness":{"type":3},"type":"rectangle","updated":1772977438387,"id":"1E41tOy-dyaZuBQN3Lmir","x":1023,"seed":1095665013,"boundElements":[],"y":-3426,"opacity":100,"height":810,"width":850,"frameId":null,"strokeStyle":"solid","versionNonce":1061539637},{"seed":2024279765,"strokeStyle":"solid","id":"OLYb0Spa8jMdMDAVSY7kT","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":16,"opacity":100,"verticalAlign":"top","updated":1772977438387,"locked":false,"text":"Why These Numbers Matter","version":6,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b3p","roundness":null,"containerId":null,"originalText":"Why These Numbers Matter","height":20,"link":null,"strokeColor":"#D29922","fillStyle":"solid","groupIds":[],"versionNonce":472492699,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1048,"angle":0,"y":-3406,"width":214.57582092285156},{"seed":315190325,"strokeStyle":"solid","id":"v4T2I69aj-jNnr6Kga4sn","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772977438387,"locked":false,"text":"The 500K\/s peak QPS and 10M concurrent WebSocket\nconnections are the two numbers that drive almost every\narchitectural decision. At these scales you cannot use a\nsimple stateless service replica pool — you need consistent\nhashing to route users to specific servers, and a Kafka\nbackbone to bridge servers during fan-out delivery.\nAll other components are sized from these two figures.","version":6,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b3q","roundness":null,"containerId":null,"originalText":"The 500K\/s peak QPS and 10M concurrent WebSocket\nconnections are the two numbers that drive almost every\narchitectural decision. At these scales you cannot use a\nsimple stateless service replica pool — you need consistent\nhashing to route users to specific servers, and a Kafka\nbackbone to bridge servers during fan-out delivery.\nAll other components are sized from these two figures.","height":122.5,"link":null,"strokeColor":"#F8F8F2","fillStyle":"solid","groupIds":[],"versionNonce":1418731669,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1048,"angle":0,"y":-3381,"width":402.989501953125},{"seed":261627285,"strokeStyle":"solid","id":"EICY_1L3S5bHGyA86S8I7","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":16,"opacity":100,"verticalAlign":"top","updated":1772977438387,"locked":false,"text":"Peak vs Average — When Does Peak Happen?","version":6,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b3r","roundness":null,"containerId":null,"originalText":"Peak vs Average — When Does Peak Happen?","height":20,"link":null,"strokeColor":"#D29922","fillStyle":"solid","groupIds":[],"versionNonce":342859579,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1048,"angle":0,"y":-3253,"width":349.39178466796875},{"seed":1447666421,"strokeStyle":"solid","id":"DAvwP8ENWIq8mH2tRXYOm","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772977438387,"locked":false,"text":"The 20x peak multiplier is real and conservative. Chat is\nsynchronous: a message sent triggers an immediate reply.\nUS evening prime time stacks EST, CST, MST, PST over 3\nhours. Add New Year's Eve or a major live sports event and\n20x becomes the floor, not the ceiling. Design for 20x or\nface cascading failures exactly when users need you most.","version":6,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b3s","roundness":null,"containerId":null,"originalText":"The 20x peak multiplier is real and conservative. Chat is\nsynchronous: a message sent triggers an immediate reply.\nUS evening prime time stacks EST, CST, MST, PST over 3\nhours. Add New Year's Eve or a major live sports event and\n20x becomes the floor, not the ceiling. Design for 20x or\nface cascading failures exactly when users need you most.","height":105,"link":null,"strokeColor":"#F8F8F2","fillStyle":"solid","groupIds":[],"versionNonce":1665746421,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1048,"angle":0,"y":-3228,"width":404.76748657226562},{"seed":1264811093,"strokeStyle":"solid","id":"8waHEEMYXYRKfu-FXoWrc","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":16,"opacity":100,"verticalAlign":"top","updated":1772977438387,"locked":false,"text":"The Storage Challenge","version":6,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b3t","roundness":null,"containerId":null,"originalText":"The Storage Challenge","height":20,"link":null,"strokeColor":"#F0883E","fillStyle":"solid","groupIds":[],"versionNonce":1162739675,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1048,"angle":0,"y":-3106,"width":175.24784851074219},{"seed":649800117,"strokeStyle":"solid","id":"h_XhZ7ntaloEnz3QAPXYb","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772977438387,"locked":false,"text":"Media is the storage killer: just 1% of messages are media\nfiles, but they contribute 96% of daily storage cost (10 TB\nvs 0.4 TB). The RF=3 Cassandra replication adds 3x cost\nbut buys 11-nines durability. At 11.5 TB\/day, reaching 18\nPB over 5 years makes tiered cold storage (S3 Glacier for\nmessages older than 90 days) financially mandatory.","version":6,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b3u","roundness":null,"containerId":null,"originalText":"Media is the storage killer: just 1% of messages are media\nfiles, but they contribute 96% of daily storage cost (10 TB\nvs 0.4 TB). The RF=3 Cassandra replication adds 3x cost\nbut buys 11-nines durability. At 11.5 TB\/day, reaching 18\nPB over 5 years makes tiered cold storage (S3 Glacier for\nmessages older than 90 days) financially mandatory.","height":105,"link":null,"strokeColor":"#F8F8F2","fillStyle":"solid","groupIds":[],"versionNonce":2121711445,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1048,"angle":0,"y":-3081,"width":416.61151123046875},{"seed":158739221,"strokeStyle":"solid","id":"WCuEZzDUnF0uG9jKfF_ZL","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":16,"opacity":100,"verticalAlign":"top","updated":1772977438387,"locked":false,"text":"Infrastructure Sizing Principles","version":6,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b3v","roundness":null,"containerId":null,"originalText":"Infrastructure Sizing Principles","height":20,"link":null,"strokeColor":"#3FB950","fillStyle":"solid","groupIds":[],"versionNonce":1490504827,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1048,"angle":0,"y":-2959,"width":242.54379272460938},{"seed":1409941621,"strokeStyle":"solid","id":"mohY5tJeiBIdo3RFELO61","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772977438387,"locked":false,"text":"WebSocket count (250) = 10M ÷ 40K safe conns\/server.\nKafka (20 brokers) is sized by throughput at RF=3, not\nmessage count. Cassandra (80 nodes) is driven by 5-year\nstorage, not write QPS alone — storage dominates at scale.\nRedis presence cluster (6 nodes) is tiny because presence\nis just 10M small keys; its cost is write frequency, not size.","version":6,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b3w","roundness":null,"containerId":null,"originalText":"WebSocket count (250) = 10M ÷ 40K safe conns\/server.\nKafka (20 brokers) is sized by throughput at RF=3, not\nmessage count. Cassandra (80 nodes) is driven by 5-year\nstorage, not write QPS alone — storage dominates at scale.\nRedis presence cluster (6 nodes) is tiny because presence\nis just 10M small keys; its cost is write frequency, not size.","height":105,"link":null,"strokeColor":"#F8F8F2","fillStyle":"solid","groupIds":[],"versionNonce":1013845173,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1048,"angle":0,"y":-2934,"width":414.2454833984375},{"seed":1010575829,"strokeStyle":"solid","id":"kFjybs_TLfb22470QzjqY","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":16,"opacity":100,"verticalAlign":"top","updated":1772977438387,"locked":false,"text":"Read:Write Ratio — Why 10:1?","version":6,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b3x","roundness":null,"containerId":null,"originalText":"Read:Write Ratio — Why 10:1?","height":20,"link":null,"strokeColor":"#1ABC9C","fillStyle":"solid","groupIds":[],"versionNonce":315491611,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1048,"angle":0,"y":-2786,"width":233.99977111816406},{"seed":589440821,"strokeStyle":"solid","id":"ZOmiXxmMxNY9llQxjMe3k","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772977438387,"locked":false,"text":"1 write per message sent. Fan-out creates 1-999 reads\nper write depending on group size. History scrolls (5×\/day\nper user × 50M DAU = 250M extra reads) compound this.\nBlended across 1:1, group, and history loads, 10:1 is the\noperational reality — reads dominate, so read path caching\n(Redis) returns 10x more value than write-path optimization.","version":6,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b3y","roundness":null,"containerId":null,"originalText":"1 write per message sent. Fan-out creates 1-999 reads\nper write depending on group size. History scrolls (5×\/day\nper user × 50M DAU = 250M extra reads) compound this.\nBlended across 1:1, group, and history loads, 10:1 is the\noperational reality — reads dominate, so read path caching\n(Redis) returns 10x more value than write-path optimization.","height":105,"link":null,"strokeColor":"#F8F8F2","fillStyle":"solid","groupIds":[],"versionNonc