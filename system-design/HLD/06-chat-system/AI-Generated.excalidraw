oundColor":"transparent","index":"b7w","roundness":null,"containerId":"tv4Tbd3iO1O5_HdtnefH0","originalText":"Region B passive","height":13.75,"link":null,"strokeColor":"#8B949E","fillStyle":"solid","groupIds":[],"versionNonce":568690069,"textAlign":"center","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-707.95200347900391,"angle":0,"y":388.125,"width":90.904006958007812},{"isDeleted":false,"locked":false,"strokeColor":"#FF7B72","link":null,"roughness":1,"groupIds":[],"index":"b7x","backgroundColor":"#1a0505","angle":0,"fillStyle":"solid","strokeWidth":2,"version":5,"roundness":{"type":3},"type":"rectangle","updated":1772977438387,"id":"t0nbxSRc_PYmh6MzPNdtt","x":-592,"seed":366702293,"boundElements":[{"type":"text","id":"dSJnxkVXTY5LtBqi5gKAN"}],"y":379,"opacity":100,"height":32,"width":115,"frameId":null,"strokeStyle":"solid","versionNonce":1313405595},{"seed":1922092085,"strokeStyle":"solid","id":"dSJnxkVXTY5LtBqi5gKAN","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":11,"opacity":100,"verticalAlign":"middle","updated":1772977438394,"locked":false,"text":"Circuit Breakers","version":7,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b7y","roundness":null,"containerId":"t0nbxSRc_PYmh6MzPNdtt","originalText":"Circuit Breakers","height":13.75,"link":null,"strokeColor":"#F8F8F2","fillStyle":"solid","groupIds":[],"versionNonce":178916085,"textAlign":"center","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-577.53749847412109,"angle":0,"y":388.125,"width":86.074996948242188},{"isDeleted":false,"locked":false,"strokeColor":"#3FB950","link":null,"roughness":1,"groupIds":[],"index":"b7z","backgroundColor":"#0a1a0a","angle":0,"fillStyle":"solid","strokeWidth":1,"version":5,"roundness":{"type":3},"type":"rectangle","updated":1772977438387,"id":"Gg1zUfes6Mi0VmS6-XPoY","x":-307,"seed":1064533397,"boundElements":[],"y":336,"opacity":100,"height":120,"width":570,"frameId":null,"strokeStyle":"solid","versionNonce":1713696571},{"seed":867762933,"strokeStyle":"solid","id":"Bu2tZMMPWfjyOLyWc-adE","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772977438387,"locked":false,"text":"Achieved: 99.99% Availability Target","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b80","roundness":null,"containerId":null,"originalText":"Achieved: 99.99% Availability Target","height":17.5,"link":null,"strokeColor":"#3FB950","fillStyle":"solid","groupIds":[],"versionNonce":777057781,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-289,"angle":0,"y":350,"width":249.47972106933594},{"seed":65461333,"strokeStyle":"solid","id":"pcHzxxiHvwfGD44rPscre","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772977438387,"locked":false,"text":"Cassandra geo-replication: failover RTO <30s,\nRPO ~seconds. LOCAL_QUORUM reads from nearest\nregion reduce read latency by 60ms+. Circuit\nbreakers stop one degraded svc cascading to total failure.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b81","roundness":null,"containerId":null,"originalText":"Cassandra geo-replication: failover RTO <30s,\nRPO ~seconds. LOCAL_QUORUM reads from nearest\nregion reduce read latency by 60ms+. Circuit\nbreakers stop one degraded svc cascading to total failure.","height":65,"link":null,"strokeColor":"#F8F8F2","fillStyle":"solid","groupIds":[],"versionNonce":1406750683,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-289,"angle":0,"y":374,"width":373.5025634765625},{"isDeleted":false,"locked":false,"strokeColor":"#D29922","link":null,"roughness":1,"groupIds":[],"index":"b82","backgroundColor":"#1a1000","angle":0,"fillStyle":"solid","strokeWidth":1,"version":5,"roundness":{"type":3},"type":"rectangle","updated":1772977438387,"id":"lEpRE7unCisjWrwRQVdB5","x":283,"seed":936544693,"boundElements":[],"y":336,"opacity":100,"height":120,"width":600,"frameId":null,"strokeStyle":"solid","versionNonce":1829269333},{"seed":1084328725,"strokeStyle":"solid","id":"PJ7sSTj7ln38KO3mJHIbM","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772977438387,"locked":false,"text":"Trade-off  |  Ceiling: 500K+ msg\/sec globally","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b83","roundness":null,"containerId":null,"originalText":"Trade-off  |  Ceiling: 500K+ msg\/sec globally","height":17.5,"link":null,"strokeColor":"#D29922","fillStyle":"solid","groupIds":[],"versionNonce":427334779,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":301,"angle":0,"y":350,"width":302.53964233398438},{"seed":1321820277,"strokeStyle":"solid","id":"KcrF-6oJawV8XSt5PgbAN","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772977438387,"locked":false,"text":"~100ms cross-region consistency window.\nSplit-brain risk during full network partition.\nConflict resolution for simultaneous sends is hard.\nActive-active rejected: too complex for this scope.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b84","roundness":null,"containerId":null,"originalText":"~100ms cross-region consistency window.\nSplit-brain risk during full network partition.\nConflict resolution for simultaneous sends is hard.\nActive-active rejected: too complex for this scope.","height":65,"link":null,"strokeColor":"#F8F8F2","fillStyle":"solid","groupIds":[],"versionNonce":1296678069,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":301,"angle":0,"y":374,"width":323.27056884765625},{"isDeleted":false,"locked":false,"strokeColor":"#58A6FF","link":null,"roughness":1,"groupIds":[],"index":"b85","backgroundColor":"#0d0d1a","angle":0,"fillStyle":"solid","strokeWidth":2,"version":5,"roundness":{"type":3},"type":"rectangle","updated":1772977438387,"id":"oTjm7MlVt77StC63kGZG3","x":-937,"seed":1745848789,"boundElements":[],"y":499,"opacity":100,"height":128,"width":1910,"frameId":null,"strokeStyle":"solid","versionNonce":1388664091},{"seed":1032423221,"strokeStyle":"solid","id":"Ge5Xs_A7ptKpnZgWPzX8f","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1772977438387,"locked":false,"text":"What We Learned — 4 Engineering Insights","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b86","roundness":null,"containerId":null,"originalText":"What We Learned — 4 Engineering Insights","height":18.75,"link":null,"strokeColor":"#58A6FF","fillStyle":"solid","groupIds":[],"versionNonce":649747989,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-915,"angle":0,"y":513,"width":313.4398193359375},{"seed":1100798101,"strokeStyle":"solid","id":"pILdRMqSgRwlTMeDhW3tG","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772977438387,"locked":false,"text":"1. Every bottleneck was a slow path (fsync, Redis CPU, FD limit, media bandwidth) contaminating the fast path (delivery). Fix = isolate the slow path.\n2. Each upgrade replaces one general component with a purpose-built one: MySQL->Cassandra (writes), Redis->Kafka (fan-out), MySQL->Redis TTL (presence), Chat server->CDN (media).\n3. Scale and consistency are always traded: every upgrade gained throughput by relaxing a consistency guarantee. Know which consistency you can afford to lose.\n4. V1-V5 bought throughput; V6 bought availability — same system, entirely different bottleneck class.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b87","roundness":null,"containerId":null,"originalText":"1. Every bottleneck was a slow path (fsync, Redis CPU, FD limit, media bandwidth) contaminating the fast path (delivery). Fix = isolate the slow path.\n2. Each upgrade replaces one general component with a purpose-built one: MySQL->Cassandra (writes), Redis->Kafka (fan-out), MySQL->Redis TTL (presence), Chat server->CDN (media).\n3. Scale and consistency are always traded: every upgrade gained throughput by relaxing a consistency guarantee. Know which consistency you can afford to lose.\n4. V1-V5 bought throughput; V6 bought availability — same system, entirely different bottleneck class.","height":65,"link":null,"strokeColor":"#F8F8F2","fillStyle":"solid","groupIds":[],"versionNonce":2133981627,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-915,"angle":0,"y":539,"width":1176.966552734375},{"isDeleted":false,"locked":false,"strokeColor":"#44475A","link":null,"roughness":1,"groupIds":[],"index":"b88","backgroundColor":"#161B22","angle":0,"fillStyle":"solid","strokeWidth":2,"version":5,"roundness":{"type":3},"type":"rectangle","updated":1772977438387,"id":"RDYdWwZy0_SKc2tavNvQJ","x":1023,"seed":2113863157,"boundElements":[],"y":-589,"opacity":100,"height":1196,"width":850,"frameId":null,"strokeStyle":"solid","versionNonce":1078973301},{"seed":699758421,"strokeStyle":"solid","id":"6TXYJSNjVPRyE-Q98p44a","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1772977438387,"locked":false,"text":"V1 -> V2: Why Cassandra + Kafka?","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b89","roundness":null,"containerId":null,"originalText":"V1 -> V2: Why Cassandra + Kafka?","height":18.75,"link":null,"strokeColor":"#F0883E","fillStyle":"solid","groupIds":[],"versionNonce":199297627,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1048,"angle":0,"y":-571,"width":247.88986206054688},{"seed":2132133045,"strokeStyle":"solid","id":"AWOtr60-S4ezdQCiOdrg-","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772977438387,"locked":false,"text":"MySQL's write failure triggered this change.\nCassandra was chosen over MySQL sharding: sharding\nadds ops complexity without fixing the fsync problem.\nKafka was chosen over Redis: it provides durability,\nlog replay, and decouples the delivery ACK from storage.\nRabbitMQ rejected: no log replay, no partition-per-conv.\nInterviewer wants: specific component justification,\nnot just 'add a queue'.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b8A","roundness":null,"containerId":null,"originalText":"MySQL's write failure triggered this change.\nCassandra was chosen over MySQL sharding: sharding\nadds ops complexity without fixing the fsync problem.\nKafka was chosen over Redis: it provides durability,\nlog replay, and decouples the delivery ACK from storage.\nRabbitMQ rejected: no log replay, no partition-per-conv.\nInterviewer wants: specific component justification,\nnot just 'add a queue'.","height":130,"link":null,"strokeColor":"#F8F8F2","fillStyle":"solid","groupIds":[],"versionNonce":1716493525,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1048,"angle":0,"y":-547,"width":355.53656005859375},{"seed":1371891221,"strokeStyle":"solid","id":"QBwClmM7tzPzOK0z9oB15","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1772977438387,"locked":false,"text":"V2 -> V3: Why Kafka Partitions + Hash LB?","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b8B","roundness":null,"containerId":null,"originalText":"V2 -> V3: Why Kafka Partitions + Hash LB?","height":18.75,"link":null,"strokeColor":"#D29922","fillStyle":"solid","groupIds":[],"versionNonce":497354491,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1048,"angle":0,"y":-411,"width":315.94476318359375},{"seed":1689901941,"strokeStyle":"solid","id":"nfn0nab56s2_KFkA2REkI","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772977438387,"locked":false,"text":"Redis CPU saturation triggered this. Partitioning by\nconv_id ensures the owning server is the only\nconsumer — eliminates N x M fan-out entirely.\nConsistent hash LB chosen over sticky cookies:\nWebSocket reconnects happen too fast for cookie\nexchange. Interviewer wants: awareness that stateful\nservices need purpose-built routing, not replication.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b8C","roundness":null,"containerId":null,"originalText":"Redis CPU saturation triggered this. Partitioning by\nconv_id ensures the owning server is the only\nconsumer — eliminates N x M fan-out entirely.\nConsistent hash LB chosen over sticky cookies:\nWebSocket reconnects happen too fast for cookie\nexchange. Interviewer wants: awareness that stateful\nservices need purpose-built routing, not replication.","height":113.75,"link":null,"strokeColor":"#F8F8F2","fillStyle":"solid","groupIds":[],"versionNonce":1078934069,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1048,"angle":0,"y":-387,"width":344.33062744140625},{"seed":3712213,"strokeStyle":"solid","id":"Wpnw-N4wuyn8UXQk7V4qq","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1772977438387,"locked":false,"text":"V3 -> V4: Why Split the Chat Server?","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b8D","roundness":null,"containerId":null,"originalText":"V3 -> V4: Why Split the Chat Server?","height":18.75,"link":null,"strokeColor":"#3FB950","fillStyle":"solid","groupIds":[],"versionNonce":453013403,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1048,"angle":0,"y":-255,"width":269.38482666015625},{"seed":1205289525,"strokeStyle":"solid","id":"FdAOksEMxse0zCgyHf8VI","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772977438387,"locked":false,"text":"FD exhaustion and heartbeat write storms triggered this.\nThe WS Gateway is a pure I\/O process using Linux\nepoll — it holds 500K connections per node with no\nbusiness logic resident in memory. Redis SETEX with a\n35s TTL entirely eliminates heartbeat DB writes:\n333K writes\/sec on a DB becomes 333K in-memory\nops\/sec on Redis. Interviewer wants: process\narchitecture awareness, not just service topology.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b8E","roundness":null,"containerId":null,"originalText":"FD exhaustion and heartbeat write storms triggered this.\nThe WS Gateway is a pure I\/O process using Linux\nepoll — it holds 500K connections per node with no\nbusiness logic resident in memory. Redis SETEX with a\n35s TTL entirely eliminates heartbeat DB writes:\n333K writes\/sec on a DB becomes 333K in-memory\nops\/sec on Redis. Interviewer wants: process\narchitecture awareness, not just service topology.","height":130,"link":null,"strokeColor":"#F8F8F2","fillStyle":"solid","groupIds":[],"versionNonce":1731472277,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1048,"angle":0,"y":-231,"width":370.4085693359375},{"seed":1350251413,"strokeStyle":"solid","id":"Zh-XgS_o16J0DK_4ZkSl2","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1772977438387,"locked":false,"text":"V4 -> V5: Why Pre-signed URLs?","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b8F","roundness":null,"containerId":null,"originalText":"V4 -> V5: Why Pre-signed URLs?","height":18.75,"link":null,"strokeColor":"#1ABC9C","fillStyle":"solid","groupIds":[],"versionNonce":1982186555,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1048,"angle":0,"y":-93,"width":233.41481018066406},{"seed":1985607925,"strokeStyle":"solid","id":"G6OGWGsPlkSPnTOQEmA7-","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772977438387,"locked":false,"text":"10 TB\/day media growth triggered this. Routing media\nthrough the chat server consumed 10 GB\/s of server\nbandwidth for zero business value. Pre-signed URLs\nremove the chat server from the media data path\ncompletely — it only stores a URL string. CDN caching\nmeans 99% of reads never reach S3. Rejected: server-\nside proxy (bandwidth hog). Rejected: client compression\nalone (reduces size, doesn't fix routing).","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b8G","roundness":null,"containerId":null,"originalText":"10 TB\/day media growth triggered this. Routing media\nthrough the chat server consumed 10 GB\/s of server\nbandwidth for zero business value. Pre-signed URLs\nremove the chat server from the media data path\ncompletely — it only stores a URL string. CDN caching\nmeans 99% of reads never reach S3. Rejected: server-\nside proxy (bandwidth hog). Rejected: client compression\nalone (reduces size, doesn't fix routing).","height":130,"link":null,"strokeColor":"#F8F8F2","fillStyle":"solid","groupIds":[],"versionNonce":993259765,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1048,"angle":0,"y":-69,"width":359.07257080078125},{"seed":1928925781,"strokeStyle":"solid","id":"fJrQBtwQ_N1IShHsDawVV","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1772977438387,"locked":false,"text":"V5 -> V6: Why Multi-Region?","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b8H","roundness":null,"containerId":null,"originalText":"V5 -> V6: Why Multi-Region?","height":18.75,"link":null,"strokeColor":"#58A6FF","fillStyle":"solid","groupIds":[],"versionNonce":922191067,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1048,"angle":0,"y":69,"width":203.41484069824219},{"seed":858652597,"strokeStyle":"solid","id":"pbhMFN-hz8yuw49AySs8k","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772977438387,"locked":false,"text":"The 99.99% SLA cannot be met single-region — one\nAZ outage causes a major incident. Active-passive with\nCassandra async geo-replication gives RTO <30s, RPO\n~seconds. Active-active was rejected: conflict\nresolution for simultaneous sends across two regions\nis a hard distributed systems problem that introduces\nclock skew, vector clocks, and merge logic — out of\nscope for a first-pass design.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b8I","roundness":null,"containerId":null,"originalText":"The 99.99% SLA cannot be met single-region — one\nAZ outage causes a major incident. Active-passive with\nCassandra async geo-replication gives RTO <30s, RPO\n~seconds. Active-active was rejected: conflict\nresolution for simultaneous sends across two regions\nis a hard distributed systems problem that introduces\nclock skew, vector clocks, and merge logic — out of\nscope for a first-pass design.","height":130,"link":null,"strokeColor":"#F8F8F2","fillStyle":"solid","groupIds":[],"versionNonce":2043939413,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1048,"angle":0,"y":93,"width":352.40362548828125},{"isDeleted":false,"locked":false,"strokeColor":"#BC8CFF","link":null,"roughness":1,"groupIds":[],"index":"b8J","backgroundColor":"#0d0d1a","angle":0,"fillStyle":"solid","strokeWidth":2,"version":5,"roundness":{"type":3},"type":"rectangle","updated":1772977438387,"id":"x-Jl_bcZKFCWSnZiGPiqG","x":1028,"seed":1830699285,"boundElements":[],"y":249,"opacity":100,"height":340,"width":840,"frameId":null,"strokeStyle":"solid","versionNonce":1158164859},{"seed":1983862389,"strokeStyle":"solid","id":"P021XKpTheKkcIG2_sF3F","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":16,"opacity":100,"verticalAlign":"top","updated":1772977438387,"locked":false,"text":"The Pattern Behind the Evolution","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b8K","roundness":null,"containerId":null,"originalText":"The Pattern Behind the Evolution","height":20,"link":null,"strokeColor":"#BC8CFF","fillStyle":"solid","groupIds":[],"versionNonce":334100405,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1048,"angle":0,"y":267,"width":268.8157958984375},{"seed":1498857429,"strokeStyle":"solid","id":"_31OoeFea6EIe40qh5QL2","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772977438387,"locked":false,"text":"Every single upgrade followed one master principle:\nisolate the hot path from the slow path.\n\nMessage delivery is the hot path — it must complete\nin <100ms P99. Every bottleneck was a slow operation\n(fsync, Redis CPU loop, FD limit, media bandwidth,\ncross-region roundtrip) that leaked into the hot path\nand dragged P99 latency with it.\n\nThe fix was always the same: give the slow operation\nits own dedicated lane. Cassandra owns durable writes.\nKafka owns fan-out routing. Redis owns ephemeral state.\nS3 + CDN own media. Circuit breakers own failure\nisolation. The hot path shrank with each version until\nit contained only: receive socket -> Kafka publish ->\nWebSocket deliver. That is what makes 500K msg\/sec\nat 100ms P99 physically achievable.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b8L","roundness":null,"containerId":null,"originalText":"Every single upgrade followed one master principle:\nisolate the hot path from the slow path.\n\nMessage delivery is the hot path — it must complete\nin <100ms P99. Every bottleneck was a slow operation\n(fsync, Redis CPU loop, FD limit, media bandwidth,\ncross-region roundtrip) that leaked into the hot path\nand dragged P99 latency with it.\n\nThe fix was always the same: give the slow operation\nits own dedicated lane. Cassandra owns durable writes.\nKafka owns fan-out routing. Redis owns ephemeral state.\nS3 + CDN own media. Circuit breakers own failure\nisolation. The hot path shrank with each version until\nit contained only: receive socket -> Kafka publish ->\nWebSocket deliver. That is what makes 500K msg\/sec\nat 100ms P99 physically achievable.","height":276.25,"link":null,"strokeColor":"#F8F8F2","fillStyle":"solid","groupIds":[],"versionNonce":1905936923,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1048,"angle":0,"y":293,"width":363.2716064453125},{"isDeleted":false,"locked":false,"strokeColor":"transparent","link":null,"roughness":1,"groupIds":[],"index":"b8M","backgroundColor":"#111827","angle":0,"fillStyle":"solid","strokeWidth":2,"version":5,"roundness":null,"type":"rectangle","updated":1772977438387,"id":"5BgoElOX3OAiSaTUljVUE","x":-1007,"seed":746192181,"boundElements":[],"y":767,"opacity":100,"height":100,"width":3000,"frameId":null,"strokeStyle":"solid","versionNonce":1134246165},{"isDeleted":false,"locked":false,"strokeColor":"transparent","link":null,"roughness":1,"groupIds":[],"index":"b8N","backgroundColor":"#0D1117","angle":0,"fillStyle":"solid","strokeWidth":2,"version":5,"roundness":null,"type":"rectangle","updated":1772977438387,"id":"yr1MdqusCCaQ_IuQ38gZn","x":-1007,"seed":655265429,"boundElements":[],"y":867,"opacity":100,"height":1982,"width":3000,"frameId":null,"strokeStyle":"solid","versionNonce":1101024955},{"isDeleted":false,"locked":false,"strokeColor":"transparent","link":null,"roughness":1,"groupIds":[],"index":"b8O","backgroundColor":"#111827","angle":0,"fillStyle":"solid","s