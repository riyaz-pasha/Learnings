":"bRft7gt3bxIFGtsvn-ef-","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":26,"opacity":100,"verticalAlign":"top","updated":1772977438387,"locked":false,"text":"Interview Cheat Sheet — Numbers, Strategy, Q&A","version":6,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bGV","roundness":null,"containerId":null,"originalText":"Interview Cheat Sheet — Numbers, Strategy, Q&A","height":32.5,"link":null,"strokeColor":"#F8F8F2","fillStyle":"solid","groupIds":[],"versionNonce":697804539,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-932,"angle":0,"y":5445,"width":635.67364501953125},{"isDeleted":false,"locked":false,"strokeColor":"transparent","link":null,"roughness":1,"groupIds":[],"index":"bGW","backgroundColor":"#30363D","angle":0,"fillStyle":"solid","strokeWidth":2,"version":6,"roundness":null,"type":"rectangle","updated":1772977438387,"id":"JxFp6nrAsTpnPYreTSz9d","x":993,"seed":934852853,"boundElements":[],"y":5429,"opacity":100,"height":600,"width":3,"frameId":null,"strokeStyle":"solid","versionNonce":441883189},{"isDeleted":false,"locked":false,"strokeColor":"#58A6FF","link":null,"roughness":1,"groupIds":[],"index":"bGX","backgroundColor":"#0a0e14","angle":0,"fillStyle":"solid","strokeWidth":2,"version":6,"roundness":{"type":3},"type":"rectangle","updated":1772977438387,"id":"CcfInh6TbS7fd2F8n7OL8","x":-932,"seed":444584533,"boundElements":[],"y":5507,"opacity":100,"height":200,"width":465,"frameId":null,"strokeStyle":"solid","versionNonce":1335824283},{"seed":1004322741,"strokeStyle":"solid","id":"dbfWuD6Xke3JLoy_g3dbt","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772977438387,"locked":false,"text":"Scale Strategy","version":6,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bGY","roundness":null,"containerId":null,"originalText":"Scale Strategy","height":17.5,"link":null,"strokeColor":"#58A6FF","fillStyle":"solid","groupIds":[],"versionNonce":1229949845,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-912,"angle":0,"y":5521,"width":100.26789855957031},{"seed":1911882005,"strokeStyle":"solid","id":"08d3D9wpFFU5IFN9RCcUk","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772977438387,"locked":false,"text":"WS Gateway: horizontal + consistent hash\nKafka: partition-per-conv + consumer groups\nCassandra: partition-per-conv + RF=3\nPresence: Redis cluster (in-memory only)\nMedia: S3+CDN (infinite horizontal scale)\nFan-out: async workers, not hot-path\nMulti-region: active-passive geo-replicated","version":6,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bGZ","roundness":null,"containerId":null,"originalText":"WS Gateway: horizontal + consistent hash\nKafka: partition-per-conv + consumer groups\nCassandra: partition-per-conv + RF=3\nPresence: Redis cluster (in-memory only)\nMedia: S3+CDN (infinite horizontal scale)\nFan-out: async workers, not hot-path\nMulti-region: active-passive geo-replicated","height":113.75,"link":null,"strokeColor":"#F8F8F2","fillStyle":"solid","groupIds":[],"versionNonce":1576035387,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-912,"angle":0,"y":5545,"width":278.524658203125},{"isDeleted":false,"locked":false,"strokeColor":"#3FB950","link":null,"roughness":1,"groupIds":[],"index":"bGa","backgroundColor":"#0a0e14","angle":0,"fillStyle":"solid","strokeWidth":2,"version":6,"roundness":{"type":3},"type":"rectangle","updated":1772977438387,"id":"Yu8pp1URFFcgR_qZbta_w","x":-447,"seed":842929781,"boundElements":[],"y":5507,"opacity":100,"height":200,"width":465,"frameId":null,"strokeStyle":"solid","versionNonce":48451829},{"seed":662536149,"strokeStyle":"solid","id":"lk158MnY2DVZlcyDSTw3A","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772977438387,"locked":false,"text":"Reliability Strategy","version":6,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bGb","roundness":null,"containerId":null,"originalText":"Reliability Strategy","height":17.5,"link":null,"strokeColor":"#3FB950","fillStyle":"solid","groupIds":[],"versionNonce":208544987,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-427,"angle":0,"y":5521,"width":131.1378173828125},{"seed":130596149,"strokeStyle":"solid","id":"J14J1TOPO5wwS29RqqGus","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772977438387,"locked":false,"text":"Delivery: Kafka durable log (replay on fail)\nStorage: Cassandra RF=3, 11-nines durability\nPresence: best-effort (30s TTL, can lose)\nPush notif: retry 3x -> DLQ -> manual replay\nCircuit breaker: all inter-service calls\nIdempotency: Redis dedup + TIMEUUID PK\nFailover: GLB health check -> Region B <90s","version":6,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bGc","roundness":null,"containerId":null,"originalText":"Delivery: Kafka durable log (replay on fail)\nStorage: Cassandra RF=3, 11-nines durability\nPresence: best-effort (30s TTL, can lose)\nPush notif: retry 3x -> DLQ -> manual replay\nCircuit breaker: all inter-service calls\nIdempotency: Redis dedup + TIMEUUID PK\nFailover: GLB health check -> Region B <90s","height":113.75,"link":null,"strokeColor":"#F8F8F2","fillStyle":"solid","groupIds":[],"versionNonce":1419209301,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-427,"angle":0,"y":5545,"width":284.10162353515625},{"isDeleted":false,"locked":false,"strokeColor":"#FF7B72","link":null,"roughness":1,"groupIds":[],"index":"bGd","backgroundColor":"#0a0e14","angle":0,"fillStyle":"solid","strokeWidth":2,"version":6,"roundness":{"type":3},"type":"rectangle","updated":1772977438387,"id":"8l4XIihaCRDmhZyu