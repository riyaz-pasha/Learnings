?","height":17.5,"link":null,"strokeColor":"#F0883E","fillStyle":"solid","groupIds":[],"versionNonce":166877941,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-912,"angle":0,"y":4901,"width":193.17182922363281},{"seed":1740837845,"strokeStyle":"solid","id":"HHCt9DdpL7W6SGrwoQFK2","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772977438387,"locked":false,"text":"Chose:   Cassandra\nOver:    MySQL single primary\nBecause: LSM no-fsync writes; native\n         sharding; RF=3 durability\nCosts:   No JOINs; eventual consistency;\n         tuning complexity\nRevisit: If msg\/sec < 10K total","version":6,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bG5","roundness":null,"containerId":null,"originalText":"Chose:   Cassandra\nOver:    MySQL single primary\nBecause: LSM no-fsync writes; native\n         sharding; RF=3 durability\nCosts:   No JOINs; eventual consistency;\n         tuning complexity\nRevisit: If msg\/sec < 10K total","height":113.75,"link":null,"strokeColor":"#F8F8F2","fillStyle":"solid","groupIds":[],"versionNonce":153926363,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-912,"angle":0,"y":4925,"width":260.68869018554688},{"isDeleted":false,"locked":false,"strokeColor":"#D29922","link":null,"roughness":1,"groupIds":[],"index":"bG6","backgroundColor":"#0a0e0a","angle":0,"fillStyle":"solid","strokeWidth":2,"version":6,"roundness":{"type":3},"type":"rectangle","updated":1772977438387,"id":"EWWORMnjy677Hw6eLgrby","x":-452,"seed":1379651893,"boundElements":[],"y":4887,"opacity":100,"height":220,"width":450,"frameId":null,"strokeStyle":"solid","versionNonce":2033529941},{"seed":1568006805,"strokeStyle":"solid","id":"UOJ0mncTSa9CADokJPfEi","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772977438387,"locked":false,"text":"Why Kafka ov