ndex":"bBo","roundness":null,"containerId":null,"originalText":"C — Data Model (Cursor Pagination)","height":16.25,"link":null,"strokeColor":"#8B949E","fillStyle":"solid","groupIds":[],"versionNonce":1306293301,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-935,"angle":0,"y":2503,"width":231.10075378417969},{"isDeleted":false,"locked":false,"strokeColor":"#F0883E","link":null,"roughness":1,"groupIds":[],"index":"bBp","backgroundColor":"#0d0800","angle":0,"fillStyle":"solid","strokeWidth":2,"version":5,"roundness":{"type":3},"type":"rectangle","updated":1772977438387,"id":"NtnziL3VlAANmTQ5dN79I","x":-927,"seed":1262852309,"boundElements":[],"y":2519,"opacity":100,"height":160,"width":500,"frameId":null,"strokeStyle":"solid","versionNonce":1669059995},{"seed":220575285,"strokeStyle":"solid","id":"RDhRhR-JKz4TwseZ16VgH","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772977438387,"locked":false,"text":"messages  (same table, different query pattern)","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bBq","roundness":null,"containerId":null,"originalText":"messages  (same table, different query pattern)","height":17.5,"link":null,"strokeColor":"#F0883E","fillStyle":"solid","groupIds":[],"versionNonce":50996629,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-907,"angle":0,"y":2531,"width":326.465576171875},{"seed":1272653717,"strokeStyle":"solid","id":"gblLjAdyJ0VJ7xZPJx2sh","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772977438387,"locked":false,"text":"conv_id:    UUID  [PK partition]     <- co-locates all msgs\nmessage_id: TIMEUUID [PK cluster DESC] <- natural cursor\nsender_id:  UUID\ncontent:    TEXT\ncreated_at: TIMESTAMP\n\nKey insight: partitioning by conv_id means pagination\nis a single-node, single-partition range scan.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bBr","roundness":null,"containerId":null,"originalText":"conv_id:    UUID  [PK partition]     <- co-locates all msgs\nmessage_id: TIMEUUID [PK cluster DESC] <- natural cursor\nsender_id:  UUID\ncontent:    TEXT\ncreated_at: TIMESTAMP\n\nKey insight: partitioning by conv_id means pagination\nis a single-node, single-partition range scan.","height":130,"link":null,"strokeColor":"#F8F8F2","fillStyle":"solid","groupIds":[],"versionNonce":642017851,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-907,"angle":0,"y":2553,"width":388.60858154296875},{"isDeleted":false,"locked":false,"strokeColor":"#D29922","link":null,"roughness":1,"groupIds":[],"index":"bBs","backgroundColor":"#1a1200","angle":0,"fillStyle":"solid","strokeWidth":1,"version":5,"roundness":{"type":3},"type":"rectangle","updated":1772977438387,"id":"rKCSQ7aQpQplSxcSqVINW","x":-927,"seed":1771793653,"boundElements":[],"y":2685,"opacity":100,"height":48,"width":500,"frameId":null,"strokeStyle":"solid","versionNonce":507161333},{"seed":1709966933,"strokeStyle":"solid","id":"Y5ga-A2QMGlZLhlbQxDN7","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":12,"opacity":100,"verticalAlign":"top","updated":1772977438387,"locked":false,"text":"SELECT * FROM messages WHERE conv_id=? AND message_id < ?\nORDER BY message_id DESC LIMIT 50   -- cursor = TIMEUUID of oldest seen msg","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bBt","roundness":null,"containerId":null,"originalText":"SELECT * FROM messages WHERE conv_id=? AND message_id < ?\nORDER BY message_id DESC LIMIT 50   -- cursor = TIMEUUID of oldest seen msg","height":30,"link":null,"strokeColor":"#D29922","fillStyle":"solid","groupIds":[],"versionNonce":2018601691,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-917,"angle":0,"y":2696,"width":502.979248046875},{"isDeleted":false,"locked":false,"strokeColor":"#44475A","link":null,"roughness":1,"groupIds":[],"index":"bBu","backgroundColor":"#161B22","angle":0,"fillStyle":"solid","strokeWidth":2,"version":5,"roundness":{"type":3},"type":"rectangle","updated":1772977438387,"id":"AaLqFvKggcOivDGzBkHtj","x":-367,"seed":866284469,"boundElements":[],"y":2519,"opacity":100,"height":200,"width":480,"frameId":null,"strokeStyle":"solid","versionNonce":2146665557},{"seed":1323578645,"strokeStyle":"solid","id":"6vjVsrCqSWmjHoBcjqU9F","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772977438387,"locked":false,"text":"Why TIMEUUID not TIMESTAMP as cursor?","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bBv","roundness":null,"containerId":null,"originalText":"Why TIMEUUID not TIMESTAMP as cursor?","height":17.5,"link":null,"strokeColor":"#3FB950","fillStyle":"solid","groupIds":[],"versionNonce":1312118651,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-347,"angle":0,"y":2537,"width":310.23971557617188},{"seed":321309301,"strokeStyle":"solid","id":"wwim3KE21j-HyWaLipAgp","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772977438387,"locked":false,"text":"TIMEUUID embeds timestamp + node ID.\nTwo simultaneous inserts on different nodes\nnever collide — ordering is globally unique\nwithout a distributed lock or sequence service.\n\nAlternative (partition by date) REJECTED:\nA conversation's messages scatter across\nmany nodes — pagination requires scatter-\ngather reads scaling as O(months of history).","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bBw","roundness":null,"containerId":null,"originalText":"TIMEUUID embeds timestamp + node ID.\nTwo simultaneous inserts on different nodes\nnever collide — ordering is globally unique\nwithout a distributed lock or sequence service.\n\nAlternative (partition by date) REJECTED:\nA conversation's messages scatter across\nmany nodes — pagination requires scatter-\ngather reads scaling as O(months of history).","height":146.25,"link":null,"strokeColor":"#F8F8F2","fillStyle":"solid","groupIds":[],"versionNonce":1544171957,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-347,"angle":0,"y":2561,"width":297.36160278320312},{"isDeleted":false,"locked":false,"strokeColor":"#44475A","link":null,"roughness":1,"groupIds":[],"index":"bBx","backgroundColor":"#161B22","angle":0,"fillStyle":"solid","strokeWidth":2,"version":5,"roundness":{"type":3},"type":"rectangle","updated":1772977438387,"id":"4mC9_NMzDQaH28E9v28g4","x":1023,"seed":1362080725,"boundElements":[],"y":939,"opacity":100,"height":1800,"width":850,"frameId":null,"strokeStyle":"solid","versionNonce":1714597915},{"seed":622096693,"strokeStyle":"solid","id":"0ut-ukCX-xa0AfrnLCDJA","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1772977438387,"locked":false,"text":"FR1 — Send & Receive: How It Works","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bBy","roundness":null,"containerId":null,"originalText":"FR1 — Send & Receive: How It Works","height":18.75,"link":null,"strokeColor":"#58A6FF","fillStyle":"solid","groupIds":[],"versionNonce":1336161045,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1048,"angle":0,"y":957,"width":273.88482666015625},{"seed":205161109,"strokeStyle":"solid","id":"81DAl_tSI9XPZ--eR7BUz","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772977438387,"locked":false,"text":"Steps 1-3: Alice's WS frame hits the Gateway\n(step 1), which validates auth and rate limits (2).\nChat Server generates a Snowflake ID for global\nordering, then fires PUBLISH to Kafka partition\nhash(conv_id) and INSERT to Cassandra in parallel\n(step 3\/3b). The ACK to Alice waits only on the\nKafka confirm — not the DB write. That parallel\ndesign is why the critical path is <65ms.\n\nSteps 4-5: Kafka consumer on Server B reads the\npartition, checks Redis TTL presence for Bob,\nand pushes via WebSocket. Total: <100ms P99.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bBz","roundness":null,"containerId":null,"originalText":"Steps 1-3: Alice's WS frame hits the Gateway\n(step 1), which validates auth and rate limits (2).\nChat Server generates a Snowflake ID for global\nordering, then fires PUBLISH to Kafka partition\nhash(conv_id) and INSERT to Cassandra in parallel\n(step 3\/3b). The ACK to Alice waits only on the\nKafka confirm — not the DB write. That parallel\ndesign is why the critical path is <65ms.\n\nSteps 4-5: Kafka consumer on Server B reads the\npartition, checks Redis TTL presence for Bob,\nand pushes via WebSocket. Total: <100ms P99.","height":210,"link":null,"strokeColor":"#F8F8F2","fillStyle":"solid","groupIds":[],"versionNonce":305919163,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1048,"angle":0,"y":981,"width":351.651611328125},{"seed":995583989,"strokeStyle":"solid","id":"9B_3yOaCeQW0lW4RvrI9G","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1772977438387,"locked":false,"text":"What Can Go Wrong — FR1","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bC0","roundness":null,"containerId":null,"originalText":"What Can Go Wrong — FR1","height":18.75,"link":null,"strokeColor":"#FF7B72","fillStyle":"solid","groupIds":[],"versionNonce":926353525,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1048,"angle":0,"y":1157,"width":198.16493225097656},{"seed":879796565,"strokeStyle":"solid","id":"Mv6WcOUNiSUX3GgvVhxMj","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772977438387,"locked":false,"text":"Kafka broker failure: Chat Server cannot PUBLISH\n-> returns immediate error to Alice. Recovery:\nexponential backoff retry + failover to replica\nbroker. After 3 failures: dead letter queue.\nCassandra write failure: message is in Kafka\nbut not persisted -> on-reconnect, consumer\nreplays from Kafka offset and inserts again.\nIdempotency key = Snowflake message_id prevents\nduplicate inserts on retry.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bC1","roundness":null,"containerId":null,"originalText":"Kafka broker failure: Chat Server cannot PUBLISH\n-> returns immediate error to Alice. Recovery:\nexponential backoff retry + failover to replica\nbroker. After 3 failures: dead letter queue.\nCassandra write failure: message is in Kafka\nbut not persisted -> on-reconnect, consumer\nreplays from Kafka offset and inserts again.\nIdempotency key = Snowflake message_id prevents\nduplicate inserts on retry.","height":157.5,"link":null,"strokeColor":"#F8F8F2","fillStyle":"solid","groupIds":[],"versionNonce":1106486619,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1048,"angle":0,"y":1179,"width":346.06561279296875},{"seed":484159157,"strokeStyle":"solid","id":"oH-GCJyPLmlOc9cbZhot7","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1772977438387,"locked":false,"text":"Data Model Decision — FR1","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bC2","roundness":null,"containerId":null,"originalText":"Data Model Decision — FR1","height":18.75,"link":null,"strokeColor":"#F0883E","fillStyle":"solid","groupIds":[],"versionNonce":1149776341,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1048,"angle":0,"y":1343,"width":203.32490539550781},{"seed":1396576277,"strokeStyle":"solid","id":"I1BWRCH-dMDmm5XFMdags","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772977438387,"locked":false,"text":"TIMEUUID as clustering key is the key design\nchoice. Alternative (TIMESTAMP) fails when two\nmessages arrive in the same millisecond on\ndifferent nodes — they get the same key, one\noverwrites the other. TIMEUUID embeds a node ID,\nguaranteeing uniqueness while remaining sortable\nby time. Partitioning by conv_id means all messages\nfor a conversation are co-located on one Cassandra\nnode — pagination is a single-partition range scan.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bC3","roundness":null,"containerId":null,"originalText":"TIMEUUID as clustering key is the key design\nchoice. Alternative (TIMESTAMP) fails when two\nmessages arrive in the same millisecond on\ndifferent nodes — they get the same key, one\noverwrites the other. TIMEUUID embeds a node ID,\nguaranteeing uniqueness while remaining sortable\nby time. Partitioning by conv_id means all messages\nfor a conversation are co-located on one Cassandra\nnode — pagination is a single-partition range scan.","height":157.5,"link":null,"strokeColor":"#F8F8F2","fillStyle":"solid","groupIds":[],"versionNonce":1286357499,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1048,"angle":0,"y":1365,"width":363.18753051757812},{"seed":1166886261,"strokeStyle":"solid","id":"NV71Jot-u117Y5usHrBAX","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1772977438387,"locked":false,"text":"Latency Budget — FR1","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bC4","roundness":null,"containerId":null,"originalText":"Latency Budget — FR1","height":18.75,"link":null,"strokeColor":"#D29922","fillStyle":"solid","groupIds":[],"versionNonce":1420635957,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1048,"angle":0,"y":1527,"width":169.30491638183594},{"seed":118410965,"strokeStyle":"solid","id":"IrgzgV4Z5o58Pu-P6uJOt","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772977438387,"locked":false,"text":"WS receive + auth:  15ms  | exceed -> add GW nodes\nKafka PUBLISH:      10ms  | exceed -> Kafka overload\nKafka consume:      30ms  | exceed -> add partitions\nWS push to Bob:     5ms   | exceed -> buffer full\nTotal budget:      <100ms | exceed -> SLA breach","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bC5","roundness":null,"containerId":null,"originalText":"WS receive + auth:  15ms  | exceed -> add GW nodes\nKafka PUBLISH:      10ms  | exceed -> Kafka overload\nKafka consume:      30ms  | exceed -> add partitions\nWS push to Bob:     5ms   | exceed -> buffer full\nTotal budget:      <100ms | exceed -> SLA breach","height":87.5,"link":null,"strokeColor":"#F8F8F2","fillStyle":"solid","groupIds":[],"versionNonce":2070432411,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1048,"angle":0,"y":1549,"width":369.235595703125},{"isDeleted":false,"locked":false,"strokeColor":"transparent","link":null,"roughness":1,"groupIds":[],"index":"bC6","backgroundColor":"#30363D","angle":0,"fillStyle":"solid","strokeWidth":2,"version":5,"roundness":null,"type":"rectangle","updated":1772977438387,"id":"CNq5_O1ZsWWLdg9ZaEpVK","x":1028,"seed":643312693,"boundElements":[],"y":1645,"opacity":100,"height":2,"width":840,"frameId":null,"strokeStyle":"solid","versionNonce":101417109},{"seed":1129242005,"strokeStyle":"solid","id":"hRFr9tqKFdu2cNp-6S4-1","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1772977438387,"locked":false,"text":"FR2 — Group Fan-out: How It Works","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bC7","roundness":null,"containerId":null,"originalText":"FR2 — Group Fan-out: How It Works","height":18.75,"link":null,"strokeColor":"#D29922","fillStyle":"solid","groupIds":[],"versionNonce":1390034747,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1048,"angle":0,"y":1659,"width":273.08984375},{"seed":1697145589,"strokeStyle":"solid","id":"aMMcrZZrzRJO8SLkwSRTN","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772977438387,"locked":false,"text":"Alice's message hits Server A (1), which publishes\nto a Kafka partition keyed by conv_id (2). A\ndedicated Fan-out Worker consumes the partition\n(3) and performs two operations: SELECT member\nlist from Cassandra conv_members (4), then for\neach member GET ws_server:{user_id} from Redis\nto find which server owns their connection.\nFinally it routes delivery events to each owning\nserver. This design keeps fan-out work off the\nhot path — Server A returns ACK to Alice before\nfan-out even begins.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bC8","roundness":null,"containerId":null,"originalText":"Alice's message hits Server A (1), which publishes\nto a Kafka partition keyed by conv_id (2). A\ndedicated Fan-out Worker consumes the partition\n(3) and performs two operations: SELECT member\nlist from Cassandra conv_members (4), then for\neach member GET ws_server:{user_id} from Redis\nto find which server owns their connection.\nFinally it routes delivery events to each owning\nserver. This design keeps fan-out work off the\nhot path — Server A returns ACK to Alice before\nfan-out even begins.","height":192.5,"link":null,"strokeColor":"#F8F8F2","fillStyle":"solid","groupIds":[],"versionNonce":240690677,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1048,"angle":0,"y":1683,"width":342.64959716796875},{"seed":275397717,"strokeStyle":"solid","id":"JRgbOFxQNzVcHsRXu4TUl","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1772977438387,"locked":false,"text":"What Can Go Wrong — FR2","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bC9","roundness":null,"containerId":null,"originalText":"What Can Go Wrong — FR2","height":18.75,"link":null,"strokeColor":"#FF7B72","fillStyle":"solid","groupIds":[],"versionNonce":493133787,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1048,"angle":0,"y":1853,"width":202.25993347167969},{"seed":485091765,"strokeStyle":"solid","id":"roEru95zk_3J-EMnhlvUD","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772977438387,"locked":false,"text":"Fan-out Worker crashes mid-delivery at member\n#250 of 500: Kafka consumer group rebalances\nin ~30s, another worker picks up from the last\ncommitted offset. Members 1-249 get duplicates\n(handled by idempotency key at WS layer). Members\n250-500 experience up to 30s delivery delay.\nThis is acceptable for group chat; for 1:1 the\nretry is sub-second due to smaller fan-out scope.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bCA","roundness":null,"containerId":null,"originalText":"Fan-out Worker crashes mid-delivery at member\n#250 of 500: Kafka consumer group rebalances\nin ~30s, another worker picks up from the last\ncommitted offset. Members 1-249 get duplicates\n(handled by idempotency key at WS layer). Members\n250-500 experience up to 30s delivery delay.\nThis is acceptable for group chat; for 1:1 the\nretry is sub-second due to smaller fan-out scope.","height":140,"link":null,"strokeColor":"#F8F8F2","fillStyle":"solid","groupIds":[],"versionNonce":1352277845,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1048,"angle":0,"y":1875,"width":348.72564697265625},{"seed":1271720725,"strokeStyle":"solid","id":"OU4GYNUpRNPEZc1FPINRL","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1772977438387,"locked":false,"text":"Data Model Decision — FR2","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bCB","roundness":null,"containerId":null,"originalText":"Data Model Decision — FR2","height":18.75,"link":null,"strokeColor":"#F0883E","fillStyle":"solid","groupIds":[],"versionNonce":890891387,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1048,"angle":0,"y":2019,"width":207.41990661621094},{"seed":495501429,"strokeStyle":"solid","id":"aMOF936ezaVU-tLbHHMYN","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772977438387,"locked":false,"text":"The user_convs reverse index is the critical\ninsertion. Without it, loading a user's inbox\n(20 most recent conversations) requires scanning\nconv_members for every conversation the user\nhas ever joined — potentially thousands of\npartitions. With user_convs (partitioned by\nuser_id, clustered by last_active DESC), the\ninbox query is a single-partition read of 20\nrows. The COUNTER type for unread_count avoids\nread-modify-write races in Cassandra.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bCC","roundness":null,"containerId":null,"originalText":"The user_convs reverse index is the critical\ninsertion. Without it, loading a user's inbox\n(20 most recent conversations) requires scanning\nconv_members for every conversation the user\nhas ever joined — potentially thousands of\npartitions. With user_convs (partitioned by\nuser_id, clustered by last_active DESC), the\ninbox query is a single-partition read of 20\nrows. The COUNTER type for unread_count avoids\nread-modify-write races in Cassandra.","height":175,"link":null,"strokeColor":"#F8F8F2","fillStyle":"solid","groupIds":[],"versionNonce":858090677,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1048,"angle":0,"y":2041,"width":353.7095947265625},{"isDeleted":false,"locked":false,"strokeColor":"transparent","link":null,"roughness":1,"groupIds":[],"index":"bCD","backgroundColor":"#30363D","angle":0,"fillStyle":"solid","strokeWidth":2,"version":5,"roundness":null,"type":"rectangle","updated":1772977438387,"id":"DXUXj9UMakIYqcn0RLiwP","x":1028,"seed":1742924245,"boundElements":[],"y":2209,"opacity":100,"height":2,"width":840,"frameId":null,"strokeStyle":"solid","versionNonce":230466843},{"seed":737208117,"strokeStyle":"solid","id":"EKJX0AC1BI82qJfKMk8tx","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1772977438387,"locked":false,"text":"FR4 — Message History: How It Works","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bCE","roundness":null,"containerId":null,"originalText":"FR4 — Message History: How It Works","height":18.75,"link":null,"strokeColor":"#3FB950","fillStyle":"solid","groupIds":[],"versionNonce":899681813,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1048,"angle":0,"y":2223,"width":283.51480102539062},{"seed":739784853,"strokeStyle":"solid","id":"WK2lrT9vvJWcZvWxoUGjV","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772977438387,"locked":false,"text":"User scrolls up -> Client fires GET \/messages?\nbefore={cursor}&limit=50. API Server computes\ncache key sha(conv_id, cursor) and checks Redis\n(step 2). Cache HIT (90%+ of requests): return\nimmediately in <35ms total. Cache MISS: Cassandra\nSELECT with cursor predicate (3), result cached\nwith 5min TTL (4), returned to client. Cursor =\nTIMEUUID of the oldest message in current view.\nStateless pagination: server holds no session.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bCF","roundness":null,"containerId":null,"originalText":"User scrolls up -> Client fires GET \/messages?\nbefore={cursor}&limit=50. API Server computes\ncache key sha(conv_id, cursor) and checks Redis\n(step 2). Cache HIT (90%+ of requests): return\nimmediately in <35ms total. Cache MISS: Cassandra\nSELECT with cursor predicate (3), result cached\nwith 5min TTL (4), returned to client. Cursor =\nTIMEUUID of the oldest message in current view.\nStateless pagination: server holds no session.","height":157.5,"link":null,"strokeColor":"#F8F8F2","fillStyle":"solid","groupIds":[],"versionNonce":2126465467,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1048,"angle":0,"y":2247,"width":348.431640625},{"seed":1108237813,"strokeStyle":"solid","id":"MsIG3ub6ql4Uo3vQ4f7lv","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1772977438387,"locked":false,"text":"What Can Go Wrong — FR4","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bCG","roundness":null,"containerId":null,"originalText":"What Can Go Wrong — FR4","height":18.75,"link":null,"strokeColor":"#FF7B72","fillStyle":"solid","groupIds":[],"versionNonce":1191150453,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1048,"angle":0,"y":2409,"width":200.53492736816406},{"seed":1960367957,"strokeStyle":"solid","id":"slTrODlZ8bY9MfMaRwLCd","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772977438387,"locked":false,"text":"Cache cold start: all 50M users open the app\nsimultaneously (e.g. app update releases). Redis\ncache is empty; all first-page reads hit Cassandra.\n10M DAU × 1 history load = 10M Cassandra reads\nin <5 minutes — 33K reads\/sec. Cassandra can\nhandle this, but read latency climbs to 200ms P99.\nMitigation: cache warming on deploy, staggered\napp update rollout, read replica nodes.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bCH","roundness":null,"containerId":null,"originalText":"Cache cold start: all 50M users open the app\nsimultaneously (e.g. app update releases). Redis\ncache is empty; all first-page reads hit Cassandra.\n10M DAU × 1 history load = 10M Cassandra reads\nin <5 minutes — 33K reads\/sec. Cassandra can\nhandle this, but read latency climbs to 200ms P99.\nMitigation: cache warming on deploy, staggered\napp update rollout, read replica nodes.","height":140,"link":null,"strokeColor":"#F8F8F2","fillStyle":"solid","groupIds":[],"versionNonce":1296325211,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1048,"angle":0,"y":2431,"width":349.55157470703125},{"seed":1322067125,"strokeStyle":"solid","id":"B7cgEjv_Zuy4dGmJka0ei","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1772977438387,"locked":false,"text":"Data Model Decision — FR4","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bCI","roundness":null,"containerId":null,"originalText":"Data Model Decision — FR4","height":18.75,"link":null,"strokeColor":"#F0883E","fillStyle":"solid","groupIds":[],"versionNonce":1535724757,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1048,"angle":0,"y":2589,"width":205.69490051269531},{"seed":1938867733,"strokeStyle":"solid","id":"9iw5XtGPZ_MKxKrqDUQV2","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772977438387,"locked":false,"text":"Partitioning by conv_id is the key decision.\nAlternative (partition by month\/date): a single\nconversation is scattered across 12 partitions per\nyear. Paginating 6 months of history requires a\nscatter-gather across 6+ nodes, O(months) latency.\nWith conv_id partitioning, any page of any\nconversation is a single-partition range scan —\nconstant time regardless of conversation age.\nTrade-off: a very active conversation (millions of\nmessages) creates a hot partition on one node.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bCJ","roundness":null,"containerId":null,"originalText":"Partitioning by conv_id is the key decision.\nAlternative (partition by month\/date): a single\nconversation is scattered across 12 partitions per\nyear. Paginating 6 months of history requires a\nscatter-gather across 6+ nodes, O(months) latency.\nWith conv_id partitioning, any page of any\nconversation is a single-partition range scan —\nconstant time regardless of conversation age.\nTrade-off: a very active conversation (millions of\nmessages) creates a hot partition on one node.","height":175,"link":null,"strokeColor":"#F8F8F2","fillStyle":"solid","groupIds":[],"versionNonce":1981699835,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1048,"angle":0,"y":2611,"width":357.1676025390625},{"isDeleted":false,"locked":false,"strokeColor":"transparent","link":null,"roughness":1,"groupIds":[],"index":"bCK","backgroundColor":"#111827","angle":0,"fillStyle":"solid","strokeWidth":2,"version":5,"roundness":null,"type":"rectangle","updated":1772977438387,"id":"mI8xax8LXGEUgjTkXqmTI","x":-1007,"seed":1981365109,"boundElements":[],"y":2929,"opacity":100,"height":100,"width":3000,"frameId":null,"strokeStyle":"solid","versionNonce":1121118773},{"isDeleted":false,"locked":false,"strokeColor":"transparent","link":null,"roughness":1,"groupIds":[],"index":"bCL","backgroundColor":"#0D1117","angle":0,"fillStyle":"solid","strokeWidth":2,"version":5,"roundness":null,"type":"rectangle","updated":1772977438387,"id":"ZxAy47-UZUWvIcPewDz7r","x":-1007,"seed":1856767189,"boundElements":[],"y":3029,"opacity":100,"height":980,"width":3000,"frameId":null,"strokeStyle":"solid","versionNonce":936361883},{"isDeleted":false,"locked":false,"strokeColor":"transparent","link":null,"roughness":1,"groupIds":[],"index":"bCM","backgroundColor":"#111827","angle":0,"fillStyle":"solid","strokeWidth":2,"version":5,"roundness":null,"type":"rectangle","updated":1772977438387,"id":"RBfD8b4mMiA4SMvBTAH4g","x":-1007,"seed":1356767797,"boundElements":[],"y":4009,"opacity":100,"height":80,"width":3000,"frameId":null,"strokeStyle":"solid","versionNonce":1036114837},{"isDeleted":false,"locked":false,"strokeColor":"transparent","link":null,"roughness":1,"groupIds":[],"index":"bCN","backgroundColor":"#161B22","angle":0,"fillStyle":"solid","strokeWidth":2,"version":5,"roundness":null,"type":"rectangle","updated":1772977438387,"id":"W0fRjKt3NCrYSLW6dh5rJ","x":-1007,"seed":26645397,"boundElements":[],"y":3029,"opacity":100,"height":60,"width":3000,"frameId":null,"strokeStyle":"solid","versionNonce":1552618555},{"isDeleted":false,"locked":false,"strokeColor":"transparent","link":null,"roughness":1,"groupIds":[],"index":"bCO","backgroundColor":"#58A6FF","angle":0,"fillStyle":"solid","strokeWidth":2,"version":6,"roundness":null,"type":"ellipse","updated":1772977438387,"id":"3guIRLm0w2n92GoWMQw3R","x":-985,"seed":755587317,"boundElements":[{"type":"text","id":"qHDMWenGIcLAjQHMpG5rb"}],"y":3041,"opacity":100,"height":47,"width":36,"frameId":null,"strokeStyle":"solid","versionNonce":1418436853},{"seed":1555853909,"strokeStyle":"solid","id":"qHDMWenGIcLAjQHMpG5rb","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":18,"opacity":100,"verticalAlign":"middle","updated":1772977438398,"locked":false,"text":"8","version":7,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bCP","roundness":null,"containerId":"3guIRLm0w2n92GoWMQw3R","originalText":"8","height":22.5,"link":null,"strokeColor":"#0D1117","fillStyle":"solid","groupIds":[],"versionNonce":2123687925,"textAlign":"center","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElement