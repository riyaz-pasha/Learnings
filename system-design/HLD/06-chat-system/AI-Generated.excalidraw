e new connection.\nCategory: Coordination-bound","version":7,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b5i","roundness":null,"containerId":null,"originalText":"Threshold: > 2 server instances\nCause: Round-robin sends reconnecting\nclient to wrong server; session state\nlost — user looks like new connection.\nCategory: Coordination-bound","height":81.25,"link":null,"strokeColor":"#F8F8F2","fillStyle":"solid","groupIds":[],"versionNonce":628161621,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-727,"angle":0,"y":-925,"width":244.63371276855469},{"seed":562242837,"strokeStyle":"dashed","id":"LpXkm79x9eHUrLPU621u7","strokeWidth":1,"roughness":1,"isDeleted":false,"startBinding":null,"endArrowhead":"arrow","opacity":100,"updated":1772977438387,"locked":false,"points":[[0,0],[-49,325]],"version":7,"elbowed":false,"type":"arrow","backgroundColor":"transparent","index":"b5j","roundness":null,"lastCommittedPoint":null,"height":325,"link":null,"startArrowhead":null,"strokeColor":"#FF7B72","fillStyle":"solid","groupIds":[],"endBinding":null,"versionNonce":1667981179,"frameId":null,"boundElements":[],"x":-551.5,"angle":0,"y":-1288.5,"width":49},{"isDeleted":false,"locked":false,"strokeColor":"#FF7B72","link":null,"roughness":1,"groupIds":[],"index":"b5k","backgroundColor":"#1a0505","angle":0,"fillStyle":"solid","strokeWidth":2,"version":7,"roundness":{"type":3},"type":"rectangle","updated":1772977438387,"id":"waVLNlaoxBYLRbrAtMeER","x":-382,"seed":342342261,"boundElements":[],"y":-963,"opacity":100,"height":118,"width":345,"frameId":null,"strokeStyle":"solid","versionNonce":1662560693},{"seed":1557308373,"strokeStyle":"solid","id":"YuBLh_-LQJdgXklfbgJhX","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1772977438387,"locked":false,"text":"Presence Heartbeat Write Storm","version":7,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b5l","roundness":null,"containerId":null,"originalText":"Presence Heartbeat Write Storm","height":18.75,"link":null,"strokeColor":"#FF7B72","fillStyle":"solid","groupIds":[],"versionNonce":2003286043,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-362,"angle":0,"y":-947,"width":236.36982727050781},{"seed":517562677,"strokeStyle":"solid","id":"Nx6rHKu4RO4-_XozWjyCX","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772977438387,"locked":false,"text":"Threshold: > 1M concurrent users\nCause: 10M users \/ 30s heartbeat =\n333K presence writes\/sec competing\nwith message writes on same DB.\nCategory: I\/O-bound + Coordination-bound","version":7,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b5m","roundness":null,"containerId":null,"originalText":"Threshold: > 1M concurrent users\nCause: 10M users \/ 30s heartbeat =\n333K presence writes\/sec competing\nwith message writes on same DB.\nCategory: I\/O-bound + Coordination-bound","height":81.25,"link":null,"strokeColor":"#F8F8F2","fillStyle":"solid","groupIds":[],"versionNonce":1579395861,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-362,"angle":0,"y":-925,"width":271.49169921875},{"seed":1608610453,"strokeStyle":"dashed","id":"BQxaRp_Y3-nmvdGzMYHND","strokeWidth":1,"roughness":1,"isDeleted":false,"startBinding":null,"endArrowhead":"arrow","opacity":100,"updated":1772977438387,"locked":false,"points":[[0,0],[89,258]],"version":7,"elbowed":false,"type":"arrow","backgroundColor":"transparent","index":"b5n","roundness":null,"lastCommittedPoint":null,"height":258,"link":null,"startArrowhead":null,"strokeColor":"#FF7B72","fillStyle":"solid","groupIds":[],"endBinding":null,"versionNonce":1200618683,"frameId":null,"boundElements":[],"x":-300.5,"angle":0,"y":-1221.5,"width":89},{"isDeleted":false,"locked":false,"strokeColor":"#44475A","link":null,"roughness":1,"groupIds":[],"index":"b5o","backgroundColor":"#161B22","angle":0,"fillStyle":"solid","strokeWidth":2,"version":7,"roundness":{"type":3},"type":"rectangle","updated":1772977438387,"id":"2tS_xwUdrwxNlIMa_ZxML","x":1023,"seed":1554012149,"boundElements":[],"y":-1363,"opacity":100,"height":600,"width":850,"frameId":null,"strokeStyle":"solid","versionNonce":923238517},{"seed":521900373,"strokeStyle":"solid","id":"lUNSI6vaExvUsevdHB-X-","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":16,"opacity":100,"verticalAlign":"top","updated":1772977438387,"locked":false,"text":"The Two Most Critical Bottlenecks","version":7,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b5p","roundness":null,"containerId":null,"originalText":"The Two Most Critical Bottlenecks","height":20,"link":null,"strokeColor":"#FF7B72","fillStyle":"solid","groupIds":[],"versionNonce":1065790811,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1048,"angle":0,"y":-1343,"width":278.11178588867188},{"seed":1420336821,"strokeStyle":"solid","id":"32mQeLBt0UxKUiT0V_tgf","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1772977438387,"locked":false,"text":"#1 — MySQL Write Saturation","version":7,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b5q","roundness":null,"containerId":null,"originalText":"#1 — MySQL Write Saturation","height":18.75,"link":null,"strokeColor":"#F0883E","fillStyle":"solid","groupIds":[],"versionNonce":1669966293,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1048,"angle":0,"y":-1311,"width":220.13984680175781},{"seed":1676476437,"strokeStyle":"solid","id":"qLLq6tMAPG_58lPijA-0W","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772977438387,"locked":false,"text":"InnoDB's durability guarantee requires an fsync()\nto the redo log on every committed transaction.\nOn a single NVMe disk, each fsync costs 0.1-1ms.\nAt 5K msg\/sec that means 5,000 fsyncs\/sec —\nright at the disk's physical ceiling. Beyond this,\nwrites queue inside the InnoDB buffer pool. Write\nlatency climbs from 2ms to 200ms to 2 seconds.\nThe chat server's async send loop stalls waiting\non the DB ACK. Users see the send spinner freeze.\nMessages never show as 'delivered'. After 30 seconds\nclients TCP-timeout and disconnect simultaneously —\ntriggering the thundering herd that kills the LB.\nThis entire cascade takes under 60 seconds.","version":7,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b5r","roundness":null,"containerId":null,"originalText":"InnoDB's durability guarantee requires an fsync()\nto the redo log on every committed transaction.\nOn a single NVMe disk, each fsync costs 0.1-1ms.\nAt 5K msg\/sec that means 5,000 fsyncs\/sec —\nright at the disk's physical ceiling. Beyond this,\nwrites queue inside the InnoDB buffer pool. Write\nlatency climbs from 2ms to 200ms to 2 seconds.\nThe chat server's async send loop stalls waiting\non the DB ACK. Users see the send spinner freeze.\nMessages never show as 'delivered'. After 30 seconds\nclients TCP-timeout and disconnect simultaneously —\ntriggering the thundering herd that kills the LB.\nThis entire cascade takes under 60 seconds.","height":227.5,"link":null,"strokeColor":"#F8F8F2","fillStyle":"solid","groupIds":[],"versionNonce":849234427,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1048,"angle":0,"y":-1287,"width":364.97964477539062},{"seed":1121858933,"strokeStyle":"solid","id":"EnbuBuceoOyvho6XXs5vv","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1772977438387,"locked":false,"text":"#2 — Redis Pub\/Sub Fan-out CPU Saturation","version":7,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b5s","roundness":null,"containerId":null,"originalText":"#2 — Redis Pub\/Sub Fan-out CPU Saturation","height":18.75,"link":null,"strokeColor":"#1ABC9C","fillStyle":"solid","groupIds":[],"versionNonce":79669045,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1048,"angle":0,"y":-1051,"width":339.32977294921875},{"seed":214023893,"strokeStyle":"solid","id":"RuP2FQkp6N8GOfKTXIR8B","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772977438387,"locked":false,"text":"Redis pub\/sub is elegantly simple but fatally naive\nat scale: every SUBSCRIBE receives every PUBLISH\non that channel — regardless of relevance. With 10\nchat servers all subscribed to all channels, each\npublish fans out 10x. At 500K msg\/sec that is 5M\ndispatch operations\/sec through Redis's single-\nthreaded event loop. Redis pegs at 100% on one CPU\ncore, its internal pub\/sub queue grows unbounded,\nand fan-out latency explodes from microseconds to\nseconds. Worse: the drain is uneven — some servers\nreceive batches of 50 messages at once. The user\nsees messages arrive in sudden bursts, wildly out\nof order. This is deeply disorienting and unfixable\nwithout replacing pub\/sub with Kafka partitions.","version":7,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b5t","roundness":null,"containerId":null,"originalText":"Redis pub\/sub is elegantly simple but fatally naive\nat scale: every SUBSCRIBE receives every PUBLISH\non that channel — regardless of relevance. With 10\nchat servers all subscribed to all channels, each\npublish fans out 10x. At 500K msg\/sec that is 5M\ndispatch operations\/sec through Redis's single-\nthreaded event loop. Redis pegs at 100% on one CPU\ncore, its internal pub\/sub queue grows unbounded,\nand fan-out latency explodes from microseconds to\nseconds. Worse: the drain is uneven — some servers\nreceive batches of 50 messages at once. The user\nsees messages arrive in sudden bursts, wildly out\nof order. This is deeply disorienting and unfixable\nwithout replacing pub\/sub with Kafka partitions.","height":245,"link":null,"strokeColor":"#F8F8F2","fillStyle":"solid","groupIds":[],"versionNonce":1708741275,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1048,"angle":0,"y":-1027,"width":369.33349609375},{"isDeleted":false,"locked":false,"strokeColor":"transparent","link":null,"roughness":1,"groupIds":[],"index":"b5u","backgroundColor":"#0D1117","angle":0,"fillStyle":"solid","strokeWidth":2,"version":5,"roundness":null,"type":"rectangle","updated":1772977438387,"id":"h8AVFk0FhWnZXirv_E61v","x":-1007,"seed":1479351349,"boundElements":[],"y":-651,"opacity":100,"height":1338,"width":3000,"frameId":null,"strokeStyle":"solid","versionNonce":2098133141},{"isDeleted":false,"locked":false,"strokeColor":"transparent","link":null,"roughness":1,"groupIds":[],"index":"b5v","backgroundColor":"#111827","angle":0,"fillStyle":"solid","strokeWidth":2,"version":5,"roundness":null,"type":"rectangle","updated":1772977438387,"id":"iS1_LgwuIE-v9-NwZQNsf","x":-1007,"seed":1292225941,"boundElements":[],"y":687,"opacity":100,"height":80,"width":3000,"frameId":null,"strokeStyle":"solid","versionNonce":1508525883},{"isDeleted":false,"locked":false,"strokeColor":"transparent","link":null,"roughness":1,"groupIds":[],"index":"b5w","backgroundColor":"#161B22","angle":0,"fillStyle":"solid","strokeWidth":2,"version":5,"roundness":null,"type":"rectangle","updated":1772977438387,"id":"UxUZfwj0PukLZOMwt1DUV","x":-1007,"seed":2055295733,"boundElements":[],"y":-651,"opacity":100,"height":60,"width":3000,"frameId":null,"strokeStyle":"solid","versionNonce":1177361909},{"isDeleted":false,"locked":false,"strokeColor":"transparent","link":null,"roughness":1,"groupIds":[],"index":"b5x","backgroundColor":"#BC8CFF","angle":0,"fillStyle":"solid","strokeWidth":2,"version":6,"roundness":null,"type":"ellipse","updated":1772977438387,"id":"Jp06Bg