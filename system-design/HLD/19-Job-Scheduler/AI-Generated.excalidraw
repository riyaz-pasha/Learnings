XPx4EvZvLgxyQGMbkwHd","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":11,"opacity":100,"verticalAlign":"middle","updated":1773066850109,"locked":false,"text":"write exec_log","version":7,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bBN","roundness":null,"containerId":"JGy4IeBv4B1wKkqYlsI3E","originalText":"write exec_log","height":13.75,"link":null,"strokeColor":"#C47B3A","fillStyle":"solid","groupIds":[],"versionNonce":369240787,"textAlign":"center","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-2127.9290008544922,"angle":0,"y":3029.08984375,"width":77.858001708984375},{"seed":202625373,"strokeStyle":"dashed","id":"5Va_R2Cfhr_rJAxiPQxIk","strokeWidth":1,"roughness":1,"isDeleted":false,"startBinding":null,"endArrowhead":null,"opacity":100,"updated":1773066850103,"locked":false,"points":[[0,0],[0,1100]],"polygon":false,"version":5,"type":"line","backgroundColor":"transparent","index":"bBO","roundness":null,"lastCommittedPoint":null,"height":1100,"link":null,"startArrowhead":null,"strokeColor":"#2A2D3A","fillStyle":"solid","groupIds":[],"endBinding":null,"versionNonce":159613619,"frameId":null,"boundElements":[],"x":-464,"angle":0,"y":2307.96484375,"width":0},{"isDeleted":false,"locked":false,"strokeColor":"#2A2D3A","link":null,"roughness":1,"groupIds":[],"index":"bBP","backgroundColor":"#1E2030","angle":0,"fillStyle":"solid","strokeWidth":1.5,"version":5,"roundness":{"type":3},"type":"rectangle","updated":1773066850103,"id":"KFM9SJvBeEs4JP6sJ4FHR","x":-444,"seed":1336647101,"boundElements":[],"y":2307.96484375,"opacity":100,"height":1100,"width":920,"frameId":null,"strokeStyle":"solid","versionNonce":1685157373},{"seed":2068504093,"strokeStyle":"solid","id":"mBfDDaJ5A3p8HMXRyMDCu","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1773066850103,"locked":false,"text":"Complete Request Lifecycle","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bBQ","roundness":null,"containerId":null,"originalText":"Complete Request Lifecycle","height":18.75,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":1845933139,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-428,"angle":0,"y":2325.96484375,"width":197.92485046386719},{"seed":98767485,"strokeStyle":"solid","id":"3TRa_od4ztQSmWyuSvaAT","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1773066850103,"locked":false,"text":"A client (Web, CLI, or Service SDK) sends HTTP POST \/jobs to\nthe Global Load Balancer, which routes to Region A. The API\nGateway enforces per-tenant rate limits via leaky bucket, then\nforwards to one of 5 stateless API servers. The API server\nvalidates the cron expression and timezone, resolves the first\nnext_fire_time, and writes the job definition to Postgres Primary.\nThe Postgres write is synchronously replicated to both read\nreplicas before ack is returned to the client. The scheduler\nnodes continuously load job definitions from their assigned\npartitions via Postgres read replicas into the in-memory\ntime-wheel. On every 1-second tick, each scheduler checks its\ntime-wheel bucket for due jobs. For each due job it calls\nRedis SET NX (idempotency lock). The winner publishes a dispatch\nmessage to Kafka topic dispatch.jobs on partition job_id mod 32.\nThe Worker Pool consumer group dequeues the message, enforces\nthe semaphore concurrency limit, executes the job payload, and\nwrites the execution result to Cassandra. If a job exceeds\nmax_retries=5, the message is routed to the dispatch.dlq topic\nfor operator inspection.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bBR","roundness":null,"containerId":null,"originalText":"A client (Web, CLI, or Service SDK) sends HTTP POST \/jobs to\nthe Global Load Balancer, which routes to Region A. The API\nGateway enforces per-tenant rate limits via leaky bucket, then\nforwards to one of 5 stateless API servers. The API server\nvalidates the cron expression and timezone, resolves the first\nnext_fire_time, and writes the job definition to Postgres Primary.\nThe Postgres write is synchronously replicated to both read\nreplicas before ack is returned to the client. The scheduler\nnodes continuously load job definitions from their assigned\npartitions via Postgres read replicas into the in-memory\ntime-wheel. On every 1-second tick, each scheduler checks its\ntime-wheel bucket for due jobs. For each due job it calls\nRedis SET NX (idempotency lock). The winner publishes a dispatch\nmessage to Kafka topic dispatch.jobs on partition job_id mod 32.\nThe Worker Pool consumer group dequeues the message, enforces\nthe semaphore concurrency limit, executes the job payload, and\nwrites the execution result to Cassandra. If a job exceeds\nmax_retries=5, the message is routed to the dispatch.dlq topic\nfor operator inspection.","height":308.75,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":1647029853,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-428,"angle":0,"y":2349.96484375,"width":422.0965576171875},{"seed":204847837,"strokeStyle":"solid","id":"8_-5INs84mvRdtxlFgzwq","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1773066850103,"locked":false,"text":"Failover Runbook","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bBS","roundness":null,"containerId":null,"originalText":"Failover Runbook","height":18.75,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":1785901555,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-428,"angle":0,"y":2643.96484375,"width":123.41993713378906},{"seed":383014717,"strokeStyle":"solid","id":"ARWWXimqefE1_WhJoAWsP","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1773066850103,"locked":false,"text":"When Region A becomes unavailable: the Global Load Balancer\ndetects health-check failure within 10 seconds and switches\n100% of traffic to Region B. The Region B Postgres WAL replica\nis promoted to primary (promoted via pg_promote()). The standby\nscheduler nodes in Region B detect the Postgres promotion and\nclaim their partitions via ZooKeeper (B has its own ensemble).\nThey scan the newly-promoted Postgres for due jobs and load\ntheir time-wheels. The Kafka Mirror already has all messages\nfrom the last checkpoint. Because WAL replication has ~100ms\nlag, up to 100ms of job definitions written just before the\nfailure may not have made it to Region B -- these are the only\njobs that could be silently lost.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bBT","roundness":null,"containerId":null,"originalText":"When Region A becomes unavailable: the Global Load Balancer\ndetects health-check failure within 10 seconds and switches\n100% of traffic to Region B. The Region B Postgres WAL replica\nis promoted to primary (promoted via pg_promote()). The standby\nscheduler nodes in Region B detect the Postgres promotion and\nclaim their partitions via ZooKeeper (B has its own ensemble).\nThey scan the newly-promoted Postgres for due jobs and load\ntheir time-wheels. The Kafka Mirror already has all messages\nfrom the last checkpoint. Because WAL replication has ~100ms\nlag, up to 100ms of job definitions written just before the\nfailure may not have made it to Region B -- these are the only\njobs that could be silently lost.","height":195,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":817879741,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-428,"angle":0,"y":2667.96484375,"width":420.75750732421875},{"seed":538994589,"strokeStyle":"solid","id":"JERIayRAtC9dmMXPz44P_","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1773066850103,"locked":false,"text":"Most Latency-Sensitive Path","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bBU","roundness":null,"containerId":null,"originalText":"Most Latency-Sensitive Path","height":18.75,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":533592979,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-428,"angle":0,"y":2891.96484375,"width":211.90484619140625},{"seed":1514892285,"strokeStyle":"solid","id":"Wi8YPKAKmVoIHrvjngUjP","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1773066850103,"locked":false,"text":"The Scheduler-to-Redis SET NX call is the most latency-sensitive\ncross-component interaction in the entire system. It cannot be\nmade asynchronous because the lock acquisition and the Kafka\npublish must be causally ordered: if Redis is called async, two\nscheduler nodes can both proceed to publish before either\nreceives a NX=0 rejection, breaking the exactly-once guarantee.\nThis synchronous call adds 2ms per dispatch and is the primary\nreason Redis must be co-located in the same AZ as the scheduler\nnodes. Moving it cross-AZ would add 5-20ms per fire event,\npushing the p99 dispatch path beyond the 1-second target.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bBV","roundness":null,"containerId":null,"originalText":"The Scheduler-to-Redis SET NX call is the most latency-sensitive\ncross-component interaction in the entire system. It cannot be\nmade asynchronous because the lock acquisition and the Kafka\npublish must be causally ordered: if Redis is called async, two\nscheduler nodes can both proceed to publish before either\nreceives a NX=0 rejection, breaking the exactly-once guarantee.\nThis synchronous call adds 2ms per dispatch and is the primary\nreason Redis must be co-located in the same AZ as the scheduler\nnodes. Moving it cross-AZ would add 5-20ms per fire event,\npushing the p99 dispatch path beyond the 1-second target.","height":162.5,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":147815197,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-428,"angle":0,"y":2915.96484375,"width":419.39254760742188},{"isDeleted":false,"locked":false,"strokeColor":"#2A2D3A","link":null,"roughness":1,"groupIds":[],"index":"bBW","backgroundColor":"#252838","angle":0,"fillStyle":"solid","strokeWidth":1,"version":5,"roundness":{"type":3},"type":"rectangle","updated":1773066850103,"id":"atSZU6-gYC9qn1IN_7Lef","x":-428,"seed":894887005,"boundElements":[],"y":3115.96484375,"opacity":100,"height":80,"width":888,"frameId":null,"strokeStyle":"solid","versionNonce":1246695731},{"seed":622088381,"strokeStyle":"solid","id":"ijJegdsCh8n59cZC8hWgT","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1773066850103,"locked":false,"text":"Key insight: Region B is not a warm spare -- it is a cold replica\nthat must execute a 10-step promotion sequence under pressure.\nThe 100ms WAL lag is the only irrecoverable data loss window;\nevery other failure mode is recoverable without data loss\nbecause Kafka messages are replicated synchronously (RF=3).","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bBX","roundness":null,"containerId":null,"originalText":"Key insight: Region B is not a warm spare -- it is a cold replica\nthat must execute a 10-step promotion sequence under pressure.\nThe 100ms WAL lag is the only irrecoverable data loss window;\nevery other failure mode is recoverable without data loss\nbecause Kafka messages are replicated synchronously 