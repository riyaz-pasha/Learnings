75,"opacity":100,"height":36,"width":130,"frameId":null,"strokeStyle":"solid","versionNonce":860825597},{"seed":289456669,"strokeStyle":"solid","id":"poP1L0pfP6pxnfv3wIzdH","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":11,"opacity":100,"verticalAlign":"middle","updated":1773066850111,"locked":false,"text":"Silent drop","version":7,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bCy","roundness":null,"containerId":"skbns4KgVhfZu1dv_4IwV","originalText":"Silent drop","height":13.75,"link":null,"strokeColor":"#C45C5C","fillStyle":"solid","groupIds":[],"versionNonce":966635187,"textAlign":"center","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-1323.9354991912842,"angle":0,"y":3985.08984375,"width":57.870998382568359},{"seed":729577085,"strokeStyle":"solid","id":"I_F4LPlSBTINNfthkZsEf","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":12,"opacity":100,"verticalAlign":"top","updated":1773066850103,"locked":false,"text":"Key: SHA256(job_id:scheduled_at_ms)\nTTL=5m covers all retry attempts","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bCz","roundness":null,"containerId":null,"originalText":"Key: SHA256(job_id:scheduled_at_ms)\nTTL=5m covers all retry attempts","height":30,"link":null,"strokeColor":"#7EC8A4","fillStyle":"solid","groupIds":[],"versionNonce":780345437,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-1540,"angle":0,"y":4019.96484375,"width":223.77569580078125},{"seed":16948957,"strokeStyle":"dashed","id":"epKR4Paz8ooG96OGzd55r","strokeWidth":1,"roughness":1,"isDeleted":false,"startBinding":null,"endArrowhead":null,"opacity":100,"updated":1773066850103,"locked":false,"points":[[0,0],[0,700]],"polygon":false,"version":5,"type":"line","backgroundColor":"transparent","index":"bD0","roundness":null,"lastCommittedPoint":null,"height":700,"link":null,"startArrowhead":null,"strokeColor":"#2A2D3A","fillStyle":"solid","groupIds":[],"endBinding":null,"versionNonce":1191403507,"frameId":null,"boundElements":[],"x":-464,"angle":0,"y":3587.96484375,"width":0},{"isDeleted":false,"locked":false,"strokeColor":"#2A2D3A","link":null,"roughness":1,"groupIds":[],"index":"bD1","backgroundColor":"#1E2030","angle":0,"fillStyle":"solid","strokeWidth":1.5,"version":5,"roundness":{"type":3},"type":"rectangle","updated":1773066850103,"id":"1jqAO3gA36gpPuYpFqkzW","x":-444,"seed":677690173,"boundElements":[],"y":3587.96484375,"opacity":100,"height":700,"width":920,"frameId":null,"strokeStyle":"solid","versionNonce":626592957},{"seed":1778666397,"strokeStyle":"solid","id":"dXPZsp0I_YwBVWj-uVfl9","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1773066850103,"locked":false,"text":"Retry Strategy","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bD2","roundness":null,"containerId":null,"originalText":"Retry Strategy","height":18.75,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":1108928915,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-428,"angle":0,"y":3605.96484375,"width":111.98992919921875},{"seed":101896189,"strokeStyle":"solid","id":"Q6yTxlbA5HOMsINfDOk4m","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1773066850103,"locked":false,"text":"The retry backoff formula is min(base x 2^attempt + jitter, 300s)\nwhere base=1s and jitter is a random fraction of the current delay\ncap. Jitter is essential: without it, all retrying workers\nsynchronize their retry attempts and create a coordinated\nstampede that hits the downstream system at exactly the same\nmoments. The 300-second cap prevents indefinite wait accumulation.\nAfter 5 attempts the total elapsed time is 1+2+4+8+16=31 seconds,\nwell within the window where the DLQ message is still actionable\nfor ops. The base of 1 second was chosen because it matches\nthe scheduler tick interval: a worker that fails and retries\nwill not conflict with the scheduler attempting to re-dispatch\nthe same job in the next tick (the Redis lock TTL of 5 minutes\nis far longer than the entire retry sequence).","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bD3","roundness":null,"containerId":null,"originalText":"The retry backoff formula is min(base x 2^attempt + jitter, 300s)\nwhere base=1s and jitter is a random fraction of the current delay\ncap. Jitter is essential: without it, all retrying workers\nsynchronize their retry attempts and create a coordinated\nstampede that hits the downstream system at exactly the same\nmoments. The 300-second cap prevents indefinite wait accumulation.\nAfter 5 attempts the total elapsed time is 1+2+4+8+16=31 seconds,\nwell within the window where the DLQ message is still actionable\nfor ops. The base of 1 second was chosen because it matches\nthe scheduler tick interval: a worker that fails and retries\nwill not conflict with the scheduler attempting to re-dispatch\nthe same job in the next tick (the Redis lock TTL of 5 minutes\nis far longer than the entire retry sequence).","height":211.25,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":930245917,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-428,"angle":0,"y":3629.96484375,"width":434.70651245117188},{"seed":982632541,"strokeStyle":"solid","id":"np_cWp4MfxEX7ZMkhM4nq","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1773066850103,"locked":false,"text":"Dead Letter Queue Policy","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bD4","roundness":null,"containerId":null,"originalText":"Dead Letter Queue Policy","height":18.75,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":17579827,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-428,"angle":0,"y":3865.96484375,"width":188.12986755371094},{"seed":156415165,"strokeStyle":"solid","id":"vWiUSBwwFNwmnrHypjjac","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1773066850103,"locked":false,"text":"The DLQ trigger fires when max_retries=5 is exhausted. The worker\npublishes the original message plus a failure_context blob\n(error_msg, attempt_count, last_worker_id) to the dispatch.dlq\ntopic. PagerDuty alert fires immediately. The ops procedure is:\nread the DLQ consumer, inspect error_msg to classify root cause\n(user code bug vs infrastructure vs bad payload), fix the\nunderlying issue, then replay via resetting the consumer group\noffset on the DLQ topic. DLQ messages expire after 7 days.\nOps must never blindly replay without root-cause analysis --\nreplaying a job with a bug simply fills the DLQ again.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bD5","roundness":null,"containerId":null,"originalText":"The DLQ trigger fires when max_retries=5 is exhausted. The worker\npublishes the original message plus a failure_context blob\n(error_msg, attempt_count, last_worker_id) to the dispatch.dlq\ntopic. PagerDuty alert fires immediately. The ops procedure is:\nread the DLQ consumer, inspect error_msg to classify root cause\n(user code bug vs infrastructure vs bad payload), fix the\nunderlying issue, then replay via resetting the consumer group\noffset on the DLQ topic. DLQ messages expire after 7 days.\nOps must never blindly replay without root-cause analysis --\nreplaying a job with a bug simply fills the DLQ again.","height":162.5,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":339788157,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-428,"angle":0,"y":3889.96484375,"width":437.42352294921875},{"seed":1039602973,"strokeStyle":"solid","id":"bqZkO2KYwvZp3AOxJ-p_T","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1773066850103,"locked":false,"text":"Idempotency Implementation","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bD6","roundness":null,"containerId":null,"originalText":"Idempotency Implementation","height":18.75,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":1581506771,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-428,"angle":0,"y":4051.96484375,"width":207.32987976074219},{"seed":871393661,"strokeStyle":"solid","id":"ztARQE4s5V6Z0vv22-Jct","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1773066850103,"locked":false,"text":"The idempotency key is SHA256(job_id + \":\" + scheduled_at_epoch_ms).\nThis is stored in Redis as idem:{hash} with TTL=5 minutes.\nThe 5-minute TTL is chosen to cover the entire retry sequence\n(max 31 seconds) plus a safety margin. The hash is computed\nbefore the Redis call so a scheduler crash between hash-compute\nand Redis-call is safe: on recovery the same hash is computed\nagain. The Cassandra execution_log table has a secondary UNIQUE\nconstraint on idempotency_key as a durable second defense in case\nRedis loses the key due to a restart or eviction.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bD7","roundness":null,"containerId":null,"originalText":"The idempotency key is SHA256(job_id + \":\" + scheduled_at_epoch_ms).\nThis is stored in Redis as idem:{hash} with TTL=5 minutes.\nThe 5-minute TTL is chosen to cover the entire retry sequence\n(max 31 seconds) plus a safety margin. The hash is computed\nbefore the Redis call so a scheduler crash between hash-compute\nand Redis-call is safe: on recovery the same hash is computed\nagain. The Cassandra execution_log table has a secondary UNIQUE\nconstraint on idempotency_key as a durable second defense in case\nRedis loses the key due to a restart or eviction.","height":146.25,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":17140189,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-428,"angle":0,"y":4075.96484375,"width":458.36651611328125},{"isDeleted":false,"locked":false,"strokeColor":"#2A2D3A","link":null,"roughness":1,"groupIds":[],"index":"bD8","backgroundColor":"#252838","angle":0,"fillStyle":"solid","strokeWidth":1,"version":5,"roundness":{"type":3},"type":"rectangle","updated":1773066850103,"id":"wajHbtri5qLYVlPJMjhuU","x":-428,"seed":1551905245,"boundElements":[],"y":4215.96484375,"opacity":100,"height":62,"width":888,"frameId":null,"strokeStyle":"solid","versionNonce":592858739},{"seed":79162941,"strokeStyle":"solid","id":"ZCwGE2wEFiH4NEVm92W3z","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1773066850103,"locked":false,"text":"Key insight: Jitter is not optional. Without it, all retrying workers\nsynchronize and stampede together. The Redis TTL of 5 minutes\nis the single most important tuning parameter -- too short\nallows duplicates; too long wastes memory on stale keys.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bD9","roundness":null,"containerId":null,"originalText":"Key insight: Jitter is not optional. Without it, all retrying workers\nsynchronize and stampede together. The Redis TTL of 5 minutes\nis the single most important tuning parameter -- too short\nallows duplicates; too long wastes memory on stale keys.","height":65,"link":null,"strokeColor":"#9AA0B4","fillStyle":"solid","groupIds":[],"versionNonce":517097021,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-418,"angle":0,"y":4225.964843