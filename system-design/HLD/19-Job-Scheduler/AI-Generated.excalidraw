,"updated":1773066850100,"id":"dluecVK31L7yjNs7YlKBM","x":-2356,"seed":1691191709,"boundElements":[],"y":5371.96484375,"opacity":100,"height":32,"width":580,"frameId":null,"strokeStyle":"solid","versionNonce":1071590067},{"seed":285494781,"strokeStyle":"solid","id":"FZeOQWgOxfK_HrD0_xDTh","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1773066850100,"locked":false,"text":"Scale Strategy - How 10x Load Is Handled","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bEL","roundness":null,"containerId":null,"originalText":"Scale Strategy - How 10x Load Is Handled","height":16.25,"link":null,"strokeColor":"#4D9E7C","fillStyle":"solid","groupIds":[],"versionNonce":716004435,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-2340,"angle":0,"y":5381.96484375,"width":267.5396728515625},{"seed":648250973,"strokeStyle":"solid","id":"Z867fSf_T7e0wbhS9BPW2","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":12,"opacity":100,"verticalAlign":"top","updated":1773066850100,"locked":false,"text":"Increase schedulers (3 -> 9); each owns smaller partition shard.\nIncrease Kafka partitions (32 -> 128) and workers (32 -> 128).\nCassandra scales horizontally: add nodes, rebalance token ring.\nRedis cluster shards idempotency keyspace across more nodes.\nStateless API servers scale horizontally behind the LB.\nTime-wheel RAM grows linearly with jobs per node partition.\nNo architectural changes required up to ~1B registered jobs.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bEM","roundness":null,"containerId":null,"originalText":"Increase schedulers (3 -> 9); each owns smaller partition shard.\nIncrease Kafka partitions (32 -> 128) and workers (32 -> 128).\nCassandra scales horizontally: add nodes, rebalance token ring.\nRedis cluster shards idempotency keyspace across more nodes.\nStateless API servers scale horizontally behind the LB.\nTime-wheel RAM grows linearly with jobs per node partition.\nNo architectural changes required up to ~1B registered jobs.","height":105,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":738482675,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-2340,"angle":0,"y":5415.96484375,"width":374.2073974609375},{"isDeleted":false,"locked":false,"strokeColor":"#2A2D3A","link":null,"roughness":1,"groupIds":[],"index":"bEN","backgroundColor":"#1E2030","angle":0,"fillStyle":"solid","strokeWidth":1.5,"version":5,"roundness":{"type":3},"type":"rectangle","updated":1773066850100,"id":"vKfnXJviaV-lh1Qb-wJBM","x":-1756,"seed":1216131773,"boundElements":[],"y":5371.96484375,"opacity":100,"height":220,"width":580,"frameId":null,"strokeStyle":"solid","versionNonce":283812755},{"isDeleted":false,"locked":false,"strokeColor":"#2A2D3A","link":null,"roughness":1,"groupIds":[],"index":"bEO","backgroundColor":"#252838","angle":0,"fillStyle":"solid","strokeWidth":1,"version":5,"roundness":null,"type":"rectangle","updated":1773066850100,"id":"P00nNOQgsh3wUkXRHia67","x":-1756,"seed":1127306013,"boundElements":[],"y":5371.96484375,"opacity":100,"height":32,"width":580,"frameId":null,"strokeStyle":"solid","versionNonce":1100396851},{"seed":1395844989,"strokeStyle":"solid","id":"HofraXBpgsst3qjUJ78GO","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1773066850100,"locked":false,"text":"Reliability Strategy - How 99.99% Is Achieved","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bEP","roundness":null,"containerId":null,"originalText":"Reliability Strategy - How 99.99% Is Achieved","height":16.25,"link":null,"strokeColor":"#4D9E7C","fillStyle":"solid","groupIds":[],"versionNonce":1534008019,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-1740,"angle":0,"y":5381.96484375,"width":293.73468017578125},{"seed":717418461,"strokeStyle":"solid","id":"dqFtoPlxx5O_xup-70IN8","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":12,"opacity":100,"verticalAlign":"top","updated":1773066850100,"locked":false,"text":"ZooKeeper takeover in 3s on scheduler crash.\nRedis SET NX prevents double-fire across all nodes.\nKafka RF=3 survives 2 broker failures without data loss.\nCassandra RF=3 survives 2 node failures without data loss.\nPostgres primary + 2 sync replicas; failover in <30s.\nRegion B promotes in <10s on region-level failure.\nWorker semaphore bounds concurrency; DLQ captures all failures.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bEQ","roundness":null,"containerId":null,"originalText":"ZooKeeper takeover in 3s on scheduler crash.\nRedis SET NX prevents double-fire across all nodes.\nKafka RF=3 survives 2 broker failures without data loss.\nCassandra RF=3 survives 2 node failures without data loss.\nPostgres primary + 2 sync replicas; failover in <30s.\nRegion B promotes in <10s on region-level failure.\nWorker semaphore bounds concurrency; DLQ captures all failures.","height":105,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":185223283,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-1740,"angle":0,"y":5415.96484375,"width":376.8353271484375},{"isDeleted":false,"locked":false,"strokeColor":"#2A2D3A","link":null,"roughness":1,"groupIds":[],"index":"bER","backgroundColor":"#1E2030","angle":0,"fillStyle":"solid","strokeWidth":1.5,"version":5,"roundness":{"type":3},"type":"rectangle","updated":1773066850100,"id":"F3vXEGqGPrKKVM5ubAXkH","x":-2356,"seed":938667069,"boundElements":[],"y":5611.96484375,"opacity":100,"height":210,"width":580,"frameId":null,"strokeStyle":"solid","versionNonce":640598547},{"isDeleted":false,"locked":false,"strokeColor":"#2A2D3A","link":null,"roughness":1,"groupIds":[],"index":"bES","backgroundColor":"#252838","angle":0,"fillStyle":"solid","strokeWidth":1,"version":5,"roundness":null,"type":"rectangle","updated":1773066850100,"id":"wqxM54QqNSZlAbIR50nAf","x":-2356,"seed":715414685,"boundElements":[],"y":5611.96484375,"opacity":100,"height":32,"width":580,"frameId":null,"strokeStyle":"solid","versionNonce":97716147},{"seed":982040829,"strokeStyle":"solid","id":"IpOJmMrETBf7GrIeZSLiV","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1773066850100,"locked":false,"text":"Top 3 Hardest Problems and Solutions","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bET","roundness":null,"containerId":null,"originalText":"Top 3 Hardest Problems and Solutions","height":16.25,"link":null,"strokeColor":"#4D9E7C","fillStyle":"solid","groupIds":[],"versionNonce":538810707,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-2340,"angle":0,"y":5621.96484375,"width":243.25570678710938},{"seed":757176669,"strokeStyle":"solid","id":"SwntQS-lcomtQ4JN8uONO","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":12,"opacity":100,"verticalAlign":"top","updated":1773066850100,"locked":false,"text":"1. Exactly-once under scheduler failover\n   Redis SET NX + Cassandra UNIQUE idempotency_key\n\n2. Scheduler SPOF and O(N) Postgres poll\n   3 partitioned nodes + in-memory time-wheel O(1)\n\n3. Restart stampede flooding worker pool\n   Leaky-bucket per tenant + worker semaphore\n   + Redis lock blocks re-dispatch of already-fired jobs","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bEU","roundness":null,"containerId":null,"originalText":"1. Exactly-once under scheduler failover\n   Redis SET NX + Cassandra UNIQUE idempotency_key\n\n2. Scheduler SPOF and O(N) Postgres poll\n   3 partitioned nodes + in-memory time-wheel O(1)\n\n3. Restart stampede flooding worker pool\n   Leaky-bucket per tenant + worker semaphore\n   + Redis lock blocks re-dispatch of already-fired jobs","height":135,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":1650783987,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-2340,"angle":0,"y":5655.96484375,"width":328.85952758789062},{"isDeleted":false,"locked":false,"strokeColor":"#2A2D3A","link":null,"roughness":1,"groupIds":[],"index":"bEV","backgroundColor":"#1E2030","angle":0,"fillStyle":"solid","strokeWidth":1.5,"version":5,"roundness":{"type":3},"type":"rectangle","updated":1773066850100,"id":"QcvuCgDGxzvaC--7MyE-H","x":-1756,"seed":465593789,"boundElements":[],"y":5611.96484375,"opacity":100,"height":210,"width":580,"frameId":null,"strokeStyle":"solid","versionNonce":1261412499},{"isDeleted":false,"locked":false,"strokeColor":"#2A2D3A","link":null,"roughness":1,"groupIds":[],"index":"bEW","backgroundColor":"#252838","angle":0,"fillStyle":"solid","strokeWidth":1,"version":5,"roundness":null,"type":"rectangle","updated":1773066850100,"id":"ds36UY4Axld9afxOCefK6","x":-1756,"seed":2038867485,"boundElements":[],"y":5611.96484375,"opacity":100,"height":32,"width":580,"frameId":null,"strokeStyle":"solid","versionNonce":1144264243},{"seed":1499847293,"strokeStyle":"solid","id":"uSifnfORMBAMWRwETilff","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1773066850100,"locked":false,"text":"Key Numbers - Memorize These 5","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bEX","roundness":null,"containerId":null,"originalText":"Key Numbers - Memorize These 5","height":16.25,"link":null,"strokeColor":"#4D9E7C","fillStyle":"solid","groupIds":[],"versionNonce":1012455379,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-1740,"angle":0,"y":5621.96484375,"width":207.36273193359375},{"seed":1948222173,"strokeStyle":"solid","id":"YUxaUibF-sT4G0W-KW