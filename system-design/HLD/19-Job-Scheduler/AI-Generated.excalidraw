left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-1760,"angle":0,"y":5017.96484375,"width":312.74349975585938},{"seed":1448534941,"strokeStyle":"solid","id":"H7mo_k3YuUFYNANo-ld_8","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":12,"opacity":100,"verticalAlign":"top","updated":1773066850103,"locked":false,"text":"         on the hot scheduler tick path","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bE4","roundness":null,"containerId":null,"originalText":"         on the hot scheduler tick path","height":15,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":1464262035,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-1760,"angle":0,"y":5035.96484375,"width":223.77555847167969},{"seed":2085775357,"strokeStyle":"solid","id":"KRN5dom77zj43xpxPamwM","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":12,"opacity":100,"verticalAlign":"top","updated":1773066850103,"locked":false,"text":"Costs:   Lost on crash; must re-scan Postgres on start","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bE5","roundness":null,"containerId":null,"originalText":"Costs:   Lost on crash; must re-scan Postgres on start","height":15,"link":null,"strokeColor":"#C45C5C","fillStyle":"solid","groupIds":[],"versionNonce":1263384861,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-1760,"angle":0,"y":5057.96484375,"width":328.04345703125},{"seed":1964925021,"strokeStyle":"solid","id":"QbLZU5crdmUIa4U4n8nuF","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":12,"opacity":100,"verticalAlign":"top","updated":1773066850103,"locked":false,"text":"Revisit: Job count exceeds available RAM per node","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bE6","roundness":null,"containerId":null,"originalText":"Revisit: Job count exceeds available RAM per node","height":15,"link":null,"strokeColor":"#C4913A","fillStyle":"solid","groupIds":[],"versionNonce":609989427,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-1760,"angle":0,"y":5079.96484375,"width":296.35150146484375},{"seed":1988906173,"strokeStyle":"dashed","id":"Tr98Lrf3-1ix-Z23sIQQS","strokeWidth":1,"roughness":1,"isDeleted":false,"startBinding":null,"endArrowhead":null,"opacity":100,"updated":1773066850103,"locked":false,"points":[[0,0],[0,760]],"polygon":false,"version":5,"type":"line","backgroundColor":"transparent","index":"bE7","roundness":null,"lastCommittedPoint":null,"height":760,"link":null,"startArrowhead":null,"strokeColor":"#2A2D3A","fillStyle":"solid","groupIds":[],"endBinding":null,"versionNonce":651332989,"frameId":null,"boundElements":[],"x":-464,"angle":0,"y":4437.96484375,"width":0},{"isDeleted":false,"locked":false,"strokeColor":"#2A2D3A","link":null,"roughness":1,"groupIds":[],"index":"bE8","backgroundColor":"#1E2030","angle":0,"fillStyle":"solid","strokeWidth":1.5,"version":5,"roundness":{"type":3},"type":"rectangle","updated":1773066850103,"id":"yjCE-Cw65_29MFFBi4PCS","x":-444,"seed":4042013,"boundElements":[],"y":4437.96484375,"opacity":100,"height":760,"width":920,"frameId":null,"strokeStyle":"solid","versionNonce":1334105299},{"seed":564396413,"strokeStyle":"solid","id":"RQSPeEN0PtN61DM_ggb3H","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1773066850103,"locked":false,"text":"The Hardest Trade-off","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bE9","roundness":null,"containerId":null,"originalText":"The Hardest Trade-off","height":18.75,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":2004735453,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-428,"angle":0,"y":4455.96484375,"width":170.11488342285156},{"seed":51677,"strokeStyle":"solid","id":"i5gKO9PRyf5L2y_i_tBGf","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1773066850103,"locked":false,"text":"The most genuinely difficult decision was Active-Passive versus\nActive-Active multi-region. The case for Active-Active is compelling:\neliminating the 10-second failover window, removing the 100ms WAL\nlag data loss, and using Region B capacity productively. But a job\nscheduler is uniquely hostile to Active-Active because its\ncorrectness invariant -- exactly-once execution -- requires global\ncoordination on every single dispatch. Two regions independently\nchecking which jobs are due will independently fire the same job.\nMaking this safe requires distributed consensus on every tick,\nessentially Paxos across regions with 50-150ms cross-region RTT\non every fire event. That single decision pushes p99 trigger\nlatency to 200ms minimum, violating the 1s NFR for the wrong\nreasons. Active-Passive with a fencing token is the correct\ncompromise: it sacrifices utilization to preserve correctness.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bEA","roundness":null,"containerId":null,"originalText":"The most genuinely difficult decision was Active-Passive versus\nActive-Active multi-region. The case for Active-Active is compelling:\neliminating the 10-second failover window, removing the 100ms WAL\nlag data loss, and using Region B capacity productively. But a job\nscheduler is uniquely hostile to Active-Active because its\ncorrectness invariant -- exactly-once execution -- requires global\ncoordination on every single dispatch. Two regions independently\nchecking which jobs are due will independently fire the same job.\nMaking this safe requires distributed consensus on every tick,\nessentially Paxos across regions with 50-150ms cross-region RTT\non every fire event. That single decision pushes p99 trigger\nlatency to 200ms minimum, violating the 1s NFR for the wrong\nreasons. Active-Passive with a fencing token is the correct\ncompromise: it sacrifices utilization to preserve correctness.","height":227.5,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":676905587,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-428,"angle":0,"y":4479.96484375,"width":425.970458984375},{"seed":476415549,"strokeStyle":"solid","id":"RhQ5oV6YCfPARrvZeQf8Y","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1773066850103,"locked":false,"text":"What Most Designs Get Wrong","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bEB","roundness":null,"containerId":null,"originalText":"What Most Designs Get Wrong","height":18.75,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":945885757,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-428,"angle":0,"y":4709.96484375,"width":225.01487731933594},{"seed":1504949917,"strokeStyle":"solid","id":"oqagMOu5r9GjyAkVtHqfH","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1773066850103,"locked":false,"text":"The most common mistake is treating the scheduler as a\nsingle-threaded cron daemon and only distributing the workers.\nThis leaves the scheduler as both a SPOF and a CPU bottleneck.\nCandidates then spend the rest of the interview adding complexity\naround the edges without fixing the root cause. The correct\ninsight is that the scheduler itself must be partitioned: each\nnode owns a disjoint subset of jobs and fires them independently.\nThe second most common mistake is ignoring DST and timezone\nhandling entirely, which causes double-fires or missed fires at\nevery clock-change boundary in every timezone where users register\ncron jobs. These are not edge cases. They are guaranteed\nproduction incidents without explicit IANA timezone handling.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bEC","roundness":null,"containerId":null,"originalText":"The most common mistake is treating the scheduler as a\nsingle-threaded cron daemon and only distributing the workers.\nThis leaves the scheduler as both a SPOF and a CPU bottleneck.\nCandidates then spend the rest of the interview adding complexity\naround the edges without fixing the root cause. The correct\ninsight is that the scheduler itself must be partitioned: each\nnode owns a disjoint subset of jobs and fires them independently.\nThe second most common mistake is ignoring DST and timezone\nhandling entirely, which causes double-fires or missed fires at\nevery clock-change boundary in every timezone where users register\ncron jobs. These are not edge cases. They are guaranteed\nproduction incidents without explicit IANA timezone handling.","height":195,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":1201536019,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-428,"angle":0,"y":4733.96484375,"width":425.87945556640625},{"isDeleted":false,"locked":false,"strokeColor":"#2A2D3A","link":null,"roughness":1,"groupIds":[],"index":"bED","backgroundColor":"#252838","angle":0,"fillStyle":"solid","strokeWidth":1,"version":5,"roundness":{"type":3},"type":"rectangle","updated":1773066850103,"id":"JCu_RQbjAF3wUQDHqsPJS","x":-428,"seed":1117575933,"boundElements":[],"y":4985.96484375,"opacity":100,"height":80,"width":888,"frameId":null,"strokeStyle":"solid","versionNonce":106807965},{"seed":262304605,"strokeStyle":"solid","id":"gH2Z4qNWigze2wH4eKhZA","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1773066850103,"locked":false,"text":"Key insight: Every trade-off reduces to the same tension --\ncorrectness versus availability. Redis over Postgres, active-passive\nover active-active, time-wheel over sorted-set: each accepts a\nspecific narrow failure mode to preserve exactly-once semantics\non the happy path. Correctness always wins in a scheduler.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bEE","roundness":null,"containerId":null,"originalText":"Key insight: Every trade-off reduces to the same tension --\ncorrectness versus availability. Redis over Postgres, active-passive\nover active-active, time-wheel over sorted-set: each accepts a\nspecific narrow failure mode to preserve exactly-once semantics\non the happy path. Correctness always wins in a scheduler.","height":81.25,"link":null,"strokeColor":"#9AA0B4","fillStyle":"solid","groupIds":[],"versionNonce":1766523315,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-418,"angle":0,"y":4995.96484375,"width":425.33343505859375},{"seed":1830158269,"strokeStyle":"dashed","id":"d-QCnqnGAto0sz7sUCKOA","strokeWidth":1,"roughness":1,"isDeleted":false,"startBinding":null,"endArrowhead":null,"opacity":100,"updated":1773066850100,"locked":false,"points":[[0,0],[3000,0]],"polygon":false,"version":5,"type":"line","backgroundColor":"transparent","index":"bEF","roundness":null,"lastCommittedPoint":null,"height":0,"link":null,"startArrowhead":null,"strokeColor":"#2A2D3A","fillStyle":"solid","groupIds":[],"endBinding":null,"versionNonce":387491475,"frameId":null,"boundElements":[],"x":-2424,"angle":0,"y":5277.96484375,"width":3000},{"isDeleted":false,"locked":false,"strokeColor":"#4D9E7C","link":null,"roughness":1,"groupIds":[],"index":"bEG","backgroundColor":"#4D9E7C","angle":0,"fillStyle":"solid","strokeWidth":2,"version":5,"roundness":null,"type":"ellipse","updated":1773066850100,"id":"pXKKVpwKJCwETjo3_zEQf","x":-2402,"seed":18415645,"boundElements":[],"y":5321.96484375,"opacity":100,"height":40,"width":40,"frameId":null,"strokeStyle":"solid","versionNonce":2030