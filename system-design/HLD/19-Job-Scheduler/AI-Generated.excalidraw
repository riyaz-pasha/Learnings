ess":null,"containerId":null,"originalText":"3","height":20,"link":null,"strokeColor":"#5C6B7A","fillStyle":"solid","groupIds":[],"versionNonce":1430866653,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-1640,"angle":0,"y":-2682.03515625,"width":9.727996826171875},{"seed":445428701,"strokeStyle":"solid","id":"BIAHKff_UOWVbRvQer_Q-","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":16,"opacity":100,"verticalAlign":"top","updated":1773066850103,"locked":false,"text":"4","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b3a","roundness":null,"containerId":null,"originalText":"4","height":20,"link":null,"strokeColor":"#C4913A","fillStyle":"solid","groupIds":[],"versionNonce":1995119987,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-1847,"angle":0,"y":-2620.03515625,"width":9.3599853515625},{"seed":300167229,"strokeStyle":"solid","id":"oym7V0Zb9PBcKIR-J_jx7","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":16,"opacity":100,"verticalAlign":"top","updated":1773066850103,"locked":false,"text":"5","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b3b","roundness":null,"containerId":null,"originalText":"5","height":20,"link":null,"strokeColor":"#C4913A","fillStyle":"solid","groupIds":[],"versionNonce":385214269,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-1921,"angle":0,"y":-2532.03515625,"width":9.8879852294921875},{"seed":1036853405,"strokeStyle":"solid","id":"KRZJUv_ANl2sEVfJzb9Z4","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":16,"opacity":100,"verticalAlign":"top","updated":1773066850103,"locked":false,"text":"6","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b3c","roundness":null,"containerId":null,"originalText":"6","height":20,"link":null,"strokeColor":"#4D9E7C","fillStyle":"solid","groupIds":[],"versionNonce":1764554515,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-2131,"angle":0,"y":-2477.03515625,"width":10.239990234375},{"isDeleted":false,"locked":false,"strokeColor":"#4D9E7C","link":null,"roughness":1,"groupIds":[],"index":"b3d","backgroundColor":"#0d1f14","angle":0,"fillStyle":"solid","strokeWidth":1.5,"version":5,"roundness":{"type":3},"type":"rectangle","updated":1773066850103,"id":"4FCJtW1uUJaX4AIGq5nXk","x":-2344,"seed":1945699581,"boundElements":[],"y":-2376.03515625,"opacity":100,"height":180,"width":440,"frameId":null,"strokeStyle":"solid","versionNonce":1167062941},{"seed":1474911581,"strokeStyle":"solid","id":"NyTBrYDDrM0ZBoDW-oXmz","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1773066850103,"locked":false,"text":"Works Well Because...","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b3e","roundness":null,"containerId":null,"originalText":"Works Well Because...","height":17.5,"link":null,"strokeColor":"#4D9E7C","fillStyle":"solid","groupIds":[],"versionNonce":356687027,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-2328,"angle":0,"y":-2360.03515625,"width":143.00987243652344},{"seed":552577469,"strokeStyle":"solid","id":"KRH5H0c8bvN0LT0WduN75","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1773066850103,"locked":false,"text":"Zero coordination overhead -- one node owns\nall scheduling decisions. No distributed lock\nprotocol needed. In-memory priority queue\nfires jobs in O(log N) time. Postgres handles\n500K job definitions with a simple index scan.\nEasy to operate, debug, and reason about.\nCorrect for small teams at low traffic.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b3f","roundness":null,"containerId":null,"originalText":"Zero coordination overhead -- one node owns\nall scheduling decisions. No distributed lock\nprotocol needed. In-memory priority queue\nfires jobs in O(log N) time. Postgres handles\n500K job definitions with a simple index scan.\nEasy to operate, debug, and reason about.\nCorrect for small teams at low traffic.","height":113.75,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":1263074301,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-2328,"angle":0,"y":-2336.03515625,"width":289.4967041015625},{"isDeleted":false,"locked":false,"strokeColor":"#C45C5C","link":null,"roughness":1,"groupIds":[],"index":"b3g","backgroundColor":"#1f0d0d","angle":0,"fillStyle":"solid","strokeWidth":1.5,"version":5,"roundness":{"type":3},"type":"rectangle","updated":1773066850103,"id":"08Mm12L2JpDqeoF2uOiVW","x":-1864,"seed":539847197,"boundElements":[],"y":-2376.03515625,"opacity":100,"height":180,"width":480,"frameId":null,"strokeStyle":"solid","versionNonce":651333203},{"seed":110370429,"strokeStyle":"solid","id":"HpmcyvMsdf6MIOuYT3a6o","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1773066850103,"locked":false,"text":"Breaks Above ~500 jobs\/s Because...","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b3h","roundness":null,"containerId":null,"originalText":"Breaks Above ~500 jobs\/s Because...","height":17.5,"link":null,"strokeColor":"#C45C5C","fillStyle":"solid","groupIds":[],"versionNonce":1344435293,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-1848,"angle":0,"y":-2360.03515625,"width":257.71173095703125},{"seed":1793410781,"strokeStyle":"solid","id":"XRg24v_5UaURfXvHJYuhD","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1773066850103,"locked":false,"text":"The Postgres poll (SELECT WHERE next_fire_time\n<= now) is O(N). At 500K+ rows it takes >1s --\nequal to the poll interval. Scheduler can never\nfinish one scan before the next is due. Trigger\nlatency grows unboundedly. Single scheduler\nnode = SPOF; crash means zero fires until\nmanual restart + stampede on recovery.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b3i","roundness":null,"containerId":null,"originalText":"The Postgres poll (SELECT WHERE next_fire_time\n<= now) is O(N). At 500K+ rows it takes >1s --\nequal to the poll interval. Scheduler can never\nfinish one scan before the next is due. Trigger\nlatency grows unboundedly. Single scheduler\nnode = SPOF; crash means zero fires until\nmanual restart + stampede on recovery.","height":113.75,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":280185843,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-1848,"angle":0,"y":-2336.03515625,"width":327.18365478515625},{"seed":263349053,"strokeStyle":"dashed","id":"5iuJ7KTgFp-0ku3NerA9k","strokeWidth":1,"roughness":1,"isDeleted":false,"startBinding":null,"endArrowhead":null,"opacity":100,"updated":1773066850103,"locked":false,"points":[[0,0],[0,700]],"polygon":false,"version":5,"type":"line","backgroundColor":"transparent","index":"b3j","roundness":null,"lastCommittedPoint":null,"height":700,"link":null,"startArrowhead":null,"strokeColor":"#2A2D3A","fillStyle":"solid","groupIds":[],"endBinding":null,"versionNonce":2146295997,"frameId":null,"boundElements":[],"x":-464,"angle":0,"y":-2828.03515625,"width":0},{"isDeleted":false,"locked":false,"strokeColor":"#2A2D3A","link":null,"roughness":1,"groupIds":[],"index":"b3k","backgroundColor":"#1E2030","angle":0,"fillStyle":"solid","strokeWidth":1.5,"version":5,"roundness":{"type":3},"type":"rectangle","updated":1773066850103,"id":"IB9wEDuBkqukUyNBfXcA0","x":-444,"seed":1767699357,"boundElements":[],"y":-2828.03515625,"opacity":100,"height":700,"width":920,"frameId":null,"strokeStyle":"solid","versionNonce":652957075},{"seed":1679194109,"strokeStyle":"solid","id":"XoMbIoyZVa_HRYwAzsXrV","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1773066850103,"locked":false,"text":"Why Start Simple","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b3l","roundness":null,"containerId":null,"originalText":"Why Start Simple","height":18.75,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":273465629,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-428,"angle":0,"y":-2810.03515625,"width":123.85490417480469},{"seed":1776316509,"strokeStyle":"solid","id":"jPtOAocpik_S9WnD2VnYK","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1773066850103,"locked":false,"text":"A baseline design reveals the load-bearing wall of the system --\nthe single component whose failure or saturation causes everything\nelse to stop. In a job scheduler, that component is always the\ntrigger engine: the thing that decides which jobs fire when. Every\nsophisticated system design decision made later -- partitioned\nleaders, exactly-once idempotency, distributed locks -- exists\nsolely to scale or harden this one responsibility. The baseline\nforces us to name it, measure its ceiling, and reason about\nwhat breaks first rather than designing complexity upfront.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b3m","roundness":null,"containerId":null,"originalText":"A baseline design reveals the load-bearing wall of the system --\nthe single component whose failure or saturation causes everything\nelse to stop. In a job scheduler, that component is always the\ntrigger engine: the thing that decides which jobs fire when. Every\nsophisticated system design decision made later -- partitioned\nleaders, exactly-once idempotency, distributed locks -- exists\nsolely to scale or harden this one responsibility. The baseline\nforces us to name it, measure its ceiling, and reason about\nwhat breaks first rather than designing complexity upfront.","height":146.25,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":2024876851,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-428,"angle":0,"y":-2786.03515625,"width":426.81549072265625},{"seed":680287421,"strokeStyle":"solid","id":"GIzIzc40JwVUhTdjmI8xi","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1773066850103,"locked":false,"text":"The Failure Cascade","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b3n","roundness":null,"containerId":null,"originalText":"The Failure Cascade","height":18.75,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":112235901,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-428,"angle":0,"y":-2602.03515625,"width":147.95989990234375},{"seed":398179613,"strokeStyle":"solid","id":"AP5-_8L1DXwTEN4c3OyUN","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1773066850103,"locked":false,"text":"As traffic exceeds ~500 jobs\/s, the Postgres poll loop starts\nslipping. The SELECT scan takes 1.2s, then 2s, then 4s. Jobs\nwhose fire_time has passed pile up unseen in the database.\nKafka begins receiving bursts instead of a steady stream, and\nworker pool utilization spikes unevenly. The History DB starts\nfalling behind on writes. Clients querying job status find stale\nresults. At this point an operator restarts the scheduler to recover\n-- but restart triggers backfill: the scheduler sees every missed\njob simultaneously and publishes all of them to Kafka at once.\nThe worker pool, already stressed, receives 10x normal volume and\ncollapses. The system is fully unavailable within 90 seconds of\nscheduler CPU saturation reaching 100%.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b3o","roundness":null,"containerId":null,"originalText":"As traffic exceeds ~500 jobs\/s, the Postgres poll loop starts\nslipping. The SELECT scan takes 1.2s, then 2s, then 4s. Jobs\nwhose fire_time has passed pile up unseen in the database.\nKafka begins receiving bursts instead of a steady stream, and\nworker pool utilization spikes unevenly. The History DB starts\nfalling behind on writes. Clients querying job status find stale\nresults. At this point an operator restarts the scheduler to recover\n-- but restart triggers backfill: the scheduler sees every missed\njob simultaneously and publishes all of them to Kafka at once.\nThe worker pool, already stressed, receives 10x normal volume and\ncollapses. The system is fully unavailable within 90 seconds of\nscheduler CPU saturation reaching 100%.","height":195,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":1785416915,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-428,"angle":0,"y":-2578.03515625,"width":434.64141845703125},{"isDeleted":false,"locked":false,"strokeColor":"#2A2D3A","link":null,"roughness":1,"groupIds":[],"index":"b3p","backgroundColor":"#252838","angle":0,"fillStyle":"solid","strokeWidth":1,"version":5,"roundness":{"type":3},"type":"rectangle","updated":1773066850103,"id":"3ZYnCkRpK3N2Er5udMW0D","x":-428,"seed":1054871933,"boundElements":[],"y":-2218.03515625,"opacity":100,"height":62,"width":888,"frameId":null,"strokeStyle":"solid","versionNonce":1046142429},{"seed":993712605,"strokeStyle":"solid","id":"begDo2hVk5ta9yWSPIXcQ","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1773066850103,"locked":false,"text":"Key insight: The single Scheduler Node is the most fragile point.\nIt is simultaneously a SPOF, a CPU bottleneck, and the cause\nof restart stampedes. Every evolution decision targets this node.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b3q","roundness":null,"containerId":null,"originalText":"Key insight: The single Scheduler Node is the most fragile point.\nIt is simultaneously a SPOF, a CPU bottleneck, and the cause\nof restart stampedes. Every evolution decision targets this node.","height":48.75,"link":null,"strokeColor":"#9AA0B4","fillStyle":"solid","groupIds":[],"versionNonce":263207539,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-418,"angle":0,"y":-2208.03515625,"width":419.52252197265625},{"seed":98407997,"strokeStyle":"dashed","id":"C-qudNM-b1cD4CdYYoWeW","strokeWidth":1,"roughness":1,"isDeleted":false,"startBinding":null,"endArrowhead":null,"opacity":100,"updated":1773066850103,"locked":false,"points":[[0,0],[3000,0]],"polygon":false,"version":5,"type":"line","backgroundColor":"transparent","index":"b3r","roundness":null,"lastCommittedPoint":null,"height":0,"link":null,"startArrowhead":null,"strokeColor":"#2A2D3A","fillStyle":"solid","groupIds":[],"endBinding":null,"versionNonce":777853501,"frameId":null,"boundElements":[],"x":-2424,"angle":0,"y":-2068.03515625,"width":3000},{"isDeleted":false,"locked":false,"strokeColor":"#C45C5C","link":null,"roughness":1,"groupIds":[],"index":"b3s","backgroundColor":"#C45C5C","angle":0,"fillStyle":"solid","strokeWidth":2,"version":5,"roundness":null,"type":"ellipse","updated":1773066850103,"id":"ovG6Pfu5eejypP_DLKt-d","x":-2402,"seed":2041169565,"boundElements":[],"y":-2024.03515625,"opacity":100,"height":40,"width":40,"frameId":null,"strokeStyle":"solid","versionNonce":1162245139},{"seed":424733437,"strokeStyle":"solid","id":"0_5LG9pMOS2ShovGbGvjo","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":20,"opacity":100,"verticalAlign":"top","updated":1773066850103,"locked":false,"text":"5","version"