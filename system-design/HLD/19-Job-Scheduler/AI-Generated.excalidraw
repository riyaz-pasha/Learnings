fillStyle":"solid","groupIds":[],"versionNonce":1245180157,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-1256,"angle":0,"y":-4124.03515625,"width":112.30778503417969},{"seed":1323996189,"strokeStyle":"solid","id":"FHkGs_kFbzSp-86Pn9hR7","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":12,"opacity":100,"verticalAlign":"top","updated":1773066850103,"locked":false,"text":"Silent failures undetected for hours","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b1M","roundness":null,"containerId":null,"originalText":"Silent failures undetected for hours","height":15,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":171534675,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-1096,"angle":0,"y":-4124.03515625,"width":210.6356201171875},{"seed":2015103101,"strokeStyle":"dashed","id":"XD-r6Jq9SYw9p31GN0OAr","strokeWidth":1,"roughness":1,"isDeleted":false,"startBinding":null,"endArrowhead":null,"opacity":100,"updated":1773066850103,"locked":false,"points":[[0,0],[0,640]],"polygon":false,"version":5,"type":"line","backgroundColor":"transparent","index":"b1N","roundness":null,"lastCommittedPoint":null,"height":640,"link":null,"startArrowhead":null,"strokeColor":"#2A2D3A","fillStyle":"solid","groupIds":[],"endBinding":null,"versionNonce":1600833885,"frameId":null,"boundElements":[],"x":-464,"angle":0,"y":-4512.03515625,"width":0},{"isDeleted":false,"locked":false,"strokeColor":"#2A2D3A","link":null,"roughness":1,"groupIds":[],"index":"b1O","backgroundColor":"#1E2030","angle":0,"fillStyle":"solid","strokeWidth":1.5,"version":5,"roundness":{"type":3},"type":"rectangle","updated":1773066850103,"id":"129WGSQyFBHW3KfQ0VW1p","x":-444,"seed":2011164893,"boundElements":[],"y":-4512.03515625,"opacity":100,"height":640,"width":920,"frameId":null,"strokeStyle":"solid","versionNonce":948356851},{"seed":1002949949,"strokeStyle":"solid","id":"11qNnQWQ8hFwJOqUX-_UX","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1773066850103,"locked":false,"text":"Design Assumptions","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b1P","roundness":null,"containerId":null,"originalText":"Design Assumptions","height":18.75,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":224630205,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-428,"angle":0,"y":-4494.03515625,"width":143.41488647460938},{"seed":53812637,"strokeStyle":"solid","id":"vt7ce_JXz-E9iE58bI5vF","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1773066850103,"locked":false,"text":"Clock drift is NTP-bounded to <=100ms. If wrong: nodes may\nsimultaneously claim the same job partition, causing double-fires.\n\nJobs are idempotent by caller contract. If wrong: the scheduler\nmust implement per-job-type idempotency itself, a far more\ncomplex guarantee across every executor integration.\n\nJob duration is bounded at <=1 hour. If wrong: pool sizing,\ntimeout handling, and heartbeat intervals all change fundamentally;\na model like Temporal workflows would be needed instead.\n\nPeak trigger density is <=50K jobs per cron boundary. If wrong:\na leaky-bucket at the trigger layer is mandatory to prevent\nworker pool stampedes at every clock-boundary alignment.\n\nPayloads are <=16KB. If wrong: queue message limits are hit\nfirst and a separate blob store for large payloads is required.\n\nTimezones use the IANA database. If wrong: DST transitions\ncause double-fires or missed fires at clock-change boundaries.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b1Q","roundness":null,"containerId":null,"originalText":"Clock drift is NTP-bounded to <=100ms. If wrong: nodes may\nsimultaneously claim the same job partition, causing double-fires.\n\nJobs are idempotent by caller contract. If wrong: the scheduler\nmust implement per-job-type idempotency itself, a far more\ncomplex guarantee across every executor integration.\n\nJob duration is bounded at <=1 hour. If wrong: pool sizing,\ntimeout handling, and heartbeat intervals all change fundamentally;\na model like Temporal workflows would be needed instead.\n\nPeak trigger density is <=50K jobs per cron boundary. If wrong:\na leaky-bucket at the trigger layer is mandatory to prevent\nworker pool stampedes at every clock-boundary alignment.\n\nPayloads are <=16KB. If wrong: queue message limits are hit\nfirst and a separate blob store for large payloads is required.\n\nTimezones use the IANA database. If wrong: DST transitions\ncause double-fires or missed fires at clock-change boundaries.","height":325,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":479686803,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-428,"angle":0,"y":-4470.03515625,"width":422.09649658203125},{"seed":626614781,"strokeStyle":"solid","id":"CTLHIJ-XazLbRN_uHYiK8","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1773066850103,"locked":false,"text":"The Binding Constraint","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b1R","roundness":null,"containerId":null,"originalText":"The Binding Constraint","height":18.75,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":792974877,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-428,"angle":0,"y":-4142.03515625,"width":170.15989685058594},{"seed":389421661,"strokeStyle":"solid","id":"M-Kgzfq46X6NuZeSRAfh9","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1773066850103,"locked":false,"text":"Exactly-once execution shapes every architectural decision.\nBecause jobs represent real-world side effects such as billing\ncharges, emails, and ETL writes, a duplicate fire is often worse\nthan a missed fire. This forces a distributed lock before every\ndispatch, an idempotency key store that survives restarts, and\na two-phase handoff from scheduler to worker. Every other choice\n-- leader election mechanism, queue semantics, ack protocol --\nexists solely to serve this single guarantee.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b1S","roundness":null,"containerId":null,"originalText":"Exactly-once execution shapes every architectural decision.\nBecause jobs represent real-world side effects such as billing\ncharges, emails, and ETL writes, a duplicate fire is often worse\nthan a missed fire. This forces a distributed lock before every\ndispatch, an idempotency key store that survives restarts, and\na two-phase handoff from scheduler to worker. Every other choice\n-- leader election mechanism, queue semantics, ack protocol --\nexists solely to serve this single guarantee.","height":130,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":941745715,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-428,"angle":0,"y":-4118.03515625,"width":422.62945556640625},{"isDeleted":false,"locked":false,"strokeColor":"#2A2D3A","link":null,"roughness":1,"groupIds":[],"index":"b1T","backgroundColor":"#252838","angle":0,"fillStyle":"solid","strokeWidth":1,"version":5,"roundness":{"type":3},"type":"rectangle","updated":1773066850103,"id":"8Uf6yoWSPsPZapTJbotA9","x":-428,"seed":832358077,"boundElements":[],"y":-3952.03515625,"opacity":100,"height":62,"width":888,"frameId":null,"strokeStyle":"solid","versionNonce":1073547901},{"seed":925820701,"strokeStyle":"solid","id":"4fmCjund0GRlblDPV3yrW","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1773066850103,"locked":false,"text":"Key insight: Exactly-once is the binding constraint. Every decision --\nlocking strategy, queue choice, ack protocol, idempotency TTL --\nexists because a duplicate job fire causes measurable real-world harm.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b1U","roundness":null,"containerId":null,"originalText":"Key insight: Exactly-once is the binding constraint. Every decision --\nlocking strategy, queue choice, ack protocol, idempotency TTL --\nexists because a duplicate job fire causes measurable real-world harm.","height":48.75,"link":null,"strokeColor":"#9AA0B4","fillStyle":"solid","groupIds":[],"versionNonce":302819283,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-418,"angle":0,"y":-3942.03515625,"width":442.2593994140625},{"seed":442366845,"strokeStyle":"dashed","id":"jap-q43XFBrUdofAsPMUq","strokeWidth":1,"roughness":1,"isDeleted":false,"startBinding":null,"endArrowhead":null,"opacity":100,"updated":1773066850103,"locked":false,"points":[[0,0],[3000,0]],"polygon":false,"version":5,"type":"line","backgroundColor":"transparent","index":"b1V","roundness":null,"lastCommittedPoint":null,"height":0,"link":null,"startArrowhead":null,"strokeColor":"#2A2D3A","fillStyle":"solid","groupIds":[],"endBinding":null,"versionNonce":1615901405,"frameId":null,"boundElements":[],"x":-2424,"angle":0,"y":-3832.03515625,"width":3000},{"isDeleted":false,"locked":false,"strokeColor":"#C4913A","link":null,"roughness":1,"groupIds":[],"index":"b1W","backgroundColor":"#C4913A","angle":0,"fillStyle":"solid","strokeWidth":2,"version":5,"roundness":null,"type":"ellipse","updated":1773066850103,"id":"jq_FvzGXm0doetfXM5ry1","x":-2402,"seed":57377757,"boundElements":[],"y":-3788.03515625,"opacity":100,"height":40,"width":40,"frameId":null,"strokeStyle":"solid","versionNonce":275658099},{"seed":375980093,"strokeStyle":"solid","id":"B3-dDiS4jwjK9