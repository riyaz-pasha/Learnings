er Election","height":15,"link":null,"strokeColor":"#8B7FD4","fillStyle":"solid","groupIds":[],"versionNonce":1150891443,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-2340,"angle":0,"y":6021.96484375,"width":90.071853637695312},{"seed":1426354941,"strokeStyle":"solid","id":"dreswtsP5Zm7trEiLnHl3","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":12,"opacity":100,"verticalAlign":"top","updated":1773066850100,"locked":false,"text":"ZooKeeper 5-node","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bFF","roundness":null,"containerId":null,"originalText":"ZooKeeper 5-node","height":15,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":1106118483,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-2140,"angle":0,"y":6021.96484375,"width":106.34384155273438},{"seed":559352669,"strokeStyle":"solid","id":"5dMrT9eGaDg4xJ-QgSSzl","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":12,"opacity":100,"verticalAlign":"top","updated":1773066850100,"locked":false,"text":"Ephemeral znodes; guaranteed session expiry","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bFG","roundness":null,"containerId":null,"originalText":"Ephemeral znodes; guaranteed session expiry","height":15,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":200778995,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-1940,"angle":0,"y":6021.96484375,"width":261.28756713867188},{"seed":209164221,"strokeStyle":"solid","id":"EBH4lkWVE36opTKcPEYdo","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":12,"opacity":100,"verticalAlign":"top","updated":1773066850100,"locked":false,"text":"etcd or DB lease table","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bFH","roundness":null,"containerId":null,"originalText":"etcd or DB lease table","height":15,"link":null,"strokeColor":"#9AA0B4","fillStyle":"solid","groupIds":[],"versionNonce":1245482643,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-1580,"angle":0,"y":6021.96484375,"width":134.59175109863281},{"seed":1887934493,"strokeStyle":"dashed","id":"vAcXBEKWsQbI8ODLHzAjG","strokeWidth":1,"roughness":1,"isDeleted":false,"startBinding":null,"endArrowhead":null,"opacity":100,"updated":1773066850100,"locked":false,"points":[[0,0],[0,740]],"polygon":false,"version":5,"type":"line","backgroundColor":"transparent","index":"bFI","roundness":null,"lastCommittedPoint":null,"height":740,"link":null,"startArrowhead":null,"strokeColor":"#2A2D3A","fillStyle":"solid","groupIds":[],"endBinding":null,"versionNonce":1869825075,"frameId":null,"boundElements":[],"x":-464,"angle":0,"y":5377.96484375,"width":0},{"isDeleted":false,"locked":false,"strokeColor":"#2A2D3A","link":null,"roughness":1,"groupIds":[],"index":"bFJ","backgroundColor":"#1E2030","angle":0,"fillStyle":"solid","strokeWidth":1.5,"version":5,"roundness":{"type":3},"type":"rectangle","updated":1773066850100,"id":"IrsMQO69vPX4NmJFgrwgl","x":-444,"seed":1735953533,"boundElements":[],"y":5377.96484375,"opacity":100,"height":740,"width":920,"frameId":null,"strokeStyle":"solid","versionNonce":1401046483},{"seed":1359738077,"strokeStyle":"solid","id":"uBP7gCKaMXclqmxbwLPqb","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1773066850100,"locked":false,"text":"30-Second Verbal Summary","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bFK","roundness":null,"containerId":null,"originalText":"30-Second Verbal Summary","height":18.75,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":226497395,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-428,"angle":0,"y":5395.96484375,"width":191.369873046875},{"seed":416502077,"strokeStyle":"solid","id":"0M8yIVcR7_Fsd3CM9nW4Q","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1773066850100,"locked":false,"text":"This system fires 100 million jobs per day at p99 under one second\nwith exactly-once guarantees. Three partitioned scheduler nodes each\nown a shard of jobs via ZooKeeper leader election. Each runs an\nin-memory time-wheel for O(1) tick lookup, acquires Redis SET NX\nbefore every dispatch, and publishes to one of 32 Kafka partitions.\nA worker consumer group executes jobs and writes to Cassandra.\nKafka RF=3, Cassandra RF=3, Postgres with 2 sync replicas.\nMulti-region active-passive with WAL replication gives 99.99%.\nThe hardest problem is exactly-once under failover: solved by\nRedis SET NX as the fast first check and Cassandra UNIQUE\nidempotency_key as a durable second defense.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bFL","roundness":null,"containerId":null,"originalText":"This system fires 100 million jobs per day at p99 under one second\nwith exactly-once guarantees. Three partitioned scheduler nodes each\nown a shard of jobs via ZooKeeper leader election. Each runs an\nin-memory time-wheel for O(1) tick lookup, acquires Redis SET NX\nbefore every dispatch, and publishes to one of 32 Kafka partitions.\nA worker consumer group executes jobs and writes to Cassandra.\nKafka RF=3, Cassandra RF=3, Postgres with 2 sync replicas.\nMulti-region active-passive with WAL replication gives 99.99%.\nThe hardest problem is exactly-once under failover: solved by\nRedis SET NX as the fast first check and Cassandra UNIQUE\nidempotency_key as a durable second defense.","height":178.75,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":229846291,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-428,"angle":0,"y":5419.96484375,"width":446.00347900390625},{"seed":1009787293,"strokeStyle":"solid","id":"0qjy_G9n-ELN8lZg8EKh5","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1773066850100,"locked":false,"text":"Likely Follow-up Questions","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bFM","roundness":null,"containerId":null,"originalText":"Likely Follow-up Questions","height":18.75,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":2006061747,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-428,"angle":0,"y":5619.96484375,"width":191.15985107421875},{"seed":273933821,"strokeStyle":"solid","id":"lKLVF8QUzmsaYlKV9sSr1","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1773066850100,"locked":false,"text":"Q: What if a job runs longer than its interval?\nA: Track RUNNING state in execution_log. On next fire, check\nprevious state and apply concurrency policy: SKIP, ALLOW, or QUEUE.\n\nQ: How do you handle DST clock rollback?\nA: Store all fire times in UTC. Evaluate cron in UTC. Convert to\nuser timezone only for display. The 01:00-02:00 window occurs twice\nat fall-back; skip second occurrence for one-time jobs.\n\nQ: How would you scale to 1 billion registered jobs?\nA: Schedulers 3 to 10, Kafka partitions 32 to 256, Cassandra\n6 to 12 nodes. Architecture unchanged -- only counts scale.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bFN","roundness":null,"containerId":null,"originalText":"Q: What if a job runs longer than its interval?\nA: Track RUNNING state in execution_log. On next fire, check\nprevious state and apply concurrency policy: SKIP, ALLOW, or QUEUE.\n\nQ: How do you handle DST clock rollback?\nA: Store all fire times in UTC. Evaluate cron in UTC. Convert to\nuser timezone only for display. The 01:00-02:00 window occurs twice\nat fall-back; skip second occurrence for one-time jobs.\n\nQ: How would you scale to 1 billion registered jobs?\nA: Schedulers 3 to 10, Kafka partitions 32 to 256, Cassandra\n6 to 12 nodes. Architecture unchanged -- only counts scale.","height":195,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":1002652755,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-428,"angle":0,"y":5643.96484375,"width":441.37548828125},{"seed":1212161629,"strokeStyle":"solid","id":"TnaKuNR-GBWw2oY9mCJzZ","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1773066850100,"locked":false,"text":"Senior vs Staff Answer","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bFO","roundness":null,"containerId":null,"originalText":"Senior vs Staff Answer","height":18.75,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":1914520051,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-428,"angle":0,"y":5897.96484375,"width":168.7498779296875},{"seed":986073789,"strokeStyle":"solid","id":"RCV-3Uvjc8-Ohr83S-k7p","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1773066850100,"locked":false,"text":"A Senior engineer adds Redis idempotency and partitioned schedulers\nand explains the exactly-once guarantee clearly. A Staff engineer\nalso covers fencing tokens preventing zombie leaders from firing\nafter partition loss, the 100ms WAL lag data loss window at\nfailover and why it is acceptable, DST edge cases and their\nproduction impact, backpressure preventing restart stampedes,\nand can explain precisely why active-active is wrong for schedulers\nspecifically: not because it is complex but because it requires\nglobal consensus on every dispatch decision, pushing p99 latency\nabove the 1-second NFR for architectural reasons.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bFP","roundness":null,"containerId":null,"originalText":"A Senior engineer adds Redis idempotency and partitioned schedulers\nand explains the exactly-once guarantee clearly. A Staff engineer\nalso covers fencing tokens preventing zombie leaders from firing\nafter partition loss, the 100ms WAL lag data loss window at\nfailover and why it is acceptable, DST edge cases and their\nproduction impact, backpressure preventing restart stampedes,\nand can explain precisely why active-active is wrong for schedulers\nspecifically: not because it is complex but because it requires\nglobal consensus on every dispatch decision, pushing p99 latency\nabove the 1-second NFR for architectural reasons.","height":162.5,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":1940294547,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-428,"angle":0,"y":5921.96484375,"width":437.657470703125},{"isDeleted":false,"locked":false,"strokeColor":"#2A2D3A","link":null,"roughness":1,"groupIds":[],"index":"bFQ","backgroundColor":"#252838","angle":0,"fillStyle":"solid","strokeWidth":1,"version":5,"roundness":{"type":3},"type":"rectangle","updated":1773066850100,"id":"RSTZJByxR9Vv0hQKOJjeG","x":-428,"seed":1753738013,"boundElements":[],"y":6035.96484375,"opacity":100,"height":64,"width":888,"frameId":null,"strokeStyle":"solid","versionNonce":882221363},{"seed":1106673533,"strokeStyle":"solid","id":"HbqYTvQgv5FLEzu1Gu2LI","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1773066850100,"locked":false,"text":"Key insight: The memorable design detail is layered exactly-once\ndefense: Redis SET NX (fast, ephemeral) plus Cassandra UNIQUE\nconstraint (durable, survives Redis restart) plus fencing token\n(prevents zombie leaders bypassing both). Three independent\nmechanisms -- any one alone would eventually fail in production.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bFR","roundness":null,"containerId":null,"originalText":"Key insight: The memorable design detail is layered exactly-once\ndefense: Redis SET NX (fast, ephemeral) plus Cassandra UNIQUE\nconstraint (durable, survives Redis restart) plus fencing token\n(prevents zombie leaders bypassing both). Three independent\nmechanisms -- any one alone would eventually fail in production.","height":81.25,"link":null,"strokeColor":"#9AA0B4","fillStyle":"solid","groupIds":[],"versionNonce":1582367443,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-418,"angle":0,"y":6045.96484375,"width":416.88351440429688}],"appState":{"shouldCacheIgnoreZoom":false,"exportScale":2,"defaultSidebarDockedPreference":false,"openMenu":null,"showWelcomeScreen":true,"currentItemStrokeColor":"#1e1e1e","bindMode":"orbit","exportWithDarkMode":false,"lockedMultiSelections":{},"currentItemRoughness":1,"currentItemTextAlign":"left","exportBackground":true,"scrolledOutside":false,"selectedElementIds":{"nf5hCrqQt9H0Rk0ZhSkwi":true,"3xqsd8Rp139CzSHNvqjI3":true,"o13uvMRKVnqkdmKGXXjd6":true,"yjCE-Cw65_29MFFBi4PCS":true,"zw_17CYwKJpZLLQ8JC6Y7":true,"SStFHG4uVLLUYG930rc7e":true,"begDo2hVk5ta9yWSPIXcQ":true,"jha-ZMEEaPELK2pee7aYJ":true,"S-4c0ETXmhuOMg_NjViAO":true,"uHry8H0C5DdjPi_xP_gCw":true,"d1ybLi9LOqbamyKYFdf-e":true,"ovnUu4TA2rV0yHN9cfK-n":true,"1M9zaIjF44BCHanmQ9cPN":true,"hppmtiu-ET5ELPmc-qGYj":true,"7x_n-M9e0oM24scbj49mr":true,"Duy8uc_8t-r-T0WNJ82aQ":true,"EgY5czPi4_5S_UfViQRMK":true,"IVN2l56pw0Afme3C-BlX1":true,"08t9GUcLYoZ86tzlhu0Wv":true,"Ft2bbCHsbt6fU-wCnCLsW":true,"E4TSyQwh3m0arBH2CU0QK":true,"Jtz_U4goAPrworK6tSXn8":true,"dCtq3vPVZPknIUhpE-itw":true,"Tr98Lrf3-1ix-Z23sIQQS":true,"cWM_4fnr85KhD2q_3ujFL":true,"a3Hzi94xNGwPSWSTUxXlc":true,"pTiXyMfy2Um-K6znmudwS":true,"wBJpWEy2tirYoQHx-LLm_":true,"eov-S9zwGdoa-5S2MdJWc":true,"L