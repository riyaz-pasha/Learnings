ments":[],"x":-1594,"angle":0,"y":-3088.03515625,"width":129.94795227050781},{"seed":1674757309,"strokeStyle":"solid","id":"LqPCcpoCEXhC0SUYWdci0","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1773066850103,"locked":false,"text":"Per Exec Record","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b2l","roundness":null,"containerId":null,"originalText":"Per Exec Record","height":16.25,"link":null,"strokeColor":"#9AA0B4","fillStyle":"solid","groupIds":[],"versionNonce":1446955389,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-1596,"angle":0,"y":-3048.03515625,"width":105.94985961914062},{"seed":1844782365,"strokeStyle":"dashed","id":"SxH7gysmmUm25hpB7vSnB","strokeWidth":1,"roughness":1,"isDeleted":false,"startBinding":null,"endArrowhead":null,"opacity":100,"updated":1773066850103,"locked":false,"points":[[0,0],[0,736]],"polygon":false,"version":5,"type":"line","backgroundColor":"transparent","index":"b2m","roundness":null,"lastCommittedPoint":null,"height":736,"link":null,"startArrowhead":null,"strokeColor":"#2A2D3A","fillStyle":"solid","groupIds":[],"endBinding":null,"versionNonce":1225414867,"frameId":null,"boundElements":[],"x":-464,"angle":0,"y":-3724.03515625,"width":0},{"isDeleted":false,"locked":false,"strokeColor":"#2A2D3A","link":null,"roughness":1,"groupIds":[],"index":"b2n","backgroundColor":"#1E2030","angle":0,"fillStyle":"solid","strokeWidth":1.5,"version":5,"roundness":{"type":3},"type":"rectangle","updated":1773066850103,"id":"JHhASN-G2XX11jacb5zkX","x":-444,"seed":1504475517,"boundElements":[],"y":-3724.03515625,"opacity":100,"height":736,"width":920,"frameId":null,"strokeStyle":"solid","versionNonce":1711444445},{"seed":272253405,"strokeStyle":"solid","id":"wUWzcJJWw0lFIvYwgh4ya","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1773066850103,"locked":false,"text":"Why These Numbers Matter","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b2o","roundness":null,"containerId":null,"originalText":"Why These Numbers Matter","height":18.75,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":1586349683,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-428,"angle":0,"y":-3706.03515625,"width":201.16485595703125},{"seed":1454374461,"strokeStyle":"solid","id":"asfjQC7Ce8zKBGP4quHVo","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1773066850103,"locked":false,"text":"The most consequential calculation is peak QPS. Starting from 100M\njobs per day and dividing by 86,400 seconds gives 1,157 avg req\/s.\nBut cron jobs do not arrive uniformly -- at top-of-hour boundaries,\nthousands of jobs fire simultaneously. A 4.3x peak factor is\nconservative for large fleets. Every queue depth, broker partition\ncount, and worker pool size must be anchored to that peak figure,\nnot the comfortable average. Designing for average traffic means\nfailing precisely when the business is most time-sensitive.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b2p","roundness":null,"containerId":null,"originalText":"The most consequential calculation is peak QPS. Starting from 100M\njobs per day and dividing by 86,400 seconds gives 1,157 avg req\/s.\nBut cron jobs do not arrive uniformly -- at top-of-hour boundaries,\nthousands of jobs fire simultaneously. A 4.3x peak factor is\nconservative for large fleets. Every queue depth, broker partition\ncount, and worker pool size must be anchored to that peak figure,\nnot the comfortable average. Designing for average traffic means\nfailing precisely when the business is most time-sensitive.","height":130,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":1861111357,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-428,"angle":0,"y":-3682.03515625,"width":436.21453857421875},{"seed":1408183965,"strokeStyle":"solid","id":"4j6kmnUKFrQe9vJgyPdN1","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1773066850103,"locked":false,"text":"Peak vs Average","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b2q","roundness":null,"containerId":null,"originalText":"Peak vs Average","height":18.75,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":2022866963,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-428,"angle":0,"y":-3520.03515625,"width":119.39993286132812},{"seed":1453937405,"strokeStyle":"solid","id":"zr_ggERUReDozkk4eHhLi","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1773066850103,"locked":false,"text":"Roughly 30% of cron jobs are scheduled at :00 minutes, 15% at :30,\nand the rest scatter across other minute offsets. At the top of any\nhour, that 30% cohort fires within 60 seconds, adding ~500 req\/s\nabove baseline. The scheduler partitions job IDs across nodes to\nspread the spike, but Kafka and the worker pool must absorb the\nburst without queuing more than 1 second of backlog -- the p99 target.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b2r","roundness":null,"containerId":null,"originalText":"Roughly 30% of cron jobs are scheduled at :00 minutes, 15% at :30,\nand the rest scatter across other minute offsets. At the top of any\nhour, that 30% cohort fires within 60 seconds, adding ~500 req\/s\nabove baseline. The scheduler partitions job IDs across nodes to\nspread the spike, but Kafka and the worker pool must absorb the\nburst without queuing more than 1 second of backlog -- the p99 target.","height":97.5,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":1877180061,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-428,"angle":0,"y":-3496.03515625,"width":457.092529296875},{"seed":1533012829,"strokeStyle":"solid","id":"WZLcXklL1ASjeKDk9rfmA","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1773066850103,"locked":false,"text":"Storage Growth Rate","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b2s","roundness":null,"containerId":null,"originalText":"Storage Growth Rate","height":18.75,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":286197171,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-428,"angle":0,"y":-3352.03515625,"width":159.7799072265625},{"seed":1382315965,"strokeStyle":"solid","id":"9Zmw0PVXh1mNHMDHAk06h","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1773066850103,"locked":false,"text":"History is the dominant storage driver at 33 GB\/day. With 90-day\nretention and RF=3, raw storage reaches approximately 9 TB.\nLZ4 compression on Cassandra at roughly 3:1 reduces this to 3 TB.\nJob definitions are negligible by comparison: 10M jobs at 4.3 KB\neach is only 43 GB total. The Redis idempotency store stays small\nbecause TTL=24h keeps only today's fires in RAM, requiring just\n6.4 GB across the 3-node cluster -- a single commodity instance.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b2t","roundness":null,"containerId":null,"originalText":"History is the dominant storage driver at 33 GB\/day. With 90-day\nretention and RF=3, raw storage reaches approximately 9 TB.\nLZ4 compression on Cassandra at roughly 3:1 reduces this to 3 TB.\nJob definitions are negligible by comparison: 10M jobs at 4.3 KB\neach is only 43 GB total. The Redis idempotency store stays small\nbecause TTL=24h keeps only today's fires in RAM, requiring just\n6.4 GB across the 3-node cluster -- a single commodity instance.","height":113.75,"link":null,"strokeColor":"#E2E4ED","fillStyle":"solid","groupIds":[],"versionNonce":261333757,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-428,"angle":0,"y":-3328.03515625,"width":431.75546264648438},{"isDeleted":false,"locked":false,"strokeColor":"#2A2D3A","link":null,"roughness":1,"groupIds":[],"index":"b2u","backgroundColor":"#252838","angle":0,"fillStyle":"solid","strokeWidth":1,"version":5,"roundness":{"type":3},"type":"rectangle","updated":1773066850103,"id":"81dfgt5inQXhCQdJ8gdLi","x":-428,"seed":634943517,"boundElements":[],"y":-3122.03515625,"opacity":100,"height":66,"width":888,"frameId":null,"strokeStyle":"solid","versionNonce":522835795},{"seed":2142071933,"strokeStyle":"solid","id":"Hh-T2LMZdmivwQB4XgIUC","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1773066850103,"locked":false,"text":"Key insight: The 4.3x peak multiplier is not a safety margin -- it\nreflects real synchronization of cron boundaries. Every component\nmust be sized for peak QPS or the system collapses at :00 every\nhour, precisely when downstream pipelines are most time-sensitive.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b2v","roundness":null,"containerId":null,"originalText":"Key insight: The 4.3x peak multiplier is not a safety margin -- it\nreflects real synchronization of cron boundaries. Every component\nmust be sized for peak QPS or the system collapses at :00 every\nhour, precisely when downstream pipelines are most time-sensitive.","height":65,"link":null,"strokeColor":"#9AA0B4","fillStyle":"solid","groupIds":[],"versionNonce":578829149,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-418,"angle":0,"y":-3112.