e":1825899844,"frameId":null,"boundElements":[{"type":"text","id":"08Scfn61nh9LjOELnULeH"}],"x":351,"angle":0,"y":2985.5,"width":0},{"seed":974101060,"strokeStyle":"solid","id":"08Scfn61nh9LjOELnULeH","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":11,"opacity":100,"verticalAlign":"middle","updated":1772873306470,"locked":false,"text":"async replication\n~100ms","version":7,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bBQ","roundness":null,"containerId":"RXwvD0SEZk8irRRQ5aY7z","originalText":"async replication ~100ms","height":27.5,"link":null,"strokeColor":"#7c3aed","fillStyle":"solid","groupIds":[],"versionNonce":541786308,"textAlign":"center","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":306.90650177001953,"angle":0,"y":3016.25,"width":88.186996459960938},{"isDeleted":false,"locked":false,"strokeColor":"#c7d2fe","link":null,"roughness":1,"groupIds":[],"index":"bBR","backgroundColor":"#f8faff","angle":0,"fillStyle":"solid","strokeWidth":1.5,"version":5,"roundness":null,"type":"rectangle","updated":1772873306458,"id":"avu0TUy8gWBpmQB6zikRq","x":709,"seed":757838276,"boundElements":[],"y":2567,"opacity":100,"height":900,"width":562,"frameId":null,"strokeStyle":"solid","versionNonce":1510718660},{"seed":601413956,"strokeStyle":"solid","id":"SD72K7zzJiyPbgQQeRxO0","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":17,"opacity":100,"verticalAlign":"top","updated":1772873306458,"locked":false,"text":"Complete Request Lifecycle","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bBS","roundness":null,"containerId":null,"originalText":"Complete Request Lifecycle","height":21.25,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":1798201724,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":727,"angle":0,"y":2585,"width":224.31483459472656},{"seed":695537860,"strokeStyle":"solid","id":"ynGWZjgdzS2URO796Cni6","strokeWidth":1,"roughness":1,"isDeleted":false,"startBinding":null,"endArrowhead":null,"opacity":100,"updated":1772873306458,"locked":false,"points":[[0,0],[522,0]],"polygon":false,"version":5,"type":"line","backgroundColor":"transparent","index":"bBT","roundness":null,"lastCommittedPoint":null,"height":0,"link":null,"startArrowhead":null,"strokeColor":"#e5e7eb","fillStyle":"solid","groupIds":[],"endBinding":null,"versionNonce":1853850692,"frameId":null,"boundElements":[],"x":727,"angle":0,"y":2609,"width":522},{"seed":765352004,"strokeStyle":"solid","id":"jCwCFVljI7dbzsJKmnlWX","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772873306458,"locked":false,"text":"A keystroke fires after 200ms debounce. The browser\nsends GET \/suggest?q=prefix to the Global Load\nBalancer, which routes to the nearest CDN edge PoP.\nOn a CDN hit (80% of requests) the top-10 list\nreturns in under 10ms from the edge. On a miss,\nthe CDN forwards to the API Gateway and Rate\nLimiter, which validates the request and routes to\nthe Autocomplete Service. The service's Shard Router\nhashes the prefix to the correct trie shard, fetches\nthe pre-computed top_k JSON (~2ms), and in parallel\nfetches the user's query history from Redis (~3ms).\nBoth results are blended using a weighted score,\npassed through the blocklist filter, and the top-10\nsuggestions return to the client within ~100ms total.\nSimultaneously, the completed search query is\npublished to Kafka asynchronously (fire-and-forget).","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bBU","roundness":null,"containerId":null,"originalText":"A keystroke fires after 200ms debounce. The browser\nsends GET \/suggest?q=prefix to the Global Load\nBalancer, which routes to the nearest CDN edge PoP.\nOn a CDN hit (80% of requests) the top-10 list\nreturns in under 10ms from the edge. On a miss,\nthe CDN forwards to the API Gateway and Rate\nLimiter, which validates the request and routes to\nthe Autocomplete Service. The service's Shard Router\nhashes the prefix to the correct trie shard, fetches\nthe pre-computed top_k JSON (~2ms), and in parallel\nfetches the user's query history from Redis (~3ms).\nBoth results are blended using a weighted score,\npassed through the blocklist filter, and the top-10\nsuggestions return to the client within ~100ms total.\nSimultaneously, the completed search query is\npublished to Kafka asynchronously (fire-and-forget).","height":280,"link":null,"strokeColor":"#374151","fillStyle":"solid","groupIds":[],"versionNonce":1583141372,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":727,"angle":0,"y":2621,"width":373.4495849609375},{"seed":2083696580,"strokeStyle":"solid","id":"FVS8C3XqmWM9U9FLuRezq","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":17,"opacity":100,"verticalAlign":"top","updated":1772873306458,"locked":false,"text":"Failover Runbook","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bBV","roundness":null,"containerId":null,"originalText":"Failover Runbook","height":21.25,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":1611553732,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":727,"angle":0,"y":2901,"width":139.87590026855469},{"seed":894441284,"strokeStyle":"solid","id":"12XyjbSStxhLG64p39Hvq","strokeWidth":1,"roughness":1,"isDeleted":false,"startBinding":null,"endArrowhead":null,"opacity":100,"updated":1772873306458,"locked":false,"points":[[0,0],[522,0]],"polygon":false,"version":5,"type":"line","backgroundColor":"transparent","index":"bBW","roundness":null,"lastCommittedPoint":null,"height":0,"link":null,"startArrowhead":null,"strokeColor":"#e5e7eb","fillStyle":"solid","groupIds":[],"endBinding":null,"versionNonce":862532220,"frameId":null,"boundElements":[],"x":727,"angle":0,"y":2925,"width":522},{"seed":1163169476,"strokeStyle":"solid","id":"OPdS7KPegHtVA-1bQs8QG","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772873306458,"locked":false,"text":"When Region A becomes unreachable: the Global Load\nBalancer health check detects failure within ~30s and\nshifts 100% of traffic to Region B. Region B serves\nsuggestions from its async trie replica — data may be\nup to 5 minutes stale, but suggestions still work.\nThe Kafka Mirror in Region B continues consuming\nfrom Region A's mirrored topics, keeping the replica\ncurrent during degraded operation. When Region A\nrecovers, the LB gradually restores traffic (10% per\nminute) to avoid thundering herd. Trie replication\ncatchup completes within ~5 minutes.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bBX","roundness":null,"containerId":null,"originalText":"When Region A becomes unreachable: the Global Load\nBalancer health check detects failure within ~30s and\nshifts 100% of traffic to Region B. Region B serves\nsuggestions from its async trie replica — data may be\nup to 5 minutes stale, but suggestions still work.\nThe Kafka Mirror in Region B continues consuming\nfrom Region A's mirrored topics, keeping the replica\ncurrent during degraded operation. When Region A\nrecovers, the LB gradually restores traffic (10% per\nminute) to avoid thundering herd. Trie replication\ncatchup completes within ~5 minutes.","height":192.5,"link":null,"strokeColor":"#374151","fillStyle":"solid","groupIds":[],"versionNonce":2027307844,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":727,"angle":0,"y":2937,"width":370.38357543945312},{"seed":1558058564,"strokeStyle":"solid","id":"7XCGi-ZgI44G_BGceXvPk","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":17,"opacity":100,"verticalAlign":"top","updated":1772873306458,"locked":false,"text":"Most Latency-Sensitive Path","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bBY","roundness":null,"containerId":null,"originalText":"Most Latency-Sensitive Path","height":21.25,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":1494582012,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":727,"angle":0,"y":3127,"width":240.15876770019531},{"seed":1758113220,"strokeStyle":"solid","id":"syMUln3ZU4sp147_Cngfd","strokeWidth":1,"roughness":1,"isDeleted":false,"startBinding":null,"endArrowhead":null,"opacity":100,"updated":1772873306458,"locked":false,"points":[[0,0],[522,0]],"polygon":false,"version":5,"type":"line","backgroundColor":"transparent","index":"bBZ","roundness":null,"lastCommittedPoint":null,"height":0,"link":null,"startArrowhead":null,"strokeColor":"#e5e7eb","fillStyle":"solid","groupIds":[],"endBinding":null,"versionNonce":255146692,"frameId":null,"boundElements":[],"x":727,"angle":0,"y":3151,"width":522},{"seed":171464004,"strokeStyle":"solid","id":"U0Uz0yGnRXTknq_CAjibh","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772873306458,"locked":false,"text":"The Autocomplete Service to Trie Shard call is the\nmost latency-sensitive path and cannot be made async.\nThe trie lookup is the core value — without it there\nare no suggestions to return. Every other call in the\nsystem is either async (Kafka publish, trie updates)\nor gracefully skippable (Redis user history has a\ntimeout fallback). The trie shard must answer within\n5ms or the API cannot meet its 100ms SLA. This is\nwhy trie shards run on dedicated high-memory nodes\nwith no noisy neighbors and co-located with API\nservers in the same availability zone.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bBa","roundness":null,"containerId":null,"originalText":"The Autocomplete Service to Trie Shard call is the\nmost latency-sensitive path and cannot be made async.\nThe trie lookup is the core value — without it there\nare no suggestions to return. Every other call in the\nsystem is either async (Kafka publish, trie updates)\nor gracefully skippable (Redis user history has a\ntimeout fallback). The trie shard must answer within\n5ms or the API cannot meet its 100ms SLA. This is\nwhy trie shards run on dedicated high-memory nodes\nwith no noisy neighbors and co-located with API\nservers in the same availability zone.","height":192.5,"link":null,"strokeColor":"#374151","fillStyle":"solid","groupIds":[],"versionNonce":367248252,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":727,"angle":0,"y":3163,"width":376.93560791015625},{"isDeleted":false,"locked":false,"strokeColor":"#f59e0b","link":null,"roughness":1,"groupIds":[],"index":"bBb","backgroundColor":"#fffbeb","angle":0,"fillStyle":"solid","strokeWidth":2,"version":5,"roundness":{"type":3},"type":"rectangle","updated":1772873306458,"id":"tWTnba_E22BR3bwlJqW_J","x":727,"seed":243600580,"boundElements":[],"y":3319,"opacity":100,"height":110,"width":526,"frameId":null,"strokeStyle":"solid","versionNonce":2110341700},{"seed":1733219396,"strokeStyle":"solid","id":"XAM-G5mP1lbWhwvhuLX21","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772873306458,"locked":false,"text":"Key insight: The only synchronous dependency on the\ncritical path is the trie shard lookup. Everything else\n— Kafka publish, Redis user history, trending updates\n— is async or has a graceful fallback. This isolation\nprotects the 100ms SLA from cascading failures.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bBc","roundness":null,"containerId":null,"originalText":"Key insight: The only synchronous dependency on the\ncritical path is the trie shard lookup. Everything else\n— Kafka publish, Redis user history, trending updates\n— is async or has a graceful fallback. This isolation\nprotects the 100ms SLA from cascading failures.","height":87.5,"link":null,"strokeColor":"#92400e","fillStyle":"solid","groupIds":[],"versionNonce":269874172,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":743,"angle":0,"y":3335,"width":366.85552978515625},{"seed":578005956,"strokeStyle":"dashed","id":"KkoRnLOkdmsMANNzpyoJ2","strokeWidth":1,"roughness":1,"isDeleted":false,"startBinding":null,"endArrowhead":null,"opacity":100,"updated":1772873306458,"locked":false,"points":[[0,0],[1450,0]],"polygon":false,"version":5,"type":"line","backgroundColor":"transparent","index":"bBd","roundness":null,"lastCommittedPoint":null,"height":0,"link":null,"startArrowhead":null,"strokeColor":"#9ca3af","fillStyle":"solid","groupIds":[],"endBinding":null,"versionNonce":460347844,"frameId":null,"boundElements":[],"x":-149,"angle":0,"y":3489,"width":1450},{"isDeleted":false,"locked":false,"strokeColor":"#ef4444","link":null,"roughness":1,"groupIds":[],"index":"bBe","backgroundColor":"#ef4444","angle":0,"fillStyle":"solid","strokeWidth":2,"version":5,"roundness":null,"type":"ellipse","updated":1772873306458,"id":"8Qaxo3oHA4JcF-HTeERKJ","x":-139,"seed":1645318980,"boundElements":[],"y":3533,"opacity":100,"height":42,"width":42,"frameId":null,"strokeStyle":"solid","versionNonce":1437471868},{"seed":1418103492,"strokeStyle":"solid","id":"KxjFlQzwXg-kmwxT_9ksV","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":16,"opacity":100,"verticalAlign":"top","updated":1772873306458,"locked":false,"text":"S9","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bBf","roundness":null,"containerId":null,"originalText":"S9","height":20,"link":null,"strokeColor":"#ffffff","fillStyle":"solid","groupIds":[],"versionNonce":860389700,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-127,"angle":0,"y":3548,"width":20.0159912109375},{"seed":745574980,