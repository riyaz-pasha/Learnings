ntFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":309.63099670410156,"angle":0,"y":758.75,"width":322.73800659179688},{"isDeleted":false,"locked":false,"strokeColor":"#3b82f6","link":null,"roughness":1,"groupIds":[],"index":"b7V","backgroundColor":"#1e3a5f","angle":0,"fillStyle":"solid","strokeWidth":2,"version":5,"roundness":{"type":3},"type":"rectangle","updated":1772873306458,"id":"MItwUvi1IixfvBJruO0Dl","x":-109,"seed":2115251140,"boundElements":[{"type":"text","id":"s3hDkWYN4UvRE9iFVVrS1"}],"y":817,"opacity":100,"height":90,"width":780,"frameId":null,"strokeStyle":"solid","versionNonce":2015402436},{"seed":1973556036,"strokeStyle":"solid","id":"s3hDkWYN4UvRE9iFVVrS1","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"middle","updated":1772873306469,"locked":false,"text":"What We Learned: Every upgrade was forced by a specific measurable failure.\nSharding before async ingest = 40 shards each with a nightly blackout.\nThe order matters: state sharding -> async writes -> cache -> personalization -> multi-region.","version":7,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b7W","roundness":null,"containerId":"MItwUvi1IixfvBJruO0Dl","originalText":"What We Learned: Every upgrade was forced by a specific measurable failure.\nSharding before async ingest = 40 shards each with a nightly blackout.\nThe order matters: state sharding -> async writes -> cache -> personalization -> multi-region.","height":52.5,"link":null,"strokeColor":"#3b82f6","fillStyle":"solid","groupIds":[],"versionNonce":1533125444,"textAlign":"center","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-40.11810302734375,"angle":0,"y":835.75,"width":642.2362060546875},{"isDeleted":false,"locked":false,"strokeColor":"#c7d2fe","link":null,"roughness":1,"groupIds":[],"index":"b7X","backgroundColor":"#f8faff","angle":0,"fillStyle":"solid","strokeWidth":1.5,"version":5,"roundness":null,"type":"rectangle","updated":1772873306458,"id":"uO6kPn3g-X7hUdpg8GgNx","x":709,"seed":570886852,"boundElements":[],"y":-581,"opacity":100,"height":1540,"width":562,"frameId":null,"strokeStyle":"solid","versionNonce":267436356},{"seed":1977684548,"strokeStyle":"solid","id":"KkJ-ssXzACxrvr2jEvCO5","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":17,"opacity":100,"verticalAlign":"top","updated":1772873306458,"locked":false,"text":"V1 to V2: Why Sharding Over Vertical Scale","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b7Y","roundness":null,"containerId":null,"originalText":"V1 to V2: Why Sharding Over Vertical Scale","height":21.25,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":896132348,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":727,"angle":0,"y":-563,"width":354.7216796875},{"seed":1611540932,"strokeStyle":"solid","id":"e_CRUh2MlYO4CwQCMLyb6","strokeWidth":1,"roughness":1,"isDeleted":false,"startBinding":null,"endArrowhead":null,"opacity":100,"updated":1772873306458,"locked":false,"points":[[0,0],[522,0]],"polygon":false,"version":5,"type":"line","backgroundColor":"transparent","index":"b7Z","roundness":null,"lastCommittedPoint":null,"height":0,"link":null,"startArrowhead":null,"strokeColor":"#e5e7eb","fillStyle":"solid","groupIds":[],"endBinding":null,"versionNonce":441448644,"frameId":null,"boundElements":[],"x":727,"angle":0,"y":-539,"width":522},{"seed":1135366468,"strokeStyle":"solid","id":"E2Sr7Zc8UYygiZHKstQAO","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772873306458,"locked":false,"text":"The alternative was vertical scaling — a larger single\nserver with more RAM. At 200 GB+ heap size, vertical\nscaling hits hardware limits and GC pause time grows\nnon-linearly with heap size. Prefix-range sharding was\nchosen because each shard is independent — no cross-\nshard coordination on reads — and shards can be added\nlinearly. The cost is hot shards, addressed in V4.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b7a","roundness":null,"containerId":null,"originalText":"The alternative was vertical scaling — a larger single\nserver with more RAM. At 200 GB+ heap size, vertical\nscaling hits hardware limits and GC pause time grows\nnon-linearly with heap size. Prefix-range sharding was\nchosen because each shard is independent — no cross-\nshard coordination on reads — and shards can be added\nlinearly. The cost is hot shards, addressed in V4.","height":122.5,"link":null,"strokeColor":"#374151","fillStyle":"solid","groupIds":[],"versionNonce":1834739068,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":727,"angle":0,"y":-527,"width":386.2034912109375},{"seed":1880721604,"strokeStyle":"solid","id":"iEXWGSebe3yYjSIS7mxPi","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":17,"opacity":100,"verticalAlign":"top","updated":1772873306458,"locked":false,"text":"V2 to V3: Why Kafka Over Direct DB Writes","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b7b","roundness":null,"containerId":null,"originalText":"V2 to V3: Why Kafka Over Direct DB Writes","height":21.25,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":316424260,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":727,"angle":0,"y":-377,"width":367.26766967773438},{"seed":418631748,"strokeStyle":"solid","id":"b3gprqt7SG8gw5Vg-q22O","strokeWidth":1,"roughness":1,"isDeleted":false,"startBinding":null,"endArrowhead":null,"opacity":100,"updated":1772873306458,"locked":false,"points":[[0,0],[522,0]],"polygon":false,"version":5,"type":"line","backgroundColor":"transparent","index":"b7c","roundness":null,"lastCommittedPoint":null,"height":0,"link":null,"startArrowhead":null,"strokeColor":"#e5e7eb","fillStyle":"solid","groupIds":[],"endBinding":null,"versionNonce":1211749884,"frameId":null,"boundElements":[],"x":727,"angle":0,"y":-353,"width":522},{"seed":1310271428,"strokeStyle":"solid","id":"IMJk7cYaUJBH5V9znTGIk","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772873306458,"locked":false,"text":"Direct async DB writes (fire-and-forget MySQL) were\nconsidered but rejected because they provide no replay,\nno backpressure signal, and no fan-out to multiple\nconsumers. Kafka gives durable replay for trie rebuilds,\nallows multiple consumer groups (trie workers, analytics,\ntrending service) from a single stream, and provides\nconsumer lag metrics for freshness SLA monitoring.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b7d","roundness":null,"containerId":null,"originalText":"Direct async DB writes (fire-and-forget MySQL) were\nconsidered but rejected because they provide no replay,\nno backpressure signal, and no fan-out to multiple\nconsumers. Kafka gives durable replay for trie rebuilds,\nallows multiple consumer groups (trie workers, analytics,\ntrending service) from a single stream, and provides\nconsumer lag metrics for freshness SLA monitoring.","height":122.5,"link":null,"strokeColor":"#374151","fillStyle":"solid","groupIds":[],"versionNonce":1366529988,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":727,"angle":0,"y":-341,"width":380.36550903320312},{"seed":1940361028,"strokeStyle":"solid","id":"vL5tQ-xcRwClF9FG7PH-j","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":17,"opacity":100,"verticalAlign":"top","updated":1772873306458,"locked":false,"text":"V3 to V4: Why CDN Over More Trie Replicas","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b7e","roundness":null,"containerId":null,"originalText":"V3 to V4: Why CDN Over More Trie Replicas","height":21.25,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":1661318780,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":727,"angle":0,"y":-175,"width":362.8817138671875},{"seed":972883652,"strokeStyle":"solid","id":"UMZEbcr1qo759O_vC7xIp","strokeWidth":1,"roughness":1,"isDeleted":false,"startBinding":null,"endArrowhead":null,"opacity":100,"updated":1772873306458,"locked":false,"points":[[0,0],[522,0]],"polygon":false,"version":5,"type":"line","backgroundColor":"transparent","index":"b7f","roundness":null,"lastCommittedPoint":null,"height":0,"link":null,"startArrowhead":null,"strokeColor":"#e5e7eb","fillStyle":"solid","groupIds":[],"endBinding":null,"versionNonce":36962116,"frameId":null,"boundElements":[],"x":727,"angle":0,"y":-151,"width":522},{"seed":364351044,"strokeStyle":"solid","id":"-2U2jzUTuOjScP3_4GHLO","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772873306458,"locked":false,"text":"Adding more trie replicas scales uniformly but the hot\nprefix problem is not uniform — 0.1% of prefixes\naccount for 50%+ of traffic. CDN caching targets\nexactly this skew: the 1,000 most popular prefixes\nabsorb 80% of load at the CDN layer, leaving trie\nservers to handle only the long tail. Cost per request\nat CDN is orders of magnitude cheaper than a trie hop.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b7g","roundness":null,"containerId":null,"originalText":"Adding more trie replicas scales uniformly but the hot\nprefix problem is not uniform — 0.1% of prefixes\naccount for 50%+ of traffic. CDN caching targets\nexactly this skew: the 1,000 most popular prefixes\nabsorb 80% of load at the CDN layer, leaving trie\nservers to handle only the long tail. Cost per request\nat CDN is orders of magnitude cheaper than a trie hop.","height":122.5,"link":null,"strokeColor":"#374151","fillStyle":"solid","groupIds":[],"versionNonce":1786873596,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":727,"angle":0,"y":-139,"width":380.5474853515625},{"seed":934618564,"strokeStyle":"solid","id":"5EnppqmtG0WY5zoMWQ2-w","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":17,"opacity":100,"verticalAlign":"top","updated":1772873306458,"locked":false,"text":"V4 to V5: Personalization on the Miss Path Only","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b7h","roundness":null,"containerId":null,"originalText":"V4 to V5: Personalization on the Miss Path Only","height":21.25,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":494630596,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":727,"angle":0,"y":35,"width":402.6785888671875},{"seed":85183812,"strokeStyle":"solid","id":"JlqNIGytV98s6a-dLFpw1","strokeWidth":1,"roughness":1,"isDeleted":false,"startBinding":null,"endArrowhead":null,"opacity":100,"updated":1772873306458,"locked":false,"points":[[0,0],[522,0]],"polygon":false,"version":5,"type":"line","backgroundColor":"transparent","index":"b7i","roundness":null,"lastCommittedPoint":null,"height":0,"link":null,"startArrowhead":null,"strokeColor":"#e5e7eb","fillStyle":"solid","groupIds":[],"endBinding":null,"versionNonce":590301052,"frameId":null,"boundElements":[],"x":727,"angle":0,"y":59,"width":522},{"seed":254903492,"strokeStyle":"solid","id":"f3wxRTWLKzFsPG1YMYNX5","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772873306458,"locked":false,"text":"Personalization only activates on CDN cache misses —\nthe 20% of requests that reach the API layer. Popular\nprefixes served from CDN are global, not personalized.\nThis is a deliberate trade-off: it means users typing\n\"the\" see global suggestions, not their personal history.\nBut it keeps CDN hit rate at 80% and avoids building\nper-user CDN keys which would explode cache cardinality.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b7j","roundness":null,"containerId":null,"originalText":"Personalization only activates on CDN cache misses —\nthe 20% of requests that reach the API layer. Popular\nprefixes served from CDN are global, not personalized.\nThis is a deliberate trade-off: it means users typing\n\"the\" see global suggestions, not their personal history.\nBut it keeps CDN hit rate at 80% and avoids building\nper-user CDN keys which would explode cache cardinality.","height":122.5,"link":null,"strokeColor":"#374151","fillStyle":"solid","groupIds":[],"versionNonce":1609039428,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":727,"angle":0,"y":71,"width":388.58355712890625},{"seed":195841092,"strokeStyle":"solid","id":"kn2ssLjb1PS5Oj7-SN3Ur","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":17,"opacity":100,"verticalAlign":"top","updated":1772873306458,"locked":false,"text":"V5 to V6: Trending Detection Design","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b7k","roundness":null,"containerId":null,"originalText":"V5 to V6: Trending Detection Design","height":21.25,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":1901131772,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":727,"angle":0,"y":237,"width":306.67974853515625},{"seed":1281500100,"strokeStyle":"solid","id":"MvFQSwhLVX0q454INf6mv","strokeWidth":1,"roughness":1,"isDeleted":false,"startBinding":null,"endArrowhead":null,"opacity":100,"updated":1772873306458,"locked":false,"points":[[0,0],[522,0]],"polygon":false,"version":5,"type":"line","backgroundColor":"transparent","index":"b7l","roundness":null,"lastCommittedPoint":null,"height":0,"link":null,"startArrowhead":null,"strokeColor":"#e5e7eb","fillStyle":"solid","groupIds":[],"endBinding":null,"versionNonce":1113036228,"frameId":null,"boundElements":[],"x":727,"angle":0,"y":261,"width":522},{"seed":930155332,"strokeStyle":"solid","id":"6IdlkQePzfDKyDe_iiLf4","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772873306458,"locked":false,"text":"Trending uses velocity (rate of change) not frequency.\nA query appearing 10K times in the last 5 minutes\nranks higher than one appearing 1M times historically.\nRedis sorted sets with expiring members implement\nsliding windows efficiently. Multi-region deployment\nwith async trie replication adds availability — Region B\ncan serve stale-by-100ms suggestions if Region A fails,\nwhich is far better than no suggestions at all.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b7m","roundness":null,"containerId":null,"originalText":"Trending uses velocity (rate of change) not frequency.\nA query appearing 10K times in the last 5 minutes\nranks higher than one appearing 1M times historically.\nRedis sorted sets with expiring members implement\nsliding windows efficiently. Multi-region deployment\nwith async trie replication adds availability — Region B\ncan serve stale-by-100ms suggestions if Region A fails,\nwhich is far better than no suggestions at all.","height":140,"link":null,"strokeColor":"#374151","fillStyle":"solid","groupIds":[],"versionNonce":1625856124,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":727,"angle":0,"y":273,"width":377.103515625},{"seed":1060569796,"strokeStyle":"solid","id":"rpLGa0OIycCOqFZH4Gw_9","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":17,"opacity":100,"verticalAlign":"top","updated":1772873306458,"locked":false,"text":"The Pattern","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b7n","roundness":null,"containerId":null,"originalText":"The Pattern","height":21.25,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":1911045444,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":727,"angle":0,"y":537,"width":104.99192810058594},{"seed":1515326020,"strokeStyle":"solid","id":"wGHzUN88nfpQcRGXvMeKu","strokeWidth":1,"roughness":1,"isDeleted":false,"startBinding":null,"endArrowhead":null,"opacity":100,"updated":1772873306458,"locked":false,"points":[[0,0],[522,0]],"polygon":false,"version":5,"type":"line","backgroundColor":"transparent","index":"b7o","roundness":null,"lastCommittedPoint":null,"height":0,"link":null,"startArrowhead":null,"strokeColor":"#e5e7eb","fillStyle":"solid","groupIds":[],"endBinding":null,"versionNonce":767043836,"frameId":null,"boundElements":[],"x":727,"angle":0,"y":261,"width":522},{"seed":2074091972,"strokeStyle":"solid","id":"Fb6My7K_xjMaOOLvkcSwL","strokeWidth":1,"roughness":1,"isDeleted":false,"startBinding":null,"endArrowhead":null,"opacity":100,"updated":1772873306458,"locked":false,"points":[[0,0],[522,0]],"polygon":false,"version":5,"type":"line","backgroundColor":"transparent","index":"b7p","roundness":null,"lastCommittedPoint":null,"height":0,"link":null,"startArrowhead":null,"strokeColor":"#e5e7eb","fillStyle":"solid","groupIds":[],"endBinding":null,"versionNonce":1207432388,"frameId":null,"boundElements":[],"x":727,"angle":0,"y":561,"width":522},{"seed":171919684,"strokeStyle":"solid","id":"ndNU49bvYcO9SGqpHhnDc","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772873306458,"locked":false,"text":"Every upgrade in this system follows the same pattern:\nisolate the bottleneck to its component, then replace\nonly that component's contract with one that scales.\nThe read path (trie) was sharded first because it was\nthe ceiling. The write path (log ingest) was decoupled\nsecond because it blocked the read path. Caching was\nadded third to exploit skew. Personalization was added\nlast because it only matters at scale and degrades\ngracefully if unavailable. Trending and multi-region\ncame last because they require all prior layers to exist.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b7q","roundness":null,"containerId":null,"originalText":"Every upgrade in this system follows the same pattern:\nisolate the bottleneck to its component, then replace\nonly that component's contract with one that scales.\nThe read path (trie) was sharded first because it was\nthe ceiling. The write path (log ingest) was decoupled\nsecond because it blocked the read path. Caching was\nadded third to exploit skew. Personalization was added\nlast because it only matters at scale and degrades\ngracefully if unavailable. Trending and multi-region\ncame last because they require all prior layers to exist.","height":175,"link":null,"strokeColor":"#374151","fillStyle":"solid","groupIds":[],"versionNonce":1262594428,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":727,"angle":0,"y":573,"width":381.37347412109375},{"isDeleted":false,"locked":false,"strokeColor":"#22c55e","link":null,"roughness":1,"groupIds":[],"index":"b7r","backgroundColor":"#f0fdf4","angle":0,"fillStyle":"solid","strokeWidth":2,"version":5,"roundness":{"type":3},"type":"rectangle","updated":1772873306458,"id":"1REzRCHMbfqaJ2zTB3Xvy","x":727,"seed":1502445764,"boundElements":[],"y":781,"opacity":100,"height":116,"width":526,"frameId":null,"strokeStyle":"solid","versionNonce":1109703748},{"seed":556320836,"strokeStyle":"solid","id":"r4lkiENR8-H254-lbuovL","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772873306458,"locked":false,"text":"Key insight: The evolution order is not arbitrary.\nSharding before async ingest creates 40 blackout\nwindows. Personalization before caching destroys\nthe hit rate. The sequence is the architecture.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b7s","roundness":null,"containerId":null,"originalText":"Key insight: The evolution order is not arbitrary.\nSharding before async ingest creates 40 blackout\nwindows. Personalization before caching destroys\nthe hit rate. The sequence is the architecture.","height":70,"link":null,"strokeColor":"#14532d","fillStyle":"solid","groupIds":[],"versionNonce":1824987644,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":743,"angle":0,"y":797,"width":339.45761108398438},{"seed":1961828292,"strokeStyle":"dashed","id":"oVvAuMWH4Kbpt90IFocfG","strokeWidth":1,"roughness":1,"isDeleted":false,"startBinding":null,"endArrowhead":null,"opacity":100,"updated":1772873306458,"locked":false,"points":[[0,0],[1450,0]],"polygon":false,"version":5,"type":"line","backgroundColor":"transparent","index":"b7t","roundness":null,"lastCommittedPoint":null,"height":0,"link":null,"startArrowhead":null,"strokeColor":"#9ca3af","fillStyle":"solid","groupIds":[],"endBinding":null,"versionNonce":2051838916,"frameId":null,"boundElements":[],"x":-149,"angle":0,"y":967,"width":1450},{"isDeleted":false,"locked":false,"strokeColor":"#b45309","link":null,"roughness":1,"groupIds":[],"index":"b7u","backgroundColor":"#b45309","angle":0,"fillStyle":"solid","strokeWidth":2,"version":5,"roundness":null,"type":"ellipse","updated":1772873306458,"id":"5tArDJLmOPcdp0dK0wW-d","x":-139,"seed":1023313732,"boundElements":[],"y":1011,"opacity":100,"height":42,"width":42,"frameId":null,"strokeStyle":"solid","versionNonce":222984828},{"seed":766836420,"strokeStyle":"solid","id":"KeLH3_Cid9VgQKPJlTe8f","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":16,"opacity":100,"verticalAlign":"top","updated":1772873306458,"locked":false,"text":"S7","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b7v","roundness":null,"containerId":null,"originalText":"S7","height":20,"link":null,"strokeColor":"#ffffff","fillStyle":"solid","groupIds"