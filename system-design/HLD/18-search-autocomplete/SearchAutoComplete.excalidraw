2ZfEkwdkKttdKCD-tyc8S","originalText":"O(log N) velocity windows","height":15,"link":null,"strokeColor":"#c4b5fd","fillStyle":"solid","groupIds":[],"versionNonce":933898308,"textAlign":"center","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":248.33599853515625,"angle":0,"y":6026.5,"width":149.3280029296875},{"isDeleted":false,"locked":false,"strokeColor":"#c4b5fd","link":null,"roughness":1,"groupIds":[],"index":"bG3","backgroundColor":"#f5f3ff","angle":0,"fillStyle":"solid","strokeWidth":1,"version":6,"roundness":null,"type":"rectangle","updated":1772873306458,"id":"I4cz1y1pHTDUk_qrfl0WG","x":441,"seed":1446380228,"boundElements":[{"type":"text","id":"cngE6N8Sz3Kju1NMch-8L"}],"y":6021,"opacity":100,"height":26,"width":190,"frameId":null,"strokeStyle":"solid","versionNonce":14086140},{"seed":963709508,"strokeStyle":"solid","id":"cngE6N8Sz3Kju1NMch-8L","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":12,"opacity":100,"verticalAlign":"middle","updated":1772873306472,"locked":false,"text":"Spark batch (too slow)","version":8,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bG4","roundness":null,"containerId":"I4cz1y1pHTDUk_qrfl0WG","originalText":"Spark batch (too slow)","height":15,"link":null,"strokeColor":"#c4b5fd","fillStyle":"solid","groupIds":[],"versionNonce":1950646212,"textAlign":"center","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":468.24800109863281,"angle":0,"y":6026.5,"width":135.50399780273438},{"isDeleted":false,"locked":false,"strokeColor":"#c7d2fe","link":null,"roughness":1,"groupIds":[],"index":"bG5","backgroundColor":"#f8faff","angle":0,"fillStyle":"solid","strokeWidth":1.5,"version":6,"roundness":null,"type":"rectangle","updated":1772873306458,"id":"JbYop9vYXg4gRmsYof7rd","x":709,"seed":517939652,"boundElements":[],"y":5465,"opacity":100,"height":832,"width":562,"frameId":null,"strokeStyle":"solid","versionNonce":2096074876},{"seed":1839089988,"strokeStyle":"solid","id":"vhijkvrmhkvULqO-YcesT","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":17,"opacity":100,"verticalAlign":"top","updated":1772873306458,"locked":false,"text":"30-Second Verbal Summary","version":6,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bG6","roundness":null,"containerId":null,"originalText":"30-Second Verbal Summary","height":21.25,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":938263876,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":727,"angle":0,"y":5483,"width":216.8858642578125},{"seed":2030862532,"strokeStyle":"solid","id":"Um0DKq0w0QyIcTT_rDD9r","strokeWidth":1,"roughness":1,"isDeleted":false,"startBinding":null,"endArrowhead":null,"opacity":100,"updated":1772873306458,"locked":false,"points":[[0,0],[522,0]],"polygon":false,"version":6,"type":"line","backgroundColor":"transparent","index":"bG7","roundness":null,"lastCommittedPoint":null,"height":0,"link":null,"startArrowhead":null,"strokeColor":"#e5e7eb","fillStyle":"solid","groupIds":[],"endBinding":null,"versionNonce":505422076,"frameId":null,"boundElements":[],"x":727,"angle":0,"y":5507,"width":522},{"seed":2026358852,"strokeStyle":"solid","id":"qXAWg-kFUmFKB8prigU9P","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772873306458,"locked":false,"text":"Search autocomplete serves ranked completions in\nunder 100ms at 200K requests per second. The core\nstructure is a prefix trie with top-K pre-computed at\nevery node — O(1) reads. The trie lives entirely in\nmemory across 15 sharded replicas because disk is\ntoo slow. Query logs flow async through Kafka into\nworkers that apply incremental delta updates to the\nprefix chain, eliminating the nightly rebuild blackout.\nCDN edge caching absorbs 80% of traffic before it\never reaches the trie. Trending uses velocity — rate\nof change over 5-minute windows — not raw frequency.\nThe hardest problem is write amplification: one log\nevent updates 10 ancestor nodes, producing 1 million\ntrie writes per second at peak.","version":6,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bG8","roundness":null,"containerId":null,"originalText":"Search autocomplete serves ranked completions in\nunder 100ms at 200K requests per second. The core\nstructure is a prefix trie with top-K pre-computed at\nevery node — O(1) reads. The trie lives entirely in\nmemory across 15 sharded replicas because disk is\ntoo slow. Query logs flow async through Kafka into\nworkers that apply incremental delta updates to the\nprefix chain, eliminating the nightly rebuild blackout.\nCDN edge caching absorbs 80% of traffic before it\never reaches the trie. Trending uses velocity — rate\nof change over 5-minute windows — not raw frequency.\nThe hardest problem is write amplification: one log\nevent updates 10 ancestor nodes, producing 1 million\ntrie writes per second at peak.","height":245,"link":null,"strokeColor":"#374151","fillStyle":"solid","groupIds":[],"versionNonce":1814789316,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":727,"angle":0,"y":5519,"width":374.90560913085938},{"seed":11411396,"strokeStyle":"solid","id":"kszQNQ3uCZdewQpTe_DKR","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":17,"opacity":100,"verticalAlign":"top","updated":1772873306458,"locked":false,"text":"Likely Follow-up Questions","version":6,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bG9","roundness":null,"containerId":null,"originalText":"Likely Follow-up Questions","height":21.25,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":1542103420,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":727,"angle":0,"y":5795,"width":216.64784240722656},{"seed":2027784004,"strokeStyle":"solid","id":"AO_TP467L1rrM8d6MqwB_","strokeWidth":1,"roughness":1,"isDeleted":false,"startBinding":null,"endArrowhead":null,"opacity":100,"updated":1772873306458,"locked":false,"points":[[0,0],[522,0]],"polygon":false,"version":6,"type":"line","backgroundColor":"transparent","index":"bGA","roundness":null,"lastCommittedPoint":null,"height":0,"link":null,"startArrowhead":null,"strokeColor":"#e5e7eb","fillStyle":"solid","groupIds":[],"endBinding":null,"versionNonce":648496196,"frameId":null,"boundElements":[],"x":727,"angle":0,"y":5819,"width":522},{"seed":364117700,"strokeStyle":"solid","id":"AONQx_Z1P1C3nOktal_VM","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772873306458,"locked":false,"text":"Q: How do you handle the hot prefix problem for 'a'?\nCDN caches top prefixes at TTL=60s so 'a' is almost\nalways a cache hit. Prefix-range sharding isolates it\non its own shard. A dedicated read replica for the\ntop-100 prefixes can be added for extreme cases.\n\nQ: How do you ensure consistency during rolling deploy?\nTop-K JSON is replaced atomically per node. Kafka\npartition-level ordering ensures prefix chain updates\napply in order across old and new workers. Idempotency\nkey prevents double-updates on version mismatch.\n\nQ: How would you scale to 2M req\/s — 10x growth?\nAdd CDN PoPs first — scales without coordination.\nIncrease trie shards from 5 to 50 with finer ranges.\nSplit Kafka consumer groups for more worker processes.\nThe shard architecture was designed for linear scale-out.","version":6,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bGB","roundness":null,"containerId":null,"originalText":"Q: How do you handle the hot prefix problem for 'a'?\nCDN caches top prefixes at TTL=60s so 'a' is almost\nalways a cache hit. Prefix-range sharding isolates it\non its own shard. A dedicated read replica for the\ntop-100 prefixes can be added for extreme cases.\n\nQ: How do you ensure consistency during rolling deploy?\nTop-K JSON is replaced atomically per node. Kafka\npartition-level ordering ensures prefix chain updates\napply in order across old and new workers. Idempotency\nkey prevents double-updates on version mismatch.\n\nQ: How would you scale to 2M req\/s — 10x growth?\nAdd CDN PoPs first — scales without coordination.\nIncrease trie shards from 5 to 50 with finer ranges.\nSplit Kafka consumer groups for more worker processes.\nThe shard architecture was designed for linear scale-out.","height":297.5,"link":null,"strokeColor":"#374151","fillStyle":"solid","groupIds":[],"versionNonce":1838223868,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":727,"angle":0,"y":5831,"width":393.74951171875},{"seed":1339000388,"strokeStyle":"solid","id":"yO6Y691C6xjmQwl8EwqFk","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":17,"opacity":100,"verticalAlign":"top","updated":1772873306458,"locked":false,"text":"Senior vs Staff Answer","version":6,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bGC","roundness":null,"containerId":null,"originalText":"Senior vs Staff Answer","height":21.25,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":1027480516,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":727,"angle":0,"y":6097,"width":191.24980163574219},{"seed":1544428996,"strokeStyle":"solid","id":"TeCRG1moMGiNPOWf3aFp_","strokeWidth":1,"roughness":1,"isDeleted":false,"startBinding":null,"endArrowhead":null,"opacity":100,"updated":1772873306458,"locked":false,"points":[[0,0],[522,0]],"polygon":false,"version":6,"type":"line","backgroundColor":"transparent","index":"bGD","roundness":null,"lastCommittedPoint":null,"height":0,"link":null,"startArrowhead":null,"strokeColor":"#e5e7eb","fillStyle":"solid","groupIds":[],"endBinding":null,"versionNonce":1377137276,"frameId":null,"boundElements":[],"x":727,"angle":0,"y":6121,"width":522},{"seed":596493636,"strokeStyle":"solid","id":"pXuOkMtvOk38Ars4fEbk2","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772873306458,"locked":false,"text":"A senior engineer designs the read path well: sharded\ntrie, pre-computed top-K, CDN caching, Kafka async\ningest. They get the latency math right and identify\nthe trie as the bottleneck.\n\nA staff engineer raises write amplification math\nunprompted, quantifies the 1M writes per second\nbefore being asked, designs idempotency proactively\nrather than as an afterthought, identifies the nightly\nbatch rebuild blackout as an existential availability\nproblem before the interviewer mentions it, and frames\nthe CDN TTL as a content-safety trade-off — not just\na performance detail. The staff answer also includes\na concrete failover runbook and recognizes that the\norder of evolution matters: sharding before async\ningest creates 40 nightly blackout windows.","version":6,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bGE","roundness":null,"containerId":null,"originalText":"A senior engineer designs the read path well: sharded\ntrie, pre-computed top-K, CDN caching, Kafka async\ningest. They get the latency math right and identify\nthe trie as the bottleneck.\n\nA staff engineer raises write amplification math\nunprompted, quantifies the 1M writes per second\nbefore being asked, designs idempotency proactively\nrather than as an afterthought, identifies the nightly\nbatch rebuild blackout as an existential availability\nproblem before the interviewer mentions it, and frames\nthe CDN TTL as a content-safety trade-off — not just\na performance detail. The staff answer also includes\na concrete failover runbook and recognizes that the\norder of evolution matters: sharding before async\ningest creates 40 nightly blackout windows.","height":280,"link":null,"strokeColor":"#374151","fillStyle":"solid","groupIds":[],"versionNonce":437125956,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":727,"angle":0,"y":6133,"width":389.74560546875},{"isDeleted":false,"locked":false,"strokeColor":"#059669","link":null,"roughness":1,"groupIds":[],"index":"bGF","backgroundColor":"#f0fdf4","angle":0,"fillStyle":"solid","strokeWidth":2,"version":6,"roundness":{"type":3},"type":"rectangle","updated":1772873306458,"id":"nuKHBVT5F9e5yrtL_zbw7","x":727,"seed":1001159876,"boundElements":[],"y":6271,"opacity":100,"height":122,"width":526,"frameId":null,"strokeStyle":"solid","versionNonce":1480180476},{"seed":1577600068,"strokeStyle":"solid","id":"qHxNUYygoWx8HA4jyI96O","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772873306458,"locked":false,"text":"Key insight: What makes this design memorable is the\nwrite amplification inversion — the system deliberately\nmakes writes 20x more expensive so reads are always\nO(1). Every other decision (CDN, Kafka, sharding,\nvelocity trending) is an application of the same\nprinciple: pay complexity costs at write time, keep\nthe read critical path unconditionally fast.","version":6,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bGG","roundness":null,"containerId":null,"originalText":"Key insight: What makes this design memorable is the\nwrite amplification inversion — the system deliberately\nmakes writes 20x more expensive so reads are always\nO(1). Every other decision (CDN, Kafka, sharding,\nvelocity trending) is an application of the same\nprinciple: pay complexity costs at write time, keep\nthe read critical path unconditionally fast.","height":122.5,"link":null,"strokeColor":"#14532d","fillStyle":"solid","groupIds":[],"versionNonce":863304388,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":743,"angle":0,"y":6287,"width":370.467529296875}],"source":"https:\/\/excalidraw.com","appState":{"shouldCacheIgnoreZoom":false,"exportScale":2,"defaultSidebarD