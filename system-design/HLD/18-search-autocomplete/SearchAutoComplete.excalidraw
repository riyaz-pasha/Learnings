null,"boundElements":[],"x":361,"angle":0,"y":5111,"width":214.07962036132812},{"isDeleted":false,"locked":false,"strokeColor":"#6b7280","link":null,"roughness":1,"groupIds":[],"index":"bEp","backgroundColor":"#f3f4f6","angle":0,"fillStyle":"solid","strokeWidth":1,"version":6,"roundness":{"type":3},"type":"rectangle","updated":1772873306458,"id":"az0mfeRbbf8mh-dhZyT1V","x":299,"seed":1651026116,"boundElements":[{"type":"text","id":"AdRpcsz2Buhz8ezo5do4K"}],"y":5135,"opacity":100,"height":35,"width":55,"frameId":null,"strokeStyle":"solid","versionNonce":1144115268},{"seed":878637124,"strokeStyle":"solid","id":"AdRpcsz2Buhz8ezo5do4K","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":10,"opacity":100,"verticalAlign":"middle","updated":1772873306472,"locked":false,"text":"Revisit\nif","version":7,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bEq","roundness":null,"containerId":"az0mfeRbbf8mh-dhZyT1V","originalText":"Revisit if","height":25,"link":null,"strokeColor":"#6b7280","fillStyle":"solid","groupIds":[],"versionNonce":1412335556,"textAlign":"center","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":309.59000015258789,"angle":0,"y":5140,"width":33.819999694824219},{"seed":253773764,"strokeStyle":"solid","id":"8nZM4Qhvu8S0A60XomY30","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":12,"opacity":100,"verticalAlign":"top","updated":1772873306458,"locked":false,"text":"Bot attacks become a serious traffic vector","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bEr","roundness":null,"containerId":null,"originalText":"Bot attacks become a serious traffic vector","height":15,"link":null,"strokeColor":"#374151","fillStyle":"solid","groupIds":[],"versionNonce":1637296068,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":361,"angle":0,"y":5139,"width":262.24755859375},{"isDeleted":false,"locked":false,"strokeColor":"#c7d2fe","link":null,"roughness":1,"groupIds":[],"index":"bEs","backgroundColor":"#f8faff","angle":0,"fillStyle":"solid","strokeWidth":1.5,"version":5,"roundness":null,"type":"rectangle","updated":1772873306458,"id":"RYenT1-F8YM-OQqkhwEVr","x":709,"seed":1187688260,"boundElements":[],"y":4501,"opacity":100,"height":860,"width":562,"frameId":null,"strokeStyle":"solid","versionNonce":77801084},{"seed":2075928260,"strokeStyle":"solid","id":"glUtT6xdXKk8Css0Fc-av","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":17,"opacity":100,"verticalAlign":"top","updated":1772873306458,"locked":false,"text":"The Hardest Trade-off","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bEt","roundness":null,"containerId":null,"originalText":"The Hardest Trade-off","height":21.25,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":1734709060,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":727,"angle":0,"y":4519,"width":192.796875},{"seed":311602756,"strokeStyle":"solid","id":"bY9nv7qbQ2S_HzgTczR4-","strokeWidth":1,"roughness":1,"isDeleted":false,"startBinding":null,"endArrowhead":null,"opacity":100,"updated":1772873306458,"locked":false,"points":[[0,0],[522,0]],"polygon":false,"version":5,"type":"line","backgroundColor":"transparent","index":"bEu","roundness":null,"lastCommittedPoint":null,"height":0,"link":null,"startArrowhead":null,"strokeColor":"#e5e7eb","fillStyle":"solid","groupIds":[],"endBinding":null,"versionNonce":1458632444,"frameId":null,"boundElements":[],"x":727,"angle":0,"y":4543,"width":522},{"seed":741098948,"strokeStyle":"solid","id":"u9bNcWGDn6jPjot4Tv4DM","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772873306458,"locked":false,"text":"The hardest decision was pre-computed top-K versus\non-demand computation at read time. The case for\non-demand is compelling: it is architecturally simpler,\navoiding all write amplification complexity, and it\nnaturally stays fresh because it computes from live\ndata every read. At small scale it works perfectly.\nThe reason it must be rejected is purely mathematical:\n200K reads per second times the O(K log K) sort cost\nper read, across all prefix depths, produces a total\nCPU load that requires an order of magnitude more\ntrie servers than the pre-compute approach. The write\npath's 20x amplification is painful to operate, but it\nconcentrates pain in the async pipeline where latency\ndoes not matter — never on the read critical path.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bEv","roundness":null,"containerId":null,"originalText":"The hardest decision was pre-computed top-K versus\non-demand computation at read time. The case for\non-demand is compelling: it is architecturally simpler,\navoiding all write amplification complexity, and it\nnaturally stays fresh because it computes from live\ndata every read. At small scale it works perfectly.\nThe reason it must be rejected is purely mathematical:\n200K reads per second times the O(K log K) sort cost\nper read, across all prefix depths, produces a total\nCPU load that requires an order of magnitude more\ntrie servers than the pre-compute approach. The write\npath's 20x amplification is painful to operate, but it\nconcentrates pain in the async pipeline where latency\ndoes not matter — never on the read critical path.","height":245,"link":null,"strokeColor":"#374151","fillStyle":"solid","groupIds":[],"versionNonce":100337348,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":727,"angle":0,"y":4555,"width":375.843505859375},{"seed":497478980,"strokeStyle":"solid","id":"Jt0M-n_sWMb3CP6dAmCpp","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":17,"opacity":100,"verticalAlign":"top","updated":1772873306458,"locked":false,"text":"What Most Designs Get Wrong","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bEw","roundness":null,"containerId":null,"originalText":"What Most Designs Get Wrong","height":21.25,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":808499068,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":727,"angle":0,"y":4845,"width":255.01678466796875},{"seed":1751164100,"strokeStyle":"solid","id":"KbULXgcfHGn7prpowc9g-","strokeWidth":1,"roughness":1,"isDeleted":false,"startBinding":null,"endArrowhead":null,"opacity":100,"updated":1772873306458,"locked":false,"points":[[0,0],[522,0]],"polygon":false,"version":5,"type":"line","backgroundColor":"transparent","index":"bEx","roundness":null,"lastCommittedPoint":null,"height":0,"link":null,"startArrowhead":null,"strokeColor":"#e5e7eb","fillStyle":"solid","groupIds":[],"endBinding":null,"versionNonce":838176324,"frameId":null,"boundElements":[],"x":727,"angle":0,"y":4869,"width":522},{"seed":838298692,"strokeStyle":"solid","id":"x6I75HfJBP7sVwYUaK5zx","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772873306458,"locked":false,"text":"The most common mistake is designing the log\ningestion path as a synchronous write. Candidates\nwho make this error attach a MySQL INSERT to every\nsuggestion request, coupling the read SLA directly to\nwrite throughput. At 200K reads per second with 5\ncompleted searches per user per day, the write path\nreceives 29K inserts per second on average — well\nbeyond a single MySQL instance. The instinct is to\nthen shard MySQL, add connection pooling, and\noptimize indexes. But the correct solution is to not\nhave a synchronous write at all. Kafka decouples the\ntwo paths completely: reads are never slowed by\nwrites, and the ingest pipeline can be scaled,\nreplayed, and monitored independently.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bEy","roundness":null,"containerId":null,"originalText":"The most common mistake is designing the log\ningestion path as a synchronous write. Candidates\nwho make this error attach a MySQL INSERT to every\nsuggestion request, coupling the read SLA directly to\nwrite throughput. At 200K reads per second with 5\ncompleted searches per user per day, the write path\nreceives 29K inserts per second on average — well\nbeyond a single MySQL instance. The instinct is to\nthen shard MySQL, add connection pooling, and\noptimize indexes. But the correct solution is to not\nhave a synchronous write at all. Kafka decouples the\ntwo paths completely: reads are never slowed by\nwrites, and the ingest pipeline can be scaled,\nreplayed, and monitored independently.","height":245,"link":null,"strokeColor":"#374151","fillStyle":"solid","groupIds":[],"versionNonce":1017407484,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":727,"angle":0,"y":4881,"width":377.66357421875},{"isDeleted":false,"locked":false,"strokeColor":"#f59e0b","link":null,"roughness":1,"groupIds":[],"index":"bEz","backgroundColor":"#fffbeb","angle":0,"fillStyle":"solid","strokeWidth":2,"version":5,"roundness":{"type":3},"type":"rectangle","updated":1772873306458,"id":"QXLoL4MUhMZVtvhDse_6I","x":727,"seed":1011434436,"boundElements":[],"y":5165,"opacity":100,"height":128,"width":526,"frameId":null,"strokeStyle":"solid","versionNonce":473114052},{"seed":1567894340,"strokeStyle":"solid","id":"neZum-tx1PdNPbC0AN_zP","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772873306458,"locked":false,"text":"Key insight: Every trade-off in this system is really\none question — where should complexity live? Pre-\ncompute moves complexity to the write path where\nlatency is free. Kafka moves complexity to the\ninfrastructure layer where it is observable and\nreplayable. CDN TTL moves complexity to ops policy.\nThe 100ms SLA is protected by moving all hard\nwork away from the read critical path.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bF0","roundness":null,"containerId":null,"originalText":"Key insight: Every trade-off in this system is really\none question — where should complexity live? Pre-\ncompute moves complexity to the write path where\nlatency is free. Kafka moves complexity to the\ninfrastructure layer where it is observable and\nreplayable. CDN TTL moves complexity to ops policy.\nThe 100ms SLA is protected by moving all hard\nwork away from the read critical path.","height":140,"link":null,"strokeColor":"#92400e","fillStyle":"solid","groupIds":[],"versionNonce":1347291260,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":743,"angle":0,"y":5181,"width":359.2535400390625},{"seed":2010522308,"strokeStyle":"dashed","id":"pty9VMUjn0ZTILKeqo0ds","strokeWidth":1,"roughness":1,"isDeleted":false,"startBinding":null,"endArrowhead":null,"opacity":100,"updated":1772873306454,"locked":false,"points":[[0,0],[1450,0]],"polygon":false,"version":5,"type":"line","backgroundColor":"transparent","index":"bF1","roundness":null,"lastCommittedPoint":null,"height":0,"link":null,"startArrowhead":null,"strokeColor":"#9ca3af","fillStyle":"solid","groupIds":[],"endBinding":null,"versionNonce":841309052,"frameId":null,"boundElements":[],"x":-149,"angle":0,"y":5353,"width":1450},{"isDeleted":false,"locked":false,"strokeColor":"#059669","link":null,"roughness":1,"groupIds":[],"index":"bF2","backgroundColor":"#059669","angle":0,"fillStyle":"solid","strokeWidth":2,"version":5,"roundness":null,"type":"ellipse","updated":1772873306454,"id":"n3mMNQbY8Y0XFx_3n8HJy","x":-139,"seed":1913465412,"boundElements":[],"y":5397,"opacity":100,"height":42,"width":42,"frameId":null,"strokeStyle":"solid","versionNonce":1617202172},{"seed":787956164,"strokeStyle":"solid","id":"GukQu78ZSPBCZOtCjyZ4o","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verti