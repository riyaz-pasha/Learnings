#22c55e","fillStyle":"solid","groupIds":[],"versionNonce":733264708,"textAlign":"center","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-48.840492248535156,"angle":0,"y":-1913.5,"width":239.68098449707031},{"isDeleted":false,"locked":false,"strokeColor":"#ef4444","link":null,"roughness":1,"groupIds":[],"index":"b4g","backgroundColor":"#fff1f2","angle":0,"fillStyle":"solid","strokeWidth":2,"version":5,"roundness":{"type":3},"type":"rectangle","updated":1772873306458,"id":"B5-CiHu8NO4pwD9oBp434","x":271,"seed":870148932,"boundElements":[{"type":"text","id":"4NHUpdPqNw3s4SnQ1Ji4k"}],"y":-1931,"opacity":100,"height":100,"width":380,"frameId":null,"strokeStyle":"solid","versionNonce":1452238972},{"seed":790061764,"strokeStyle":"solid","id":"4NHUpdPqNw3s4SnQ1Ji4k","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"middle","updated":1772873306467,"locked":false,"text":"Breaks Above ~2K req\/s Because...\nSingle trie = no horizontal scale.\nNightly rebuild = 10-30 min read blackout.\nGC pauses spike p99 above 100ms.","version":7,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b4h","roundness":null,"containerId":"B5-CiHu8NO4pwD9oBp434","originalText":"Breaks Above ~2K req\/s Because...\nSingle trie = no horizontal scale.\nNightly rebuild = 10-30 min read blackout.\nGC pauses spike p99 above 100ms.","height":65,"link":null,"strokeColor":"#ef4444","fillStyle":"solid","groupIds":[],"versionNonce":1334096580,"textAlign":"center","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":330.69448852539062,"angle":0,"y":-1913.5,"width":260.61102294921875},{"isDeleted":false,"locked":false,"strokeColor":"#c7d2fe","link":null,"roughness":1,"groupIds":[],"index":"b4i","backgroundColor":"#f8faff","angle":0,"fillStyle":"solid","strokeWidth":1.5,"version":5,"roundness":null,"type":"rectangle","updated":1772873306458,"id":"47mVuQtt-JNB9Nuo2IkJG","x":709,"seed":791046724,"boundElements":[],"y":-2267,"opacity":100,"height":870,"width":562,"frameId":null,"strokeStyle":"solid","versionNonce":1711601916},{"seed":1994949060,"strokeStyle":"solid","id":"ika0jeBw1FBrmdKp2MhZB","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":18,"opacity":100,"verticalAlign":"top","updated":1772873306458,"locked":false,"text":"Why Start Simple","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b4j","roundness":null,"containerId":null,"originalText":"Why Start Simple","height":22.5,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":597697732,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":727,"angle":0,"y":-2249,"width":148.62591552734375},{"seed":1031514436,"strokeStyle":"solid","id":"vEhAf8KgSS9WRzC6f9KCM","strokeWidth":1,"roughness":1,"isDeleted":false,"startBinding":null,"endArrowhead":null,"opacity":100,"updated":1772873306458,"locked":false,"points":[[0,0],[522,0]],"polygon":false,"version":5,"type":"line","backgroundColor":"transparent","index":"b4k","roundness":null,"lastCommittedPoint":null,"height":0,"link":null,"startArrowhead":null,"strokeColor":"#e5e7eb","fillStyle":"solid","groupIds":[],"endBinding":null,"versionNonce":24410492,"frameId":null,"boundElements":[],"x":727,"angle":0,"y":-2225,"width":522},{"seed":641589444,"strokeStyle":"solid","id":"UFPpqLm20q0cT3F2dw56i","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772873306458,"locked":false,"text":"The baseline reveals the core read path clearly: a\nprefix arrives, the trie is traversed, and pre-computed\ntop-K results are returned without any aggregation.\nThis simplicity is its strength at small scale. The\nin-memory lookup is genuinely fast — microseconds\nper query — and the nightly batch rebuild keeps the\nwrite path completely decoupled from reads.\n\nIn a system design interview, starting here shows\nyou understand what problem is actually being solved\nbefore reaching for distributed systems complexity.\nThe baseline also exposes the precise failure mode,\nwhich makes the subsequent evolution feel motivated\nrather than arbitrary.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b4l","roundness":null,"containerId":null,"originalText":"The baseline reveals the core read path clearly: a\nprefix arrives, the trie is traversed, and pre-computed\ntop-K results are returned without any aggregation.\nThis simplicity is its strength at small scale. The\nin-memory lookup is genuinely fast — microseconds\nper query — and the nightly batch rebuild keeps the\nwrite path completely decoupled from reads.\n\nIn a system design interview, starting here shows\nyou understand what problem is actually being solved\nbefore reaching for distributed systems complexity.\nThe baseline also exposes the precise failure mode,\nwhich makes the subsequent evolution feel motivated\nrather than arbitrary.","height":245,"link":null,"strokeColor":"#374151","fillStyle":"solid","groupIds":[],"versionNonce":1497820228,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":727,"angle":0,"y":-2213,"width":369.34747314453125},{"seed":952969284,"strokeStyle":"solid","id":"Ufq7yS5PpkInH5S5sqaa6","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":18,"opacity":100,"verticalAlign":"top","updated":1772873306458,"locked":false,"text":"The Failure Cascade","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b4m","roundness":null,"containerId":null,"originalText":"The Failure Cascade","height":22.5,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":1948248572,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":727,"angle":0,"y":-2013,"width":177.55191040039062},{"seed":1493663684,"strokeStyle":"solid","id":"nMRw7zE27Xp_G8alf9izF","strokeWidth":1,"roughness":1,"isDeleted":false,"startBinding":null,"endArrowhead":null,"opacity":100,"updated":1772873306458,"locked":false,"points":[[0,0],[522,0]],"polygon":false,"version":5,"type":"line","backgroundColor":"transparent","index":"b4n","roundness":null,"lastCommittedPoint":null,"height":0,"link":null,"startArrowhead":null,"strokeColor":"#e5e7eb","fillStyle":"solid","groupIds":[],"endBinding":null,"versionNonce":1302905796,"frameId":null,"boundElements":[],"x":727,"angle":0,"y":-1989,"width":522},{"seed":1057679172,"strokeStyle":"solid","id":"3VFvVhUAQBUz91q_0tL7Q","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772873306458,"locked":false,"text":"As traffic exceeds ~2K req\/s, the single trie node\nbecomes the bottleneck. JVM garbage collection pauses\non a large heap (the trie can be 50-200 GB) spike p99\nlatency above 100ms. API servers waiting on trie\nresponses begin to queue up. Connection pool exhaustion\nfollows within seconds. The load balancer sees healthy\nAPI servers (they respond to health checks) but every\nreal request times out. Client retries double the load.\nThe system enters a death spiral and becomes\ncompletely unavailable — not degraded, unavailable.\n\nSeparately, every night the batch rebuild holds a\nwrite lock on the trie for 10-30 minutes. During this\nwindow all suggestion reads return stale data or fail\nentirely. At Google-scale this is unacceptable.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b4o","roundness":null,"containerId":null,"originalText":"As traffic exceeds ~2K req\/s, the single trie node\nbecomes the bottleneck. JVM garbage collection pauses\non a large heap (the trie can be 50-200 GB) spike p99\nlatency above 100ms. API servers waiting on trie\nresponses begin to queue up. Connection pool exhaustion\nfollows within seconds. The load balancer sees healthy\nAPI servers (they respond to health checks) but every\nreal request times out. Client retries double the load.\nThe system enters a death spiral and becomes\ncompletely unavailable — not degraded, unavailable.\n\nSeparately, every night the batch rebuild holds a\nwrite lock on the trie for 10-30 minutes. During this\nwindow all suggestion reads return stale data or fail\nentirely. At Google-scale this is unacceptable.","height":262.5,"link":null,"strokeColor":"#374151","fillStyle":"solid","groupIds":[],"versionNonce":1359563388,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":727,"angle":0,"y":-1977,"width":387.63153076171875},{"isDeleted":false,"locked":false,"strokeColor":"#ef4444","link":null,"roughness":1,"groupIds":[],"index":"b4p","backgroundColor":"#fff1f2","angle":0,"fillStyle":"solid","strokeWidth":2,"version":5,"roundness":{"type":3},"type":"rectangle","updated":1772873306458,"id":"aGxgXzIPMM3vC0eHXSj2Y","x":727,"seed":1865768644,"boundElements":[],"y":-1685,"opacity":100,"height":110,"width":526,"frameId":null,"strokeStyle":"solid","versionNonce":384019268},{"seed":841279044,"strokeStyle":"solid","id":"gH-JtAto_VwslCfkHuCSV","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772873306458,"locked":false,"text":"Key insight: The single trie node is the most fragile\npoint. It cannot be horizontally scaled without first\nsolving prefix-range sharding. Every other component\nin the baseline is stateless and trivially scalable.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b4q","roundness":null,"containerId":null,"originalText":"Key insight: The single trie node is the most fragile\npoint. It cannot be horizontally scaled without first\nsolving prefix-range sharding. Every other component\nin the baseline is stateless and trivially scalable.","height":70,"link":null,"strokeColor":"#991b1b","fillStyle":"solid","groupIds":[],"versionNonce":2062719740,"textAlign":"left","fontFamily":5,"lineH