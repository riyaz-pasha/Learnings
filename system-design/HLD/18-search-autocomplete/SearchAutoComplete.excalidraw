oughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772873306454,"locked":false,"text":"1. Write amplification (1M writes\/s at peak)\n   -> 20 async Kafka workers + idempotency\n\n2. Nightly rebuild blackout (10-30 min)\n   -> Incremental delta updates via workers\n   (no full rebuild ever needed)\n\n3. Hot prefix overload (a- gets 10x traffic)\n   -> CDN caches top prefixes at TTL=60s\n   + prefix-range isolation per shard","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bFI","roundness":null,"containerId":null,"originalText":"1. Write amplification (1M writes\/s at peak)\n   -> 20 async Kafka workers + idempotency\n\n2. Nightly rebuild blackout (10-30 min)\n   -> Incremental delta updates via workers\n   (no full rebuild ever needed)\n\n3. Hot prefix overload (a- gets 10x traffic)\n   -> CDN caches top prefixes at TTL=60s\n   + prefix-range isolation per shard","height":162.5,"link":null,"strokeColor":"#374151","fillStyle":"solid","groupIds":[],"versionNonce":231674876,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-93,"angle":0,"y":5737,"width":279.044677734375},{"isDeleted":false,"locked":false,"strokeColor":"#3b82f6","link":null,"roughness":1,"groupIds":[],"index":"bFJ","backgroundColor":"#eff6ff","angle":0,"fillStyle":"solid","strokeWidth":2,"version":5,"roundness":{"type":3},"type":"rectangle","updated":1772873306454,"id":"9XQ3wpfJmbwBvK5IVZN2b","x":283,"seed":1230584260,"boundElements":[],"y":5697,"opacity":100,"height":190,"width":376,"frameId":null,"strokeStyle":"solid","versionNonce":2135110780},{"seed":1897226564,"strokeStyle":"solid","id":"hEWR0DRrMR3qTaQ-FzU3h","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":16,"opacity":100,"verticalAlign":"top","updated":1772873306454,"locked":false,"text":"Key Numbers to Memorize","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bFK","roundness":null,"