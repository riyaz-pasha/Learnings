":[],"index":"b2I","backgroundColor":"#f8faff","angle":0,"fillStyle":"solid","strokeWidth":1,"version":5,"roundness":null,"type":"rectangle","updated":1772873306458,"id":"Wr_LsKqtDYy80v9kmEsJf","x":481,"seed":139294020,"boundElements":[{"type":"text","id":"2yF323wxUCmhoKSAuY4QH"}],"y":-3555,"opacity":100,"height":50,"width":200,"frameId":null,"strokeStyle":"solid","versionNonce":702821244},{"seed":1291201732,"strokeStyle":"solid","id":"2yF323wxUCmhoKSAuY4QH","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"middle","updated":1772873306464,"locked":false,"text":"Trie Sharding","version":7,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b2J","roundness":null,"containerId":"Wr_LsKqtDYy80v9kmEsJf","originalText":"Trie Sharding","height":17.5,"link":null,"strokeColor":"#bfdbfe","fillStyle":"solid","groupIds":[],"versionNonce":255389124,"textAlign":"center","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":535.52100372314453,"angle":0,"y":-3538.75,"width":90.957992553710938},{"isDeleted":false,"locked":false,"strokeColor":"#c7d2fe","link":null,"roughness":1,"groupIds":[],"index":"b2K","backgroundColor":"#f8faff","angle":0,"fillStyle":"solid","strokeWidth":1.5,"version":5,"roundness":null,"type":"rectangle","updated":1772873306458,"id":"hLXdFCYjkBFePEanun16V","x":709,"seed":2057040964,"boundElements":[],"y":-4547,"opacity":100,"height":1090,"width":562,"frameId":null,"strokeStyle":"solid","versionNonce":713581564},{"seed":253545412,"strokeStyle":"solid","id":"OOxjv644DEb3z0ZpAPAx2","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":18,"opacity":100,"verticalAlign":"top","updated":1772873306458,"locked":false,"text":"Design Assumptions","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b2L","roundness":null,"containerId":null,"originalText":"Design Assumptions","height":22.5,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":1805445572,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":727,"angle":0,"y":-4529,"width":172.09786987304688},{"seed":479638340,"strokeStyle":"solid","id":"3Vv0VjuqYtN6DmplM76-a","strokeWidth":1,"roughness":1,"isDeleted":false,"startBinding":null,"endArrowhead":null,"opacity":100,"updated":1772873306458,"locked":false,"points":[[0,0],[522,0]],"polygon":false,"version":5,"type":"line","backgroundColor":"transparent","index":"b2M","roundness":null,"lastCommittedPoint":null,"height":0,"link":null,"startArrowhead":null,"strokeColor":"#e5e7eb","fillStyle":"solid","groupIds":[],"endBinding":null,"versionNonce":1481802876,"frameId":null,"boundElements":[],"x":727,"angle":0,"y":-4505,"width":522},{"seed":1097312964,"strokeStyle":"solid","id":"Vn4bibR4HZKaePgPiFpdf","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772873306458,"locked":false,"text":"English-first assumes locale-partitioned tries are a later\nphase. Launching globally without partitioning causes\ncross-language suggestion contamination.\n\nClient debouncing (~200ms between keystrokes) is assumed.\nWithout it, mobile keyboards firing on every character\nmultiply peak QPS by 10x — a tier-breaking spike.\n\nTop-K is fixed at 10. Variable-K requires different\npre-computation at every trie node — not a config change\nbut a significant infrastructure rebuild.\n\nContent safety in V1 is blocklist-based, not ML.\nContext-sensitive harmful queries can slip through until\na Phase 2 ML classifier is added to the serve path.\n\nTrie updates may lag reads by up to 5 minutes. Real-time\ntrend surfacing requires a synchronous ingestion path\nand significantly higher infrastructure cost.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b2N","roundness":null,"containerId":null,"originalText":"English-first assumes locale-partitioned tries are a later\nphase. Launching globally without partitioning causes\ncross-language suggestion contamination.\n\nClient debouncing (~200ms between keystrokes) is assumed.\nWithout it, mobile keyboards firing on every character\nmultiply peak QPS by 10x — a tier-breaking spike.\n\nTop-K is fixed at 10. Variable-K requires different\npre-computation at every trie node — not a config change\nbut a significant infrastructure rebuild.\n\nContent safety in V1 is blocklist-based, not ML.\nContext-sensitive harmful queries can slip through until\na Phase 2 ML classifier is added to the serve path.\n\nTrie updates may lag reads by up to 5 minutes. Real-time\ntrend surfacing requires a synchronous ingestion path\nand significantly higher infrastructure cost.","height":332.5,"link":null,"strokeColor":"#374151","fillStyle":"solid","groupIds":[],"versionNonce":1868763460,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":727,"angle":0,"y":-4493,"width":411.529541015625},{"seed":539865668,"strokeStyle":"solid","id":"aQfFeMe0LdpsvD7d36RbS","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":18,"opacity":100,"verticalAlign":"top","updated":1772873306458,"locked":false,"text":"The Binding Constraint","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b2O","roundness":null,"containerId":null,"originalText":"The Binding Constraint","height":22.5,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":2030343420,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":727,"angle":0,"y":-4091,"width":204.19184875488281},{"seed":1472645572,"strokeStyle":"solid","id":"tWh3s-JbtydUimgY660Eq","strokeWidth":1,"roughness":1,"isDeleted":false,"startBinding":null,"endArrowhead":null,"opacity":100,"updated":1772873306458,"locked":false,"points":[[0,0],[522,0]],"polygon":false,"version":5,"type":"line","backgroundColor":"transparent","index":"b2P","roundness":null,"lastCommittedPoint":null,"height":0,"link":null,"startArrowhead":null,"strokeColor":"#e5e7eb","fillStyle":"solid","groupIds":[],"endBinding":null,"versionNonce":1995983044,"frameId":null,"boundElements":[],"x":727,"angle":0,"y":-4067,"width":522},{"seed":2068902212,"strokeStyle":"solid","id":"3915g7e7uFumowC95dgaz","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772873306458,"locked":false,"text":"Latency (P99 < 100ms) shapes every other decision.\nIt rules out disk-based trie storage entirely, forces\npre-computation of top-K at every node, constrains\npersonalization depth on the critical path, and sets\nthe minimum replica count to handle 200K req\/s.\n\nA system missing 100ms is not slightly degraded —\nit is broken. Users stop typing before suggestions\nappear, and the feature delivers no value at all.\nEvery trade-off in later sections traces back here.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b2Q","roundness":null,"containerId":null,"originalText":"Latency (P99 < 100ms) shapes every other decision.\nIt rules out disk-based trie storage entirely, forces\npre-computation of top-K at every node, constrains\npersonalization depth on the critical path, and sets\nthe minimum replica count to handle 200K req\/s.\n\nA system missing 100ms is not slightly degraded —\nit is broken. Users stop typing before suggestions\nappear, and the feature delivers no value at all.\nEvery trade-off in later sections traces back here.","height":175,"link":null,"strokeColor":"#374151","fillStyle":"solid","groupIds":[],"versionNonce":1243649404,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":727,"angle":0,"y":-4055,"width":356.56561279296875},{"isDeleted":false,"locked":false,"strokeColor":"#f59e0b","link":null,"roughness":1,"groupIds":[],"index":"b2R","backgroundColor":"#fffbeb","angle":0,"fillStyle":"solid","strokeWidth":2,"version":5,"roundness":{"type":3},"type"