:1.25,"frameId":null,"boundElements":[],"x":353.00398254394531,"angle":0,"y":-1078.625,"width":225.99203491210938},{"isDeleted":false,"locked":false,"strokeColor":"#f59e0b","link":null,"roughness":1,"groupIds":[],"index":"b5O","backgroundColor":"#fffbeb","angle":0,"fillStyle":"solid","strokeWidth":2,"version":5,"roundness":{"type":3},"type":"rectangle","updated":1772873306458,"id":"ocnt925CLL3_xu0RIzWzQ","x":-109,"seed":267457860,"boundElements":[{"type":"text","id":"ZxgvkiR4LtqxOW0vUz95T"}],"y":-953,"opacity":100,"height":130,"width":370,"frameId":null,"strokeStyle":"solid","versionNonce":1434018684},{"seed":1596312772,"strokeStyle":"solid","id":"ZxgvkiR4LtqxOW0vUz95T","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"middle","updated":1772873306468,"locked":false,"text":"BN-3: Synchronous Log DB Write\nThreshold: > ~5,000 writes\/s\nSync SQL INSERT on read critical path;\nconnection pool exhausts at peak.\nCategory: IO","version":7,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b5P","roundness":null,"containerId":"ocnt925CLL3_xu0RIzWzQ","originalText":"BN-3: Synchronous Log DB Write\nThreshold: > ~5,000 writes\/s\nSync SQL INSERT on read critical path;\nconnection pool exhausts at peak.\nCategory: IO","height":81.25,"link":null,"strokeColor":"#f59e0b","fillStyle":"solid","groupIds":[],"versionNonce":68695620,"textAlign":"center","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-51.809494018554688,"angle":0,"y":-928.625,"width":255.61898803710938},{"isDeleted":false,"locked":false,"strokeColor":"#f59e0b","link":null,"roughness":1,"groupIds":[],"index":"b5Q","backgroundColor":"#fffbeb","angle":0,"fillStyle":"solid","strokeWidth":2,"version":5,"roundness":{"type":3},"type":"rectangle","updated":1772873306458,"id":"0e4WMfzAoXQGWaUH_YuvU","x":281,"seed":1708627012,"boundElements":[{"type":"text","id":"KPljMEcp3gwZsQg4y6TYG"}],"y":-953,"opacity":100,"height":130,"width":370,"frameId":null,"strokeStyle":"solid","versionNonce":200774652},{"seed":1373924292,"strokeStyle":"solid","id":"KPljMEcp3gwZsQg4y6TYG","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"middle","updated":1772873306468,"locked":false,"text":"BN-4: Blocking Trie Call in API\nThreshold: > ~20,000 req\/s\nThread-per-request model exhausts\npool before trie saturates.\nCategory: CPU \/ Concurrency","version":7,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b5R","roundness":null,"containerId":"0e4WMfzAoXQGWaUH_YuvU","originalText":"BN-4: Blocking Trie Call in API\nThreshold: > ~20,000 req\/s\nThread-per-request model exhausts\npool before trie saturates.\nCategory: CPU \/ Concurrency","height":81.25,"link":null,"strokeColor":"#f59e0b","fillStyle":"solid","groupIds":[],"versionNonce":1673579972,"textAlign":"center","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":353.03648376464844,"angle":0,"y":-928.625,"width":225.92703247070312},{"seed":1701466948,"strokeStyle":"dashed","id":"8rJGXL0V6-18OMEMxIS8c","strokeWidth":1.5,"roughness":1,"isDeleted":false,"startBinding":null,"endArrowhead":"arrow","opacity":100,"updated":1772873306458,"locked":false,"points":[[0,0],[0,-67]],"version":5,"elbowed":false,"type":"arrow","backgroundColor":"transparent","index":"b5S","roundness":null,"lastCommittedPoint":null,"height":67,"link":null,"startArrowhead":null,"strokeColor":"#ef4444","fillStyle":"solid","groupIds":[],"endBinding":null,"versionNonce":609989756,"frameId":null,"boundElements":[],"x":51,"angle":0,"y":-1103.5,"width":0},{"seed":1858554564,"strokeStyle":"dashed","id":"wO-jp0jjbL3Aj5TwNqNM-","strokeWidth":1.5,"roughness":1,"isDeleted":false,"startBinding":null,"endArrowhead":"arrow","opacity":100,"updated":1772873306458,"locked":false,"points":[[0,0],[0,-67]],"version":5,"elbowed":false,"type":"arrow","backgroundColor":"transparent","index":"b5T","roundness":null,"lastCommittedPoint":null,"height":67,"link":null,"startArrowhead":null,"strokeColor":"#ef4444","fillStyle":"solid","groupIds":[],"endBinding":null,"versionNonce":667214148,"frameId":null,"boundElements":[],"x":461,"angle":0,"y":-1103.5,"width":0},{"isDeleted":false,"locked":false,"strokeColor":"#c7d2fe","link":null,"roughness":1,"groupIds":[],"index":"b5U","backgroundColor":"#f8faff","angle":0,"fillStyle":"solid","strokeWidth":1.5,"version":5,"roundness":null,"type":"rectangle","updated":1772873306458,"id":"4K09X0UCBmmPRYc3eNjoa","x":709,"seed":1083789892,"boundElements":[],"y":-1401,"opacity":100,"height":830,"width":562,"frameId":null,"strokeStyle":"solid","versionNonce":1281869052},{"seed":700344772,"strokeStyle":"solid","id":"ITb7bLxL7P3qYNMT4M0zw","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":18,"opacity":100,"verticalAlign":"top","updated":1772873306458,"locked":false,"text":"The Two Most Critical Bottlenecks","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b5V","roundness":null,"containerId":null,"originalText":"The Two Most Critical Bottlenecks","height":22.5,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":1654659268,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":727,"angle":0,"y":-1383,"width":312.87579345703125},{"seed":1834258756,"strokeStyle":"solid","id":"zdaxnEoWKS-sNEwrY2k_H","strokeWidth":1,"roughness":1,"isDeleted":false,"startBinding":null,"endArrowhead":null,"opacity":100,"updated":1772873306458,"locked":false,"points":[[0,0],[522,0]],"polygon":false,"version":5,"type":"line","backgroundColor":"transparent","index":"b5W","roundness":null,"lastCommittedPoint":null,"height":0,"link":null,"startArrowhead":null,"strokeColor":"#e5e7eb","fillStyle":"solid","groupIds":[],"endBinding":null,"versionNonce":698205564,"frameId":null,"boundElements":[],"x":727,"angle":0,"y":-1359,"width":522},{"seed":985254084,"strokeStyle":"solid","id":"2qeng3DKeMQT6PezYhoMU","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":16,"opacity":100,"verticalAlign":"top","updated":1772873306458,"locked":false,"text":"BN-1: Single Trie Node","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b5X","roundness":null,"containerId":null,"originalText":"BN-1: Single Trie Node","height":20,"link":null,"strokeColor":"#ef4444","fillStyle":"solid","groupIds":[],"versionNonce":472408132,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":727,"angle":0,"y":-1345,"width":171.80787658691406},{"seed":629936196,"strokeStyle":"solid","id":"UD7plT8uNjv6nlluhXahE","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772873306458,"locked":false,"text":"The trie is a single large in-memory structure on one\nserver. JVM garbage collection must periodically stop\nall threads to reclaim memory in a 50-200 GB heap.\nEach GC pause lasts 100-500ms — long enough to\nbreach the 100ms SLA for every request queued\nduring that window. At 2K req\/s even a 200ms GC\npause means 400 requests failing simultaneously.\nThere is no way to share a mutable trie across servers\nwithout solving distributed coordination, so the only\npath forward is prefix-range sharding — each shard\nowning a disjoint slice of the prefix space and serving\nreads independently with no cross-shard coordination.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b5Y","roundness":null,"containerId":null,"originalText":"The trie is a single large in-memory structure on one\nserver. JVM garbage collection must periodically stop\nall threads to reclaim memory in a 50-200 GB heap.\nEach GC pause lasts 100-500ms — long enough to\nbreach the 100ms SLA for every request queued\nduring that window. At 2K req\/s even a 200ms GC\npause means 400 requests failing simultaneously.\nThere is no way to share a mutable trie across servers\nwithout solving distributed coordination, so the only\npath forward is prefix-range sharding — each shard\nowning a disjoint slice of the prefix space and serving\nreads independently with no cross-shard coordination.","height":210,"link":null,"strokeColor":"#374151","fillStyle":"solid","groupIds":[],"versionNonce":1631565308,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":727,"angle":0,"y":-1321,"width":378.36346435546875},{"seed":497641412,"strokeStyle":"solid","id":"aWVpHx_CJdWegnQ0_gFYv","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":16,"opacity":100,"verticalAlign":"top","updated":1772873306458,"locked":false,"text":"BN-2: Nightly Batch Rebuild","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b5Z","roundness":null,"containerId":null,"originalText":"BN-2: Nightly Batch Rebuild","height":20,"link":null,"strokeColor":"#ef4444","fillStyle":"solid","groupIds":[],"versionNonce":473675716,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":727,"angle":0,"y":-1123,"width":218.95980834960938},{"seed":1731186500,"strokeStyle":"solid","id":"uSDQshbIMOdH-5geu3voK","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772873306458,"locked":false,"text":"The batch job reads every query log, recomputes\nfrequency counts, rebuilds the entire trie, and\nswaps the pointer. This takes 10-30 minutes on\nlarge datasets. During this window the in-memory\ntrie is either locked for writes (blocking reads) or\nserving a frozen snapshot that can be hours stale.\nFrom a user perspective: during every nightly deploy\nwindow, autocomplete silently stops reflecting any\nquery typed in the past 24 hours. The fix requires\nan incremental async update pipeline where individual\nquery log events flow through Kafka into trie workers\nthat update only the affected prefix chain — not the\nentire structure. This is a fundamental redesign.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b5a","roundness":null,"containerId":null,"originalText":"The batch job reads every query log, recomputes\nfrequency counts, rebuilds the entire trie, and\nswaps the pointer. This takes 10-30 minutes on\nlarge datasets. During this window the in-memory\ntrie is either locked for writes (blocking reads) or\nserving a frozen snapshot that can be hours stale.\nFrom a user perspective: during every nightly deploy\nwindow, autocomplete silently stops reflecting any\nquery typed in the past 24 hours. The fix requires\nan incremental async update pipeline where individual\nquery log events flow through Kafka into trie workers\nthat update only the affected prefix chain — not the\nentire structure. This is a fundamental redesign.","height":227.5,"link":null,"strokeColor":"#374151","fillStyle":"solid","groupIds":[],"versionNonce":542086780,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":727,"angle":0,"y":-1099,"width":370.21554565429688},{"isDeleted":false,"locked":false,"strokeColor":"#ef4444","link":null,"roughness":1,"groupIds":[],"index":"b5b","backgroundColor":"#fff1f2","angle":0,"fillStyle":"solid","strokeWidth":2,"version":5,"roundness":{"type":3},"type":"rectangle","updated":1772873306458,"id":"_yBGrGW7NQQeIja2vXLdk","x":727,"seed":310200004,"boundElements":[],"y":-871,"opacity":100,"height":116,"width":526,"frameId":null,"strokeStyle":"solid","versionNonce":2130190148},{"seed":1949290052,"strokeStyle":"solid","id":"EKtDBAOSl5ucipbUml7Cp","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772873306458,"locked":false,"text":"Key insight: BN-1 and BN-2 are not independent.\nFixing trie sharding without fixing the rebuild means\n40 shards each doing a nightly blackout. Both must\nbe solved together — sharding + incremental updates\n— before the system can serve production traffic.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b5c","roundness":null,"containerId":null,"originalText":"Key insight: BN-1 and BN-2 are not independent.\nFixing trie sharding without fixing the rebuild means\n40 shards each doing a nightly blackout. Both must\nbe solved together — sharding + incremental updates\n— before the system can serve production traffic.","height":87.5,"link":null,"strokeColor":"#991b1b","fillStyle":"solid","groupIds":[],"versionNonce":596600572,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":743,"angle":0,"y":-855,"width":363.10357666015625},{"seed":488990148,"strokeStyle":"dashed","id":"5_cAVJg_tdAMtz3ZQAFQe","strokeWidth":1,"roughness":1,"isDeleted":false,"startBinding":null,"endArrowhead":null,"opacity":100,"updated":1772873306458,"locked":false,"points":[[0,0],[1450,0]],"polygon":false,"version":5,"type":"line","backgroundColor":"transparent","index":"b5d","roundness":null,"lastCommittedPoint":null,"height":0,"link":null,"startArrowhead":null,"strokeColor":"#9ca3af","fillStyle":"solid","groupIds":[],"endBinding":null,"versionNonce":750491332,"frameId":null,"boundElements":[],"x":-149,"angle":0,"y":-695,"width":1450},{"isDeleted":false,"locked":false,"strokeColor":"#0d9488","link":null,"roughness":1,"groupIds":[],"index":"b5e","backgroundColor":"#0d9488","angle":0,"fillStyle":"solid","strokeWidth":2,"version":5,"roundness":null,"type":"ellipse","updated":1772873306458,"id":"CQNIaO2zDSXwR3xRah9ZE","x":-139,"seed":1383861572,"boundElements":[],"y":-651,"opacity":100,"height":42,"width":42,"frameId":null,"strokeStyle":"solid","versionNonce":1065428860},{"seed":93439172,"strokeStyle":"solid","id":"VUsTWpLAQlcttQpqcu0JB","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":16,"opacity":100,"verticalAlign":"top","updated":1772873306458,"locked":false,"text":"S6","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b5f","roundness":nul