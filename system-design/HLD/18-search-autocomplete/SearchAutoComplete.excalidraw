oupIds":[],"endBinding":null,"versionNonce":917839740,"frameId":null,"boundElements":[],"x":-93,"angle":0,"y":5521,"width":340},{"seed":306947652,"strokeStyle":"solid","id":"CZvyaSxS4HLEQorNMOcXq","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772873306454,"locked":false,"text":"10x load handled by:\n\n  CDN absorbs 80% of reads at edge\n  (no trie hit needed at all)\n\n  Trie shards scale linearly — add shards\n  for more prefix-space coverage\n\n  Kafka consumer groups scale workers\n  independently from read path\n\n  Redis user history partitioned by uid hash","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bFA","roundness":null,"containerId":null,"originalText":"10x load handled by:\n\n  CDN absorbs 80% of reads at edge\n  (no trie hit needed at all)\n\n  Trie shards scale linearly — add shards\n  for more prefix-space coverage\n\n  Kafka consumer groups scale workers\n  independently from read path\n\n  Redis user history partitioned by uid hash","height":195,"link":null,"strokeColor":"#374151","fillStyle":"solid","groupIds":[],"versionNonce":1180422140,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-93,"angle":0,"y":5531,"width":279.57769775390625},{"isDeleted":false,"locked":false,"strokeColor":"#ef4444","link":null,"roughness":1,"groupIds":[],"index":"bFB","backgroundColor":"#fff1f2","angle":0,"fillStyle":"solid","strokeWidth":2,"version":5,"roundness":{"type":3},"type":"rectangle","updated":1772873306454,"id":"oWkhacCmEdFYbvOgp1khf","x":283,"seed":973487556,"boundElements":[],"y":5491,"opacity":100,"height":190,"width":376,"frameId":null,"strokeStyle":"solid","versionNonce":2128113788},{"seed":1300358468,"strokeStyle":"solid","id":"Sux7cji-E2dMXlGS6PXfe","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":16,"opacity":100,"verticalAlign":"top","updated":1772873306454,"locked":false,"text":"Reliability Strategy","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bFC","roundness":null,"containerId":null,"originalText":"Reliability Strategy","height":20,"link":null,"strokeColor":"#ef4444","fillStyle":"solid","groupIds":[],"versionNonce":804061436,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":299,"angle":0,"y":5501,"width":149.87184143066406},{"seed":1377606852,"strokeStyle":"solid","id":"tTcs97ZeT0A12Pw-oLTPY","strokeWidth":1,"roughness":1,"isDeleted":false,"startBinding":null,"endArrowhead":null,"opacity":100,"updated":1772873306454,"locked":false,"points":[[0,0],[340,0]],"polygon":false,"version":5,"type":"line","backgroundColor":"transparent","index":"bFD","roundness":null,"lastCommittedPoint":null,"height":0,"link":null,"startArrowhead":null,"strokeColor":"#fca5a5","fillStyle":"solid","groupIds":[],"endBinding":null,"versionNonce":1629192572,"frameId":null,"boundElements":[],"x":299,"angle":0,"y":5521,"width":340},{"seed":1903453252,"strokeStyle":"solid","id":"2HKwXFjZIAf3Y_bftm3ss","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772873306454,"locked":false,"text":"99.99% achieved by:\n\n  Multi-region: Region B hot standby\n  with async trie replica ~100ms lag\n\n  Circuit breakers on Redis + trie calls\n  with graceful global top-K fallback\n\n  Kafka topic mirroring for cross-region\n  log catchup after failover\n\n  CDN serves stale during API outage","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bFE","roundness":null,"containerId":null,"originalText":"99.99% achieved by:\n\n  Multi-region: Region B hot standby\n  with async trie replica ~100ms lag\n\n  Circuit breakers on Redis + trie calls\n  with graceful global top-K fallback\n\n  Kafka topic mirroring for cross-region\n  log catchup after failover\n\n  CDN serves stale during API outage","height":195,"link":null,"strokeColor":"#374151",