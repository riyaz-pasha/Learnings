trokeStyle":"solid","versionNonce":1894249596},{"seed":424069828,"strokeStyle":"solid","id":"ccV8BW-z3DcRm58yOyRZq","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772873306458,"locked":false,"text":"Latency Budget","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b9b","roundness":null,"containerId":null,"originalText":"Latency Budget","height":16.25,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":1763483972,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-93,"angle":0,"y":2201,"width":100.46389770507812},{"seed":1864946244,"strokeStyle":"solid","id":"JuB0E4Z7W9K0_RLGlVmZZ","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":12,"opacity":100,"verticalAlign":"top","updated":1772873306458,"locked":false,"text":"T+0ms    Log event arrives in Kafka\nT+10ms   Trending Worker consumes event\nT+12ms   ZINCRBY trending:bucket:{min} 1 query\nT+30s    Rotate buckets compute velocity\nT+100ms  If velocity>10x publish trending.boost\nT+300ms  CDN TTL expiry propagates to edge","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b9c","roundness":null,"containerId":null,"originalText":"T+0ms    Log event arrives in Kafka\nT+10ms   Trending Worker consumes event\nT+12ms   ZINCRBY trending:bucket:{min} 1 query\nT+30s    Rotate buckets compute velocity\nT+100ms  If velocity>10x publish trending.boost\nT+300ms  CDN TTL expiry propagates to edge","height":90,"link":null,"strokeColor":"#374151","fillStyle":"solid","groupIds":[],"versionNonce":1030489340,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-93,"angle":0,"y":2219,"width":286.78756713867188},{"isDeleted":false,"locked":false,"strokeColor":"#c7d2fe","link":null,"roughness":1,"groupIds":[],"index":"b9d","backgroundColor":"#f8faff","angle":0,"fillStyle":"solid","strokeWidth":1.5,"version":5,"roundness":{"type":3},"type":"rectangle","updated":1772873306458,"id":"GrGmIoJRSkeHmW83RZ4dE","x":365,"seed":1516104132,"boundElements":[],"y":2193,"opacity":100,"height":96,"width":296,"frameId":null,"strokeStyle":"solid","versionNonce":587192516},{"seed":1577324868,"strokeStyle":"solid","id":"GIu4z4drQ0Tt_4AxYRbtq","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"top","updated":1772873306458,"locked":false,"text":"Redis Sorted Set Pattern","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b9e","roundness":null,"containerId":null,"originalText":"Redis Sorted Set Pattern","height":16.25,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":1880753532,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":375,"angle":0,"y":2201,"width":165.7628173828125},{"seed":1769556164,"strokeStyle":"solid","id":"TvzWnnexQB8kVwwPAT-yM","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":11,"opacity":100,"verticalAlign":"top","updated":1772873306458,"locked":false,"text":"Key: trending:5min:{epoch_bucket}\nType: ZSET  TTL: 600s auto-expire\nMember: query string\nScore: hit count in window\n\nVelocity = ZSCORE(now_bucket)\n         \/ ZSCORE(prev_bucket)","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b9f","roundness":null,"containerId":null,"originalText":"Key: trending:5min:{epoch_bucket}\nType: ZSET  TTL: 600s auto-expire\nMember: query string\nScore: hit count in window\n\nVelocity = ZSCORE(now_bucket)\n         \/ ZSCORE(prev_bucket)","height":96.25,"link":null,"strokeColor":"#0d9488","fillStyle":"solid","groupIds":[],"versionNonce":982523972,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":375,"angle":0,"y":2219,"width":200.54075622558594},{"isDeleted":false,"locked":false,"strokeColor":"#ef4444","link":null,"roughness":1,"groupIds":[],"index":"b9g","backgroundColor":"#fff1f2","angle":0,"fillStyle":"solid","strokeWidth":1.5,"version":5,"roundness":{"type":3},"type":"rectangle","updated":1772873306458,"id":"vBf-sniogTW_mgt7R1kdF","x":-109,"seed":1348177988,"boundElements":[{"type":"text","id":"yL_AH8l-JgLf5xbttVPsM"}],"y":2303,"opacity":100,"height":40,"width":770,"frameId":null,"strokeStyle":"solid","versionNonce":238286332},{"seed":1116268484,"strokeStyle":"solid","id":"yL_AH8l-JgLf5xbttVPsM","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"middle","updated":1772873306470,"locked":false,"text":"Failure: Redis node down -> trending scores reset -> graceful fallback to historical global scores only.","version":7,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b9h","roundness":null,"containerId":"vBf-sniogTW_mgt7R1kdF","originalText":"Failure: Redis node down -> trending scores reset -> graceful fallback to historical global scores only.","height":16.25,"link":null,"strokeColor":"#ef4444","fillStyle":"solid","groupIds":[],"versionNonce":1654053188,"textAlign":"center","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-45.43145751953125,"angle":0,"y":2314.875,"width":642.8629150390625},{"isDeleted":false,"locked":false,"strokeColor":"#c7d2fe","link":null,"roughness":1,"groupIds":[],"index":"b9i","backgroundColor":"#f8faff","angle":0,"fillStyle":"solid","strokeWidth":1.5,"version":5,"roundness":null,"type":"rectangle","updated":1772873306458,"id":"tLORur-F2EYZVZ3Kh3YOP","x":709,"seed":1142902596,"boundElements":[],"y":1077,"opacity":100,"height":1318,"width":562,"frameId":null,"strokeStyle":"solid","versionNonce":616289916},{"seed":628934340,"strokeStyle":"solid","id":"KMbW9NUIVhrefI7Udw582","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":17,"opacity":100,"verticalAlign":"top","updated":1772873306458,"locked":false,"text":"FR-1: How Autocomplete Actually Works","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b9j","roundness":null,"containerId":null,"originalText":"FR-1: How Autocomplete Actually Works","height":21.25,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":1987043140,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":727,"angle":0,"y":1095,"width":325.53277587890625},{"seed":2067746372,"strokeStyle":"solid","id":"25Sv1bq_O4eB0LYq0jUGF","strokeWidth":1,"roughness":1,"isDeleted":false,"startBinding":null,"endArrowhead":null,"opacity":100,"updated":1772873306458,"locked":false,"points":[[0,0],[522,0]],"polygon":false,"version":5,"type":"line","backgroundColor":"transparent","index":"b9k","roundness":null,"lastCommittedPoint":null,"height":0,"link":null,"startArrowhead":null,"strokeColor":"#e5e7eb","fillStyle":"solid","groupIds":[],"endBinding":null,"versionNonce":1349756668,"frameId":null,"boundElements":[],"x":727,"angle":0,"y":1119,"width":522},{"seed":373614020,"strokeStyle":"solid","id":"ShTchAbhGa2LmQqJ1OMb4","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772873306458,"locked":false,"text":"The read path splits at the CDN into two branches.\nFor the 80% CDN hit case latency is under 10ms —\nthe suggestion was pre-computed and cached at edge.\nFor the 20% miss case, the API runs two fetches in\nparallel: a trie shard lookup (~2ms) and a Redis\nuser history read (~3ms). Redis timeout is non-\nblocking: if history takes more than 10ms, the system\nfalls back to global top-K and still returns in time.\nThe trie lookup is always the guaranteed fast path.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b9l","roundness":null,"containerId":null,"originalText":"The read path splits at the CDN into two branches.\nFor the 80% CDN hit case latency is under 10ms —\nthe suggestion was pre-computed and cached at edge.\nFor the 20% miss case, the API runs two fetches in\nparallel: a trie shard lookup (~2ms) and a Redis\nuser history read (~3ms). Redis timeout is non-\nblocking: if history takes more than 10ms, the system\nfalls back to global top-K and still returns in time.\nThe trie lookup is always the guaranteed fast path.","height":157.5,"link":null,"strokeColor":"#374151","fillStyle":"solid","groupIds":[],"versionNonce":1597724356,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":727,"angle":0,"y":1131,"width":371.0555419921875},{"seed":2074840388,"strokeStyle":"solid","id":"XAaaNpJjJJnMJbx1m7y67","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":16,"opacity":100,"verticalAlign":"top","updated":1772873306458,"locked":false,"text":"FR-1: Data Model Decision","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b9m","roundness":null,"containerId":null,"originalText":"FR-1: Data Model Decision","height":20,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":1172137852,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":727,"angle":0,"y":1289,"width":205.83981323242188},{"seed":1557218500,"strokeStyle":"solid","id":"k9t5pjasXoQ_b9aD0cMjk","strokeWidth":1,"roughness":1,"isDeleted":false,"startBinding":null,"endArrowhead":null,"opacity":100,"updated":1772873306458,"locked":false,"points":[[0,0],[522,0]],"polygon":false,"version":5,"type":"line","backgroundColor":"transparent","index":"b9n","roundness":null,"lastCommittedPoint":null,"height":0,"link":null,"startArrowhead":null,"strokeColor":"#e5e7eb","fillStyle":"solid","groupIds":[],"endBinding":null,"versionNonce":514580036,"frameId":null,"boundElements":[],"x":727,"angle":0,"y":1309,"width":522},{"seed":257166404,"strokeStyle":"solid","id":"XbDdOpCObMLNqmUBcmA1N","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772873306458,"locked":false,"text":"top_k is stored pre-computed at every trie node, not\ncomputed at read time. This trades write complexity\nfor read speed. The alternative — computing top-K\nby scanning children at read time — adds O(K log K)\nsorting to the hot path and breaks the 100ms SLA.\nPre-computation pays the cost at write time once;\nevery read is O(1) forever after.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b9o","roundness":null,"containerId":null,"originalText":"top_k is stored pre-computed at every trie node, not\ncomputed at read time. This trades write complexity\nfor read speed. The alternative — computing top-K\nby scanning children at read time — adds O(K log K)\nsorting to the hot path and breaks the 100ms SLA.\nPre-computation pays the cost at write time once;\nevery read is O(1) forever after.","height":122.5,"link":null,"strokeColor":"#374151","fillStyle":"solid","groupIds":[],"versionNonce":1497044988,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":727,"angle":0,"y":1321,"width":366.43548583984375},{"seed":85058500,"strokeStyle":"solid","id":"Mb0hJu3wUXyyAY9MtY7bP","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":17,"opacity":100,"verticalAlign":"top","updated":1772873306458,"locked":false,"text":"FR-3: Write Amplification is the Core Problem","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b9p","roundness":null,"containerId":null,"originalText":"FR-3: Write Amplification is the Core Problem","height":21.25,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":1033860548,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":727,"angle":0,"y":1523,"width":373.8807373046875},{"seed":1143524164,"strokeStyle":"solid","id":"grRj-bkLVDlODp5BkYzYa","strokeWidth":1,"roughness":1,"isDeleted":false,"startBinding":null,"endArrowhead":null,"opacity":100,"updated":1772873306458,"locked":false,"points":[[0,0],[522,0]],"polygon":false,"version":5,"type":"line","backgroundColor":"transparent","index":"b9q","roundness":null,"lastCommittedPoint":null,"height":0,"link":null,"startArrowhead":null,"strokeColor":"#e5e7eb","fillStyle":"solid","groupIds":[],"endBinding":null,"versionNonce":110016636,"frameId":null,"boundElements":[],"x":727,"angle":0,"y":1547,"width":522},{"seed":1593230020,"strokeStyle":"solid","id":"c2GslMDwyDLzxnrza35rQ","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772873306458,"locked":false,"text":"Every search must update every ancestor in the trie\nnot just the leaf. A query 'prefix tree' has 11 ancestor\nnodes, so 1 log event causes 11 node writes. At 100K\nevents\/s that is 1M node writes per second — far too\nhigh for the API to absorb synchronously. Kafka\nprovides the decoupling: the API publishes in under\n1ms, and 20 dedicated worker processes consume and\napply updates in background. Idempotency is essential\nbecause Kafka delivers at-least-once: a worker crash\nand replay would double-count without INSERT IGNORE.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b9r","roundness":null,"containerId":null,"originalText":"Every search must update every ancestor in the trie\nnot just the leaf. A query 'prefix tree' has 11 ancestor\nnodes, so 1 log event causes 11 node writes. At 100K\nevents\/s that is 1M node writes per second — far too\nhigh for the API to absorb synchronously. Kafka\nprovides the decoupling: the API publishes in under\n1ms, and 20 dedicated worker processes consume and\napply updates in background. Idempotency is essential\nbecause Kafka delivers at-least-once: a worker crash\nand replay would double-count without INSERT IGNORE.","height":175,"link":null,"strokeColor":"#374151","fillStyle":"solid","groupIds":[],"versionNonce":2033458500,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":727,"angle":0,"y":1559,"width":392.90957641601562},{"seed":1813629508,"strokeStyle":"solid","id":"LSFWWPpWKav17bSiJoeTI","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":17,"opacity":100,"verticalAlign":"top","updated":1772873306458,"locked":false,"text":"FR-5: Velocity Not Frequency","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b9s","roundness":null,"containerId":null,"originalText":"FR-5: Velocity Not Frequency","height":21.25,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":2040154364,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":727,"angle":0,"y":1813,"width":241.46783447265625},{"seed":2121261508,"strokeStyle":"solid","id":"8CgfGbj2eu6pS2goQoyHK","strokeWidth":1,"roughness":1,"isDeleted":false,"startBinding":null,"endArrowhead":null,"opacity":100,"updated":1772873306458,"locked":false,"points":[[0,0],[522,0]],"polygon":false,"version":5,"type":"line","backgroundColor":"transparent","index":"b9t","roundness":null,"lastCommittedPoint":null,"height":0,"link":null,"startArrowhead":null,"strokeColor":"#e5e7eb","fillStyle":"solid","groupIds":[],"endBinding":null,"versionNonce":986174660,"frameId":null,"boundElements":[],"x":727,"angle":0,"y":1837,"width":522},{"seed":488048964,"strokeStyle":"solid","id":"2WfnDS9HqWXgs_RTl85UD","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772873306458,"locked":false,"text":"Absolute frequency is useless for trending. The query\n'the' appears billions of times but is never trending.\nVelocity — rate of change over a short window — is\nwhat matters. A query at 5K hits in 5 minutes when\nits 5-minute baseline is 100 is trending at 50x.\nRedis sorted sets with 5-minute expiring buckets\nimplement this in O(log N) per increment. The 10x\nthreshold suppresses normal traffic fluctuations while\ncatching viral events. Bot traffic is mitigated by\ndeduplicating on user ID in the Kafka consumer\nbefore incrementing the sorted set score.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b9u","roundness":null,"containerId":null,"originalText":"Absolute frequency is useless for trending. The query\n'the' appears billions of times but is never trending.\nVelocity — rate of change over a short window — is\nwhat matters. A query at 5K hits in 5 minutes when\nits 5-minute baseline is 100 is trending at 50x.\nRedis sorted sets with 5-minute expiring buckets\nimplement this in O(log N) per increment. The 10x\nthreshold suppresses normal traffic fluctuations while\ncatching viral events. Bot traffic is mitigated by\ndeduplicating on user ID in the Kafka consumer\nbefore incrementing the sorted set score.","height":192.5,"link":null,"strokeColor":"#374151","fillStyle":"solid","groupIds":[],"versionNonce":366987644,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":727,"angle":0,"y":1849,"width":366.603515625},{"seed":997015748,"strokeStyle":"solid","id":"GL0B16Y5N_efK28c89Fm0","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":16,"opacity":100,"verticalAlign":"top","updated":1772873306458,"locked":false,"text":"Latency Budget","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b9v","roundness":null,"containerId":null,"originalText":"Latency Budget","height":20,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":267951172,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":727,"angle":0,"y":2037,"width":123.64790344238281},{"seed":823167044,"strokeStyle":"solid","id":"1LsO9diIAbPfEWMX_CfWy","strokeWidth":1,"roughness":1,"isDeleted":false,"startBinding":null,"endArrowhead":null,"opacity":100,"updated":1772873306458,"locked":false,"points":[[0,0],[522,0]],"polygon":false,"version":5,"type":"line","backgroundColor":"transparent","index":"b9w","roundness":null,"lastCommittedPoint":null,"height":0,"link":null,"startArrowhead":null,"strokeColor":"#e5e7eb","fillStyle":"solid","groupIds":[],"endBinding":null,"versionNonce":2124495356,"frameId":null,"boundElements":[],"x":727,"angle":0,"y":2057,"width":522},{"seed":836689860,"strokeStyle":"solid","id":"gqFRGAMXwLpE8DYxV-81h","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":14,"opacity":100,"verticalAlign":"top","updated":1772873306458,"locked":false,"text":"FR-1 read budget: 100ms total. CDN hit path uses\n<10ms. Miss path: normalize 5ms + trie 2ms + Redis\n3ms + blend 3ms = 13ms at API, plus network. Leaves\n~70ms for network RTT to client. This is why CDN\nedge PoPs close to users are required, not optional.\n\nFR-3 write budget: infinite (async). Kafka consumer\nlag is the freshness SLA: 5 min max lag allowed.\n\nFR-5 trending budget: 5 min end-to-end from first\nquery surge to suggestion appearing in CDN results.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b9x","roundness":null,"containerId":null,"originalText":"FR-1 read budget: 100ms total. CDN hit path uses\n<10ms. Miss path: normalize 5ms + trie 2ms + Redis\n3ms + blend 3ms = 13ms at API, plus network. Leaves\n~70ms for network RTT to client. This is why CDN\nedge PoPs close to users are required, not optional.\n\nFR-3 write budget: infinite (async). Kafka consumer\nlag is the freshness SLA: 5 min max lag allowed.\n\nFR-5 trending budget: 5 min end-to-end from first\nquery surge to suggestion appearing in CDN results.","height":192.5,"link":null,"strokeColor":"#374151","fillStyle":"solid","groupIds":[],"versionNonce":581202884,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":727,"angle":0,"y":2069,"width":363.49560546875},{"isDeleted":false,"locked":false,"strokeColor":"#f59e0b","link":null,"roughness":1,"groupIds":[],"index":"b9y","backgroundColor":"#fffbeb","angle":0,"fillStyle":"solid","strokeWidth":2,"version":5,