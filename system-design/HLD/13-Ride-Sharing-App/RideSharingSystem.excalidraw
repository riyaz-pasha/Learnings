{"source":"https:\/\/excalidraw.com","version":2,"type":"excalidraw","elements":[{"seed":2101326261,"strokeStyle":"solid","id":"K85YS_yJFHHEu1ebvUKYj","strokeWidth":2,"isDeleted":false,"roughness":1,"fontSize":36,"opacity":100,"verticalAlign":"top","text":"Ride Sharing App","updated":1773238143513,"locked":false,"version":27,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b9n","roundness":null,"containerId":null,"originalText":"Ride Sharing App","height":45,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":1799386131,"lineHeight":1.25,"textAlign":"left","fontFamily":8,"frameId":null,"boundElements":[],"x":623,"angle":0,"width":316.79998779296875,"y":150},{"seed":84950587,"strokeStyle":"solid","id":"roJ2EzzQ0LEMuHjwBVaCg","strokeWidth":2,"isDeleted":false,"roughness":1,"fontSize":20,"opacity":100,"verticalAlign":"top","text":"Fare Estimation\n\n- User enters source and destination on the app.\n- Then clicks then button get the estimate.\n- On click of button app initiates an API call\n  GET \/api\/v1\/fare-estimation\n  { source:{lat,long}, destination:{lat,long} }\n\n- The request then lands on the API Gateway and and forwaded to the \n  Ride service.\n\n- Ride service will first connect with third party geospatial providers like\n  Google Directions API to fetch optimal route between the source and destination.\n- This third party providers will takes real-time traffic, one-way roads, road closures,\n  tolls into account and provides optimal route.\n- This providers returns distance in km\/miles and estimated time.\n\n- Then ride service will calculates fare based on distance and time and returns it to the user.\n","updated":1773238143513,"locked":false,"version":868,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b9o","roundness":null,"containerId":null,"originalText":"Fare Estimation\n\n- User enters source and destination on the app.\n- Then clicks then button get the estimate.\n- On click of button app initiates an API call\n  GET \/api\/v1\/fare-estimation\n  { source:{lat,long}, destination:{lat,long} }\n\n- The request then lands on the API Gateway and and forwaded to the \n  Ride service.\n\n- Ride service will first connect with third party geospatial providers like\n  Google Directions API to fetch optimal route between the source and destination.\n- This third party providers will takes real-time traffic, one-way roads, road closures,\n  tolls into account and provides optimal route.\n- This providers returns distance in km\/miles and estimated time.\n\n- Then ride service will calculates fare based on distance and time and returns it to the user.\n","height":475,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":1044302493,"lineHeight":1.25,"textAlign":"left","fontFamily":8,"frameId":null,"boundElements":[],"x":287,"angle":0,"width":1045,"y":1795},{"isDeleted":false,"locked":false,"strokeColor":"#1e1e1e","link":null,"groupIds":[],"roughness":1,"index":"b9p","backgroundColor":"transparent","angle":0,"fillStyle":"solid","updated":1773238143513,"version":74,"roundness":{"type":3},"type":"rectangle","strokeWidth":2,"id":"36MJXY-wkDhtZy3Pl3AES","boundElements":[{"id":"hRpBXPSnxdDaes4VT_G9z","type":"text"},{"id":"kJCheticmnGZCCUr-h8ky","type":"arrow"}],"x":2066.8309455378758,"seed":159872597,"y":1851.85531499032,"opacity":100,"height":90,"width":131,"frameId":null,"strokeStyle":"solid","versionNonce":1641970099},{"seed":1403405435,"strokeStyle":"solid","id":"hRpBXPSnxdDaes4VT_G9z","strokeWidth":2,"isDeleted":false,"roughness":1,"fontSize":20,"opacity":100,"verticalAlign":"middle","text":"Rider\nClient","updated":1773238143513,"locked":false,"version":57,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b9q","roundness":null,"containerId":"36MJXY-wkDhtZy3Pl3AES","originalText":"Rider Client","height":50,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionN