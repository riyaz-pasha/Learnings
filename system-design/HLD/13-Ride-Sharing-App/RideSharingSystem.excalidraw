rtArrowhead":null,"elbowed":false,"backgroundColor":"transparent","angle":0,"endBinding":{"mode":"orbit","elementId":"ffhalFOwR7gpTruAmKZfG","fixedPoint":[0.23478862756456939,0.23478862756456817]},"fillStyle":"solid","updated":1773238143513,"strokeWidth":2,"roundness":{"type":2},"type":"arrow","version":71,"id":"TJHjPT196us5q3Yh08wqX","x":2663.8309455378758,"boundElements":[],"seed":1185534843,"y":1829.9150073731325,"opacity":100,"height":4,"points":[[0,0],[207,4]],"width":207,"frameId":null,"strokeStyle":"solid","versionNonce":687671763},{"isDeleted":false,"locked":false,"strokeColor":"#364fc7","link":null,"endArrowhead":null,"groupIds":["rTHNFNDA7pXXB0N2T1f4J","puEzt2iwecZ6wtg19jXKU"],"roughness":1,"startBinding":null,"index":"bA0","startArrowhead":null,"backgroundColor":"#228be6","endBinding":null,"angle":0,"fillStyle":"solid","updated":1773238143513,"version":2706,"strokeWidth":1,"type":"line","roundness":null,"id":"uIPOZA44pBRxyCq-fMM2_","boundElements":[],"x":3414.3906297921276,"seed":582807835,"y":1841.6171412192548,"opacity":100,"points":[[0,0],[0,81.24504586319145],[1.777062999357842,95.937110042488229],[13.975545169118597,101.33520266828153],[32.245950078908578,105.6036749382846],[51.728985227062111,106.70598204429881],[68.362900608740844,105.6069084227593],[83.964224179182196,102.88989158362904],[99.525371886428275,95.35807376427104],[100.58910440204657,81.24504586319145],[101.43255738417912,11.066502392818677],[100.15182896713623,-0.35378750279016202],[87.543907698200826,-6.4460293724298694],[73.39395832349102,-9.8971712026213652],[54.998413783395669,-10.91127596339463],[43.322977231062616,-10.881763683096402],[18.460883213902022,-8.6867049254338724],[0,0]],"height":117.61725800769344,"width":101.43255738417912,"frameId":null,"polygon":false,"strokeStyle":"solid","versionNonce":948924637},{"isDeleted":false,"locked":false,"strokeColor":"#364fc7","link":null,"groupIds":["rTHNFNDA7pXXB0N2T1f4J","puEzt2iwecZ6wtg19jXKU"],"roughness":1,"index":"bA1","backgroundColor":"#ffffff","angle":0,"fillStyle":"solid","updated":1773238143513,"version":959,"strokeWidth":1,"type":"ellipse","roundness":null,"id":"ghykcw13XxJjS_BcJ2Tc8","boundElements":[{"id":"oR7Z1HabD8CfPz0CC12an","type":"arrow"}],"x":3414.0171675148522,"seed":634787259,"y":1829.2922871916103,"opacity":100,"height":27.530163152424731,"width":101.25296680383022,"frameId":null,"strokeStyle":"solid","versionNonce":1862424435},{"seed":2141300315,"strokeStyle":"solid","id":"EUAstzivi0gEHD-LDbsxo","strokeWidth":2,"isDeleted":false,"roughness":1,"fontSize":20,"opacity":100,"verticalAlign":"top","text":"Database","updated":1773238143513,"locked":false,"version":178,"autoResize":true,"type":"text","backgroundColor":"#228be6","index":"bA2","roundness":null,"containerId":null,"originalText":"Database","height":25,"link":null,"strokeColor":"#000000","fillStyle":"hachure","groupIds":["X1bXUswCKv-ENCdN6uqXZ","puEzt2iwecZ6wtg19jXKU"],"versionNonce":981945661,"lineHeight":1.25,"textAlign":"center","fontFamily":1,"frameId":null,"boundElements":[],"x":3416.0123945170199,"angle":0,"y":1949.2922871916103,"width":99},{"isDeleted":false,"locked":false,"strokeColor":"#1e1e1e","link":null,"endArrowhead":"arrow","groupIds":[],"startBinding":{"mode":"orbit","elementId":"ffhalFOwR7gpTruAmKZfG","fixedPoint":[0.83685579019004031,0.16314420980995487]},"roughness":1,"index":"bA3","startArrowhead":null,"elbowed":false,"backgroundColor":"transparent","angle":0,"endBinding":{"mode":"orbit","elementId":"ghykcw13XxJjS_BcJ2Tc8","fixedPoint":[0.50009999999999999,0.34615575002794663]},"fillStyle":"solid","updated":1773238143513,"strokeWidth":2,"roundness":{"type":2},"type":"arrow","version":76,"id":"oR7Z1HabD8CfPz0CC12an","x":3203.7917842814186,"boundElements":[],"seed":1173526325,"y":1830.1625043585973,"opacity":100,"height":6.7347251199998936,"points":[[0,0],[202.87131785135352,6.7347251199998936]],"width":202.87131785135352,"frameId":null,"strokeStyle":"solid","versionNonce":239923475},{"seed":521543797,"strokeStyle":"solid","id":"5bO1XiFVLM5HtzHrfqGCl","strokeWidth":2,"isDeleted":false,"roughness":1,"fontSize":20,"opacity":100,"verticalAlign":"top","text":"Fare\n- id\n- userId\n- source\n- destination\n- distanceInKm\n- eta\n- …metadata\n","updated":1773238143513,"locked":false,"version":97,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bA4","roundness":null,"containerId":null,"originalText":"Fare\n- id\n- userId\n- source\n- destination\n- distanceInKm\n- eta\n- …metadata\n","height":225,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":2114231709,"lineHeight":1.25,"textAlign":"left","fontFamily":8,"frameId":null,"boundElements":[],"x":3572.6668557533421,"angle":0,"width":154,"y":1817.0700717882883},{"seed":1764721627,"strokeStyle":"solid","id":"3Lvf5PMQT7JSvW47czNo6","strokeWidth":2,"isDeleted":false,"roughness":1,"fontSize":20,"opacity":100,"verticalAlign":"top","text":"Ride confirmation\n\n- After fare returned to the client, proceeds with the ride.\n\n- Request is forwarded to the Ride service.\n- Ride service accepts this request and creates a new entry in the ride table with\n  - Ride ( id, riderId, driverId(nullable — matched later), source, destination, distance, eta, \n           status (driverRequested|driverMatched|driverConfirmed|rideStarted|rideEnded))\n- puts a new message in the message queue with rideId\n- returns ride details back to the UI.\n- UI will show finding drivers to the rider.\n\n- Driver Matching worker will consume this event\/message from the queue and finds driver near by.\n\n- To find the drivers nearby we need to capture drivers location periodically. \n\n- Drivers will have a dedicated app to send location updates, accept\/decline rides.\n- When driver logs into the app and makes themselves available to accept rides (online status)\n  drivers client app sends location coordinates periodically.\n- These location coordinates are forwarded to Location Service and Added in the location database.\n- This database needs to be supporting high throughput because each drivers will send their location\n    coordinates evey 10-20 seconds periodically. Database should support high tps. \n- Also this database should support effective queries to find drivers nearby.\n- Few Relational databases support this but has thier own drawbacks interms of scaling and querying.\n- One option we can go ahead with is Redis GeoHashing.\n- We can store drivers location coordinates in the redis.\n- We will also store whether drivers is online or not in the redis.\n\n- Driver matching worker will query this redis database with source coordinates and fetched nearby 10-20 drivers.\n- Then these drivers list is stored in the redis with rideId->drivers.\n\n- Driver matching service will iterate through the drivers and\n- fetch status of driver from redis (to know whether any request already sent to driver or driver in ride)\n- If driver is free then we send a notification to the driver about the ride\n  (websocket, server sent event or push notifications)\n- We also update driver status in redis to rideRequestSent so that other ride requests do not send same event to the driver.\n\n- If driver accepts the request then we update the ride status as well as driver status.\n- If the driver declines it then we move on to the other driver.\n\n- Meanwhile rider app will keep on polling the ride service and check whether any driver matched or not.\n","updated":1773238143513,"locked":false,"version":2749,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bA5","roundness":null,"containerId":null,"originalText":"Ride confirmation\n\n- After fare returned to the client, proceeds with the ride.\n\n- Request is forwarded to the Ride service.\n- Ride service accepts this request and creates a new entry in the ride table with\n  - Ride ( id, riderId, driverId(nullable — matched later), source, destination, distance, eta, \n           status (driverRequested|driverMatched|driverConfirmed|rideStarted|rideEnded))\n- puts a new message in the message queue with rideId\n- returns ride details back to the UI.\n- UI will show finding drivers to the rider.\n\n- Driver Matching worker will consume this event\/message from the queue and finds driver near by.\n\n- To find the drivers nearby we need to capture drivers location periodically. \n\n- Drivers will have a dedicated app to send location updates, accept\/decline rides.\n- When driver logs into the app and makes themselves available to accept rides (online status)\n  drivers client app sends location coordinates periodically.\n- These location coordinates are forwarded to Location Service and Added in the location database.\n- This database needs to be supporting high throughput because each drivers will send their location\n    coordinates evey 10-20 seconds periodically. Database should support high tps. \n- Also this database should support effective queries to find drivers nearby.\n- Few Relational databases support this but has thier own drawbacks interms of scaling and querying.\n- One option we can go ahead with is Redis GeoHashing.\n- We can store drivers location coordinates in the redis.\n- We will also store whether drivers is online or not in the redis.\n\n- Driver matching worker will query this redis database with source coordinates and fetched nearby 10-20 drivers.\n- Then these drivers list is stored in the redis with rideId->drivers.\n\n- Driver matching service will iterate through the drivers and\n- fetch status of driver from redis (to know whether any request already sent to driver or driver in ride)\n- If driver is free then we send a notification to the driver about the ride\n  (websocket, server sent event or push notifications)\n- We also update driver status in redis to rideRequestSent so that other ride requests do not send same event to the driver.\n\n- If driver accepts the request then we update the ride status as well as driver status.\n- If the driver declines it then we move on to the other driver.\n\n- Meanwhile rider app will keep on polling the ride service and check whether any driver matched or not.\n","height":1050,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":1213421235,"lineHeight":1.25,"textAlign":"left","fontFamily":8,"frameId":null,"boundElements":[],"x":271.23431424715238,"angle":0,"width":1364,"y":2361.6990704842578}],"appState":{"shouldCacheIgnoreZoom":false,"exportScale":2,"defaultSidebarDockedPreference":false,"openMenu":null,"showWelcomeScreen":true,"currentItemStrokeColor":"#1e1e1e","bindMode":"orbit","exportWithDarkMode":false,"lockedMultiSelections":{},"currentItemRoughness":1,"currentItemTextAlign":"left","exportBackground":true,"scrolledOutside":false,"selectedElementIds":{},"zenModeEnabled":false,"currentItemStartArrowhead":null,"zoom":{"value":0.55848100000000001},"theme":"light","activeTool":{"locked":false,"fromSelection":false,"lastActiveTool":null,"type":"selection","customType":null},"exportEmbedScene":false,"gridStep":5,"lastPointerDownWith":"mouse","selectedGroupIds":{},"currentItemBackgroundColor":"transparent","scrollY":1196.1090316529462,"penDetected":false,"viewBackgroundColor":"#ffffff","name":"Untitled-2026-03-09-1511","currentItemFontFamily":5,"currentItemArrowType":"round","currentItemOpacity":100,"preferredSelectionTool":{"type":"selection","initialized":true},"scrollX":808.19263898640361,"stats":{"open":false,"panels":3},"objectsSnapModeEnabled":false,"gridSize":20,"gridModeEnabled":false,"openSidebar":null,"currentItemRoundness":"round","currentItemStrokeStyle":"solid","editingGroupId":null,"previousSelectedElementIds":{"bxNiopdvFOa84ln7HFhiH":true},"currentChartType":"bar","currentItemStrokeWidth":2,"cursorButton":"up","currentItemEndArrowhead":"arrow","currentItemFillStyle":"solid","currentItemFontSize":20,"selectedLinearElement":null,"penMode":false},"files":{}}