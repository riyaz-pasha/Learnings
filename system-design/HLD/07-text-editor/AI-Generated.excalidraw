 doc problem:\n'100 editors x 2 ops\/s = 200 ops\/s\non a single thread' impresses.","height":262.5,"link":null,"strokeColor":"#a0a0a0","fillStyle":"solid","groupIds":[],"versionNonce":425875443,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":371,"angle":0,"y":5938.4609375000009,"width":265.559814453125},{"isDeleted":false,"locked":false,"strokeColor":"#86efac","link":null,"roughness":1,"groupIds":[],"index":"bBT","backgroundColor":"#1A4D2E","angle":0,"fillStyle":"solid","strokeWidth":1,"version":6,"roundness":{"type":3},"type":"rectangle","updated":1773086198057,"id":"KtqP3QfhB1gTYywFq-HID","x":371,"seed":1532455475,"boundElements":[{"type":"text","id":"eJTGkh0N4ia5w-MUVmKSz"}],"y":6126.4609375000009,"opacity":100,"height":28,"width":178,"frameId":null,"strokeStyle":"solid","versionNonce":1720030397},{"seed":1005693907,"strokeStyle":"solid","id":"eJTGkh0N4ia5w-MUVmKSz","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"middle","updated":1773086198080,"locked":false,"text":"45-MIN STRUCTURE","version":8,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bBU","roundness":null,"containerId":"KtqP3QfhB1gTYywFq-HID","originalText":"45-MIN STRUCTURE","height":16.25,"link":null,"strokeColor":"#86efac","fillStyle":"solid","groupIds":[],"versionNonce":1824531219,"textAlign":"center","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":391.35350799560547,"angle":0,"y":6132.3359375000009,"width":137.29298400878906},{"seed":1058191731,"strokeStyle":"solid","id":"5bbJ1TBKR7BCrK49q_e_z","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1773086198057,"locked":false,"text":"0-5 min:  Requirements + NFRs\n5-10 min: Capacity estimation\n10-20 min: Baseline design\n20-30 min: Bottlenecks + evolution\n30-40 min: Deep dives (OT, offline)\n40-45 min: Trade-offs + wrap-up\n\nAlways check in at minute 20:\n'I have covered X and Y. Should\nI go deeper or move to Z?'","version":6,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bBV","roundness":null,"containerId":null,"originalText":"0-5 min:  Requirements + NFRs\n5-10 min: Capacity estimation\n10-20 min: Baseline design\n20-30 min: Bottlenecks + evolution\n30-40 min: Deep dives (OT, offline)\n40-45 min: Trade-offs + wrap-up\n\nAlways check in at minute 20:\n'I have covered X and Y. Should\nI go deeper or move to Z?'","height":187.5,"link":null,"strokeColor":"#a0a0a0","fillStyle":"solid","groupIds":[],"versionNonce":835581213,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":371,"angle":0,"y":6162.4609375000009,"width":256.85986328125},{"isDeleted":false,"locked":false,"strokeColor":"#c4b5fd","link":null,"roughness":1,"groupIds":[],"index":"bBW","backgroundColor":"#2D1B69","angle":0,"fillStyle":"solid","strokeWidth":1,"version":6,"roundness":{"type":3},"type":"rectangle","updated":1773086198057,"id":"Ef71fe2_UoJaMiwLv6rGR","x":371,"seed":33624851,"boundElements":[{"type":"text","id":"-vAKpBqW6NUmcniSVr16V"}],"y":6306.4609375000009,"opacity":100,"height":28,"width":148,"frameId":null,"strokeStyle":"solid","versionNonce":302855987},{"seed":892549299,"strokeStyle":"solid","id":"-vAKpBqW6NUmcniSVr16V","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":13,"opacity":100,"verticalAlign":"middle","updated":1773086198080,"locked":false,"text":"FOLLOW-UP Qs","version":8,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bBX","roundness":null,"containerId":"Ef71fe2_UoJaMiwLv6rGR","originalText":"FOLLOW-UP Qs","height":16.25,"link":null,"strokeColor":"#c4b5fd","fillStyle":"solid","groupIds":[],"versionNonce":361777331,"textAlign":"center","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":395.489501953125,"angle":0,"y":6312.3359375000009,"width":99.02099609375},{"seed":911190611,"strokeStyle":"solid","id":"7PvWUWIbzHNBjCbsxU8Hk","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1773086198057,"locked":false,"text":"Q: How would you add comments?\nA: Comments are anchored to a\n   char position range in the op log.\n   They're stored as metadata ops.\n\nQ: How would you add version diff?\nA: Replay ops between two rev#s.\n   Display as red\/green highlights.\n\nQ: How would you scale to 10x?\nA: Add more docID shards. Fan-out\n   workers scale independently.\n   Bigtable auto-scales tablets.","version":6,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bBY","roundness":null,"containerId":null,"originalText":"Q: How would you add comments?\nA: Comments are anchored to a\n   char position range in the op log.\n   They're stored as metadata ops.\n\nQ: How would you add version diff?\nA: Replay ops between two rev#s.\n   Display as red\/green highlights.\n\nQ: How would you scale to 10x?\nA: Add more docID shards. Fan-out\n   workers scale independently.\n   Bigtable auto-scales tablets.","height":243.75,"link":null,"strokeColor":"#a0a0a0","fillStyle":"solid","groupIds":[],"versionNonce":342218963,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":371,"angle":0,"y":6342.4609375000009,"width":260.954833984375},{"isDeleted":false,"locked":false,"strokeColor":"#4a9eed","link":null,"roughness":1,"groupIds":[],"index":"bBZ","backgroundColor":"#1E3A5F","angle":0,"fillStyle":"solid","strokeWidth":2,"version":6,"roundness":{"type":3},"type":"rectangle","updated":1773086198057,"id":"MaZeFhoUYB_6TDlnqelGB","x":371,"seed":1781327859,"boundElements":[{"type":"text","id":"ZpJBzzkMLLxRQCodS2ZW4"}],"y":6518.4609375000009,"opacity":100,"height":30,"width":368,"frameId":null,"strokeStyle":"solid","versionNonce":807342557},{"seed":1456566675,"strokeStyle":"solid","id":"ZpJBzzkMLLxRQCodS2ZW4","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"middl