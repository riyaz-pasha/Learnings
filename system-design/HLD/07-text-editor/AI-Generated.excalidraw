lse,"fontSize":13,"opacity":100,"verticalAlign":"middle","updated":1773086198080,"locked":false,"text":"COMMON MISTAKES","version":8,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bBO","roundness":null,"containerId":"N6z4b8ridwPkzzwu9srt8","originalText":"COMMON MISTAKES","height":16.25,"link":null,"strokeColor":"#f87171","fillStyle":"solid","groupIds":[],"versionNonce":808762323,"textAlign":"center","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":395.29249572753906,"angle":0,"y":5740.3359375000009,"width":129.41500854492188},{"seed":1480612787,"strokeStyle":"solid","id":"ctL2_CEme4G9GAAd3HVjL","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":15,"opacity":100,"verticalAlign":"top","updated":1773086198057,"locked":false,"text":"X Designing CRUD storage first\nX Forgetting WebSocket is stateful\nX Not mentioning OT\/CRDT at all\nX Saying 'just use Kafka' without\n  explaining why async helps\nX Missing the hot doc problem\nX Not explaining offline behaviour\nX Using SQL for the op log","version":6,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bBP","roundness":null,"containerId":null,"originalText":"X Designing CRUD storage first\nX Forgetting WebSocket is stateful\nX Not mentioning OT\/CRDT at all\nX Saying 'just use Kafka' without\n  explaining why async helps\nX Missing the hot doc problem\nX Not explaining offline behaviour\nX Using SQL for the op log","height":150,"link":null,"strokeColor":"#a0a0a0","fillStyle":"solid","groupIds":[],"versionNonce":410890237,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":371,"angle":0,"y":5770.4609375000009,"width":260.54983520507812},{"isDeleted":false,"locked":false,"strokeColor":"#5eead4","link":null,"roughness":1,"groupIds":[],"index":"bBQ","backgroundColor":"#1A4D4D","angle":0,"fillStyle":"solid","strokeWidth":1,"version":6,"roundness":{"type":3},"type":"rectangle","updated":1773086198057,"id":"wkcUV